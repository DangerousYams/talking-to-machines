---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import ScrollProgress from '../components/scroll/ScrollProgress';
import ChapterNav from '../components/ui/ChapterNav';
import ChapterDrawer from '../components/ui/ChapterDrawer';
import LanguageSelector from '../components/ui/LanguageSelector.astro';
import PaywallGate from '../components/ui/PaywallGate';
import QuotaCounter from '../components/ui/QuotaCounter';
import QuotaBanner from '../components/ui/QuotaBanner';
import PageViewTracker from '../components/analytics/PageViewTracker';
import ScrollDepthTracker from '../components/analytics/ScrollDepthTracker';
import GtagHead from '../components/analytics/GtagHead.astro';
import HeadSEO from '../components/seo/HeadSEO.astro';
import { ListenController } from '../components/chapter/ChapterBeats';
import ListenButton from '../components/chapter/ListenButton';
import BeatProgress from '../components/chapter/BeatProgress';
import { chapters, type Chapter } from '../data/chapters';
import { getDir } from '../data/languages';
import { getChapterMeta } from '../data/chapter-meta-i18n';

interface Props {
  chapter: Chapter;
  locale?: string;
}

const { chapter, locale = 'en' } = Astro.props;

// Load widget/break translations for this locale and chapter
let widgetTranslations: Record<string, Record<string, string>> = {};
try {
  const chapterMod = await import(`../i18n/translations/${locale}/ch${chapter.number}.ts`);
  Object.assign(widgetTranslations, chapterMod.default || {});
} catch { /* translations not yet available for this locale/chapter */ }
try {
  const breaksMod = await import(`../i18n/translations/${locale}/breaks.ts`);
  Object.assign(widgetTranslations, breaksMod.default || {});
} catch { /* breaks translations not yet available */ }
// English fallback — merge in any keys not already present
if (locale !== 'en') {
  try {
    const enChapterMod = await import(`../i18n/translations/en/ch${chapter.number}.ts`);
    const enData = enChapterMod.default || {};
    for (const [ns, strings] of Object.entries(enData) as [string, Record<string, string>][]) {
      if (!widgetTranslations[ns]) widgetTranslations[ns] = {};
      for (const [key, val] of Object.entries(strings)) {
        if (!(key in widgetTranslations[ns])) widgetTranslations[ns][key] = val;
      }
    }
  } catch {}
  try {
    const enBreaksMod = await import(`../i18n/translations/en/breaks.ts`);
    const enData = enBreaksMod.default || {};
    for (const [ns, strings] of Object.entries(enData) as [string, Record<string, string>][]) {
      if (!widgetTranslations[ns]) widgetTranslations[ns] = {};
      for (const [key, val] of Object.entries(strings)) {
        if (!(key in widgetTranslations[ns])) widgetTranslations[ns][key] = val;
      }
    }
  } catch {}
}

const rawPrev = chapters.find((c) => c.number === chapter.number - 1);
const rawNext = chapters.find((c) => c.number === chapter.number + 1);
// Interludes: ch3 → workshop → ch4, ch6 → field-guide → ch7
// field-guide + absolutely-youre-right are English-only for now.
// workshop has translations, so it surfaces in all locales with a localized title.
const workshopTitles: Record<string, string> = {
  en: 'The Workshop',
  es: 'El Workshop',
  hi: 'The Workshop',
  fr: 'Le Workshop',
  de: 'Der Workshop',
  pt: 'O Workshop',
  ar: 'الورشة',
  id: 'The Workshop',
  bn: 'The Workshop',
  te: 'The Workshop',
  ta: 'The Workshop',
  mr: 'The Workshop',
  kn: 'The Workshop',
  gu: 'The Workshop',
  ja: 'ワークショップ',
  ko: '더 워크숍',
  zh: 'Workshop',
  tr: 'The Workshop',
  vi: 'The Workshop',
};
const localizedWorkshopTitle = workshopTitles[locale] || 'The Workshop';
const nextInterludes: Record<number, { slug: string; title: string; allLocales?: boolean }> = {
  3: { slug: 'workshop', title: localizedWorkshopTitle, allLocales: true },
  6: { slug: 'field-guide', title: 'The Field Guide' },
  11: { slug: 'absolutely-youre-right', title: '"Absolutely, You\'re Right!"' },
};
const prevInterludes: Record<number, { slug: string; title: string; allLocales?: boolean }> = {
  4: { slug: 'workshop', title: localizedWorkshopTitle, allLocales: true },
  7: { slug: 'field-guide', title: 'The Field Guide' },
};
const rawNextInterlude = nextInterludes[chapter.number];
const nextInterlude = rawNextInterlude && (rawNextInterlude.allLocales || locale === 'en') ? rawNextInterlude : undefined;
const next = nextInterlude
  ? { slug: nextInterlude.slug, title: nextInterlude.title, number: chapter.number, hook: '', accent: chapter.accent, concepts: [] } as Chapter
  : rawNext;
const rawPrevInterlude = prevInterludes[chapter.number];
const prevInterlude = rawPrevInterlude && (rawPrevInterlude.allLocales || locale === 'en') ? rawPrevInterlude : undefined;
const prev = prevInterlude && rawPrev
  ? { ...rawPrev, slug: prevInterlude.slug, title: prevInterlude.title, number: chapter.number } as typeof rawPrev
  : rawPrev;
const needsPaywall = chapter.number > 1;
const hasBeats = chapter.beats && chapter.beats.length > 0;
const textDir = getDir(locale);
const isTranslated = locale !== 'en';
const localizedMeta = getChapterMeta(locale, chapter.slug, chapter.title, chapter.hook);
const metaTitle = `${localizedMeta.title} — Talking to Machines`;
const metaDesc = `${localizedMeta.title} — ${localizedMeta.hook}`;
---

<!doctype html>
<html lang={locale} dir={textDir}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={metaDesc} />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={localizedMeta.hook} />
    <title>{metaTitle}</title>
    <HeadSEO
      title={metaTitle}
      description={metaDesc}
      path={`/${chapter.slug}`}
      locale={locale}
      type="chapter"
      chapterNumber={chapter.number}
      concepts={chapter.concepts}
      ogImage={`/og/${chapter.slug}.png`}
    />
    <GtagHead />
    <!-- Mobile redirect removed: unified scroll experience on all devices -->
  </head>
  <body class="bg-cream text-deep min-h-screen">
    <script define:vars={{ __widgetLocale: locale, __widgetTranslations: widgetTranslations }}>
      window.__WIDGET_LOCALE = __widgetLocale;
      window.__WIDGET_TRANSLATIONS = __widgetTranslations;
    </script>
    <ScrollProgress color={chapter.accent} client:load />
    <PageViewTracker variant="scroll" chapter={chapter.slug} client:load />
    <ScrollDepthTracker
      chapterSlug={chapter.slug}
      variant="scroll"
      totalSections={chapter.beats ? chapter.beats.length : undefined}
      client:load
    />

    <!-- Floating header — minimal, stays out of the way -->
    <header class="fixed top-0 left-0 right-0 z-40 transition-all duration-500">
      <div class="bg-cream/90 backdrop-blur-lg border-b border-deep/[0.04]">
        <div class="max-w-[960px] mx-auto px-6 md:px-10 h-12 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <ChapterDrawer currentSlug={chapter.slug} accentColor={chapter.accent} locale={locale} client:load />
            <a
              href="/"
              class="text-[13px] tracking-[0.06em] no-underline text-subtle/70 hover:text-deep transition-colors"
              style="font-family: var(--font-heading); font-weight: 500;"
            >
              Talking to Machines
            </a>
          </div>
          <div class="flex items-center gap-2 md:gap-3">
            <LanguageSelector currentLocale={locale} chapterSlug={chapter.slug} />
            <span class:list={[{ hidden: isTranslated }]}><ListenButton accentColor={chapter.accent} client:load /></span>
            <!-- QuotaCounter removed from header — only shown when user runs out -->
            {hasBeats && (
              <span class:list={[{ hidden: isTranslated }]}>
                <BeatProgress
                  beats={chapter.beats!}
                  accentColor={chapter.accent}
                  chapterSlug={chapter.slug}
                  client:load
                />
              </span>
            )}
            <span class="hidden md:inline text-[11px] tracking-[0.08em] uppercase text-subtle/50" style="font-family: var(--font-mono);">
              {chapter.number} / {chapters.length}
            </span>
          </div>
        </div>
      </div>
    </header>

    {needsPaywall && (
      <PaywallGate chapterTitle={chapter.title} accentColor={chapter.accent} chapterSlug={chapter.slug} client:load />
    )}

    <QuotaBanner client:load />

    <main class="pt-12">
      <slot />
    </main>

    <div class:list={[{ hidden: isTranslated }]}><ListenController accentColor={chapter.accent} chapterSlug={chapter.slug} client:load /></div>

    <ChapterNav prev={prev} next={next} locale={locale} client:load />

    <!-- Footer -->
    <footer class="py-20 px-6">
      <div class="max-w-[680px] mx-auto text-center">
        <div class="flex items-center justify-center gap-3 mb-4 opacity-30">
          <div class="w-8 h-px bg-deep"></div>
          <svg width="8" height="8" viewBox="0 0 8 8" fill="none"><path d="M4 0l4 4-4 4L0 4z" fill="currentColor"/></svg>
          <div class="w-8 h-px bg-deep"></div>
        </div>
        <a href="/" class="text-[13px] text-subtle/60 no-underline hover:text-deep transition-colors" style="font-family: var(--font-body);">Talking to Machines</a>
      </div>
    </footer>
    <Analytics />
  </body>
</html>
