---
// WhatsApp share image — 1080×1350 (4:5), all absolute positioning
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Share Card</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,800;1,400&family=Source+Serif+4:ital,wght@0,400;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 1080px;
      height: 1350px;
      overflow: hidden;
      background: #F8F6F3;
    }

    /* ── The canvas ── */
    .canvas {
      position: relative;
      width: 1080px;
      height: 1350px;
      overflow: hidden;
    }

    /* ── Background blobs ── */
    .blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(100px);
      pointer-events: none;
    }

    /* ── All elements absolutely placed ── */
    .el {
      position: absolute;
    }
  </style>
</head>
<body>
<div class="canvas">

  <!-- ── Network graph background ── -->
  <svg class="el" style="top: 0; left: 0;" width="1080" height="1350" viewBox="0 0 1080 1350" fill="none">
    <!-- ── Lines ── -->
    <!-- Top zone -->
    <line x1="55" y1="25" x2="200" y2="60" stroke="#16C79A" stroke-width="1.2" opacity="0.16"/>
    <line x1="200" y1="60" x2="130" y2="155" stroke="#7B61FF" stroke-width="1.2" opacity="0.13"/>
    <line x1="55" y1="25" x2="130" y2="155" stroke="#F5A623" stroke-width="1" opacity="0.07"/>
    <line x1="850" y1="35" x2="1010" y2="80" stroke="#E94560" stroke-width="1" opacity="0.11"/>
    <line x1="1010" y1="80" x2="960" y2="170" stroke="#16C79A" stroke-width="1.2" opacity="0.13"/>
    <line x1="850" y1="35" x2="960" y2="170" stroke="#7B61FF" stroke-width="1" opacity="0.07"/>
    <line x1="200" y1="60" x2="420" y2="20" stroke="#0EA5E9" stroke-width="1.2" opacity="0.12"/>
    <line x1="420" y1="20" x2="650" y2="45" stroke="#E94560" stroke-width="1" opacity="0.07"/>
    <line x1="650" y1="45" x2="850" y2="35" stroke="#16C79A" stroke-width="1.2" opacity="0.12"/>

    <!-- Upper flanks -->
    <line x1="130" y1="155" x2="60" y2="310" stroke="#E94560" stroke-width="1.2" opacity="0.14"/>
    <line x1="60" y1="310" x2="170" y2="400" stroke="#16C79A" stroke-width="1.2" opacity="0.12"/>
    <line x1="130" y1="155" x2="170" y2="400" stroke="#F5A623" stroke-width="1" opacity="0.06"/>
    <line x1="960" y1="170" x2="1040" y2="300" stroke="#F5A623" stroke-width="1.2" opacity="0.14"/>
    <line x1="1040" y1="300" x2="920" y2="390" stroke="#7B61FF" stroke-width="1.2" opacity="0.12"/>
    <line x1="960" y1="170" x2="920" y2="390" stroke="#E94560" stroke-width="1" opacity="0.06"/>

    <!-- Mid-gap band (y ~420-480, between title and killer line) -->
    <line x1="170" y1="400" x2="310" y2="450" stroke="#7B61FF" stroke-width="1.2" opacity="0.14"/>
    <line x1="310" y1="450" x2="220" y2="530" stroke="#16C79A" stroke-width="1" opacity="0.07"/>
    <line x1="170" y1="400" x2="220" y2="530" stroke="#0EA5E9" stroke-width="1" opacity="0.06"/>
    <line x1="920" y1="390" x2="790" y2="440" stroke="#16C79A" stroke-width="1.2" opacity="0.14"/>
    <line x1="790" y1="440" x2="880" y2="520" stroke="#E94560" stroke-width="1" opacity="0.07"/>
    <line x1="920" y1="390" x2="880" y2="520" stroke="#F5A623" stroke-width="1" opacity="0.06"/>
    <line x1="310" y1="450" x2="790" y2="440" stroke="#7B61FF" stroke-width="0.8" opacity="0.04"/>

    <!-- Left drift down -->
    <line x1="220" y1="530" x2="90" y2="620" stroke="#F5A623" stroke-width="1.2" opacity="0.13"/>
    <line x1="90" y1="620" x2="160" y2="740" stroke="#7B61FF" stroke-width="1.2" opacity="0.12"/>
    <line x1="220" y1="530" x2="160" y2="740" stroke="#E94560" stroke-width="1" opacity="0.06"/>
    <line x1="160" y1="740" x2="50" y2="830" stroke="#16C79A" stroke-width="1.2" opacity="0.13"/>
    <line x1="90" y1="620" x2="50" y2="830" stroke="#0EA5E9" stroke-width="1" opacity="0.06"/>

    <!-- Right drift down -->
    <line x1="880" y1="520" x2="990" y2="630" stroke="#7B61FF" stroke-width="1.2" opacity="0.13"/>
    <line x1="990" y1="630" x2="910" y2="730" stroke="#16C79A" stroke-width="1.2" opacity="0.12"/>
    <line x1="880" y1="520" x2="910" y2="730" stroke="#F5A623" stroke-width="1" opacity="0.06"/>
    <line x1="910" y1="730" x2="1030" y2="820" stroke="#E94560" stroke-width="1.2" opacity="0.13"/>
    <line x1="990" y1="630" x2="1030" y2="820" stroke="#7B61FF" stroke-width="1" opacity="0.06"/>

    <!-- Lower flanks (y ~830-1000) -->
    <line x1="50" y1="830" x2="140" y2="960" stroke="#E94560" stroke-width="1.2" opacity="0.14"/>
    <line x1="140" y1="960" x2="60" y2="1060" stroke="#7B61FF" stroke-width="1.2" opacity="0.12"/>
    <line x1="50" y1="830" x2="60" y2="1060" stroke="#F5A623" stroke-width="1" opacity="0.06"/>
    <line x1="1030" y1="820" x2="950" y2="950" stroke="#16C79A" stroke-width="1.2" opacity="0.14"/>
    <line x1="950" y1="950" x2="1040" y2="1050" stroke="#F5A623" stroke-width="1.2" opacity="0.12"/>
    <line x1="1030" y1="820" x2="1040" y2="1050" stroke="#7B61FF" stroke-width="1" opacity="0.06"/>

    <!-- Bottom spread -->
    <line x1="60" y1="1060" x2="190" y2="1170" stroke="#16C79A" stroke-width="1.2" opacity="0.14"/>
    <line x1="190" y1="1170" x2="110" y2="1280" stroke="#E94560" stroke-width="1.2" opacity="0.12"/>
    <line x1="60" y1="1060" x2="110" y2="1280" stroke="#0EA5E9" stroke-width="1" opacity="0.06"/>
    <line x1="190" y1="1170" x2="350" y2="1250" stroke="#7B61FF" stroke-width="1" opacity="0.07"/>
    <line x1="110" y1="1280" x2="350" y2="1250" stroke="#F5A623" stroke-width="1" opacity="0.06"/>
    <line x1="1040" y1="1050" x2="900" y2="1160" stroke="#E94560" stroke-width="1.2" opacity="0.14"/>
    <line x1="900" y1="1160" x2="1000" y2="1280" stroke="#7B61FF" stroke-width="1.2" opacity="0.12"/>
    <line x1="1040" y1="1050" x2="1000" y2="1280" stroke="#16C79A" stroke-width="1" opacity="0.06"/>
    <line x1="900" y1="1160" x2="740" y2="1240" stroke="#F5A623" stroke-width="1" opacity="0.07"/>
    <line x1="1000" y1="1280" x2="740" y2="1240" stroke="#0EA5E9" stroke-width="1" opacity="0.06"/>
    <line x1="350" y1="1250" x2="740" y2="1240" stroke="#16C79A" stroke-width="0.8" opacity="0.04"/>
    <line x1="110" y1="1280" x2="350" y2="1330" stroke="#16C79A" stroke-width="1" opacity="0.07"/>
    <line x1="1000" y1="1280" x2="780" y2="1330" stroke="#E94560" stroke-width="1" opacity="0.07"/>

    <!-- ── Nodes ── -->
    <!-- Top scatter -->
    <circle cx="55" cy="25" r="5" fill="#16C79A" opacity="0.22"/>
    <circle cx="200" cy="60" r="9" fill="#7B61FF" opacity="0.17"/>
    <circle cx="420" cy="20" r="4" fill="#0EA5E9" opacity="0.20"/>
    <circle cx="650" cy="45" r="6" fill="#E94560" opacity="0.15"/>
    <circle cx="850" cy="35" r="11" fill="#16C79A" opacity="0.14"/>
    <circle cx="1010" cy="80" r="5" fill="#E94560" opacity="0.20"/>

    <!-- Upper flanks -->
    <circle cx="130" cy="155" r="7" fill="#F5A623" opacity="0.18"/>
    <circle cx="960" cy="170" r="8" fill="#7B61FF" opacity="0.16"/>
    <circle cx="60" cy="310" r="4" fill="#E94560" opacity="0.22"/>
    <circle cx="1040" cy="300" r="13" fill="#F5A623" opacity="0.13"/>

    <!-- Mid-gap -->
    <circle cx="170" cy="400" r="6" fill="#16C79A" opacity="0.20"/>
    <circle cx="310" cy="450" r="10" fill="#7B61FF" opacity="0.15"/>
    <circle cx="920" cy="390" r="5" fill="#E94560" opacity="0.20"/>
    <circle cx="790" cy="440" r="8" fill="#16C79A" opacity="0.16"/>

    <!-- Mid sides -->
    <circle cx="220" cy="530" r="4" fill="#0EA5E9" opacity="0.20"/>
    <circle cx="880" cy="520" r="6" fill="#F5A623" opacity="0.18"/>
    <circle cx="90" cy="620" r="12" fill="#F5A623" opacity="0.13"/>
    <circle cx="990" cy="630" r="4" fill="#7B61FF" opacity="0.22"/>
    <circle cx="160" cy="740" r="5" fill="#7B61FF" opacity="0.19"/>
    <circle cx="910" cy="730" r="9" fill="#16C79A" opacity="0.15"/>

    <!-- Lower flanks -->
    <circle cx="50" cy="830" r="7" fill="#16C79A" opacity="0.18"/>
    <circle cx="1030" cy="820" r="5" fill="#E94560" opacity="0.20"/>
    <circle cx="140" cy="960" r="10" fill="#E94560" opacity="0.14"/>
    <circle cx="950" cy="950" r="7" fill="#16C79A" opacity="0.18"/>
    <circle cx="60" cy="1060" r="4" fill="#7B61FF" opacity="0.22"/>
    <circle cx="1040" cy="1050" r="12" fill="#F5A623" opacity="0.13"/>

    <!-- Bottom -->
    <circle cx="190" cy="1170" r="8" fill="#16C79A" opacity="0.16"/>
    <circle cx="900" cy="1160" r="6" fill="#E94560" opacity="0.18"/>
    <circle cx="350" cy="1250" r="5" fill="#7B61FF" opacity="0.19"/>
    <circle cx="740" cy="1240" r="9" fill="#F5A623" opacity="0.14"/>
    <circle cx="110" cy="1280" r="6" fill="#E94560" opacity="0.17"/>
    <circle cx="1000" cy="1280" r="4" fill="#7B61FF" opacity="0.21"/>
    <circle cx="350" cy="1330" r="3" fill="#0EA5E9" opacity="0.18"/>
    <circle cx="780" cy="1330" r="7" fill="#E94560" opacity="0.15"/>

    <!-- Tiny accents -->
    <circle cx="340" cy="10" r="2.5" fill="#F5A623" opacity="0.16"/>
    <circle cx="750" cy="30" r="3" fill="#7B61FF" opacity="0.13"/>
    <circle cx="30" cy="230" r="2" fill="#0EA5E9" opacity="0.17"/>
    <circle cx="1060" cy="220" r="3" fill="#16C79A" opacity="0.14"/>
    <circle cx="240" cy="470" r="2.5" fill="#E94560" opacity="0.14"/>
    <circle cx="850" cy="460" r="2" fill="#F5A623" opacity="0.16"/>
    <circle cx="40" cy="720" r="3" fill="#0EA5E9" opacity="0.13"/>
    <circle cx="1060" cy="710" r="2.5" fill="#E94560" opacity="0.15"/>
    <circle cx="100" cy="1150" r="2" fill="#F5A623" opacity="0.16"/>
    <circle cx="1050" cy="1140" r="3" fill="#16C79A" opacity="0.14"/>
    <circle cx="500" cy="1300" r="3" fill="#0EA5E9" opacity="0.15"/>
    <circle cx="600" cy="1320" r="2" fill="#16C79A" opacity="0.17"/>
  </svg>

  <!-- ── Killer line: y=60 ── -->
  <div class="el" style="top: 60px; left: 80px; width: 920px; text-align: center;">
    <span style="font-family: 'Playfair Display', Georgia, serif; font-size: 76px; font-weight: 800; line-height: 1.25; color: #1A1A2E;">
      The future belongs to those<br />who ask the <em style="font-style: italic; color: #7B61FF;">right questions.</em>
    </span>
  </div>

  <!-- ── Dots divider: y=438 ── -->
  <div class="el" style="top: 438px; left: 0; width: 1080px; display: flex; justify-content: center; gap: 16px;">
    <div style="width: 10px; height: 10px; border-radius: 50%; background: #E94560; opacity: 0.55;"></div>
    <div style="width: 10px; height: 10px; border-radius: 50%; background: #7B61FF; opacity: 0.50;"></div>
    <div style="width: 10px; height: 10px; border-radius: 50%; background: #16C79A; opacity: 0.55;"></div>
    <div style="width: 10px; height: 10px; border-radius: 50%; background: #F5A623; opacity: 0.60;"></div>
    <div style="width: 10px; height: 10px; border-radius: 50%; background: #0EA5E9; opacity: 0.45;"></div>
  </div>

  <!-- ── Title: y=525 ── -->
  <div class="el" style="top: 525px; left: 0; width: 1080px; text-align: center;">
    <span style="font-family: 'Playfair Display', Georgia, serif; font-size: 108px; font-weight: 800; line-height: 1.05; color: #1A1A2E;">
      Talking to<br /><span style="color: #E94560;">Machines</span>
    </span>
  </div>

  <!-- ── Details: y=790 ── -->
  <div class="el" style="top: 790px; left: 0; width: 1080px; display: flex; justify-content: center; align-items: center; gap: 24px;">
    <span style="font-family: 'JetBrains Mono', monospace; font-size: 30px; font-weight: 600; color: #1A1A2E; opacity: 0.55;">Live on Zoom</span>
    <div style="width: 8px; height: 8px; border-radius: 50%; background: #1A1A2E; opacity: 0.2;"></div>
    <span style="font-family: 'JetBrains Mono', monospace; font-size: 30px; font-weight: 600; color: #1A1A2E; opacity: 0.55;">3 sessions</span>
    <div style="width: 8px; height: 8px; border-radius: 50%; background: #1A1A2E; opacity: 0.2;"></div>
    <span style="font-family: 'JetBrains Mono', monospace; font-size: 30px; font-weight: 600; color: #E94560; opacity: 0.70;">April 20, 22, 24</span>
  </div>

  <!-- ── Dots divider: y=872 ── -->
  <div class="el" style="top: 872px; left: 0; width: 1080px; display: flex; justify-content: center; gap: 16px;">
    <div style="width: 10px; height: 10px; border-radius: 50%; background: #16C79A; opacity: 0.55;"></div>
    <div style="width: 10px; height: 10px; border-radius: 50%; background: #F5A623; opacity: 0.50;"></div>
    <div style="width: 10px; height: 10px; border-radius: 50%; background: #E94560; opacity: 0.55;"></div>
    <div style="width: 10px; height: 10px; border-radius: 50%; background: #7B61FF; opacity: 0.50;"></div>
    <div style="width: 10px; height: 10px; border-radius: 50%; background: #0EA5E9; opacity: 0.45;"></div>
  </div>

  <!-- ── Instructor: y=960 ── -->
  <div class="el" style="top: 960px; left: 0; width: 1080px; display: flex; flex-direction: column; align-items: center; gap: 28px;">
    <img src="/images/shalin.png" alt="Shalin Shodhan" width="170" height="170" style="border-radius: 50%; object-fit: cover; border: 3px solid rgba(123, 97, 255, 0.2);" />
    <div style="text-align: center;">
      <div style="font-family: 'Playfair Display', Georgia, serif; font-size: 36px; font-weight: 800; color: #1A1A2E;">Shalin Shodhan</div>
      <div style="font-family: 'Source Serif 4', Georgia, serif; font-size: 26px; color: #6B7280; margin-top: 10px; line-height: 1.6;">Creator of award-winning educational apps</div>
      <div style="font-family: 'Source Serif 4', Georgia, serif; font-size: 26px; color: #6B7280; line-height: 1.6;">Author of the first interactive AI curriculum</div>
    </div>
  </div>

</div>
</body>
</html>
