---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import ProjectPlanner from '../../components/widgets/ch11/ProjectPlanner';
import ShowcaseGallery from '../../components/widgets/ch11/ShowcaseGallery';

const chapter = chapters[10];
---

<ChapterLayout chapter={chapter} locale="gu">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>11</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          ચેપ્ટર ઈલેવન
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          કંઈક Real<br />Build કર
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Creation વગર knowledge trivia છે.<br />Ship કરવાનો time છે.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        Final chapter. Last ten chapters માં, "help me with my essay" થી agents build, hallucinations debug, અને future of work think ત્યાં પહોંચ્યો. Most adults than more AI વિશે learn કર્યું. પણ uncomfortable truth: <strong>build ન કરે ત્યાં સુધી none matter.</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        AI વિશે read — swimming વિશે read same. Buoyancy ની physics study, Olympic races watch, every stroke technique memorize. પણ પાણીમાં ન ઊતરે ત્યાં — actually <em>know</em> ન. Just know <em>about</em>.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        Chapter jump in. Toy exercise or follow-along tutorial નહીં. Real project. તું choose. Care about. Someone ને બતાવીને કહી શકે: <em>"મેં build કર્યું."</em>
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ YOUR TOOLKIT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        તારું Toolkit
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Ten chapters ના skills, use ready:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem 1.5rem; margin-bottom: 2.5rem;">
        {[
          { ch: '1', label: 'Prompt architecture', color: '#E94560' },
          { ch: '2', label: 'Advanced techniques', color: '#0F3460' },
          { ch: '3', label: 'Context engineering', color: '#7B61FF' },
          { ch: '4', label: 'The AI landscape', color: '#0EA5E9' },
          { ch: '5', label: 'Tool use & agents', color: '#F5A623' },
          { ch: '6', label: 'Agent architecture', color: '#E94560' },
          { ch: '7', label: 'AI pair programming', color: '#7B61FF' },
          { ch: '8', label: 'Orchestration', color: '#0F3460' },
          { ch: '9', label: 'Critical thinking', color: '#E94560' },
          { ch: '10', label: 'The human edge', color: '#16C79A' },
        ].map((item) => (
          <div style="display: flex; align-items: center; gap: 0.6rem; padding: 0.4rem 0;">
            <span style={`font-family: var(--font-mono); font-size: 0.6rem; font-weight: 700; color: ${item.color}; opacity: 0.7; width: 1.25rem; text-align: right; flex-shrink: 0;`}>{item.ch}</span>
            <span style={`font-family: var(--font-body); font-size: 0.9rem; color: var(--color-deep); opacity: 0.8;`}>{item.label}</span>
          </div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        સવાલ હવે: આ બધા સાથે શું કરીશ?
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ PLAN BEFORE YOU BUILD ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Build પહેલાં Plan
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        First-time builders ની biggest mistake? Straight tools પર jump. Claude open, huge prompt type, one shot માં everything build try. Fail. Frustrated. Quit.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        Best projects prompt થી start ન થાય. Paper પર plan થી. શું build? કોના માટે? "Done" કેવું look? Keyboard touch before answers.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        Chapter 8 યાદ — orchestrating complexity? Capstone project એનું miniature version. Work pieces માં break. Build before know what building. દરેક piece પર AI collaborator — whole thing magic wand નહીં.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
        <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
        {[
          { word: 'Choose.', desc: 'Actually care about — pick. Passion hard parts through persistence fuel.' },
          { word: 'Scope.', desc: 'Half cut. Then half again. Finished small project > abandoned big one.' },
          { word: 'Decompose.', desc: '5-8 tasks break. Each task one sitting completable.' },
          { word: 'Build.', desc: 'One task at a time. AI use each piece. Move on before every output verify.' },
          { word: 'Ship.', desc: 'Done > perfect. Share. Feedback. Iterate.' },
        ].map((step, i) => (
          <div style={`position: relative; padding-bottom: ${i < 4 ? '1.75rem' : '0'};`}>
            <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
            <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
              <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
              <span style="opacity: 0.7;"> {step.desc}</span>
            </p>
          </div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        One more thing: જતાં જતાં document. Project itself half story. Build કેવી રીતે — decisions, iterations, dead ends — other half. Finished project explain — any test score than worth more.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: PROJECT PLANNER ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ProjectPlanner client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE 3-WEEK SPRINT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        3-Week Sprint
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Project weekend લે or semester — rhythm same. Real ship framework battle-tested:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div style="display: flex; flex-direction: column; gap: 2rem;">
        {[
          {
            week: 'Week 1',
            title: 'Ideate & Scope',
            color: '#F5A623',
            tasks: [
              'Project pick. ઉપર Project Planner use.',
              '"Done" કેવું look — one-paragraph description write.',
              'Project 5-8 tasks break, clear deliverables.',
              'Each task — which AI tools use — identify.',
              'Hardest part tiny prototype build first. Work થાય — rest follow.',
            ],
          },
          {
            week: 'Week 2',
            title: 'Build',
            color: chapter.accent,
            tasks: [
              'Tasks one at a time. Skip ahead ન.',
              'Each task — Chapter 1 ની prompt-evaluate-refine loop use.',
              '"Prompts that worked" log રાખ. Later thank yourself.',
              'Stuck? Relevant chapter re-read. Answer usually technique you haven\'t tried.',
              'Mid-week friend or family feedback. Fresh eyes catch what yours miss.',
            ],
          },
          {
            week: 'Week 3',
            title: 'Polish & Present',
            color: '#7B61FF',
            tasks: [
              'Three most obvious rough edges fix. Ignore rest.',
              'Project description write: what it does, how built, what learned.',
              '3 key prompts document — process critical.',
              '2-minute walkthrough create (video, slides, or live demo).',
              'Share. Teacher, friend, online, student showcase.',
            ],
          },
        ].map((week, i) => (
          <FadeInBlock client:visible delay={0.15 + i * 0.1}>
            <div style={`background: ${week.color}06; border: 1px solid ${week.color}15; border-radius: 12px; padding: 1.5rem 1.75rem;`}>
              <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 1rem;">
                <span style={`font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: ${week.color}; background: ${week.color}15; padding: 3px 10px; border-radius: 100;`}>
                  {week.week}
                </span>
                <span style={`font-family: var(--font-heading); font-size: 1.05rem; font-weight: 700; color: var(--color-deep);`}>
                  {week.title}
                </span>
              </div>
              <ul style="margin: 0; padding-left: 1.25rem;">
                {week.tasks.map((task) => (
                  <li style="font-family: var(--font-body); font-size: 0.9rem; line-height: 1.7; color: var(--color-deep); opacity: 0.8; margin-bottom: 0.35rem;">
                    {task}
                  </li>
                ))}
              </ul>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- BRIDGE TO SHOWCASE GALLERY -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        બીજા students શું build કરી — જો. પછી તારું gallery add કર.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: SHOWCASE GALLERY ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ShowcaseGallery client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CLOSING — THE SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto mb-8" style="max-width: 55ch;">
        Eleven chapters પહેલાં, "help me with my essay" type અને best hope. હવે context engineer, agents design, outputs verify, અને every step judgment bring.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto mb-8" style="max-width: 55ch;">
        Tools things build ન કરે. <strong>Tools સાથે people things build.</strong> અને તારી generation ને ever had access — best toolkit.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        જા, કંઈક એવું બનાવ જે ફક્ત તને જ સૂઝે.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-center mt-8" style={`font-family: var(--font-heading); font-size: 1.8rem; font-weight: 800; color: ${chapter.accent}; letter-spacing: -0.02em;`}>
        Ship કર.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ COURSE COMPLETE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pb-24">
    <FadeInBlock client:visible>
      <div style={`text-align: center; padding: 3rem 2rem; border-radius: 16px; background: ${chapter.accent}06; border: 1px solid ${chapter.accent}15; position: relative; overflow: hidden;`}>
        <div style={`position: absolute; top: -1px; left: -1px; width: 40px; height: 40px; border-top: 2px solid ${chapter.accent}40; border-left: 2px solid ${chapter.accent}40; border-radius: 16px 0 0 0;`}></div>
        <div style={`position: absolute; bottom: -1px; right: -1px; width: 40px; height: 40px; border-bottom: 2px solid ${chapter.accent}40; border-right: 2px solid ${chapter.accent}40; border-radius: 0 0 16px 0;`}></div>

        <p style="font-family: var(--font-mono); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-subtle); margin: 0 0 0.75rem;">
          Course complete
        </p>
        <p style={`font-family: var(--font-heading); font-size: 1.5rem; font-weight: 800; color: ${chapter.accent}; margin: 0 0 0.75rem; letter-spacing: -0.02em;`}>
          11 chapters finish!
        </p>
        <p style="font-family: var(--font-body); font-size: 0.95rem; line-height: 1.7; color: var(--color-deep); opacity: 0.6; max-width: 40ch; margin: 0 auto 2rem;">
          હવે real learning start — જા કંઈક build અને જ્યારે જરૂર પડે ત્યારે any chapter re-read.
        </p>

        <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem;">
          <a
            href="/gu"
            style={`display: inline-flex; align-items: center; gap: 6px; padding: 0.6rem 1.5rem; border-radius: 100px; font-family: var(--font-body); font-size: 0.85rem; font-weight: 600; text-decoration: none; background: ${chapter.accent}; color: white; transition: all 0.3s;`}
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
            Home પર પાછા
          </a>
          <a
            href="/gu/ch1"
            style="display: inline-flex; align-items: center; gap: 6px; padding: 0.6rem 1.5rem; border-radius: 100px; font-family: var(--font-body); font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1px solid rgba(26,26,46,0.12); color: var(--color-deep); transition: all 0.3s;"
          >
            Chapter 1 ફરી વાંચ
          </a>
        </div>
      </div>
    </FadeInBlock>
  </section>

</ChapterLayout>
