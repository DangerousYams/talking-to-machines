---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ContextWindowViz from '../../components/widgets/ch3/ContextWindowViz';
import ForgettingExperiment from '../../components/widgets/ch3/ForgettingExperiment';
import VibeCheck from '../../components/breaks/VibeCheck';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';
import ForYouCard from '../../components/ui/ForYouCard';

const chapter = chapters[2];
const conceptsSummary = chapter.concepts.map(c => c.name).join(', ');
---

<ChapterLayout chapter={chapter} locale="gu">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>3</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          પ્રકરણ ત્રણ
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Context<br />Engineering
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          AI ભૂલતું નથી &mdash; એણે ક્યારેય<br />યાદ જ નહોતું રાખ્યું.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        દર વખતે જ્યારે તું AI ને message મોકલે, ત્યારે એ તારી <em>આખી conversation</em> શરૂઆતથી વાંચે &mdash; તારો દરેક message, એનો દરેક response &mdash; reply generate કરે, અને પછી બધું ભૂલી જાય. આગલા turn માં, એ જ. આખી transcript ફરીથી feed થાય. એ દુનિયાનો સૌથી dedicated પણ amnesiac reader છે: દર વખતે સંપૂર્ણ, દર વખતે zero થી શરૂ.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONCEPT SETUP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Window ની ધાર છે
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10" style="margin-top: 0;">
        AI દર turn માં જે transcript ફરી વાંચે છે? એ <strong>context window</strong> નામની વસ્તુમાં રહે છે &mdash; જે <strong>tokens</strong> માં measure થાય (લગભગ એક token = ત્રણ-ચતુર્થાંશ word). Claude ની window લગભગ 200,000 tokens ધરાવે &mdash; 500-page book જેટલું. ઘણું લાગે, પણ તું જે message મોકલે, AI જે response આપે, અને દરેક hidden system instruction &mdash; બધા એ જ budget માંથી ખાય. એ તારી ધારણા કરતાં ઝડપથી ભરાય.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Budget ખૂટે ત્યારે, સૌથી જૂના messages ધારથી પડી જાય. તેં message ત્રણમાં dietary restrictions જણાવ્યા હતા? Message પંદર સુધીમાં AI ને એ ન દેખાય. એ બેદરકાર નથી &mdash; એ literally જોઈ જ શકતું નથી જે હવે એની સામે નથી. AI ફક્ત એટલું જ સારું છે જેટલી information અત્યારે એની window માં છે.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        એટલે જ best AI users ફક્ત સારા prompts નથી લખતા &mdash; એ manage કરે છે કે window <em>માં</em> શું જાય. નિયમિત summarize કર જેથી key details visible રહે. Important વાત પહેલાં રાખ. Topic બદલાય ત્યારે fresh start કર. Structured formats વાપર જેથી AI context efficiently parse કરી શકે. <strong>Context engineering એ નવું prompt engineering છે.</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>મુખ્ય વાત</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          સરસ prompt લખવો એ step one છે. AI ની સામે કઈ information મૂકવી &mdash; અને કેવી રીતે structure કરવી &mdash; ત્યાં ખરી power છે. દુનિયાનો best prompt પણ fail થાય જો context ખોટો હોય.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Context window ને ભરાતું, overflow થતું, અને ભૂલતું &mdash; real time માં જો.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ContextWindowViz client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONTEXT ENGINEERING STRATEGIES ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Context Manage કરવાની Strategies
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14">
        હવે તું window સમજે છે, તો pro ની જેમ manage કરતા શીખ. આ techniques છે જે "AI use કરું છું" અને "AI થી extraordinary results મેળવું છું" વચ્ચેનો ફરક છે.
      </p>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      <FadeInBlock client:visible delay={0.16}>
        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: #7B61FF;">1</div>
          <div style="flex: 1;">
            <p style="font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: #7B61FF; margin: 0 0 0.35rem; line-height: 1.3;">જતાં જતાં Summarize કર</p>
            <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">દર 5-10 messages પછી, AI ને key decisions અને details નો ટૂંકો recap લખવા કહે. પછી એ summary આગલા message માં paste કર. આ context ને "reset" કરે, સૌથી important information આગળ રાખીને.</p>
          </div>
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.24}>
        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: #16C79A;">2</div>
          <div style="flex: 1;">
            <p style="font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: #16C79A; margin: 0 0 0.35rem; line-height: 1.3;">Important વાત પહેલાં રાખ</p>
            <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">સૌથી critical information message ની શરૂઆતમાં રાખ, અંતમાં નહીં. AI શરૂઆતની અને અંતની information પર વધુ ધ્યાન આપે &mdash; વચ્ચેનું ખોવાઈ શકે, ખાસ કરીને લાંબા prompts માં.</p>
          </div>
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.32}>
        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: #0EA5E9;">3</div>
          <div style="flex: 1;">
            <p style="font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: #0EA5E9; margin: 0 0 0.35rem; line-height: 1.3;">Strategy થી Fresh start કર</p>
            <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">Topic ઘણો બદલાય ત્યારે નવી conversation શરૂ કરવામાં ડર નહીં. તેં શું decide કર્યું એનો summary લઈ જા, full history નહીં. Clean context ઘણીવાર cluttered context કરતાં better હોય.</p>
          </div>
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.40}>
        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: #F5A623;">4</div>
          <div style="flex: 1;">
            <p style="font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: #F5A623; margin: 0 0 0.35rem; line-height: 1.3;">શું યાદ રાખવું એ clearly કહે</p>
            <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">"Important: user vegetarian છે. આ ભૂલીશ નહીં." વિચિત્ર લાગે, પણ કામ કરે. Explicit reminders anchors ની જેમ કામ કરે જેને AI વધુ ગંભીરતાથી લે.</p>
          </div>
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.48}>
        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: #E94560;">5</div>
          <div style="flex: 1;">
            <p style="font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: #E94560; margin: 0 0 0.35rem; line-height: 1.3;">Structured formats વાપર</p>
            <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">Bulleted lists, headers, અને clear labels AI ને context efficiently parse કરવામાં મદદ કરે. સારી રીતે organized prompt, prose ના paragraph કરતાં double token value ધરાવે.</p>
          </div>
        </div>
      </FadeInBlock>
    </div>
  </section>

  <!-- ═══ THE FORGETTING EXPERIMENT ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ForgettingExperiment client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <div class="py-8">
    <ForYouCard
      chapterSlug={chapter.slug}
      chapterTitle={chapter.title}
      chapterConcepts={conceptsSummary}
      accentColor={chapter.accent}
      client:load
    />
  </div>
  <SharePrompt text="આખરે સમજાયું કે AI conversation વચ્ચે કેમ 'ભૂલી' જાય. Memory નથી — context window છે. આ course live demos સાથે ખૂબ clearly explain કરે." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        હવે તું whiteboard જુએ છે. Window ની ધાર અનુભવે છે. એ AI સાથેની દરેક conversation બદલી નાખશે.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        તું fundamentals શીખ્યો &mdash; prompting, asking, અને context. આગળ: power prompts ની cheat sheet જે તારી સાથે લઈ જવાની.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Vibe Check" client:visible>
        <VibeCheck client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
