---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import PromptLaboratory from '../../components/widgets/ch2/PromptLaboratory';
import FlipTheScript from '../../components/widgets/ch2/FlipTheScript';
import DebugThePrompt from '../../components/widgets/ch2/DebugThePrompt';

const chapter = chapters[1];
---

<ChapterLayout chapter={chapter} locale="gu">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>2</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          ચેપ્ટર ટુ
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          પૂછવાની<br />કળા
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          સૌથી સારો prompt એ છે<br />જે AI ને તને questions પૂછવા મજબૂર કરે.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        છેલ્લા chapter માં તેં good prompt ના પાંચ building blocks શીખ્યા — Role, Task, Format, Constraints, Examples. એ foundation છે. પણ ingredients જાણવાથી chef ન બનાય.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        આ chapter <em>technique</em> વિશે છે. Prompt type કરનાર અને prompt <em>craft</em> કરનાર વચ્ચેનો ફરક. Question પૂછવા અને <strong>right</strong> question પૂછવા વચ્ચેનો ફરક — એ question જે genuinely useful કંઈક unlock કરે.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        સૌથી સારા AI users topic ના experts નથી — <strong>એ પૂછવાના experts છે.</strong> અને પૂછવું એ એક skill છે જે તું શીખી શકે.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SOCRATIC FLIP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        The Socratic Flip
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        મોટાભાગના લોકો AI ને vending machine ની જેમ વાપરે. Prompt નાખો, answer લો. પણ best results <em>conversations</em> માંથી આવે, commands માંથી નહીં. અને સૌથી powerful conversation technique 2,400 વર્ષ જૂની છે.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Socrates ક્યારેય question નો directly answer ન આપતા. એ <em>વધુ</em> questions પૂછતા — probing, clarifying, challenging — જ્યાં સુધી એના students પોતે deeper understanding સુધી ન પહોંચે. તું AI સાથે same approach વાપરી શકે, પણ flipped.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AI ને answer માંગવાના બદલે, AI ને કહે કે તારો interview લે. એને clarifying questions પૂછવા દે જે તને પૂછવાનું ભૂલાઈ ગયું.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        વિચાર: જ્યારે તું type કરે "birthday party plan કર," ત્યારે ડઝનો details છોડી દે છે જે answer ને drastically change કરે. કેટલા લોકો? Budget શું? Indoor કે outdoor? AI ને ખબર નથી — પણ એ પૂછી શકે.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>The Socratic Prompt</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          "હું birthday party plan કરવા માંગુ છું. Planning શરૂ કરતા પહેલાં, મને 5 specific questions પૂછ જે મારી exact situation માટે tailored plan બનાવવામાં help કરે. એક-એક કરીને પૂછ અને મારા response ની રાહ જો."
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        આ single technique — questions કોણ પૂછે એ flip કરવું — સૌથી powerful upgrades માંથી એક છે. એ AI ને answer machine માંથી <strong>thinking partner</strong> બનાવે.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FLIP THE SCRIPT ═══ -->
  <section id="flip-the-script" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <FlipTheScript client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ FEW-SHOT PROMPTING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        બતાવ, કહે નહીં
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        વિચાર કે તું friend ને style explain કરી રહ્યો છે. તું પાંચ minute words માં describe કરી શકે — "playful પણ childish નહીં, casual પણ sloppy નહીં, short sentences અને unexpected comparisons." અથવા તું simply example બતાવી શકે: <em>"આવું લખ."</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        આ છે <strong>few-shot prompting</strong>. Abstract માં describe કરવાના બદલે, AI ને concrete examples આપ. એક example "one-shot" prompt છે. બે-ત્રણ examples "few-shot" છે. Zero examples — જ્યાં તું ફક્ત describe કરે — "zero-shot" છે.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style="--accent: #6B7280;">
        <span class="prompt-block-label" style="color: #6B7280;">Zero-shot (describing)</span>
        <p class="m-0" style="color: var(--color-deep);">"Running shoes ની product description લખ. Punchy અને conversational બનાવ, short sentences સાથે. Marketing clichés ન વાપર."</p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Few-shot (showing)</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          "CloudRunner X1 running shoe ની product description લખ. આ style જોઈએ:<br /><br />
          <em>Example: 'The Weekender Tote — તારું laptop, lunch, અને questionable life choices fit થાય. Water-resistant canvas કારણ કે તું કંઈક ચોક્કસ ઢોળીશ. Five pockets, એમાંથી કોઈ પછી યાદ નહીં આવે.'</em><br /><br />
          આ tone match કર: short sentences, self-aware humor, buzzwords કરતાં specificity."
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85] mb-10">
        Few-shot version dramatically better results આપશે. AI "smarter" ન થયું — પણ તેં vague direction ના બદલે <strong>concrete target</strong> આપ્યું. એક good example સો words ની description ની બરાબર છે.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Key insight</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          જ્યારે AI તારી style match ન કરે, ત્યારે વધુ adjectives ન ઉમેર. Example આપ. "આવું" હંમેશા "more punchy but also warm but not too casual" ને beat કરે.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ MINI-CHALLENGE: Zero to Few-Shot ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-12">
    <FadeInBlock client:visible>
      <div style={`background: linear-gradient(135deg, ${chapter.accent}08, ${chapter.accent}04); border: 1px solid ${chapter.accent}20; border-radius: 12px; padding: 2rem 2rem 1.75rem;`}>
        <p style={`font-family: var(--font-mono); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: ${chapter.accent}; margin: 0 0 0.75rem;`}>
          Quick experiment
        </p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0 0 1rem; color: var(--color-deep);">
          કંઈક વિચાર જે તેં recently AI ને લખવા કહ્યું — email, story, social media post. હવે વિચાર કે જો તેં tone નો concrete example include કર્યો હોત. Output કેટલો different હોત?
        </p>
        <p style="font-size: 0.9rem; line-height: 1.7; margin: 0; color: var(--color-deep); opacity: 0.6;">
          એ યાદ રાખ. નીચે Prompt Laboratory માં real test કરી શકીશ.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CHAIN OF THOUGHT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Step by Step વિચાર
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        એક wild વાત: AI ને math problem solve કરવાનું કહે, તો ખોટો answer આવી શકે. પણ <em>step by step solve કર</em> કહે, તો ઘણી વાર right answer આવે. Answer same છે. Question different છે.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        આ technique ને <strong>chain-of-thought prompting</strong> કહે છે. Directly answer માંગવાના બદલે, AI ને reasoning show કરવાનું કહે. "Step by step think through કર." "Answer આપતા પહેલાં break down કર." "જતા-જતા reasoning explain કર."
      </p>
    </FadeInBlock>

    <!-- Before/After comparison -->
    <FadeInBlock client:visible delay={0.2}>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
        <div>
          <div class="prompt-block" style="--accent: #E94560; min-height: 100%;">
            <span class="prompt-block-label" style="color: #E94560;">Chain-of-thought વગર</span>
            <p class="m-0" style="color: var(--color-deep); font-size: 0.85rem;">
              "Bat અને ball સાથે $1.10 ના. Bat, ball કરતાં $1.00 વધારે. Ball ના કેટલા?"
            </p>
            <p style="color: #E94560; font-size: 0.8rem; margin: 1rem 0 0; font-weight: 600;">
              AI answer: $0.10 (ખોટો)
            </p>
          </div>
        </div>
        <div>
          <div class="prompt-block" style={`--accent: ${chapter.accent}; min-height: 100%;`}>
            <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
            <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Chain-of-thought સાથે</span>
            <p class="m-0" style="color: var(--color-deep); font-size: 0.85rem;">
              "Bat અને ball સાથે $1.10 ના. Bat, ball કરતાં $1.00 વધારે. Ball ના કેટલા? Step by step think કર."
            </p>
            <p style={`color: ${chapter.accent}; font-size: 0.8rem; margin: 1rem 0 0; font-weight: 600;`}>
              AI answer: $0.05 (correct)
            </p>
          </div>
        </div>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        આ કેમ work કરે? જ્યારે AI ને step by step reasoning show કરવાનું કહે, ત્યારે દરેક step આગળના step માં feed થાય. AI ને scratch paper આપવા જેવું છે — જેટલું વધુ thinking લખે, final answer એટલો better આવે.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        Chain-of-thought AI ને smarter ન બનાવે. Slower બનાવે — અને slower thinking ઘણી વાર better thinking હોય.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        આ ફક્ત math માટે નથી. Reasoning જોઈએ ત્યારે વાપર: argument analyze કરવા, options compare કરવા, project plan કરવા, code debug કરવા. જ્યારે પણ human ને "show their work" કહેવાય, AI ને પણ એ જ કહે.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE PROMPT ASSEMBLY ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Techniques ને જોડવી
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Real power techniques combine કરવાથી આવે. Few-shot examples <em>plus</em> chain-of-thought. System role <em>plus</em> constraints <em>plus</em> format specification. દરેક technique એક lever છે, અને multiple levers ખેંચવાથી એવું result આવે જે એકલા કોઈ lever ન આપી શકે.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        પણ અહીં nuance છે જે beginners ને experts થી separate કરે: <strong>more હંમેશા better નથી.</strong> Casual brainstorm ને એક-બે techniques જોઈએ. High-stakes essay ને પાંચ. Informal question ને zero. Skill એ જાણવામાં છે — કેટલા levers ખેંચવા — અને કયા.
      </p>
    </FadeInBlock>

    <!-- Technique stack visual -->
    <FadeInBlock client:visible delay={0.2}>
      <div style="margin-bottom: 2.5rem;">
        {[
          { label: 'Casual brainstorm', techniques: ['Task'], color: '#6B7280', width: '25%' },
          { label: 'School assignment', techniques: ['Role', 'Task', 'Format'], color: '#F5A623', width: '50%' },
          { label: 'Important project', techniques: ['Role', 'Context', 'Task', 'Format', 'Examples'], color: '#0EA5E9', width: '75%' },
          { label: 'High-stakes output', techniques: ['Role', 'Context', 'Examples', 'Task', 'Format', 'Constraints', 'Chain-of-thought'], color: '#0F3460', width: '100%' },
        ].map((level, i) => (
          <FadeInBlock client:visible delay={i * 0.06} key={i}>
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem;">
              <span style={`font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600; color: ${level.color}; width: 120px; flex-shrink: 0; text-align: right;`}>
                {level.label}
              </span>
              <div style="flex: 1; height: 24px; background: rgba(26,26,46,0.03); border-radius: 6px; overflow: hidden;">
                <div style={`height: 100%; width: ${level.width}; background: linear-gradient(90deg, ${level.color}20, ${level.color}40); border-radius: 6px; display: flex; align-items: center; padding: 0 8px; gap: 4px;`}>
                  {level.techniques.map((t, j) => (
                    <span key={j} style={`font-family: var(--font-mono); font-size: 0.55rem; font-weight: 600; color: ${level.color}; opacity: 0.8;`}>
                      {t}{j < level.techniques.length - 1 ? ' +' : ''}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.4}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Key insight</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Over-prompting real thing છે. Simple question માટે 500-word prompt answer better ન બનાવે — actually AI ને confuse કરી શકે. Prompt complexity ને task complexity સાથે match કર.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: PROMPT LABORATORY ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <PromptLaboratory client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

