---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import BeatSection from '../../components/chapter/BeatSection';
import PromptMakeover from '../../components/widgets/ch1/PromptMakeover';
import GuessThePrompt from '../../components/widgets/ch1/GuessThePrompt';
import IterationLoop from '../../components/widgets/ch1/IterationLoop';
import PromptRoast from '../../components/widgets/ch1/PromptRoast';
import PromptComparison from '../../components/widgets/ch1/PromptComparison';
import BeatCompletionCard from '../../components/chapter/BeatCompletionCard';

const chapter = chapters[0];
const beats = chapter.beats!;
---

<ChapterLayout chapter={chapter} locale="gu">

  <!-- ═══ BEAT 1: The Communication Gap ═══ -->
  <BeatSection
    beatId={beats[0].id}
    beatNumber={1}
    totalBeats={beats.length}
    title="વાતચીતની ખાઈ"
    tldr="અસ્પષ્ટ prompts થી અસ્પષ્ટ answers મળે. AI શું કરી શકે અને મોટાભાગના લોકો એની પાસે શું કરાવે — આ વચ્ચેની ખાઈ એક communication problem છે."
    estimatedMinutes={beats[0].estimatedMinutes}
    accentColor={chapter.accent}
    nextBeatTitle="પાંચ Building Blocks"
    isFirst={true}
    client:load
  >
    <!-- HERO -->
    <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
      <div class="chapter-number" style={`color: ${chapter.accent};`}>1</div>

      <div class="max-w-[680px] mx-auto text-center relative z-10">
        <FadeInBlock client:visible>
          <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
            ચેપ્ટર વન
          </p>
        </FadeInBlock>

        <FadeInBlock client:visible delay={0.15}>
          <h1
            class="mb-8 leading-[1.08]"
            style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
          >
            તું પહેલેથી જ<br />AI ની ભાષા જાણે છે
          </h1>
        </FadeInBlock>

        <FadeInBlock client:visible delay={0.3}>
          <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
            તારો પહેલો draft magic નહીં હોય.<br />પણ ત્રીજો હોઈ શકે.
          </p>
        </FadeInBlock>
      </div>

      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
        <div class="w-px h-10 bg-deep/40"></div>
      </div>
    </section>

    <!-- STORY OPENER -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
      <FadeInBlock client:visible>
        <p class="drop-cap text-lg leading-[1.85] mb-8">
          તું આખી જિંદગી AI સાથે વાત કરતો રહ્યો છે. જ્યારે પણ તેં search bar માં કંઈક type કર્યું, Siri ને question પૂછ્યો, કે Netflix recommendation મળી, ત્યારે કોઈ algorithm સાંભળી રહ્યું હતું. પણ machine <em>ને</em> કંઈક કહેવું અને machine <em>સાથે</em> વાત કરવી — એમાં ફરક છે.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-8">
          અત્યારે લાખો લોકો ChatGPT માં prompt type કરે, mediocre response મળે, અને વિચારે: <em>"લાગે છે AI એટલું smart નથી."</em> એ ખોટા છે. AI ખૂબ capable છે. બસ એ બરાબર રીતે પૂછતા નથી.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.2}>
        <p class="text-lg leading-[1.85]">
          <strong>AI શું કરી શકે</strong> અને <strong>મોટાભાગના લોકો એની પાસે શું કરાવે</strong> — આ વચ્ચેની ખાઈ ઘણી મોટી છે. અને આ technology ની problem નથી — આ communication ની problem છે. જે તું પહેલેથી fix કરી જાણે છે.
        </p>
      </FadeInBlock>
    </section>

    <Divider accent={chapter.accent} client:load />

    <!-- THE VAGUE PROMPT PROBLEM -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
      <FadeInBlock client:visible>
        <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
        <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
          Vague Prompt ની Problem
        </h2>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-12">
          બે લોકો same AI ને essay માં help માંગે. એકને useless response મળે. બીજાને genuinely brilliant કંઈક મળે. Same AI. ફરક ફક્ત એટલો છે કે એમણે કેવી રીતે પૂછ્યું.
        </p>
      </FadeInBlock>
    </section>

    <section class="max-w-[960px] mx-auto px-6 md:px-10 pb-16">
      <FadeInBlock client:visible delay={0.2}>
        <PromptComparison accentColor={chapter.accent} client:visible />
      </FadeInBlock>
    </section>
    <BeatCompletionCard beatId={beats[0].id} beatTitle="વાતચીતની ખાઈ" nextBeatTitle="પાંચ Building Blocks" accentColor={chapter.accent} client:visible />
  </BeatSection>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BEAT 2: The Five Building Blocks ═══ -->
  <BeatSection
    beatId={beats[1].id}
    beatNumber={2}
    totalBeats={beats.length}
    title="પાંચ Building Blocks"
    tldr="દરેક સારા prompt માં Role, Task, Format, Constraints, અને Examples નું કોઈ combination હોય છે."
    estimatedMinutes={beats[1].estimatedMinutes}
    accentColor={chapter.accent}
    nextBeatTitle="Iteration ની Mindset"
    client:load
  >
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
      <FadeInBlock client:visible>
        <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
        <h2 class="mb-8" style="font-family: var(--font-heading);">
          પાંચ Building Blocks
        </h2>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-6">
          AI માંથી incredible results મેળવનારા લોકો અને generic mush મેળવનારા લોકો વચ્ચે શું ફરક છે? Talent નથી. કોઈ secret tool નથી. એક formula છે — પાંચ building blocks જે દર વખતે કામ કરે છે.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.2}>
        <p class="text-lg leading-[1.85] mb-14">
          તારે હંમેશા બધા પાંચ ની જરૂર નથી. પણ એ જાણવું કે એ exist કરે છે, એ Matrix જોતા શીખવા જેવું છે. એક વાર pattern દેખાઈ ગયો, પછી તું એને unsee ન કરી શકે.
        </p>
      </FadeInBlock>

      <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
        {[
          { letter: 'R', name: 'Role', color: '#E94560', text: 'AI ને શું બનવું જોઈએ? "તું એક AP English tutor છે" — આ બધું બદલી નાખે છે. Tutor explain કરે. Professor lecture આપે. Friend riff કરે. Role થી tone, vocabulary, અને depth shape થાય.' },
          { letter: 'T', name: 'Task', color: '#0F3460', text: 'Exactly શું કરવાનું છે? "મારી essay માં help કર" નહીં, પણ "મારા thesis statement ને strengthen કર." Ruthlessly specific બન. એક prompt માં એક task હંમેશા ત્રણ કરતાં better હોય.' },
          { letter: 'F', name: 'Format', color: '#7B61FF', text: 'Response કેવો દેખાવો જોઈએ? "મને 3 alternatives આપ" એક format છે. "bulleted list તરીકે," "100 words ની અંદર," કે "pros અને cons નો table" — આ બધા format છે. Format rambling ને અટકાવે.' },
          { letter: 'C', name: 'Constraints', color: '#16C79A', text: 'શું ન કરવું જોઈએ? "Clichés વાપરીશ નહીં." "200 words ની અંદર રાખ." Constraints guardrails છે. AI ને unhelpful જગ્યાએ જતું અટકાવે.' },
          { letter: 'E', name: 'Examples', color: '#F5A623', text: 'Show કર, tell ન કર. જો તારે specific style જોઈએ તો "good" કેવું દેખાય એનો example આપ. એક example સો words ની description ની બરાબર છે.' },
        ].map((block, i) => (
          <FadeInBlock client:visible delay={i * 0.08}>
            <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
              <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${block.color};`}>
                {block.letter}
              </div>
              <div style="flex: 1;">
                <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${block.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                  {block.name}
                </p>
                <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                  {block.text}
                </p>
              </div>
            </div>
          </FadeInBlock>
        ))}
      </div>

      <FadeInBlock client:visible delay={0.5}>
        <div class="insight-box">
          <p style="font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;">Key insight</p>
          <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
            તારે દર વખતે બધા પાંચ ની જરૂર નથી. Casual question માં constraints અને examples ની જરૂર નથી. પણ જ્યારે AI તને garbage આપે, ત્યારે જો કે શું missing છે. લગભગ હંમેશા આ પાંચમાંથી કંઈક હોય.
          </p>
        </div>
      </FadeInBlock>
    </section>

    <!-- BRIDGE TO PROMPT MAKEOVER -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
      <FadeInBlock client:visible>
        <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
          બસ theory પૂરી. હવે building blocks ને action માં જોવાનો time છે.
        </p>
      </FadeInBlock>
    </section>

    <!-- WIDGET: PROMPT MAKEOVER -->
    <section id="prompt-makeover" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
      <FadeInBlock client:visible>
        <PromptMakeover client:visible />
      </FadeInBlock>
    </section>
    <BeatCompletionCard beatId={beats[1].id} beatTitle="પાંચ Building Blocks" nextBeatTitle="Iteration ની Mindset" accentColor={chapter.accent} client:visible />
  </BeatSection>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BEAT 3: The Iteration Mindset ═══ -->
  <BeatSection
    beatId={beats[2].id}
    beatNumber={3}
    totalBeats={beats.length}
    title="Iteration ની Mindset"
    tldr="કોઈ પહેલી try માં nail ન કરે. Prompt, evaluate, refine, repeat — આ loop જ actual skill છે."
    estimatedMinutes={beats[2].estimatedMinutes}
    accentColor={chapter.accent}
    nextBeatTitle="પોતાને Test કર"
    client:load
  >
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
      <FadeInBlock client:visible>
        <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
        <h2 class="mb-8" style="font-family: var(--font-heading);">
          Iteration, Perfection નહીં
        </h2>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-10">
          પહેલો prompt લગભગ ક્યારેય work ન કરે. અને એ ઠીક છે. <strong>Actually એ જ તો આખો point છે.</strong>
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
          જ્યારે તું AI નો કોઈ amazing demo જુએ, ત્યારે તું final prompt જોઈ રહ્યો છે — જે કોઈએ પાંચ, દસ, કદાચ વીસ rounds ની refinement પછી બનાવ્યો છે. તું highlight reel જોઈ રહ્યો છે, practice sessions નહીં.
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.2}>
        <p class="text-lg leading-[1.85] mb-10">
          Real workflow કંઈક આવો દેખાય છે:
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.25}>
        <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
          <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
          {[
            { word: 'Prompt.', desc: 'તારો best first attempt લખ.' },
            { word: 'Evaluate.', desc: 'Response વાંચ. શું સારું છે? શું ખોટું છે?' },
            { word: 'Refine.', desc: 'Prompt ને adjust કર. જ્યાં fail થયું ત્યાં more specific બન.' },
            { word: 'Repeat.', desc: 'ત્યાં સુધી જ્યાં સુધી output એવું ન થાય જે તું actually use કરે.' },
          ].map((step, i) => (
            <div style={`position: relative; padding-bottom: ${i < 3 ? '1.75rem' : '0'};`}>
              <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
              <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
                <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
                <span style="opacity: 0.7;"> {step.desc}</span>
              </p>
            </div>
          ))}
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg leading-[1.85] mb-10">
          આ loop — prompt, evaluate, refine, repeat — AI સાથે કામ કરવાની <em>actual skill</em> છે. પહેલી try માં magical perfect prompt craft કરવો — એ myth છે.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.35}>
        <div class="insight-box">
          <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Average good result માં 3-5 iterations લાગે, 1 નહીં.</p>
          <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
            જો તું પહેલી try માં nail કરી રહ્યો છે, તો કદાચ તું enough hard push નથી કરતો. Best outputs back-and-forth માંથી આવે જ્યાં તું અને AI સાથે મળીને refine કરો.
          </p>
        </div>
      </FadeInBlock>
    </section>

    <!-- WIDGET: ITERATION LOOP -->
    <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
      <FadeInBlock client:visible>
        <IterationLoop client:visible />
      </FadeInBlock>
    </section>

    <Divider accent={chapter.accent} client:load />

    <!-- THE PROMPT SPECTRUM -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
      <FadeInBlock client:visible>
        <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
        <h2 class="mb-8" style="font-family: var(--font-heading);">
          The Prompt Spectrum
        </h2>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-12">
          દરેક prompt ને એક spectrum પર વિચાર — vague થી precise સુધી:
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <div style="margin-bottom: 3rem;">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 1.25rem;">
            <span style="font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600; letter-spacing: 0.08em; color: var(--color-subtle); opacity: 0.6;">VAGUE</span>
            <div style="flex: 1; height: 4px; border-radius: 2px; background: linear-gradient(90deg, #CBD5E1 0%, #F5A623 40%, #E94560 70%, #16C79A 100%);"></div>
            <span style="font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600; letter-spacing: 0.08em; color: var(--color-subtle); opacity: 0.6;">PRECISE</span>
          </div>
          <div class="grid grid-cols-3 gap-4 text-center">
            <div>
              <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-subtle); margin: 0 0 4px;">"મને help કર"</p>
              <p style="font-family: var(--font-body); font-size: 0.7rem; color: var(--color-subtle); opacity: 0.5; margin: 0;">generic response</p>
            </div>
            <div>
              <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-amber); margin: 0 0 4px;">"X વિશે લખ"</p>
              <p style="font-family: var(--font-body); font-size: 0.7rem; color: var(--color-subtle); opacity: 0.5; margin: 0;">okay પણ unfocused</p>
            </div>
            <div>
              <p style={`font-family: var(--font-mono); font-size: 0.75rem; color: ${chapter.accent}; font-weight: 600; margin: 0 0 4px;`}>"બધા પાંચ blocks"</p>
              <p style="font-family: var(--font-body); font-size: 0.7rem; color: var(--color-subtle); opacity: 0.5; margin: 0;">targeted, useful</p>
            </div>
          </div>
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.2}>
        <p class="text-lg leading-[1.85] mb-10">
          તારો goal હંમેશા "precise" end પર હોવાનો નથી. Casual brainstorm purpose થી vague હોઈ શકે. પણ <strong>તારે intentionally choose કરવું જોઈએ કે તું spectrum પર ક્યાં છે</strong>, accidentally ત્યાં land ન થવું જોઈએ.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.25}>
        <p class="text-lg leading-[1.85]">
