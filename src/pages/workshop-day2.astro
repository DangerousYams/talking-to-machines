---
export const prerender = true;
import '../styles/global.css';

const slides = [
  'welcome', 'cheatsheet', 'today',
  'break-land',
  'big-three',
  'china', 'local', 'map', 'limits',
  'break-agents',
  'agent-def', 'agent-why', 'agent-calls', 'agent-skills', 'agent-skills-how',
  'agent-future', 'personal-software',
  'extension-url',
  'day3-tease',
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Workshop · Day 2 — Talking to Machines</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Caveat:wght@500;600;700&display=swap" />
  <style>
    /* ══════════════════════════════════════════════════════
       Workshop Day 2 — slide-specific styles
       ══════════════════════════════════════════════════════ */
    body.card-deck-page { background: var(--color-cream); }

    .deck-slide {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 5rem;
      box-sizing: border-box;
    }

    /* Progress rail */
    .progress-rail {
      position: fixed;
      top: 20px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 6px;
      z-index: 50;
      padding: 8px 14px;
      background: rgba(250, 248, 245, 0.75);
      backdrop-filter: blur(10px);
      border-radius: 100px;
      border: 1px solid rgba(26,26,46,0.05);
    }
    .progress-dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: rgba(26,26,46,0.15);
      transition: all 0.3s ease;
    }
    .progress-dot.active {
      background: var(--color-purple);
      width: 16px;
      border-radius: 100px;
    }
    .progress-dot.visited { background: rgba(26,26,46,0.35); }

    /* Slide number */
    .slide-num {
      position: absolute;
      bottom: 28px;
      right: 40px;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      color: var(--color-subtle);
      opacity: 0.5;
    }

    /* Keyboard hint */
    .kbd-hint {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-subtle);
      opacity: 0.55;
      z-index: 50;
      transition: opacity 0.5s ease;
      pointer-events: none;
    }
    .kbd-hint.hidden { opacity: 0; }
    .kbd-hint kbd {
      font-family: var(--font-mono);
      background: rgba(26,26,46,0.06);
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 0.7rem;
      margin: 0 2px;
    }

    /* ─── Staggered entrance ─── */
    .stagger > * {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1);
    }
    .deck-slide.is-active .stagger > * { opacity: 1; transform: translateY(0); }
    .deck-slide.is-active .stagger > *:nth-child(1) { transition-delay: 0.1s; }
    .deck-slide.is-active .stagger > *:nth-child(2) { transition-delay: 0.2s; }
    .deck-slide.is-active .stagger > *:nth-child(3) { transition-delay: 0.3s; }
    .deck-slide.is-active .stagger > *:nth-child(4) { transition-delay: 0.4s; }
    .deck-slide.is-active .stagger > *:nth-child(5) { transition-delay: 0.5s; }
    .deck-slide.is-active .stagger > *:nth-child(6) { transition-delay: 0.6s; }

    /* ─── Print / export-to-PDF ─── */
    @media print {
      @page { size: 1600px 900px; margin: 0; }
      html, body {
        background: var(--color-cream) !important;
        width: 1600px !important;
        height: auto !important;
      }
      body.card-deck-page::before { display: none !important; }
      .progress-rail, .kbd-hint { display: none !important; }
      .card-deck-container {
        height: auto !important;
        max-height: none !important;
        overflow: visible !important;
        scroll-snap-type: none !important;
      }
      .card-deck-card, .deck-slide {
        width: 1600px !important;
        height: 900px !important;
        scroll-snap-align: none !important;
        page-break-after: always !important;
        break-after: page !important;
        overflow: hidden !important;
      }
      .card-deck-card:last-child, .deck-slide:last-child {
        page-break-after: auto !important;
        break-after: auto !important;
      }
      .stagger > * { opacity: 1 !important; transform: none !important; transition: none !important; }
      * { animation: none !important; }

      [data-slide="break-land"],
      [data-slide="break-agents"],
      [data-slide="day3-tease"] { display: none !important; }

      .ai-grid { grid-template-columns: repeat(3, 1fr) !important; }
      .mode-grid { grid-template-columns: repeat(3, 1fr) !important; }
      .notable-grid { grid-template-columns: repeat(4, 1fr) !important; }
      .china-grid { grid-template-columns: repeat(3, 1fr) !important; }
      .limits-grid { grid-template-columns: repeat(3, 1fr) !important; }
      .auto-grid { grid-template-columns: 1fr 1fr !important; }
      .local-grid { grid-template-columns: 1fr 1fr !important; }
      .map-grid { grid-template-columns: repeat(3, 1fr) !important; }
      .loop-diagram-big { flex-direction: row !important; }
      .calls-grid { grid-template-columns: repeat(3, 1fr) !important; }
      .skills-examples { grid-template-columns: repeat(3, 1fr) !important; }
      .show-grid { grid-template-columns: repeat(3, 1fr) !important; }
      .arch-grid { grid-template-columns: 1fr 1fr !important; }
    }

    /* ─── Utilities ─── */
    .caveat { font-family: 'Caveat', cursive; font-weight: 600; }
    .mono-label {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-subtle);
    }
    .constellation { display: inline-flex; gap: 10px; align-items: center; }
    .constellation span { width: 7px; height: 7px; border-radius: 50%; opacity: 0.6; }

    /* ══════════════════════════════════════════════════════
       WELCOME — "Day Two" wordmark
       ══════════════════════════════════════════════════════ */
    .slide-welcome {
      align-items: center;
      justify-content: center;
      text-align: center;
    }
    .slide-welcome .eyebrow {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--color-subtle);
      margin-bottom: 1.5rem;
    }
    .slide-welcome .wordmark {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(5rem, 13vw, 11rem);
      line-height: 1.05;
      letter-spacing: -0.04em;
      margin: 0;
    }
    .slide-welcome .wordmark .day {
      display: block;
      color: var(--color-deep);
      font-style: italic;
      font-weight: 500;
    }
    .slide-welcome .wordmark .two {
      display: block;
      color: var(--color-purple);
    }
    .slide-welcome .tagline {
      font-family: var(--font-body);
      font-style: italic;
      font-size: 1.3rem;
      color: var(--color-subtle);
      margin-top: 2rem;
    }
    .slide-welcome .tagline strong { color: var(--color-purple); font-weight: 600; font-style: normal; }

    /* ══════════════════════════════════════════════════════
       CHEAT SHEET (compact replay of Day 1)
       ══════════════════════════════════════════════════════ */
    .slide-cheatsheet { justify-content: center; padding: 3rem 4rem; }
    .cheatsheet-content { max-width: 1440px; margin: 0 auto; width: 100%; }
    .cheatsheet-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid rgba(26,26,46,0.08);
      padding-bottom: 1.25rem;
    }
    .cheatsheet-title {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.25rem, 4vw, 3rem);
      letter-spacing: -0.03em;
      line-height: 1;
      margin: 0;
    }
    .cheatsheet-title .accent { color: var(--color-accent-red); font-style: italic; }
    .cheatsheet-sub {
      font-family: 'Caveat', cursive;
      font-size: 1.3rem;
      color: var(--color-subtle);
      transform: rotate(-1deg);
      display: inline-block;
    }
    .cheatsheet-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px 12px;
    }
    .cs-card {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.07);
      border-radius: 10px;
      padding: 0.75rem 1rem;
      display: flex;
      align-items: baseline;
      gap: 0.85rem;
      min-height: 64px;
    }
    .cs-num {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 1.5rem;
      letter-spacing: -0.02em;
      flex-shrink: 0;
      line-height: 1;
      min-width: 2ch;
    }
    .cs-title {
      font-family: var(--font-body);
      font-weight: 600;
      font-size: 0.96rem;
      line-height: 1.3;
      color: var(--color-deep);
    }
    .cs-title em { font-style: italic; color: var(--color-navy); font-weight: 600; }

    /* Cheat sheet footer — link to the Playbook */
    .cheatsheet-cta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-top: 1.25rem;
      padding-top: 1rem;
      border-top: 1px dashed rgba(26,26,46,0.1);
      flex-wrap: wrap;
    }
    .cheatsheet-cta-lead {
      font-family: 'Caveat', cursive;
      font-size: 1.3rem;
      color: var(--color-purple);
      transform: rotate(-1deg);
      display: inline-block;
    }
    .cheatsheet-cta-link {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      color: var(--color-purple);
      text-decoration: none;
      padding: 7px 14px;
      border-radius: 100px;
      border: 1px solid rgba(123,97,255,0.25);
      background: rgba(123,97,255,0.05);
      transition: all 0.2s ease;
    }
    .cheatsheet-cta-link:hover {
      background: rgba(123,97,255,0.12);
      border-color: rgba(123,97,255,0.4);
    }
    .cheatsheet-cta-link .path { color: var(--color-deep); opacity: 0.55; }

    /* ══════════════════════════════════════════════════════
       TODAY — three-beat agenda
       ══════════════════════════════════════════════════════ */
    .slide-today { justify-content: center; }
    .today-content { max-width: 1100px; margin: 0 auto; width: 100%; }
    .today-head { margin-bottom: 2.5rem; text-align: center; }
    .today-head h1 {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 5vw, 3.75rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0.5rem 0 0.5rem;
    }
    .today-head .sub {
      font-family: var(--font-body);
      font-style: italic;
      color: var(--color-subtle);
      font-size: 1.15rem;
    }
    .today-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    .today-card {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.08);
      border-radius: 14px;
      padding: 2rem 1.75rem;
      position: relative;
      overflow: hidden;
    }
    .today-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
    }
    .today-card.a::before { background: var(--color-amber); }
    .today-card.b::before { background: var(--color-accent-red); }
    .today-card.c::before { background: var(--color-teal); }
    .today-num {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-subtle);
      margin-bottom: 0.75rem;
    }
    .today-card h3 {
      font-family: var(--font-heading);
      font-size: 1.6rem;
      font-weight: 800;
      margin: 0 0 0.6rem;
      letter-spacing: -0.02em;
    }
    .today-card.a h3 { color: var(--color-amber); }
    .today-card.b h3 { color: var(--color-accent-red); }
    .today-card.c h3 { color: var(--color-teal); }
    .today-card p {
      font-family: var(--font-body);
      font-size: 1rem;
      line-height: 1.55;
      color: var(--color-deep);
      margin: 0;
    }

    /* ══════════════════════════════════════════════════════
       SECTION BREAK slides
       ══════════════════════════════════════════════════════ */
    .slide-break { justify-content: center; align-items: center; text-align: center; }
    .break-label {
      font-family: 'Caveat', cursive;
      font-weight: 600;
      font-size: 1.75rem;
      color: var(--color-purple);
      transform: rotate(-2deg);
      display: inline-block;
      margin-bottom: 0.5rem;
    }
    .break-title {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(4rem, 10vw, 8rem);
      letter-spacing: -0.04em;
      line-height: 0.95;
      margin: 0;
      font-style: italic;
    }
    .break-title .period { color: var(--color-purple); font-style: normal; }
    .break-under {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-subtle);
      margin-top: 2rem;
    }
    .slide-break.break-agents .break-label { color: var(--color-accent-red); }
    .slide-break.break-agents .break-title .period { color: var(--color-accent-red); }
    .slide-break.break-build .break-label { color: var(--color-teal); }
    .slide-break.break-build .break-title .period { color: var(--color-teal); }

    /* ══════════════════════════════════════════════════════
       BIG THREE — ChatGPT · Claude · Gemini
       ══════════════════════════════════════════════════════ */
    .slide-big-three { justify-content: center; }
    .bt-content { max-width: 1280px; margin: 0 auto; width: 100%; }
    .bt-head { text-align: center; margin-bottom: 2.5rem; }
    .bt-head h1 {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 5vw, 3.75rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0.5rem 0;
    }
    .bt-head h1 em { font-style: italic; color: var(--color-purple); }
    .bt-head .sub {
      font-family: var(--font-body);
      font-style: italic;
      color: var(--color-subtle);
      font-size: 1.15rem;
    }
    .ai-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
    .ai-card {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.08);
      border-radius: 14px;
      padding: 1.75rem 1.5rem;
      position: relative;
      overflow: hidden;
    }
    .ai-card .ai-glyph {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 3rem;
      line-height: 1;
      letter-spacing: -0.03em;
      opacity: 0.12;
      position: absolute;
      right: 1.25rem;
      top: 1.25rem;
      user-select: none;
    }
    .ai-card .ai-maker {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-subtle);
      margin-bottom: 0.5rem;
    }
    .ai-card h3 {
      font-family: var(--font-heading);
      font-size: 2rem;
      font-weight: 800;
      margin: 0 0 0.75rem;
      letter-spacing: -0.02em;
    }
    .ai-card .ai-verdict {
      font-family: var(--font-body);
      font-style: italic;
      font-size: 1.05rem;
      color: var(--color-deep);
      line-height: 1.5;
      margin: 0 0 1.1rem;
      padding-bottom: 1rem;
      border-bottom: 1px dashed rgba(26,26,46,0.12);
    }
    .ai-card ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .ai-card li {
      font-family: var(--font-body);
      font-size: 0.92rem;
      line-height: 1.45;
      color: var(--color-deep);
      padding: 0.25rem 0 0.25rem 1.1rem;
      position: relative;
    }
    .ai-card li::before {
      content: '•';
      position: absolute;
      left: 0;
      font-weight: 700;
    }
    .ai-card.gpt { border-top: 4px solid var(--color-teal); }
    .ai-card.gpt h3, .ai-card.gpt .ai-glyph, .ai-card.gpt li::before { color: var(--color-teal); }
    .ai-card.claude { border-top: 4px solid var(--color-amber); }
    .ai-card.claude h3, .ai-card.claude .ai-glyph, .ai-card.claude li::before { color: var(--color-amber); }
    .ai-card.gemini { border-top: 4px solid var(--color-sky); }
    .ai-card.gemini h3, .ai-card.gemini .ai-glyph, .ai-card.gemini li::before { color: var(--color-sky); }

    /* ══════════════════════════════════════════════════════
       SINGLE-AI deep dive (ChatGPT / Claude / Gemini)
       ══════════════════════════════════════════════════════ */
    .slide-verdict { justify-content: center; }
    .verdict-content { max-width: 1180px; margin: 0 auto; width: 100%; }
    .verdict-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-subtle);
      margin-bottom: 1rem;
    }
    .verdict-title {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(3rem, 6vw, 5rem);
      letter-spacing: -0.03em;
      line-height: 1;
      margin: 0 0 1.25rem;
    }
    .verdict-title em { font-style: italic; }
    .verdict-sub {
      font-family: var(--font-body);
      font-size: 1.45rem;
      line-height: 1.5;
      color: var(--color-deep);
      max-width: 60ch;
      margin: 0 0 2.5rem;
    }
    .verdict-sub strong { color: var(--color-deep); font-weight: 700; }

    /* Claude — strengths list */
    .verdict-list {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem 2rem;
      max-width: 900px;
    }
    .verdict-list li {
      list-style: none;
      font-family: var(--font-body);
      font-size: 1.15rem;
      padding: 0.5rem 0 0.5rem 1.75rem;
      position: relative;
      color: var(--color-deep);
    }
    .verdict-list li::before {
      content: '→';
      position: absolute;
      left: 0;
      top: 0.5rem;
      font-weight: 700;
    }

    /* Gemini — modes grid */
    .mode-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.85rem;
      max-width: 1000px;
    }
    .mode-chip {
      background: var(--color-warm-white);
      border: 1px solid rgba(14,165,233,0.2);
      border-radius: 10px;
      padding: 0.9rem 1.1rem;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .mode-chip .mode-kind {
      font-family: var(--font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--color-sky);
    }
    .mode-chip .mode-name {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 1.15rem;
      color: var(--color-deep);
      letter-spacing: -0.01em;
    }
    .mode-chip .mode-desc {
      font-family: var(--font-body);
      font-size: 0.82rem;
      color: var(--color-subtle);
      line-height: 1.35;
      margin-top: 2px;
    }

    /* Color-coded verdict slides */
    .slide-verdict.gpt .verdict-title em { color: var(--color-teal); }
    .slide-verdict.claude .verdict-title em { color: var(--color-amber); }
    .slide-verdict.gemini .verdict-title em { color: var(--color-sky); }
    .slide-verdict.claude .verdict-list li::before { color: var(--color-amber); }

    /* ChatGPT — quote callout */
    .gpt-callout {
      background: var(--color-warm-white);
      border-left: 4px solid var(--color-teal);
      padding: 1.5rem 1.75rem;
      border-radius: 8px;
      max-width: 780px;
      font-family: var(--font-body);
      font-style: italic;
      font-size: 1.2rem;
      line-height: 1.55;
      color: var(--color-deep);
    }
    .gpt-callout .attrib {
      display: block;
      margin-top: 0.6rem;
      font-family: var(--font-mono);
      font-style: normal;
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--color-subtle);
    }

    /* ══════════════════════════════════════════════════════
       CHINA models
       ══════════════════════════════════════════════════════ */
    .slide-china { justify-content: center; }
    .china-head { max-width: 780px; margin: 0 auto 2.5rem; text-align: center; }
    .china-head .eyebrow {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-subtle);
    }
    .china-head h1 {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 5vw, 3.75rem);
      letter-spacing: -0.03em;
