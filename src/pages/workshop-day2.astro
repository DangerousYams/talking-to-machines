    .principle-title .hl-purple { color: var(--color-purple); }
    .principle-title .hl-teal { color: var(--color-teal); }
    .principle-title .hl-amber { color: var(--color-amber); }
    .principle-title .hl-sky { color: var(--color-sky); }
    .principle-body {
      font-family: var(--font-body);
      font-size: 1.5rem;
      line-height: 1.55;
      color: var(--color-deep);
