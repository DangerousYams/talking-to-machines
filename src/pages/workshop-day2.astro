      text-transform: uppercase;
      color: var(--color-teal);
      margin-bottom: 2px;
    }
    .skill-chip .name {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 1rem;
      color: var(--color-deep);
      letter-spacing: -0.01em;
      line-height: 1.25;
    }
    .skills-footer {
      margin-top: 1.5rem;
      text-align: center;
      font-family: 'Caveat', cursive;
      font-size: 1.3rem;
      color: var(--color-teal);
      transform: rotate(-1deg);
      display: block;
    }

    /* Skills — how slide */
    .slide-skills-how { justify-content: center; padding: 3rem 4rem; }
    .show-content { max-width: 1260px; margin: 0 auto; width: 100%; }
    .show-head { max-width: 820px; margin: 0 auto 1.75rem; text-align: center; }
    .show-head .eyebrow {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-subtle);
    }
    .show-head h1 {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.25rem, 4.5vw, 3.25rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0.75rem 0 0.5rem;
    }
    .show-head h1 em { font-style: italic; color: var(--color-teal); }
    .show-head .sub {
      font-family: var(--font-body);
      font-style: italic;
      color: var(--color-subtle);
      font-size: 1.05rem;
    }
    .show-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.1rem;
    }
    .show-card {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.08);
      border-top: 3px solid currentColor;
      border-radius: 14px;
      padding: 1.4rem 1.3rem;
    }
    .show-card.find { color: var(--color-teal); }
    .show-card.care { color: var(--color-accent-red); }
    .show-card.use { color: var(--color-purple); }
    .show-card .step {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-subtle);
      margin-bottom: 0.4rem;
    }
    .show-card h3 {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 1.35rem;
      letter-spacing: -0.02em;
      margin: 0 0 0.75rem;
    }
    .show-card p {
      font-family: var(--font-body);
      font-size: 0.92rem;
      line-height: 1.5;
      color: var(--color-deep);
      margin: 0 0 0.65rem;
    }
    .show-card p:last-child { margin-bottom: 0; }
    .show-card code {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      background: rgba(22,199,154,0.08);
      color: var(--color-teal);
      padding: 1px 6px;
      border-radius: 4px;
    }
    .show-card.care code { background: rgba(233,69,96,0.08); color: var(--color-accent-red); }
    .show-card.use code { background: rgba(123,97,255,0.08); color: var(--color-purple); }
    .show-card .pills {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
      margin-top: 0.5rem;
    }
    .show-card .pill {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      padding: 2px 8px;
      border-radius: 100px;
      border: 1px solid currentColor;
      color: currentColor;
      background: rgba(255,255,255,0.5);
    }
    .show-footer {
      margin-top: 1.5rem;
      text-align: center;
      font-family: 'Caveat', cursive;
      font-size: 1.35rem;
      color: var(--color-purple);
      transform: rotate(-1deg);
      display: block;
    }

    /* ══════════════════════════════════════════════════════
       EXTENSION-URL — call to action
       ══════════════════════════════════════════════════════ */
    .slide-ext-url { justify-content: center; text-align: center; }
    .ext-content { max-width: 900px; margin: 0 auto; }
    .ext-eyebrow {
      font-family: 'Caveat', cursive;
      font-size: 1.7rem;
      color: var(--color-teal);
      transform: rotate(-2deg);
      display: inline-block;
    }
    .ext-content h1 {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 5vw, 3.75rem);
      letter-spacing: -0.03em;
      line-height: 1.1;
      margin: 1rem 0 1.5rem;
    }
    .ext-url {
      display: inline-block;
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: clamp(1.5rem, 2.8vw, 2.2rem);
      color: var(--color-deep);
      margin: 1.5rem 0;
      padding: 1rem 2rem;
      background: var(--color-warm-white);
      border: 1.5px solid rgba(26,26,46,0.08);
      border-radius: 12px;
      letter-spacing: -0.01em;
      box-shadow: 0 8px 28px rgba(15,52,96,0.08);
    }
    .ext-url .accent { color: var(--color-teal); }
    .ext-url .path { color: var(--color-subtle); font-weight: 500; }
    .ext-desc {
      font-family: var(--font-body);
      font-size: 1.1rem;
      color: var(--color-subtle);
      font-style: italic;
      margin: 0 auto 1rem;
      max-width: 560px;
      line-height: 1.55;
    }
    .ext-tags {
      display: inline-flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: center;
      margin-top: 1.5rem;
    }
    .ext-tag {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 6px 12px;
      border-radius: 100px;
      background: rgba(22,199,154,0.08);
      color: var(--color-teal);
      border: 1px solid rgba(22,199,154,0.2);
    }

    /* ══════════════════════════════════════════════════════
       DAY 3 TEASE — closing
       ══════════════════════════════════════════════════════ */
    .slide-closing { justify-content: center; align-items: center; text-align: center; }
    .closing-label {
      font-family: 'Caveat', cursive;
      font-size: 1.6rem;
      color: var(--color-teal);
      transform: rotate(-2deg);
      margin-bottom: 1rem;
      display: inline-block;
    }
    .closing-title {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(3rem, 7vw, 5.5rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0.5rem 0 1.75rem;
      max-width: 18ch;
    }
    .closing-title .accent { color: var(--color-teal); font-style: italic; }
    .closing-desc {
      font-family: var(--font-body);
      font-size: 1.25rem;
      color: var(--color-deep);
      line-height: 1.6;
      max-width: 620px;
    }
    .closing-footer {
      font-family: var(--font-body);
      color: var(--color-subtle);
      font-style: italic;
      margin-top: 2rem;
      font-size: 1rem;
    }

    /* ══════════════════════════════════════════════════════
       Responsive (laptop fallback)
       ══════════════════════════════════════════════════════ */
    @media (max-width: 1100px) {
      .deck-slide { padding: 3rem 2rem; }
      .today-grid, .ai-grid, .china-grid, .calls-grid, .skills-examples, .show-grid { grid-template-columns: 1fr; gap: 1rem; }
      .notable-grid { grid-template-columns: repeat(2, 1fr); }
      .mode-grid { grid-template-columns: repeat(2, 1fr); }
      .limits-grid { grid-template-columns: 1fr; }
      .auto-grid { grid-template-columns: 1fr; }
      .local-grid { grid-template-columns: 1fr; }
      .map-grid { grid-template-columns: 1fr; }
      .arch-grid { grid-template-columns: 1fr; }
      .loop-diagram-big { flex-direction: column; gap: 1rem; }
      .loop-arrow-big { transform: rotate(90deg); }
      .cheatsheet-grid { grid-template-columns: repeat(2, 1fr); }
      .verdict-list { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body class="card-deck-page">

  <!-- Progress rail -->
  <div class="progress-rail" id="rail">
    {slides.map((_, i) => <div class="progress-dot" data-idx={i}></div>)}
  </div>

  <!-- Keyboard hint -->
  <div class="kbd-hint" id="kbd-hint">
    <kbd>←</kbd> <kbd>→</kbd> navigate · <kbd>space</kbd> next
  </div>

  <!-- Deck -->
  <div class="card-deck-container" id="deck">

    <!-- ═══ 01 · Welcome · Day Two ═══ -->
    <section class="card-deck-card deck-slide slide-welcome" data-slide="welcome">
      <div class="stagger">
        <div class="eyebrow">Talking to Machines</div>
        <h1 class="wordmark">
          <span class="day">Day</span>
          <span class="two">Two.</span>
        </h1>
        <p class="tagline">The day you <strong>build something</strong>.</p>
      </div>
      <div class="slide-num">01 · Welcome</div>
    </section>

    <!-- ═══ 02 · Cheat sheet ═══ -->
    <section class="card-deck-card deck-slide slide-cheatsheet" data-slide="cheatsheet">
      <div class="cheatsheet-content stagger">
        <div class="cheatsheet-header">
          <h1 class="cheatsheet-title">The <span class="accent">15</span>, in one glance.</h1>
          <span class="cheatsheet-sub">from Day 1 →</span>
        </div>
        <div class="cheatsheet-grid">
          <div class="cs-card"><span class="cs-num" style="color:#E94560;">01</span><span class="cs-title">Learn for the AI of <em>tomorrow</em>.</span></div>
          <div class="cs-card"><span class="cs-num" style="color:#7B61FF;">02</span><span class="cs-title">Not technical — it's <em>communication</em>.</span></div>
          <div class="cs-card"><span class="cs-num" style="color:#0F3460;">03</span><span class="cs-title">Choose → Communicate → Evaluate.</span></div>
          <div class="cs-card"><span class="cs-num" style="color:#F5A623;">04</span><span class="cs-title">Pick the <em>right</em> AI for the task.</span></div>
          <div class="cs-card"><span class="cs-num" style="color:#16C79A;">05</span><span class="cs-title">Frame the conversation, not the prompt.</span></div>
          <div class="cs-card"><span class="cs-num" style="color:#7B61FF;">06</span><span class="cs-title">Great <em>examples</em> beat great instructions.</span></div>
          <div class="cs-card"><span class="cs-num" style="color:#E94560;">07</span><span class="cs-title">Ask AI to ask <em>you</em> questions.</span></div>
          <div class="cs-card"><span class="cs-num" style="color:#0EA5E9;">08</span><span class="cs-title">Ask AI for help <em>with</em> AI.</span></div>
          <div class="cs-card"><span class="cs-num" style="color:#E94560;">09</span><span class="cs-title"><em>Iteration</em> is everything. 3–5 passes.</span></div>
          <div class="cs-card"><span class="cs-num" style="color:#F5A623;">10</span><span class="cs-title">Don't take the <em>quick win</em>.</span></div>
          <div class="cs-card"><span class="cs-num" style="color:#F5A623;">11</span><span class="cs-title">Never trust <em>one</em> machine. Cross-check.</span></div>
          <div class="cs-card"><span class="cs-num" style="color:#16C79A;">12</span><span class="cs-title">Always <em>humanize</em>. Deslop everything.</span></div>
          <div class="cs-card"><span class="cs-num" style="color:#E94560;">13</span><span class="cs-title">Conviction. Art. Sense. <em>Judgment</em>.</span></div>
          <div class="cs-card"><span class="cs-num" style="color:#16C79A;">14</span><span class="cs-title">Your <em>sessions</em> become your SOP.</span></div>
          <div class="cs-card"><span class="cs-num" style="color:#0EA5E9;">15</span><span class="cs-title">Every task = <em>Know</em> · <em>Do</em> · <em>Show</em>.</span></div>
        </div>
        <div class="cheatsheet-cta">
          <span class="cheatsheet-cta-lead">Want the 9 actual prompts? →</span>
          <a class="cheatsheet-cta-link" href="https://talkingtomachines.xyz/playbook" target="_blank" rel="noopener">
            talkingtomachines.xyz<span class="path">/playbook</span>
          </a>
        </div>
      </div>
      <div class="slide-num">02 · Cheat sheet</div>
    </section>

    <!-- ═══ 04 · Today ═══ -->
    <section class="card-deck-card deck-slide slide-today" data-slide="today">
      <div class="today-content stagger">
        <div class="today-grid">
          <div class="today-card a">
            <div class="today-num">Beat 01</div>
            <h3>Lay of the land.</h3>
            <p>The Big Three. What each is actually for. What to pay for, what to get free.</p>
          </div>
          <div class="today-card b">
            <div class="today-num">Beat 02</div>
            <h3>Agents changed everything.</h3>
            <p>An LLM with a goal, in a loop, calling tools. Why that one idea broke everything open.</p>
          </div>
          <div class="today-card c">
            <div class="today-num">Beat 03</div>
            <h3>We build.</h3>
            <p>A real Chrome extension. Yours. Installed on your machine by the end of the day.</p>
          </div>
        </div>
      </div>
      <div class="slide-num">03 · Today</div>
    </section>

    <!-- ═══ 05 · Break — Lay of the land ═══ -->
    <section class="card-deck-card deck-slide slide-break" data-slide="break-land">
      <div class="stagger" style="display: flex; flex-direction: column; align-items: center;">
        <span class="break-label">First — let's get the map right →</span>
        <h1 class="break-title">Lay of the land<span class="period">.</span></h1>
        <p class="break-under">Who makes what · who's best at what · what's worth paying for</p>
      </div>
      <div class="slide-num">04 · Break</div>
    </section>

    <!-- ═══ 06 · Big Three intro ═══ -->
    <section class="card-deck-card deck-slide slide-big-three" data-slide="big-three">
      <div class="bt-content stagger">
        <div class="bt-head">
          <span class="mono-label">The only three that matter — right now</span>
          <h1>ChatGPT. Claude. <em>Gemini.</em></h1>
          <p class="sub">All three have their place. Only one is best at each thing.</p>
        </div>
        <div class="ai-grid">
          <div class="ai-card gpt">
            <span class="ai-glyph">G</span>
            <div class="ai-maker">OpenAI</div>
            <h3>ChatGPT</h3>
            <p class="ai-verdict">The default everyone knows — and the one that's quietly fallen behind for pro work.</p>
            <ul>
              <li>Huge install base, sticky brand</li>
              <li>Good for quick answers, travel, casual writing</li>
              <li>Falls short on long, structured, serious work</li>
            </ul>
          </div>
          <div class="ai-card claude">
            <span class="ai-glyph">C</span>
            <div class="ai-maker">Anthropic</div>
            <h3>Claude</h3>
            <p class="ai-verdict">The pro's choice. Best thinking, best writing, best coding partner you can buy.</p>
            <ul>
              <li>Coding agents · Claude Code · SDK</li>
              <li>Long-form composition &amp; planning</li>
              <li>Serious discussions that hold their shape</li>
            </ul>
          </div>
          <div class="ai-card gemini">
            <span class="ai-glyph">G</span>
            <div class="ai-maker">Google DeepMind</div>
            <h3>Gemini</h3>
            <p class="ai-verdict">The swiss army knife. More modes than anyone else — video, audio, images, research.</p>
            <ul>
              <li>Veo · Nano Banana · NotebookLM</li>
              <li>The most generous free tier, by far</li>
              <li>Rapid monthly shipping cadence</li>
            </ul>
          </div>
