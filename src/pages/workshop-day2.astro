    .principle-body em { color: var(--color-navy); }
    .deck-slide p { max-width: none; }

    /* ══════════════════════════════════════════════════════
       AGENT-CALLS — CLIs · MCPs · APIs
       ══════════════════════════════════════════════════════ */
    .slide-calls { justify-content: center; }
    .calls-content { max-width: 1240px; margin: 0 auto; width: 100%; }
    .calls-head { text-align: center; margin-bottom: 2.5rem; }
    .calls-head h1 {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 5vw, 3.75rem);
      letter-spacing: -0.03em;
      margin: 0.5rem 0;
    }
    .calls-head h1 em { font-style: italic; color: var(--color-purple); }
    .calls-head .sub {
      font-family: var(--font-body);
      font-style: italic;
      color: var(--color-subtle);
      font-size: 1.1rem;
    }
    .calls-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
    .calls-card {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.08);
      border-radius: 14px;
      padding: 1.75rem 1.5rem;
    }
    .calls-card.cli { border-top: 3px solid var(--color-purple); }
    .calls-card.mcp { border-top: 3px solid var(--color-teal); }
    .calls-card.api { border-top: 3px solid var(--color-navy); }
    .calls-card .acronym {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-subtle);
