    }
    .calls-card h3 {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 1.7rem;
      margin: 0 0 0.75rem;
      letter-spacing: -0.02em;
    }
    .calls-card.cli h3 { color: var(--color-purple); }
    .calls-card.mcp h3 { color: var(--color-teal); }
    .calls-card.api h3 { color: var(--color-navy); }
    .calls-card p {
      font-family: var(--font-body);
      font-size: 0.98rem;
      line-height: 1.5;
      color: var(--color-deep);
      margin: 0 0 0.9rem;
