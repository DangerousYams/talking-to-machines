    .calls-card .egs {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .calls-card .eg {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      padding: 3px 9px;
      border-radius: 100px;
      border: 1px solid rgba(26,26,46,0.15);
      color: var(--color-deep);
      background: var(--color-cream);
    }

    /* ══════════════════════════════════════════════════════
       SKILLS — concept slide + how-to slide
       ══════════════════════════════════════════════════════ */
    .slide-skills { justify-content: center; padding: 3rem 4rem; }
    .skills-content { max-width: 1180px; margin: 0 auto; width: 100%; }
    .skills-head { max-width: 820px; margin: 0 auto 2rem; text-align: center; }
    .skills-head .eyebrow {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-subtle);
    }
    .skills-head h1 {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 5vw, 3.75rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0.75rem 0 1rem;
    }
    .skills-head h1 em { font-style: italic; color: var(--color-teal); }
    .skills-lead {
      font-family: var(--font-body);
      font-size: 1.2rem;
      line-height: 1.55;
      color: var(--color-deep);
      max-width: 720px;
      margin: 0 auto 1.25rem;
    }
    .skills-lead em { color: var(--color-navy); font-weight: 600; }
    .skills-lead .alien {
      font-family: 'Caveat', cursive;
      font-size: 1.05em;
      color: var(--color-accent-red);
      font-style: normal;
      font-weight: 600;
    }
    .skills-examples {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
