---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ContextWindowViz from '../../components/widgets/ch3/ContextWindowViz';
import ForgettingExperiment from '../../components/widgets/ch3/ForgettingExperiment';
import SystemPromptSandbox from '../../components/widgets/ch3/SystemPromptSandbox';

const chapter = chapters[2];
---

<ChapterLayout chapter={chapter} locale="ta">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>3</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          அத்தியாயம் மூன்று
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Context<br />Engineering
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          AI மறந்துவிடுவதில்லை &mdash; அது<br />முதலிலேயே நினைவில் வைத்துக் கொள்ளவில்லை.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        உன் நண்பனுடன் பேசிக்கொண்டிருக்கிறாய் என்று வைத்துக் கொள், ஆனால் சில நிமிடங்களுக்கு ஒருமுறை யாரோ ஒருவர் உன் இருவரும் எழுதிக்கொண்டிருக்கும் வைட்போர்டை அழித்துவிடுகிறார். நீ மீண்டும் தொடங்குகிறாய். உன் நண்பன் எஞ்சியிருப்பதைப் பார்த்து எதுவும் நடக்காதது போல் தொடர முயற்சிக்கிறான். நீண்ட உரையாடலின்போது AI-யின் "மூளைக்குள்" இப்படித்தான் இருக்கும்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        <strong>AI-க்கு நினைவகம் இல்லை.</strong> நீ நினைப்பது போல் இல்லை. நேற்றைய உரையாடலை அது நினைவில் வைத்திருக்காது. <em>இந்த</em> உரையாடலின் தொடக்கத்தைக் கூட அது நினைவில் வைத்திருக்காது, அது போதுமான அளவு நீண்டால். அது கொடுக்கும் ஒவ்வொரு பதிலும் முற்றிலும் தற்போது அதற்குத் தெரியும் தகவல்களின் அடிப்படையில் மட்டுமே &mdash; <strong>context window</strong> எனப்படும் உரைப் பகுதி.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        இந்த window-ஐ புரிந்துகொள்வது &mdash; அதில் என்ன செல்கிறது, அது எவ்வளவு பெரியது, அது நிரம்பும்போது என்ன நடக்கிறது &mdash; AI-யுடன் வேலை செய்வதில் மிக முக்கியமான திறமைகளில் ஒன்று.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE WHITEBOARD METAPHOR ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        அழிக்கப்படும் வைட்போர்ட்
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        நீ AI-க்கு ஒரு செய்தி அனுப்பும்போது, உண்மையில் என்ன நடக்கிறது: சிஸ்டம் உன் <em>முழு உரையாடலையும்</em> &mdash; நீ அனுப்பிய ஒவ்வொரு செய்தி, AI கொடுத்த ஒவ்வொரு பதில் &mdash; எல்லாவற்றையும் எடுத்து மீண்டும் மாடலுக்கு ஒற்றை உரைத் துண்டாக கொடுக்கிறது. AI அனைத்தையும் படித்து, அடுத்த பதிலை உருவாக்கி, பின்னர்... எல்லாவற்றையும் மறந்துவிடுகிறது.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        அடுத்த முறை நீ ஒரு செய்தி அனுப்பும்போது, முழு செயல்முறையும் மீண்டும் நடக்கிறது. சிஸ்டம் மீண்டும் முழு உரையாடலையும் ஒட்டுகிறது, உன் புதிய செய்தியைச் சேர்க்கிறது, AI முழுவதையும் புதிதாக படிக்கிறது. இது உலகின் மிகவும் விடாமுயற்சியான ஆனால் மறதியான வாசகனைப் போல் &mdash; ஒவ்வொரு முறையும் முழுமையாக, ஆனால் ஒவ்வொரு திருப்பத்திலும் புதிதாக ஆரம்பிக்கிறது.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AI உருவாக்கும் ஒவ்வொரு பதிலும் அந்த தருணத்தில் context window-இல் என்ன இருக்கிறதோ அதன் அடிப்படையிலேயே. அதைவிட ஒன்றும் இல்லை. Context window என்பது நினைவகம் அல்ல. அது ஒரு வைட்போர்ட் &mdash; அதற்கு விளிம்புகள் உண்டு.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        இதன் பெரிய விளைவுகள் உண்டு. AI-க்கு தற்போது முன்னால் இருக்கும் தகவல்களைப் போலத்தான் நல்லது என்று அர்த்தம். முக்கியமான விவரம் ஒன்றை விட்டுவிட்டாயா? AI அதை மாயமாக நினைவுபடுத்தாது. Window-ஐ சத்தத்தால் நிரப்பினால்? AI குழப்பமடையும். <strong>Context window தான் உன் மிக முக்கியமான வளம்.</strong> அதை நிர்வகிக்கக் கற்றுக்கொள்வதுதான் சாதாரண பயனர்களையும் உண்மையில் சக்திவாய்ந்த முடிவுகளை பெறுபவர்களையும் பிரிக்கும் காரியம்.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ TOKENS — THE AI'S ALPHABET ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Tokens: AI-யின் எழுத்துக்கள்
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI வார்த்தைகளை நீ படிப்பது போல் படிப்பதில்லை. அது <strong>tokens</strong> படிக்கிறது &mdash; உரைத் துண்டுகள் பொதுவாக ஒரு வார்த்தையின் முக்கால் பங்கு அளவில் இருக்கும். "incredible" என்ற வார்த்தை இரண்டு tokens. "AI" ஒரு token. ஒரு வார்த்தைக்கு முன்னால் இருக்கும் ஸ்பேஸ் அடிக்கடி அதே token-இல் சேர்க்கப்படும்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: #7B61FF;">
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>விரைவு கணக்கு</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          1 token &asymp; 4 எழுத்துக்கள் &asymp; 0.75 வார்த்தைகள்<br />
          100 tokens &asymp; 75 வார்த்தைகள்<br />
          வழக்கமான ஒரு பக்க உரை &asymp; 300 tokens<br />
          முழு நாவல் ஒன்று &asymp; 100,000 tokens
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        இது ஏன் முக்கியம்? ஏனெனில் ஒவ்வொரு AI மாடலுக்கும் tokens-இல் அளக்கப்படும் <strong>context window size</strong> உண்டு. Claude-இன் context window 200,000 tokens வைத்திருக்க முடியும் &mdash; அது சுமார் 500 பக்க புத்தகம். GPT-4o 128,000 வைத்திருக்கிறது. இவை மகத்தானதாக தோன்றலாம், ஆனால் நீ நினைப்பதை விட விரைவாக நிரம்பிவிடும்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        நீ அனுப்பும் ஒவ்வொரு செய்தி, AI எழுதும் ஒவ்வொரு பதில், பின்னணியில் வேலை செய்யும் ஒவ்வொரு system instruction &mdash; இவை எல்லாம் அதே பகிர்ந்த பட்ஜெட்டிலிருந்து tokens பயன்படுத்துகின்றன. அந்த பட்ஜெட் தீர்ந்தால், விஷயங்கள் விளிம்பிலிருந்து கீழே விழ ஆரம்பித்துவிடும்.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: CONTEXT WINDOW VIZ ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ContextWindowViz client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ WHEN THE WINDOW OVERFLOWS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Window நிரம்பி வழியும்போது
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        நீ உரையாடலில் பத்தாவது செய்தியில் இருக்கிறாய். மூன்றாவது செய்தியில் உன் உணவுக் கட்டுப்பாடுகளைக் குறிப்பிட்டாய். பதினைந்தாவது செய்தியில், உணவகப் பரிந்துரைகளில் ஆழமாக இருக்கிறாய். நீ கேட்கிறாய்: <em>"காத்திரு, நான் என்ன உணவுக் கட்டுப்பாடுகளை குறிப்பிட்டேன்?"</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        AI சொல்கிறது: <em>"நீ குறிப்பிட்ட உணவுக் கட்டுப்பாடுகள் எதையும் குறிப்பிட்டதாக நினைக்கவில்லை."</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        நீ விரக்தியடைகிறாய். <em>அது அங்கேயே இருக்கிறது, நான் சொன்னேன்!</em> ஆனால் விஷயம் என்னவென்றால்: அது அங்கே <strong>இல்லை</strong>. இப்போது இல்லை. அந்த ஆரம்பகால செய்தி தெரியும் window-விலிருந்து நழுவியிருக்கலாம், அல்லது மாடல் அதை சமீபத்திய context-ற்கு விரும்பி குறைவான முன்னுரிமை கொடுத்திருக்கலாம். AI கவனக்குறைவாக இல்லை. அதன் முன்னால் இல்லாததை அது உண்மையிலேயே பார்க்க முடியாது.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>இது ஒரு bug அல்ல. இது architecture.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI context window-ஐ ஒரே உட்காருமானத்தில் ஆவணம் படிக்கும் மனிதனைப் போல் செயலாக்குகிறது. ஆவணம் 100 பக்கங்கள் நீளமாக இருந்தால், 95ஆம் பக்கத்தில் 3ஆம் பக்கத்தின் விவரங்கள் மங்கலாக இருக்கலாம். தீர்வு பெரிய window அல்ல &mdash; உள்ளே போடுவதை புத்திசாலித்தனமாக பேக் செய்வதுதான்.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FORGETTING EXPERIMENT ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ForgettingExperiment client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SYSTEM PROMPT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        System Prompt: மறைந்த வழிமுறைகள்
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
