---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import DebugDetective from '../../components/widgets/ch9/DebugDetective';
import EvalFramework from '../../components/breaks/EvalFramework';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[8];
---

<ChapterLayout chapter={chapter} locale="ta">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>9</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          அத்தியாயம் ஒன்பது
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          AI தவறாகச்<br />சொல்லும்போது
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Amateurs-ஐ pros-இலிருந்து<br />பிரிக்கும் verification பழக்கங்கள்.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        உனக்கு flawless essay எழுத உதவிய அதே AI, அதே confidence-உடன், Napoleon Waterloo போரில் வென்றார் என்றும் சொல்லலாம். தயங்காது. தடுமாறாது. முழுமையாக fabricate செய்யப்பட்ட "fact"-ஐ மற்ற எல்லாவற்றுக்கும் பயன்படுத்தும் அதே authoritative tone-ல் சொல்லும். AI யுடன் வேலை செய்வதின் மையத்தில் இருக்கும் paradox இது: <strong>அதை useful ஆக்கும் அதே fluency, அதை dangerous ஆகவும் ஆக்குகிறது.</strong>
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONCEPT: HALLUCINATION ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        நம்பகத்தோற்றம் உண்மை அல்ல
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10" style="margin-top: 0;">
        AI models database-இலிருந்து facts retrieve செய்வதில்லை. அடுத்த most likely word-ஐ predict செய்கின்றன. Real விஷயம் பற்றி கேட்டால், training data சரியான தகவலை நோக்கி guide செய்கிறது. இல்லாத ஒன்று பற்றி கேட்டால், model "எனக்கு தெரியாது" சொல்வதில்லை. சரியான பதில் <em>எப்படி இருக்கும்</em> என்பதை generate செய்கிறது &mdash; பெயர்கள், தேதிகள், citations எல்லாம் சேர்த்து. எல்லாம் fabricated.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        AI எவ்வளவு confident-ஆக sound ஆகிறது என்பதற்கும் எவ்வளவு accurate ஆக இருக்கிறது என்பதற்கும் எந்த correlation-உம் இல்லை. தவறான பதிலும் சரியான பதிலும் வெளியிலிருந்து ஒரே மாதிரி தெரியும். "சரியா தெரியுது" test-க்கு மதிப்பில்லை. உன் ஒரே defense &mdash; verification.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>முக்கிய கருத்து</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI க்கு truth என்ற concept இல்லை. <em>Plausibility</em> என்ற concept இருக்கிறது. Pattern-க்கு fit ஆகும் text generate செய்கிறது &mdash; அந்த text reality-க்கு match ஆகிறதா இல்லையா என்பது வேறு கதை.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        உன் detector-ஐ test செய்துபார். AI claims-ல் எது real, எது fabricated என்று சொல்ல முடியுமா?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <DebugDetective client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="Every AI user needs this chapter. It teaches you exactly how AI hallucinates, why it agrees with wrong answers, and how to catch it. Super practical." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        AI யிலிருந்து அதிக value பெறுபவர்கள் &mdash; எப்போது trust செய்ய வேண்டும், எப்போது verify செய்ய வேண்டும் என்று exactly கற்றுக்கொண்டவர்கள்.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        AI எப்போது தவறு என்று தெரிவது ஒரு பெரிய கேள்விக்கு வழிவகுக்கிறது: அது <em>ஒருபோதும்</em> செய்ய முடியாதது என்ன? அடுத்தது, பிடிவாதமாக, அழகாக மனிதனாகவே இருக்கும் skills-ஐ explore செய்வோம் &mdash; ஏன் அவை முன்னெப்போதையும் விட முக்கியம் என்பதையும்.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(233,69,96,0.06) 15%, rgba(233,69,96,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#E94560" toolName="Eval Framework" client:visible>
        <EvalFramework client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
