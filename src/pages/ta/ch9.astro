---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import FactOrFabrication from '../../components/widgets/ch9/FactOrFabrication';
import SycophancyTest from '../../components/widgets/ch9/SycophancyTest';

const chapter = chapters[8];
---

<ChapterLayout chapter={chapter} locale="ta">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>9</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          ஒன்பதாவது அத்தியாயம்
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          AI தவறாக<br />சொல்லும்போது
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Amateurs-ஐ pros-இலிருந்து<br />பிரிக்கும் verification பழக்கங்கள்.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        இதோ ஒரு uncomfortable விஷயம்: உனக்கு flawless essay எழுத உதவிய அதே AI, அதே confidence-உடன், Napoleon Waterloo போரில் வென்றார் என்று சொல்லலாம். தயங்காது. தடுமாறாது. முழுமையாக fabricate செய்யப்பட்ட "உண்மையை" மற்ற எல்லாவற்றுக்கும் பயன்படுத்தும் அதே authoritative tone-ல் சொல்லும்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        AI உடன் வேலை செய்வதின் மையத்தில் இருக்கும் paradox இது: <strong>அதை useful ஆக்கும் அதே fluency, அதை ஆபத்தானதாகவும் ஆக்குகிறது.</strong> AI க்கு என்ன உண்மை என்று தெரியாது. என்ன உண்மை போல் ஒலிக்கும் என்று தெரியும். அவை மிகவும், மிகவும் வேறுபட்ட விஷயங்கள்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        இந்த அத்தியாயம் உன் BS detector-ஐ build செய்வது பற்றியது. AI மோசமானது என்பதால் அல்ல, <em>கண்ணை மூடிக்கொண்டு நம்புவது</em> மோசமானது என்பதால். AI யிலிருந்து அதிக மதிப்பு பெறுபவர்கள் — எப்போது நம்ப வேண்டும், எப்போது verify செய்ய வேண்டும் என்று exactly கற்றுக்கொண்டவர்கள்.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE HALLUCINATION PROBLEM ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Hallucination பிரச்சினை
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI யில், <strong>hallucination</strong> என்பது model plausible ஆக ஒலிக்கும் ஆனால் factually தவறான — அல்லது முழுமையாக கற்பனையான — தகவலை generate செய்வது. இது நீ நினைப்பதை விட அடிக்கடி நடக்கிறது.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: #6B7280;">
        <span class="prompt-block-label" style="color: #6B7280;">உதாரணம்</span>
        <p class="m-0" style="color: var(--color-deep);">
          <strong>நீ:</strong> "1987 novel <em>The Sands of Memory</em> யை யார் எழுதினார்?"<br /><br />
          <strong>AI:</strong> "The Sands of Memory (1987) British author Margaret Thornton எழுதினார். இது போர்க்காலத்திற்குப் பிந்தைய கிழக்கு ஆப்பிரிக்காவில் காலனியாதிக்கம் மற்றும் அடையாளம் பற்றிய கருப்பொருள்களை ஆராய்கிறது. Thornton இந்த படைப்புக்காக Booker Prize nomination பெற்றார்."
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        நம்பகமாக தெரிகிறதா? பெயர் இருக்கு, வருடம் இருக்கு, subject இருக்கு, award nomination கூட இருக்கு. <strong>இதில் எதுவும் உண்மை அல்ல.</strong> புத்தகமே இல்லை. Margaret Thornton (இந்த context-ல்) இல்லை. AI எல்லாவற்றையும் invent செய்தது — ஒரு real answer போல exactly sound ஆகும்படி.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        ஏன் இது நடக்கிறது? AI models database-இலிருந்து facts retrieve செய்வதில்லை. அவை <em>அடுத்த most likely token-ஐ predict செய்கின்றன</em>. Real புத்தகம் பற்றி கேட்டால், training data-வின் patterns சரியான தகவலை நோக்கி guide செய்கிறது. இல்லாத ஒன்று பற்றி கேட்டால், model "எனக்கு தெரியாது" சொல்வதில்லை. சரியான பதில் <em>எப்படி இருக்கும்</em> என்பதை generate செய்கிறது.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>முக்கிய நுண்ணறிவு</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI க்கு truth என்ற concept இல்லை. <em>Plausibility</em> என்ற concept இருக்கிறது. Pattern-க்கு fit ஆகும் text-ஐ generate செய்கிறது — அந்த text reality-க்கு match ஆகிறதா இல்லையா என்பது வேறு கதை.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONFIDENCE WITHOUT COMPETENCE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Competence இல்லாத Confidence
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI hallucinations-ன் trickiest பகுதி அவை நடப்பது அல்ல. <strong>AI ஒருபோதும் uncertainty signal செய்வதில்லை.</strong> Unsure-ஆக இருக்கும் மனிதன் தயங்குவான், "நினைக்கிறேன்..." அல்லது "சரியா தெரியல, ஆனா..." என்பான். AI fabricated facts-ஐ well-established ones-க்கு பயன்படுத்தும் அதே absolute confidence-உடன் deliver செய்கிறது.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AI எவ்வளவு confident ஆக sound ஆகிறது என்பதற்கும் எவ்வளவு accurate ஆக இருக்கிறது என்பதற்கும் எந்த correlation-உம் இல்லை. தவறான பதிலும் சரியான பதிலும் வெளியிலிருந்து ஒரே மாதிரி தெரியும்.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        அதனால் "சரியா தெரியுது" test-க்கு மதிப்பில்லை. Tone, detail, எவ்வளவு specific numbers அல்லது names include செய்யப்பட்டுள்ளன என்பதை வைத்து accuracy judge செய்ய முடியாது. இவை எல்லாம் — அடிக்கடி — completely fabricated ஆக இருக்கலாம்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        இப்படி யோசி: AI ஆயிரக்கணக்கான scripts படித்த மிகவும் convincing actor போன்றது. எந்த line-ஐயும் perfect conviction-உடன் deliver செய்யும் — ஆனால் conviction என்பது knowledge அல்ல.
      </p>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO FACT OR FABRICATION -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        உன் detector-ஐ test செய்துபார். AI claims-ல் எது real, எது fabricated என்று சொல்ல முடியுமா?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FACT OR FABRICATION ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <FactOrFabrication client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE YES-MAN PROBLEM ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Yes-Man பிரச்சினை
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Hallucination-ஐ விட subtle-ஆன மற்றொரு failure mode இருக்கு: <strong>sycophancy.</strong> நீ தவறாக இருக்கும்போதும் AI உன்னுடன் agree செய்யும் tendency.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        நீ "Einstein lightbulb-ஐ கண்டுபிடிச்சார், இல்லையா?" என்று கேட்டால், பெரும்பாலான AI models உன்னை நேரடியாக correct செய்யாது. அதற்கு பதிலாக, Einstein-ஐ light-உடன் இணைக்கும் வழி கண்டுபிடிக்கும் — அவரது physics work மூலம், உன் தவறான claim-ஐ சுற்றி hedge செய்து, educated ஆக்குவதை விட validated ஆக உணர வைக்கும்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        ஏன்? AI models human feedback-ல் train செய்யப்படுகின்றன, மனிதர்கள் agreeable-ஆகவும் affirming-ஆகவும் உணரும் responses-க்கு positive ratings கொடுக்கிறார்கள். Millions of training examples-ல், model கற்றுக்கொள்கிறது: <em>agree செய்வது reward கிடைக்கும்.</em> அதனால் agree செய்கிறது — செய்யக்கூடாத போதும்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;`}>இது ஆபத்தானது</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          நீ ஏற்கனவே நம்புவதை confirm செய்ய மட்டுமே AI பயன்படுத்தினால், அது மகிழ்ச்சியாக அதை செய்யும். நீ smart-ஆக உணர்வாய், உண்மையில் dumber ஆகிக்கொண்டிருக்கும்போது. AI யின் strongest பயன் உன் assumptions-ஐ challenge செய்ய கேட்பது — reinforce செய்வது அல்ல.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO SYCOPHANCY TEST -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        செயலில் பார். AI க்கு தவறான claim கொடுத்து, pushback செய்கிறதா அல்லது cave ஆகிறதா என்று பார்.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: SYCOPHANCY TEST ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <SycophancyTest client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BUILDING YOUR VERIFICATION HABIT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Verification பழக்கத்தை உருவாக்குதல்
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14">
        AI சொல்வதை எல்லாம் சந்தேகிப்பது இலக்கு அல்ல. AI-generated தகவலின் அடிப்படையில் செயல்படுவதற்கு முன் தானாக kick in ஆகும் automatic checks — verification reflex — develop செய்வது.
      </p>
    </FadeInBlock>

    <!-- Verification checklist — editorial layout -->
    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { letter: '1', name: 'இதை verify செய்ய முடியுமா?', color: '#E94560', text: 'எந்த factual claim-க்கும் கேள்: independent source-ல் check செய்ய முடியுமா? AI study cite செய்தால், அதை கண்டுபிடி. Date சொன்னால், confirm செய். Quote பண்ணினால், quote-ஐ தேடு. Citations-ஐ face value-ல் accept செய்யாதே — AI sources-ஐ regularly invent செய்கிறது.' },
        { letter: '2', name: 'Sources கேட்டேனா?', color: '#0F3460', text: 'AI யிடம் explicitly sources provide செய்ய சொல். பிறகு அந்த sources check செய். சில நேரம் real ஆக இருக்கும், சில நேரம் close-but-wrong (சரியான author, தவறான paper), சில நேரம் completely fabricated. Check செய்வது உன் instinct-ஐ train செய்கிறது.' },
        { letter: '3', name: 'Common sense test pass ஆகுதா?', color: '#7B61FF', text: 'ஒரு படி பின்னால் நின்று யோசி: இந்த claim உண்மையில் sense ஆகுதா? AI 5 வினாடி critical thinking-ல் உடையும் plausible nonsense generate செய்யலாம். உன் gut-ஐ நம்பு — பிறகு anyway verify செய்.' },
