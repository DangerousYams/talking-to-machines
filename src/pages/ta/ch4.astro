---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ToolWall from '../../components/widgets/ch4/ToolWall';
import WorkflowBuilder from '../../components/widgets/ch4/WorkflowBuilder';
import HeadToHead from '../../components/widgets/ch4/HeadToHead';

const chapter = chapters[3];
---

<ChapterLayout chapter={chapter} locale="ta">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>4</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          நான்காம் அத்தியாயம்
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          AI<br />உலகம்
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          நீ இப்பவே பயன்படுத்தக்கூடிய<br />ஒவ்வொரு AI டூலுக்கும் வழிகாட்டி.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        பெரும்பாலான மக்கள் "AI" என்று சொல்லும்போது, அவர்களுக்கு ChatGPT தான் நினைவுக்கு வரும். ஒருவேளை Google Gemini-ஐ, அல்லது Claude-ன் பேரைக் கேட்டிருக்கலாம். இது "இணையம்" என்று சொல்லி Google-ஐ மட்டும் குறிப்பிடுவது மாதிரி. தவறு இல்லை. ஆனால் மகத்தான ஒன்றின் சிறிய துண்டு மட்டும்தான்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        இப்போவே நீ இன்றைக்கே பயன்படுத்தக்கூடிய நூறு கணக்கான AI டூல்கள் இருக்கின்றன -- ஏதோ கற்பனையான எதிர்காலத்தில் அல்ல, உன் browser-இல் இருந்தே இப்பவே. ஒரு வாக்கியத்தில் இருந்து அசலான படங்களை உருவாக்கும் டூல்கள். முழு பாடல்களையே இயற்றும் டூல்கள். உன் ஆராய்ச்சி தலைப்பில் எழுதப்பட்ட ஒவ்வொரு கல்விக் கட்டுரையையும் படித்து, கருத்து ஒருமைப்பாட்டை மூன்று பத்திகளில் சுருக்கும் டூல்கள்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        இந்த அத்தியாயம் உன் வழிகாட்டி. முழுமையான பட்டியல் அல்ல -- அது அடுத்த செவ்வாய்கிழமையே காலாவதியாகிவிடும் -- ஆனால் <strong>நிலப்பரப்பின் வரைபடம்</strong>தான். முக்கியமான பிரிவுகள், தெரிந்துகொள்ள வேண்டிய டூல்கள், மற்றும் சரியான ஒன்றைத் தேர்ந்தெடுக்க உதவும் சிந்தனைக் கட்டமைப்பு.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BEYOND THE CHATBOT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Chatbot-ஐ தாண்டி
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Chatbot என்பது பனிப்பாறையின் நுனி மட்டும். அதன் கீழே, AI பல்வேறு சிறப்பு திறன்களாக பிரிந்து, ஒவ்வொன்றும் வெவ்வேறு வேலைக்கு வெவ்வேறு மாதிரியான கருவியாக மாறியிருக்கிறது.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        இசைக்கருவிகளைப் பத்தி யோசித்துப் பார். பியானோ மற்றும் மேளத் தட்டு இரண்டுமே "இசைக்கருவிகள்" தான், ஆனால் நீ பியானோ வாசிப்பவரிடம் beat போடச் சொல்ல மாட்டாய், மேளக்காரரிடம் concerto வாசிக்கச் சொல்ல மாட்டாய். AI டூல்களும் அதே மாதிரி. படத் தயாரிப்புக்காக உருவாக்கப்பட்ட டூல் கோடிங் டூலிலிருந்து அடிப்படையிலேயே வேறுபட்டது -- வேறு கட்டமைப்பு, வேறு பயிற்சித் தரவு, வேறு வலிமைகள்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        10 AI டூல்களை மேலோட்டமாக தெரிந்த ஒருவன் ஒரே டூலை ஆழமாக தெரிந்த ஒருவனை தொடர்ந்து விஞ்சுவான். விரிவான விழிப்புணர்வு ஆழமான நிபுணத்துவத்தை வெல்லும் -- ஆரம்பத்தில்.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        இன்றைய நிலையில் இருக்கும் நிலப்பரப்பு இதுதான், இந்த டூல்கள் உண்மையில் <em>என்ன செய்கின்றன</em> என்பதின் அடிப்படையில் ஒழுங்கமைக்கப்பட்டது.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE EIGHT FAMILIES ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        எட்டு குடும்பங்கள்
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14">
        நீ எந்த AI டூலை சந்தித்தாலும் அது இந்த பிரிவுகளில் ஏதேனும் ஒன்றில் பொருந்தும். சில டூல்கள் எல்லைகளைத் தாண்டுகின்றன, ஆனால் இந்த குடும்பங்களைப் புரிந்துகொள்வது குழப்பத்தைப் புரிந்துகொள்ள மனரீதியான வரைபடத்தை அளிக்கிறது.
      </p>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { icon: '1', name: 'படம் உருவாக்கும் கருவிகள்', color: '#E94560', text: 'எழுத்து உள்ளே செல்கிறது, படங்கள் வெளியே வருகின்றன. ஃபோட்டோ ரியலிஸ்டிக் காட்சிகளில் இருந்து anime வரை oil paintings வரை. Midjourney, DALL-E 3, Stable Diffusion, Flux, Ideogram. மிகவும் ஜனநாயகப்படுத்தும் பிரிவு -- யார் வேண்டுமானாலும் வார்த்தைகளில் இருந்து காட்சிக் கலையை உருவாக்கலாம்.' },
        { icon: '2', name: 'படம் திருத்தும் கருவிகள்', color: '#F5A623', text: 'உண்மையான படத்தை வைத்து அதை மாற்றுக. பின்புலத்தை நீக்கு, resolution-ஐ அதிகரி, பொருள்களை மாற்று, காட்சிகளை மறு-வெளிச்சமிடு. Photoshop AI, Magnific, Clipdrop. இவை மனித photographers மற்றும் designers-ஐ மாற்றுவதை விட அவர்களை ஊக்குவிக்கின்றன.' },
        { icon: '3', name: 'வீடியோ உருவாக்கும் கருவிகள்', color: '#7B61FF', text: 'புதிய எல்லை. எழுத்து அல்லது ஸ்டில் படங்களில் இருந்து வீடியோ கிளிப்புகளை உருவாக்கு. Sora, Runway, Kling, Pika. இன்னும் ஆரம்ப நிலையில் -- பெரும்பாலான கிளிப்புகள் 30 வினாடிக்குக் கீழே -- ஆனால் அதிர்ச்சிகரமான வேகத்தில் மேம்படுகின்றன. திரைப்படத் தயாரிப்பு இனி ஒருபோதும் அதே மாதிரி இருக்காது.' },
        { icon: '4', name: 'இசை & ஆடியோ', color: '#16C79A', text: 'எழுத்து விளக்கத்தில் இருந்து முழு பாடல்கள், 30-வினாடி மாதிரியில் இருந்து குரல் நகல், தேவைக்கேற்ப ஒலி விளைவுகள். Suno, Udio, ElevenLabs. இந்த கருவிகள் ஒரு ஸ்டுடியோவும் குழுவும் செய்யக்கூடியதை ஒரு prompt-ஆக சுருக்கின்றன.' },
        { icon: '5', name: 'ஆராய்ச்சி முகவர்கள்', color: '#0EA5E9', text: 'உனக்காக இணையம் (அல்லது கல்வித் தரவுத்தளங்களை) படிக்கும் AI. Perplexity தேடி மேற்கோள் காட்டுகிறது. Elicit கட்டுரைகளை படிக்கிறது. Consensus அறிவியல் ஒருமைப்பாட்டைக் கண்டறிகிறது. NotebookLM உன் ஆவணங்களை நிபுணனாக மாற்றுகிறது.' },
        { icon: '6', name: 'AI Browser-கள்', color: '#6B7280', text: 'மனிதனைப் போல வலையில் navigate செய்யக்கூடிய agents. பொத்தான்களை அழுத்து, படிவங்களை நிரப்பு, பக்கங்களுக்கு இடையில் navigate செய். Arc, Operator, Claude Computer Use. "கேள்விகளுக்கு பதிலளி" மற்றும் "பணிகளைச் செய்" என்பதற்கு இடையிலான பாலம்.' },
        { icon: '7', name: 'கோடிங் கருவிகள்', color: '#E94560', text: 'கோடை எழுதி, திருத்தி, இயக்கி, debug செய்யும் AI. Claude Code உன் terminal-இல் இருந்து வேலை செய்கிறது. Cursor மற்றும் Windsurf முழு எடிட்டர்கள். Copilot inline-ஆக பரிந்துரைக்கிறது. Replit Agent முற்றிலும் புதிய app-களை scratch-இல் இருந்து உருவாக்குகிறது.' },
        { icon: '8', name: 'Chatbot-கள் & உதவியாளர்கள்', color: '#0F3460', text: 'நீ ஏற்கனவே அறிந்த பொது-நோக்க உரையாடல் AI: ChatGPT, Claude, Gemini. அவை Swiss army knives -- பல விஷயங்களில் நல்லவை, எப்படி prompt செய்வது தெரிந்தால் சிறந்தவை (அது உனக்குத் தெரியும், அத்தியாயம் 1-3 நன்றி).' },
      ].map((family, i) => (
        <FadeInBlock client:visible delay={i * 0.06}>
          <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${family.color};`}>
              {family.icon}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${family.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {family.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {family.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>முக்கிய நுண்ணறிவு</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          இந்த பிரிவுகள் ஒன்றுசேர்ந்து வருகின்றன. படம் உருவாக்கும் கருவிகள் வீடியோவை சேர்க்கின்றன. Chatbot-கள் கருவி பயன்பாட்டைப் பெறுகின்றன. கோடிங் கருவிகள் agents-ஆக மாறுகின்றன. இரண்டு ஆண்டுகளில், எல்லைகள் மங்கிவிடும். ஆனால் இப்போது, சிறப்பாளர்கள் இன்னும் தங்கள் சிறப்பில் பொதுவாளர்களை வெல்கிறார்கள்.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO TOOL WALL -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        முழு பட்டியலை ஆராய்ந்து பார். என்ன செய்கிறது என்று தெரிந்துகொள்ள எந்த கருவியையும் கிளிக் செய்.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: TOOL WALL ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ToolWall client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CHOOSING THE RIGHT TOOL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
