---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ToolWall from '../../components/widgets/ch4/ToolWall';
import DreamProject from '../../components/breaks/DreamProject';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[3];
---

<ChapterLayout chapter={chapter} locale="ta">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>4</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          அத்தியாயம் நான்கு
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          AI<br />உலகம்
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          நீ இப்பவே பயன்படுத்தக்கூடிய<br />ஒவ்வொரு AI tool-க்கும் வழிகாட்டி.
        </p>
        <p class="mt-6" style="font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.08em; color: rgba(26,26,46,0.3);">
          கடைசியாக புதுப்பிக்கப்பட்டது மார்ச் 2026
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        பெரும்பாலான மக்கள் "AI" என்று சொல்லும்போது ChatGPT தான் நினைவுக்கு வரும். "இணையம்" என்று சொல்லி Google மட்டும் குறிப்பிடுவது போன்றது. இப்போது நீ இன்றே பயன்படுத்தக்கூடிய நூற்றுக்கணக்கான AI tools இருக்கின்றன &mdash; ஒரு வாக்கியத்திலிருந்து photorealistic படங்கள் உருவாக்கும் tools, முழு பாடல்கள் இயற்றும் tools, உன் research topic பற்றிய ஒவ்வொரு academic paper-ஐயும் படித்து consensus-ஐ மூன்று paragraphs-ல் summarize செய்யும் tools. இந்த chapter உன் நிலப்பரப்பின் வரைபடம்.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE EIGHT FAMILIES ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        எட்டு குடும்பங்கள்
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        இசைக்கருவிகளைப் பற்றி யோசி. Piano-வும் drum kit-உம் இரண்டும் "instruments" தான், ஆனால் pianist-கிட்ட beat போடச் சொல்ல மாட்டாய். AI tools-உம் அதே மாதிரி &mdash; image generation-க்காக build ஆன tool, code-க்காக build ஆனதிலிருந்து அடிப்படையில் வேறு. நீ சந்திக்கும் ஒவ்வொரு tool-உம் இந்த எட்டு குடும்பங்களில் ஒன்றில் fit ஆகும்.
      </p>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { icon: '1', name: 'படம் உருவாக்குபவை', color: '#E94560', text: 'Text உள்ளே, images வெளியே. Midjourney, DALL-E 3, Stable Diffusion, Flux, Ideogram.' },
        { icon: '2', name: 'படம் திருத்துபவை', color: '#F5A623', text: 'உண்மையான படத்தை வைத்து transform செய்யும். Photoshop AI, Magnific, Clipdrop.' },
        { icon: '3', name: 'வீடியோ உருவாக்குபவை', color: '#7B61FF', text: 'Text அல்லது stills-இலிருந்து video clips generate செய்யும். Sora, Runway, Kling, Pika.' },
        { icon: '4', name: 'இசை & ஆடியோ', color: '#16C79A', text: 'Prompt-இலிருந்து முழு பாடல்கள், voice cloning, sound effects. Suno, Udio, ElevenLabs.' },
        { icon: '5', name: 'ஆராய்ச்சி முகவர்கள்', color: '#0EA5E9', text: 'உனக்காக internet படிக்கும் AI. Perplexity, Elicit, Consensus, NotebookLM.' },
        { icon: '6', name: 'AI Browsers', color: '#6B7280', text: 'மனிதனைப் போல web-ல் navigate செய்யும் agents. Arc, Operator, Claude Computer Use.' },
        { icon: '7', name: 'Coding Tools', color: '#E94560', text: 'Code எழுதி, edit செய்து, debug செய்யும் AI. Claude Code, Cursor, Antigravity, Copilot.' },
        { icon: '8', name: 'Chatbots & உதவியாளர்கள்', color: '#0F3460', text: 'நீ ஏற்கனவே அறிந்த general-purpose conversational AI: ChatGPT, Claude, Gemini.' },
      ].map((family, i) => (
        <FadeInBlock client:visible delay={i * 0.06}>
          <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${family.color};`}>
              {family.icon}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${family.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {family.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {family.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>முக்கிய கருத்து</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          10 AI tools-ஐ மேலோட்டமாக தெரிந்த ஒருவன், ஒரே tool-ஐ ஆழமாக தெரிந்த ஒருவனை தொடர்ந்து விஞ்சுவான். ஒரு professional carpenter-க்கு பிடித்த tool இல்லை &mdash; <em>ஒவ்வொரு வேலைக்கும்</em> பிடித்த tool இருக்கும்.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        முழு catalog-ஐ explore செய். என்ன செய்கிறது என்று தெரிய எந்த tool-ஐயும் click செய்.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ToolWall client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="There are way more AI tools than I realized. This interactive guide maps out 8 families of tools — image gen, video, music, research, coding — with examples of each." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Landscape ஒவ்வொரு மாதமும் மாறுகிறது. ஆனால் tools மாறினாலும் categories நிலையானவை &mdash; <em>அது</em> தான் மனப்பாடம் செய்ய வேண்டிய வரைபடம்.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        இதுவரை இந்த tools உனக்கு பதிலளிக்கின்றன மட்டுமே. அவை <em>தாங்களாகவே action எடுக்க</em> முடிந்தால் என்ன? Tool-இலிருந்து agent-க்கு மாறும் பாய்ச்சல் அதுதான் &mdash; அது எல்லாவற்றையும் மாற்றுகிறது.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(14,165,233,0.06) 15%, rgba(14,165,233,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#0EA5E9" toolName="Dream Project" client:visible>
        <DreamProject client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
