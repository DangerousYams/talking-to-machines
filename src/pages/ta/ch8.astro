---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import ProjectOrchestrator from '../../components/widgets/ch8/ProjectOrchestrator';
import ContextPacking from '../../components/widgets/ch8/ContextPacking';

const chapter = chapters[7];
---

<ChapterLayout chapter={chapter} locale="ta">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>8</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          எட்டாவது அத்தியாயம்
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          சிக்கலை<br />ஒழுங்கமைத்தல்
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          எந்த context window-க்கும்<br />பெரிய projects-ல் AI manage செய்தல்.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        ஒவ்வொரு ஆர்வமுள்ள beginner-க்கும் ஒரு தருணம் வரும்: AI யிடம் உண்மையான ஒன்று build செய்ய சொல்கிறாய் — full game, backend உள்ள website, citations உள்ள research paper — எல்லாம் உடைகிறது. AI போதுமான அளவு smart இல்லை என்பதால் அல்ல. Project ஒரு single conversation-க்கு மிகப் பெரியது என்பதால்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        ஒரு wall of requirements paste செய்கிறாய், AI confident-ஆக சொல்வது போல் ஒரு response கொடுக்கிறது, இருபது நிமிடம் கழித்து நீ கேட்டதில் பாதியை மறந்துவிட்டது, architecture-ல் தன்னையே contradict செய்துகொண்டது, இல்லாத library-யை hallucinate செய்துவிட்டது என்று புரிகிறது. மறுபடி try செய்கிறாய். அதே result, வேறு hallucinations.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        இது AI problem அல்ல. இது ஒரு <strong>orchestration problem</strong>. இதை solve செய்ய கற்றுக்கொள்வது — one-off tasks-க்கு AI பயன்படுத்துபவனுக்கும் உண்மையான விஷயங்களை build செய்பவனுக்கும் இடையேயான வித்தியாசம்.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE ONE-PROMPT TRAP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        One-Prompt பொறி
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI பயன்படுத்த முதலில் கற்றுக்கொள்ளும்போது, எல்லாவற்றையும் ஒரே shot-ல் செய்ய முயற்சிப்பது இயல்பு. ஒரே massive prompt. ஒரே conversation. ஒரே முயற்சி. Simple tasks-க்கு — email எழுதுவது, ideas brainstorm செய்வது, concept explain செய்வது — இது fine.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        ஆனால் complexity one-prompt approach ஐ மூன்று வழிகளில் உடைக்கிறது:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 2.5rem;">
        {[
          { num: '1', title: 'Context overflow', text: 'AI ஒரு நேரத்தில் இவ்வளவு தகவல் மட்டுமே வைத்திருக்க முடியும். Full project அந்த limit-ஐ தாண்டுகிறது, அதனால் AI உன் முந்தைய requirements-ஐ "மறக்க" ஆரம்பிக்கிறது.' },
          { num: '2', title: 'Attention dilution', text: 'Context window-க்குள்ளேயே, AI யிடம் ஒரே நேரத்தில் பன்னிரண்டு concerns juggle செய்ய சொன்னால், ஒவ்வொன்றுக்கும் குறைவான focus கிடைக்கும். எல்லாவற்றிலும் quality குறையும்.' },
          { num: '3', title: 'Error compounding', text: 'Complex output-ல் ஒரு சிறிய தவறு cascade ஆகும். AI database schema தவறாக எழுதினால், அந்த schema மேல் build ஆன எல்லாமே தவறு — generated code-ன் wall-ல் அதை கண்டுபிடிப்பது கடினம்.' },
        ].map((item, i) => (
          <FadeInBlock client:visible delay={0.2 + i * 0.08}>
            <div style="display: flex; gap: 1.25rem; align-items: flex-start;">
              <div style={`flex-shrink: 0; width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 0.8rem; font-weight: 700; color: white; background: ${chapter.accent};`}>
                {item.num}
              </div>
              <div style="flex: 1;">
                <p style={`font-family: var(--font-heading); font-size: 1rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.3rem; line-height: 1.3;`}>
                  {item.title}
                </p>
                <p style="font-size: 0.95rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                  {item.text}
                </p>
              </div>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.5}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        தீர்வு சிறந்த prompt அல்ல. சிறந்த process.
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ DECOMPOSITION: THE MASTER SKILL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Decomposition: மாஸ்டர் திறமை
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Professional software engineers ஒரே sitting-ல் முழு applications build செய்வதில்லை. அவர்கள் அவற்றை துண்டுகளாக உடைக்கிறார்கள் — modules, components, functions — ஒவ்வொன்றுக்கும் தெளிவான purpose, inputs, outputs இருக்கும். பிறகு அவற்றை assemble செய்கிறார்கள்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        AI உடன் complex projects-ல் வேலை செய்வதற்கும் அதே discipline தேவை. உன் project ஐ <strong>decompose</strong> செய்ய வேண்டும் — ஒரு single, focused AI conversation நன்றாக handle செய்யும் அளவுக்கு சிறிய tasks-ஆக.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        நல்ல decomposition மூன்று rules follow செய்கிறது:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
        <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
        {[
          { word: 'Single responsibility.', desc: 'ஒவ்வொரு task ஒரே ஒரு விஷயம் செய்யும். "Database design செய் AND API build செய் AND frontend எழுது" மூன்று tasks, ஒன்று அல்ல.' },
          { word: 'Clear interfaces.', desc: 'ஒவ்வொரு task-க்கும் defined input (ஆரம்பிக்க என்ன தேவை) மற்றும் defined output (என்ன produce செய்கிறது) இருக்கும். ஒரு task-ன் output அடுத்ததின் input ஆகும்.' },
          { word: 'Minimal dependencies.', desc: 'Parallel ஆக செய்யக்கூடிய tasks-ஐ parallel ஆக செய். ஒரு task உண்மையிலேயே மற்றொன்றின் output தேவைப்படும்போது மட்டுமே dependency உருவாக்கு.' },
        ].map((step, i) => (
          <div style={`position: relative; padding-bottom: ${i < 2 ? '1.75rem' : '0'};`}>
            <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
            <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
              <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
              <span style="opacity: 0.7;"> {step.desc}</span>
            </p>
          </div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Decomposition ஒரு human skill, AI skill அல்ல.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI task breakdown brainstorm செய்ய உதவலாம், ஆனால் வேலையை எப்படி பிரிப்பது, எது எதை depend செய்கிறது, எதை prioritize செய்வது — அது உன் வேலை. இது project management, நீ develop செய்யக்கூடிய மிக மதிப்புள்ள skills-ல் ஒன்று.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO PROJECT ORCHESTRATOR -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        ஒரு real project decompose செய்துபார். Tasks drag செய், dependencies track செய், plan உருவாகுவதை பார்.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: PROJECT ORCHESTRATOR ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ProjectOrchestrator client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE HANDOFF PATTERN ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Handoff Pattern
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Project ஐ tasks-ஆக உடைத்தபிறகு, அவற்றை connect செய்ய ஒரு வழி தேவை. AI workflows-ல், இந்த connection தான் <strong>handoff</strong> — ஒரு conversation-ன் output அடுத்ததின் input ஆகும் தருணம்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: var(--color-navy);">
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Handoff Pattern</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          Conversation 1 ஒரு <strong>artifact</strong> produce செய்கிறது — document, schema, plan.<br />
          அந்த artifact Conversation 2 க்கு <strong>context</strong> ஆக paste செய்யப்படுகிறது.<br />
          Conversation 2 அதன் மேல் build செய்து அடுத்த artifact produce செய்கிறது.<br />
          Project முடியும் வரை repeat செய்.
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        இதை relay race என்று நினை. ஒவ்வொரு runner (conversation) தன் பகுதியை ஓடி baton (artifact) ஐ அடுத்தவருக்கு pass செய்கிறார். Baton தான் critical piece — அது drop ஆனால் அல்லது garble ஆனால், அடுத்த runner தடுமாறுவார்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        அதாவது உன் handoff artifacts <em>crisp</em> ஆக இருக்க வேண்டும். Data model-ன் vague description-ஐ விட database schema சிறந்த handoff. "User stuff handle செய்யும் backend வேண்டும்" என்பதை விட numbered list of API endpoints சிறந்தது. Artifact எவ்வளவு sharp ஆக இருக்கிறதோ, அடுத்த conversation அவ்வளவு நன்றாக perform செய்யும்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        உன் handoff artifact-ன் quality, downstream-ல் build ஆகும் எல்லாவற்றின் quality-யையும் நிர்ணயிக்கிறது. Garbage in, garbage out — conversations-க்கு இடையே.
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONTEXT PACKING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Context Packing கலை
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ஒவ்வொரு முறை புதிய AI conversation ஆரம்பிக்கும்போது, பெரும்பாலான மக்கள் கவனிக்காத ஒரு முடிவை நீ எடுக்கிறாய்: <strong>என்ன context include செய்வது?</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        உன்கிட்ட limited budget இருக்கு — context window. தொடர்புடைய information-ன் குவியல் இருக்கு: code files, documentation, முந்தைய conversations, error logs, design specs. எல்லாம் fit ஆகாது. Fit ஆனாலும், எல்லாவற்றையும் dump செய்தால் AI-ன் attention dilute ஆகும்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        Context packing என்பது trip-க்கு suitcase pack செய்வது போன்றது. உன் முழு wardrobe-ஐயும் கொண்டு போக முடியாது. எங்கே போகிறாய் (task), என்ன தேவை (relevant information), என்ன விட்டுவிடலாம் (மற்றவை எல்லாம்) என்று யோசிக்க வேண்டும்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div style="display: flex; flex-direction: column; gap: 1.25rem; margin-bottom: 2.5rem;">
        {[
          { label: 'மிகக் குறைவான context', color: '#E94560', text: 'AI க்கு தேவையான தகவல் இல்லை, இடைவெளிகளை hallucinations-ஆல் நிரப்புகிறது. Confident ஆக பேசும் ஆனால் details-ஐ invent செய்யும்.' },
          { label: 'மிக அதிகமான context', color: '#F5A623', text: 'AI overwhelm ஆகிறது. முக்கியமான details noise-ல் மறைகிறது. Output generic-ஆகவும் unfocused-ஆகவும் மாறும்.' },
