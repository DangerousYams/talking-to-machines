---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ContextPacking from '../../components/widgets/ch8/ContextPacking';
import ComplexityScore from '../../components/breaks/ComplexityScore';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[7];
---

<ChapterLayout chapter={chapter} locale="ta">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>8</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          அத்தியாயம் எட்டு
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          சிக்கலை<br />ஒழுங்கமைத்தல்
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          எந்த context window-க்கும் பெரிய<br />projects-ல் AI manage செய்தல்.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        ஒவ்வொரு ambitious beginner-க்கும் ஒரு தருணம் வரும்: AI யிடம் உண்மையான ஒன்று build செய்ய சொல்கிறாய் &mdash; full game, backend உள்ள website, citations உள்ள research paper &mdash; எல்லாம் உடைகிறது. AI போதுமான அளவு smart இல்லை என்பதால் அல்ல. Project ஒரு single conversation-க்கு மிகப் பெரியது என்பதால். Requirements wall-ஐ paste செய்கிறாய், இருபது நிமிடம் கழித்து நீ கேட்டதில் பாதியை மறந்துவிட்டது என்று புரிகிறது.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        இது AI problem அல்ல. இது <strong>orchestration problem</strong>. இதை solve செய்ய கற்றுக்கொள்வது &mdash; one-off tasks-க்கு AI பயன்படுத்துபவனுக்கும் உண்மையான விஷயங்கள் build செய்பவனுக்கும் உள்ள வித்தியாசம்.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONTEXT PACKING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Context Packing கலை
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Complex projects one-prompt approach-ஐ உடைக்கும். Context overflow ஆகிறது, attention dilute ஆகிறது, errors compound ஆகின்றன. Fix &mdash; better prompt அல்ல, <strong>decomposition</strong>. Project-ஐ focused tasks-ஆக உடை, பிறகு ஒவ்வொரு task-க்கும் AI க்கு உண்மையில் என்ன context தேவை என்று carefully choose செய். மிகக் குறைவாக இருந்தால் hallucinate செய்யும். மிக அதிகமாக இருந்தால் focus இழக்கும். Sweet spot &mdash; surgical precision.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Suitcase pack செய்வது போல் நினை. முழு wardrobe-ஐயும் கொண்டு போக முடியாது. எங்கே போகிறாய் (task), என்ன தேவை (relevant information), என்ன விட்டுவிடலாம் (மற்றவை எல்லாம்) என்று யோசிக்க வேண்டும். ஒவ்வொரு conversation-க்கும் exactly தேவையான context &mdash; அதிகம் இல்லை, குறைவும் இல்லை.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style="font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;">முக்கிய கருத்து</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          உன் handoff artifact-ன் quality, downstream-ல் build ஆகும் எல்லாவற்றின் quality-யையும் நிர்ணயிக்கிறது. Crisp schema எப்போதும் vague description-ஐ விட better. Garbage in, garbage out &mdash; conversations-க்கு இடையே.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Context suitcase pack செய்துபார். Overflow ஆகாமல் தேவையானதை fit செய்ய முடியுமா?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ContextPacking client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="The hardest part of AI isn't prompting — it's orchestrating complex projects across multiple conversations. This course finally explains how." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style="border-color: var(--color-navy); max-width: 50ch; margin: 0 auto 2rem;">
        Complex projects பயமாக இல்லை. அவை crisp artifacts-ஆல் இணைக்கப்பட்ட focused conversations-ன் தொடர் மட்டுமே.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        அடுத்தது: AI <em>தவறாக</em> இருக்கும்போது தெரிந்துகொள்வது. Hallucinations, sycophancy, உன்னை நேர்மையாக வைக்கும் verification habits.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(15,52,96,0.06) 15%, rgba(15,52,96,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#0F3460" toolName="Complexity Score" client:visible>
        <ComplexityScore client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
