---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import PromptLaboratory from '../../components/widgets/ch2/PromptLaboratory';
import FlipTheScript from '../../components/widgets/ch2/FlipTheScript';
import DebugThePrompt from '../../components/widgets/ch2/DebugThePrompt';

const chapter = chapters[1];
---

<ChapterLayout chapter={chapter} locale="ta">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>2</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          இரண்டாம் அத்தியாயம்
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          கேள்வி கேட்கும்<br />கலை
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          சிறந்த prompt என்பது AI யிடம்<br />கேள்விகள் கேட்க வைக்கும் கேள்வி.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        முந்தைய அத்தியாயத்தில், நல்ல prompt எழுதுவதற்கான ஐந்து அடிப்படை கூறுகளை நீ கற்றுக்கொண்டாய் — Role, Task, Format, Constraints, Examples. அது அடித்தளம். ஆனால் சமையல் பொருட்களை அறிந்திருப்பது உன்னை சமையல்காரன் ஆக்காது.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        இந்த அத்தியாயம் <em>நுட்பங்களைப் பற்றியது</em>. prompt ஐ வெறுமனே டைப் செய்பவனுக்கும் அதை <em>கைவினைப்பொருள் போல</em> வடிவமைப்பவனுக்கும் உள்ள வித்தியாசம். கேள்வி கேட்பதற்கும் <strong>சரியான</strong> கேள்வி கேட்பதற்கும் உள்ள வித்தியாசம் — உண்மையில் பயனுள்ள ஒன்றை திறந்துவிடும் கேள்வி.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        சிறந்த AI பயனர்கள் அந்த விஷயத்தில் நிபுணர்கள் அல்ல — <strong>அவர்கள் கேள்வி கேட்பதில் நிபுணர்கள்.</strong> கேள்வி கேட்பது என்பது நீ கற்றுக்கொள்ளக்கூடிய திறமை.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SOCRATIC FLIP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        சாக்ரட்டீஸ் முறை திருப்பம்
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        பெரும்பாலான மக்கள் AI யை வெண்டிங் மெஷின் போல் பயன்படுத்துகிறார்கள். Prompt போட்டு, பதில் வாங்கு. ஆனால் சிறந்த முடிவுகள் கட்டளைகளிலிருந்து அல்ல, <em>உரையாடல்களிலிருந்து</em> வருகின்றன. மற்றும் மிக சக்திவாய்ந்த உரையாடல் நுட்பம் 2,400 ஆண்டுகள் பழையது.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        சாக்ரட்டீஸ் ஒருபோதும் கேள்வியை நேராக பதில் சொல்லவில்லை. அவர் <em>மேலும்</em> கேள்விகளை கேட்டார் — ஆழமாய் கேட்டு, தெளிவுபடுத்தி, சவால் விடுத்து — அவருடைய மாணவர்கள் ஆழமான புரிதலை தாங்களே அடையும் வரை. நீ AI யுடன் அதே அணுகுமுறையை பயன்படுத்தலாம், ஆனால் தலைகீழாக.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AI யிடம் பதில் கேட்பதற்கு பதிலாக, AI உன்னை இன்டர்வியூ செய்யச் சொல். நீ யோசிக்க மறந்த தெளிவுபடுத்தும் கேள்விகளை அது கேட்கட்டும்.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        இதைப் பற்றி யோசி: நீ "பிறந்தநாள் விழா திட்டமிடு" என்று டைப் செய்யும்போது, பதிலை பெருமளவில் மாற்றும் டஜன் கணக்கான விவரங்களை விட்டுவிடுகிறாய். எத்தனை நபர்கள்? பட்ஜெட் என்ன? உள்ளேயா அல்லது வெளியேயா? AI க்கு தெரியாது — ஆனால் அது கேட்கலாம்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>சாக்ரட்டீஸ் Prompt</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          "நான் ஒரு பிறந்தநாள் விழா திட்டமிட விரும்புகிறேன். நீ திட்டமிட ஆரம்பிப்பதற்கு முன், என் சரியான சூழ்நிலைக்கு ஏற்ற திட்டத்தை உருவாக்க உதவும் 5 குறிப்பிட்ட கேள்விகளை என்னிடம் கேள். அவைகளை ஒவ்வொன்றாக கேட்டு என் பதிலுக்காக காத்திரு."
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        இந்த ஒற்றை நுட்பம் — யார் கேள்விகள் கேட்கிறார்கள் என்பதை தலைகீழாக மாற்றுவது — நீ செய்யக்கூடிய மிக சக்திவாய்ந்த மேம்பாடுகளில் ஒன்று. இது AI யை பதில் இயந்திரத்திலிருந்து <strong>சிந்தனை பங்குதாரராக</strong> மாற்றுகிறது.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FLIP THE SCRIPT ═══ -->
  <section id="flip-the-script" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <FlipTheScript client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ FEW-SHOT PROMPTING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        காட்டு, விளக்காதே
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        உன் நண்பனிடம் ஒரு style ஐ விளக்க முயல்கிறாய் என்று கற்பனை செய். அதை வார்த்தைகளில் விளக்க ஐந்து நிமிடங்கள் செலவழிக்கலாம் — "நான் விளையாட்டுத்தனமாக ஆனால் குழந்தைத்தனமாக இல்லாமல், சாதாரணமாக ஆனால் அலட்சியமாக இல்லாமல், குறுகிய வாக்கியங்கள் மற்றும் எதிர்பாராத ஒப்பீடுகளுடன் வேண்டும்." அல்லது நீ ஒரு உதாரணத்தை காண்பிக்கலாம்: <em>"இதைப் போல் எழுது."</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        அது தான் <strong>few-shot prompting</strong>. நீ விரும்புவதை சுருக்கமாக விவரிக்க முயல்வதற்கு பதிலாக, AI க்கு உறுதியான உதாரணங்களை கொடுக்கிறாய். ஒரு உதாரணம் "one-shot" prompt. இரண்டு அல்லது மூன்று உதாரணங்கள் "few-shot". பூஜ்யம் உதாரணங்கள் — நீ விரும்புவதை வெறுமனே விவரிப்பது — "zero-shot".
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style="--accent: #6B7280;">
        <span class="prompt-block-label" style="color: #6B7280;">Zero-shot (விவரிப்பது)</span>
        <p class="m-0" style="color: var(--color-deep);">"ஓடும் ஷூக்களுக்கு தயாரிப்பு விவரம் எழுது. அது punch யும் உரையாடல் மாதிரியும் இருக்க வேண்டும், குறுகிய வாக்கியங்களுடன். மார்க்கெட்டிங் clichés தவிர்."</p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Few-shot (காண்பிப்பது)</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          "CloudRunner X1 ஓடும் ஷூவுக்கு தயாரிப்பு விவரம் எழுது. நான் விரும்பும் style இது:<br /><br />
          <em>உதாரணம்: 'The Weekender Tote — உன் லேப்டாப், உன் மதிய உணவு, மற்றும் உன் சந்தேகத்திற்குரிய வாழ்க்கை முடிவுகள் அடங்கும். தண்ணீர் எதிர்ப்பு canvas, ஏதோ சிந்துவாய் என்று எங்களுக்கு தெரியும். ஐந்து பாக்கெட்டுகள், எதையும் பிறகு நினைவில் இருக்காது.'</em><br /><br />
          இந்த tone match செய்: குறுகிய வாக்கியங்கள், சுய-விழிப்புள்ள நகைச்சுவை, buzzwords க்கு பதிலாக specificity."
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85] mb-10">
        Few-shot version நாடகமாக சிறந்த முடிவுகளை உருவாக்கும். AI "புத்திசாலியாக" இருப்பதால் அல்ல — ஆனால் நீ அதற்கு தெளிவில்லாத திசையின் பதிலாக <strong>உறுதியான இலக்கை</strong> கொடுத்தாய். ஒரு நல்ல உதாரணம் நூறு வார்த்தைகள் விவரம் போல் மதிப்புள்ளது.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>முக்கிய நுண்ணறிவு</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI நீ விரும்பும் style match செய்யவில்லை என்றால், மேலும் adjectives சேர்க்காதே. உதாரணம் சேர். "இதைப் போல்" என்பது "மேலும் punchy ஆனால் அதேசமயம் warm ஆனால் அதிகமாக casual இல்லாமல்" என்பதை விட எப்போதும் வெல்லும்.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ MINI-CHALLENGE: Zero to Few-Shot ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-12">
    <FadeInBlock client:visible>
      <div style={`background: linear-gradient(135deg, ${chapter.accent}08, ${chapter.accent}04); border: 1px solid ${chapter.accent}20; border-radius: 12px; padding: 2rem 2rem 1.75rem;`}>
        <p style={`font-family: var(--font-mono); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: ${chapter.accent}; margin: 0 0 0.75rem;`}>
          விரைவான பரிசோதனை
        </p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0 0 1rem; color: var(--color-deep);">
          சமீபத்தில் நீ AI யிடம் எழுத சொன்ன ஏதாவது ஒன்றைப் பற்றி யோசி — மின்னஞ்சல், கதை, சமூக ஊடக post. இப்போது நீ விரும்பிய tone க்கு ஒரு உறுதியான உதாரணத்தை சேர்த்திருந்தால் கற்பனை செய். output எப்படி மாறியிருக்கும்?
        </p>
        <p style="font-size: 0.9rem; line-height: 1.7; margin: 0; color: var(--color-deep); opacity: 0.6;">
          அதை மனதில் வைத்துக்கொள். கீழே உள்ள Prompt Laboratory உன்னை உண்மையில் test செய்ய அனுமதிக்கும்.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CHAIN OF THOUGHT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        படிப்படியாக சிந்தி
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
