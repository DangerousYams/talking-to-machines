---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import TerminalPlayground from '../../components/widgets/ch7/TerminalPlayground';
import ShipIt from '../../components/breaks/ShipIt';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[6];
---

<ChapterLayout chapter={chapter} locale="ta">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>7</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          அத்தியாயம் ஏழு
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Claude Code<br />கற்றுக்கொள்
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          உன் AI pair programmer, முதல்<br />command இலிருந்து custom Skills வரை.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        ஒவ்வொரு coder-க்கும் நினைவில் இருக்கும் ஒரு தருணம் உண்டு. Terminal திறந்து, natural language-ல் ஒரு request type செய்யும்போது, AI உன் files படிக்கிறது, architecture புரிந்துகொள்கிறது, பல files-ல் code எழுதுகிறது, run செய்கிறது, error வருகிறது, error fix செய்கிறது, மறுபடி run செய்கிறது &mdash; நீ ஒரு line கூட தொடாமல். Claude Code autocomplete அல்ல. உன் முழு project-ஐயும் பார்க்கும், files-ல் changes செய்யும், shell commands execute செய்யும், தன் தவறுகளை iterate செய்யும் <em>agentic</em> coding tool.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        ஆனால் tool, அதை steer செய்யும் மனிதனைப் பொறுத்தது. Claude Code ஒரு second-ல் ஆயிரம் lines perfect code எழுதலாம் &mdash; அல்லது ஆயிரம் lines plausible-ஆக தெரியும் garbage எழுதலாம். வித்தியாசம் நீதான்.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE LOOP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Specify, Generate, Verify
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Claude Code-க்கு task கொடுத்தால், agent loop run ஆகிறது: codebase படி, என்ன மாற்ற வேண்டும் என்று plan செய், edits எழுது, code run செய், எது உடைந்தாலும் fix செய். இந்த loop மூன்று, ஐந்து, பத்து முறை cycle ஆகலாம் &mdash; எல்லாம் seconds-ல். உன் வேலை இனி ஒவ்வொரு line எழுதுவது அல்ல. என்ன build செய்ய வேண்டும் என்று <strong>specify</strong> செய்வது, AI generate செய்ய விடுவது, பிறகு அது உண்மையில் correct-ஆ என்று <strong>verify</strong> செய்வது. பெரும்பாலான beginners கடைசி step-ஐ skip செய்கிறார்கள். Code appear ஆகிறது, reasonable-ஆ தெரிகிறது, move on செய்துவிடுவார்கள். அவர்களாக ஆகாதே. Generated code ஒரு first draft. உன் verification தான் அதை publishable ஆக மாற்றும் edit.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Secret weapon &mdash; <code>CLAUDE.md</code> file. Project root-ல் போட்டால் Claude Code ஒவ்வொரு session ஆரம்பத்திலும் படிக்கும். உன் tech stack, naming conventions, style rules, testing expectations &mdash; எல்லாம் ஒரு முறை encode செய்தால் போதும். Chapter 3-ன் context engineering coding-க்கு apply ஆவது.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>இலக்கு ஒவ்வொரு line எழுதுவது அல்ல &mdash; ஒவ்வொரு line புரிந்துகொள்வது.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Claude generate செய்யும் code படிக்க முடியவில்லை என்றால், verify செய்ய முடியாது. சிறந்த Claude Code users அதிக code generate செய்பவர்கள் அல்ல &mdash; சிறந்த கேள்விகள் கேட்டு நுட்பமான bugs catch செய்பவர்கள்.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Loop-ஐ action-ல் பார். ஒரு request type செய்து Claude Code வேலை செய்வதை பார்.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="terminal-playground" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <TerminalPlayground client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="This chapter on Claude Code is wild — watched an AI pair programmer think through a problem, write code, and debug itself. The future of coding is here." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Claude Code உனக்காக code எழுதவில்லை &mdash; உன்னுடன் சேர்ந்து code எழுதுகிறது.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        ஒரு conversation ஒரு task handle செய்யலாம். ஆனால் real projects-ல் dozens இருக்கும். அடுத்தது: பெரிய ambitions-ஐ AI உண்மையில் execute செய்யக்கூடிய pieces-ஆக உடைப்பது எப்படி.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Ship It" client:visible>
        <ShipIt client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
