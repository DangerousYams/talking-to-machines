---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import TasteTest from '../../components/widgets/ch10/TasteTest';
import IrreplaceableYou from '../../components/breaks/IrreplaceableYou';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';
import ForYouCard from '../../components/ui/ForYouCard';

const chapter = chapters[9];
const conceptsSummary = chapter.concepts.map(c => c.name).join(', ');
---

<ChapterLayout chapter={chapter} locale="ta">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>10</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          அத்தியாயம் பத்து
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Taste தான்<br />Product
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          AI options generate செய்கிறது. நீ சரியானதை<br />choose செய்கிறாய். அதுதான் skill.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        AI முப்பது seconds-ல் ஒரு website generate செய்ய முடியும். பெரும்பாலானவை ஒரே மாதிரி தெரியும்: rounded corners, gradient backgrounds, generic hero sections, placeholder stock phrases. இது <strong>AI slop</strong> &mdash; யாரும் taste exercise செய்யாதபோது வரும் default output. Technically functional. Aesthetically மறக்கக்கூடியது. AI கொடுப்பதை better-க்கு push செய்யாமல் accept செய்தால் கிடைப்பது இது.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        Antidote அதிக prompting அல்ல. Standards வைத்திருப்பது. Good எப்படி இருக்கும் என்று தெரிந்திருப்பது. AI கிட்ட சரியாக guess செய்யும் என்று hope பண்ணுவதற்கு பதிலாக, நீ என்ன விரும்புகிறாய் என்று காண்பிப்பது.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ REFERENCES ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        விளக்கங்களை விட References
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        "Modern-ஆகவும் clean-ஆகவும் இருக்கட்டும்" என்பது AI க்கு கிட்டத்தட்ட ஒன்றும் சொல்வதில்லை. "stripe.com மாதிரி இருக்கட்டும் &mdash; minimal, நிறைய whitespace, ஒரே accent color, பெரிய bold headings" என்பது எல்லாவற்றையும் சொல்கிறது. <strong>References எப்போதும் descriptions-ஐ beat செய்யும்.</strong> ஒரு screenshot ஆயிரம் வார்த்தை prompting-க்கு சமம். நீ விரும்பும் விஷயங்களின் examples collect செய் &mdash; websites, apps, designs &mdash; agent-கிட்ட கொடு. "இந்த layout வேண்டும் ஆனால் இந்த colors-உடன்." "இந்த typography ஆனால் dashboard-க்கு apply செய்."
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Taste பிறவிக்குணம் அல்ல. Exposure + judgment. சிறந்த விஷயங்களை பார்த்து அவை <em>ஏன்</em> சிறந்தவை என்று புரிந்துகொள்வதன் மூலம் develop ஆகிறது. நீ collect செய்யும் references அதிகமாக, உன் கண் கூர்மையாகும். உன் கண் கூர்மையாக, agent-கிட்ட உன் instructions better ஆகும்.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>மூன்று evaluation lenses</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Agent build செய்வதை மூன்று lens-கள் வழியாக judge செய். <strong>Visual:</strong> என் references போல் தெரிகிறதா? <strong>Functional:</strong> நான் specify செய்ததை செய்கிறதா? <strong>User:</strong> நான் உண்மையில் இதை use செய்ய விரும்புவேனா? இதில் ஏதாவது ஒன்றுக்கு no என்றால், iterate செய். இந்த lenses apply செய்ய code படிக்க தெரிய வேண்டியதில்லை.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ HUMAN EDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        மனித முன்னணி
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        AI options generate செய்கிறது. நீ சரியானதை choose செய்கிறாய். அந்த judgment &mdash; taste, empathy, vision &mdash; உன் edge. AI ஒரு minute-ல் பத்து logo variants produce செய்யலாம். ஆனால் உன் brand-க்கு எது <em>சரியாக feel</em> ஆகிறது என்று உனக்கு மட்டுமே தெரியும். AI பத்து versions landing page draft செய்யலாம். ஆனால் உன் audience-உடன் எது resonate ஆகும் என்று உனக்கு மட்டுமே தெரியும். Scarce skill generation அல்ல. <strong>Curation</strong>.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        AI fundamentally செய்ய முடியாதது: <em>என்ன</em> build செய்ய வேண்டும் என்று choose செய்வது. <em>யாருக்காக</em> என்று decide செய்வது. <em>ஏன்</em> முக்கியம் என்று determine செய்வது. Creative vision set செய்வது. Room read செய்வது. ஏன் என்று articulate செய்ய முடியாவிட்டாலும் ஏதோ "off" ஆக இருக்கிறது என்று feel ஆவது. இவை AI-ல் உள்ள bugs அல்ல &mdash; மனிதனாக இருப்பதின் features. Generation free ஆன உலகில், இவை முன்னெப்போதையும் விட மதிப்புள்ளவை.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        இந்த options-ஐ best-இலிருந்து worst-க்கு rank செய். பிறகு experts எப்படி score செய்தார்கள் &mdash; ஏன் என்றும் பார்.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <TasteTest client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <div class="py-8">
    <ForYouCard
      chapterSlug={chapter.slug}
      chapterTitle={chapter.title}
      chapterConcepts={conceptsSummary}
      accentColor={chapter.accent}
      client:load
    />
  </div>
  <SharePrompt text="'AI generates options. You choose the right one.' This chapter on taste, references, and the human edge is the most important lesson in building with AI." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Generation free ஆன உலகில், taste மட்டுமே matter ஆகிறது.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        ஒரே ஒரு chapter மிச்சம். இனி theory இல்லை. நீ கற்றுக்கொண்ட எல்லாவற்றையும் combine செய்து உண்மையான ஒன்று build செய்யும் நேரம் &mdash; நீ மட்டுமே நினைக்கும் ஒன்று.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(22,199,154,0.06) 15%, rgba(22,199,154,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#16C79A" toolName="Irreplaceable You" client:visible>
        <IrreplaceableYou client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
