---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import AgentBlueprint from '../../components/widgets/ch6/AgentBlueprint';
import FailureModesLab from '../../components/widgets/ch6/FailureModesLab';
import HandoffChain from '../../components/widgets/ch6/HandoffChain';

const chapter = chapters[5];
---

<ChapterLayout chapter={chapter} locale="ta">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>6</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          அத்தியாயம் ஆறு
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          ஏஜென்ட்களை<br />உருவாக்குதல்
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          ஒரு AI ஏஜென்ட்டை ஆரம்பம் முதல்<br />வடிவமைத்து உருவாக்குதல்.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        சாட்போட் உங்கள் பேச்சுக்காக காத்திருக்கும். ஆனால் ஏஜென்ட் அப்படி இல்லை. ஒரு இலக்கைக் கொடுங்கள் — "செவ்வாய் கிரக குடியேற்றம் பற்றி ஆராய்ந்து அறிக்கை எழுது" — அது வேலையை படிகளாக பிரித்து, சரியான கருவிகளைத் தேர்ந்தெடுத்து, ஒன்றன்பின் ஒன்றாக நிறைவேற்றி, தனது முடிவுகளைச் சரிபார்த்து, வேலை முடியும் வரை தொடர்ந்து கொண்டே இருக்கும். உங்கள் உதவி தேவையில்லை.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        இந்த வித்தியாசம் — <em>கட்டளைகளுக்கு பதிலளிப்பது</em> மற்றும் <em>இலக்கைத் தேடுவது</em> — கணிப்பான் மற்றும் சக ஊழியர் இடையே உள்ள வித்தியாசம். சாட்போட்கள் கேள்விகளுக்கு பதிலளிக்கின்றன. ஏஜென்ட்கள் பிரச்சினைகளைத் தீர்க்கின்றன.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        இந்த அத்தியாயம் ஏஜென்ட்கள் உண்மையில் எப்படி வேலை செய்கின்றன என்பதை — அவற்றை இயக்கும் சுழற்சி, அவற்றை நம்பகமானதாக மாற்றும் கட்டமைப்பு, அவை கவனமின்றி கட்டப்பட்டால் அபாயகரமானதாக மாற்றும் தோல்வி முறைகள் — பற்றியது.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE AGENT LOOP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        ஏஜென்ட் சுழற்சி
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        அத்தியாயம் 5-ல், நீங்கள் அடிப்படை கருவி-பயன்பாட்டு சுழற்சியைக் கண்டீர்கள்: கவனி, சிந்தி, செயல்படு. ஏஜென்ட்கள் அதை மிகவும் அபிலாஷையுடன் நீட்டிக்கின்றன — ஐந்து-படி சுழற்சியாக, ஒவ்வொன்றும் வெவ்வேறு உள் கூறுகளால் இயக்கப்படுகிறது:
      </p>
    </FadeInBlock>

    <!-- Loop Steps with architecture component for each -->
    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { letter: 'G', word: 'இலக்கு', color: '#E94560', desc: 'மனிதனிடமிருந்து உயர்மட்ட நோக்கத்தைப் பெறுதல். தெளிவான இலக்கு இல்லாமல், அது முடிந்ததா என்பதை தீர்மானிக்க ஏஜென்ட்டுக்கு வழியில்லை. "செவ்வாயைப் பற்றி ஆராயுங்கள்" இலக்கல்ல. "ஆதாரங்களுடன் செவ்வாய் கிரக குடியேற்ற சவால்களின் 500-சொல் சுருக்கம் எழுதுங்கள்" இலக்கு.' },
        { letter: 'P', word: 'திட்டம்', color: '#7B61FF', desc: 'இலக்கை உறுதியான படிகளாகப் பிரித்தல். சிறந்த திட்டமிடுபவர்கள் ஒரு படி தோல்வியடையும்போது தகவமைக்கும் நெகிழ்வான திட்டங்களை உருவாக்குகின்றன. மோசமான திட்டமிடுபவர்கள் முதல் ஆச்சரியத்தில் உடைந்துவிடும் கடினமான ஸ்கிரிப்ட்களை உருவாக்குகின்றன.' },
        { letter: 'T', word: 'செயல்படு', color: '#0EA5E9', desc: 'சரியான கருவியைப் பயன்படுத்தி ஒவ்வொரு படியையும் இயக்குதல் — தேடுபொறிகள், கோட் இன்டர்பிரீட்டர்கள், கோப்பு ரீடர்கள், API கள், கணிப்பான்கள். ஏஜென்ட்கள் வெறுமனே சிந்திக்கவில்லை. அவை செயல்படுகின்றன.' },
        { letter: 'M', word: 'நினைவு', color: '#16C79A', desc: 'என்ன நடந்தது என்பதைப் பதிவுசெய்து முடிவுகளைச் சரிபார்த்தல். அது என்ன செய்தது, என்ன கண்டுபிடித்தது என்ற நினைவு இல்லாமல், சுழற்சியில் சிக்கிய ஏஜென்ட் அதே தோல்வியுற்ற செயலை எப்போதும் திரும்பத் திரும்பச் செய்யலாம்.' },
        { letter: 'E', word: 'மதிப்பீடு', color: '#F5A623', desc: 'இது வேலை செய்ததா? இந்த தரவு நம்பகமானதா? இலக்கிற்கு நெருக்கமாகிவிட்டேனா? மதிப்பீட்டாளர் ஏஜென்ட்டை வெறும் இயங்கும் மற்றும் நல்லதைக் கருதும் ஸ்கிரிப்ட்டிலிருந்து பிரிக்கிறது. ஏதேனும் தவறு இருந்தால், திட்டத்தைச் சரிசெய்து மீண்டும் சுழற்சி செய்யுங்கள்.' },
      ].map((step, i) => (
        <FadeInBlock client:visible delay={i * 0.08}>
          <div style={`display: flex; gap: 1.25rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1rem; font-weight: 800; color: white; background: ${step.color};`}>
              {step.letter}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.05rem; font-weight: 700; color: ${step.color}; margin: 0 0 0.3rem; line-height: 1.3;`}>
                {step.word}
              </p>
              <p style="font-size: 0.95rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {step.desc}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <p class="text-lg leading-[1.85] mb-10">
        முக்கிய சொல் <em>சுழற்சி</em>. ஏஜென்ட் ஒரு முறை திட்டமிட்டு அதைக் குருட்டுத்தனமாக நிறைவேற்றுவதில்லை. அது திட்டமிட்டு, செயல்பட்டு, கவனித்து, மதிப்பிட்டு, சரிசெய்கிறது. சிறந்த ஏஜென்ட்கள் மூன்றாவது படி தவறாகப் போனால் கருணையுடன் மீள்பவை.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.55}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        சாட்போட் ஒரு திருப்பம். ஏஜென்ட் முழு உரையாடல் — தன்னுடன், அதன் கருவிகளுடன், உலகத்துடன்.
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO AGENT BLUEPRINT -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        ஒன்றை உருவாக்க நேரம் வந்தது. உங்கள் சொந்த ஏஜென்ட்டை ஆரம்பம் முதல் வடிவமையுங்கள்.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: AGENT BLUEPRINT ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <AgentBlueprint client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ WHEN AGENTS FAIL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        ஏஜென்ட்கள் தோல்வியடையும்போது
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ஏஜென்ட்கள் சாட்போட்களைப் போல் தோல்வியடைவதில்லை. சாட்போட் உங்களுக்கு தவறான பதிலை தந்துவிட்டு காத்திருக்கும். ஏஜென்ட் தனக்குத்தானே தவறான பதிலை கொடுத்து, <em>அதன் மீது செயல்பட்டு</em>, பிறகு அந்த உடைந்த முடிவை அடுத்த தீர்மானத்திற்கு பயன்படுத்துகிறது. தோல்விகள் கூட்டி பெருக்கப்படுகின்றன.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        ஏஜென்ட்கள் தவறு செய்யும் மூன்று வழக்கமான வழிகள் உள்ளன:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>தோல்வி முறை 1: எல்லையில்லா சுழற்சி</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          ஏஜென்ட் அதே செயலைத் திரும்பத் திரும்பச் செய்வதில் சிக்கிக்கொள்கிறது. ஆராய்ச்சி ஏஜென்ட் "ஒரு மூலம் அதிகம்" தேடிக்கொண்டே இருக்கிறது, ஒருபோதும் எழுத ஆரம்பிக்கவில்லை. நிறுத்தும் நிபந்தனை இல்லாமல், நீங்கள் பிளக்கை இழுக்கும் வரை — அல்லது API கிரெடிட் முடியும் வரை — அது இயங்கிக்கொண்டே இருக்கும்.
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="prompt-block mb-10" style={`--accent: #7B61FF;`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:#7B61FF;`}></div>
        <span class="prompt-block-label" style="color: #7B61FF;">தோல்வி முறை 2: தவறான கருவி</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          ஏஜென்ட் அந்த வேலையைச் செய்ய முடியாத கருவியைத் தேர்ந்தெடுக்கிறது. அது உங்கள் ஹார்ட் டிரைவில் உள்ள கோப்பிற்காக வெப் தேடல் செய்ய முயற்சிக்கிறது, அல்லது கட்டுரையை சுருக்குவதற்கு கணிப்பானை அழைக்கிறது. ஏஜென்ட் முட்டாள் என்பதல்ல — அது வேலைக்குப் பொருந்துமா என்பதைச் சரிபார்க்காமல் தன் கருவிப் பெட்டியிலிருந்து எடுத்தது.
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="prompt-block mb-10" style={`--accent: #F5A623;`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:#F5A623;`}></div>
        <span class="prompt-block-label" style="color: #F5A623;">தோல்வி முறை 3: கற்பனையான செயல்கள்</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
