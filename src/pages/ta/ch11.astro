---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ProjectInstructionsBuilder from '../../components/widgets/ch11/ProjectInstructionsBuilder';

const chapter = chapters[10];
---

<ChapterLayout chapter={chapter} locale="ta">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>11</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          அத்தியாயம் பதினொன்று
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          உண்மையான ஒன்று<br />Build செய்
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Creation இல்லாத knowledge trivia.<br />Ship செய்யும் நேரம் வந்தாச்சு.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        கடைசி chapter-க்கு வந்துவிட்டாய். பத்து chapters-ல் "என் essay-க்கு உதவு" என்பதிலிருந்து context engineering, agents build செய்வது, hallucinations debug செய்வது வரை வந்தாய். பெரும்பாலான adults-ஐ விட AI பற்றி அதிகம் கற்றுக்கொண்டாய். ஆனால் uncomfortable உண்மை: <strong>நீ ஏதாவது build செய்யும் வரை இதில் எதுவும் matter ஆகாது.</strong> AI பற்றி படிப்பது swimming பற்றி படிப்பது போன்றது &mdash; ஒவ்வொரு stroke technique-ஐயும் study செய்யலாம், ஆனால் தண்ணீரில் இறங்கும் வரை உனக்கு எதுவும் <em>தெரியாது</em>. அதைப் <em>பற்றி</em> மட்டும் தெரியும்.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ SET UP YOUR AI ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        உன் AI-ஐ Setup செய்
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        முதல் prompt எழுதுவதற்கு முன், பெரும்பாலான beginners skip செய்யும் ஒரு power move இருக்கு: <strong>உன் AI tool-க்கு permanent instruction file கொடு.</strong> ஒவ்வொரு session-லும் project மறுபடி explain செய்வதற்கு பதிலாக, ஒரு முறை எழுதினால் AI automatically படிக்கும். Claude Code <code>CLAUDE.md</code> படிக்கும். Cursor <code>.cursorrules</code> படிக்கும். GitHub Copilot <code>.github/copilot-instructions.md</code> படிக்கும். Same concept, different filenames. Chapter 3-ன் context engineering &mdash; project level-ல் apply ஆவது.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        நல்ல instruction file மூன்று கேள்விகளுக்கு பதில் சொல்கிறது: என்ன build செய்கிறாய், rules என்ன, "good" எப்படி இருக்கும்? இவை சரியாக இருந்தால் ஒவ்வொரு AI conversation-உம் பத்து steps முன்னால் ஆரம்பிக்கும். Project-ஐ finish செய்யும் அளவுக்கு சிறியதாக scope செய் &mdash; completed weekend hack எப்போதும் abandoned masterpiece-ஐ விட better.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style="font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;">முக்கிய கருத்து</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          நல்ல project instruction file &mdash; உனக்கு உதவும் AI க்கும் உன்னை <em>புரிந்துகொள்ளும்</em> AI க்கும் உள்ள வித்தியாசம். ஒரு முறை எழுது, ஒவ்வொரு session-லும் benefit பெறு.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        உன் project instruction file-ஐ இங்கேயே build செய். Sections நிரப்பி, உன் AI tool-க்கு export செய்.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="project-instructions-builder" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ProjectInstructionsBuilder client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Tools விஷயங்கள் build செய்வதில்லை. Tools-உடன் மனிதர்கள் build செய்கிறார்கள். உன் generation-க்கு இதுவரை access கிடைத்ததிலேயே சிறந்த toolkit உன்கிட்ட இருக்கு.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto mb-8" style="max-width: 55ch;">
        பதினொரு chapters முன், நீ "என் essay-க்கு உதவு" டைப் செய்து best-ஐ hope பண்ணினாய். இப்போ context engineer செய்கிறாய், agents design செய்கிறாய், outputs verify செய்கிறாய், ஒவ்வொரு step-லும் judgment கொண்டுவருகிறாய். Course முடிந்தது. உண்மையான learning இப்போது ஆரம்பிக்கிறது &mdash; நீ மட்டுமே நினைக்கும் ஒன்றை போய் உருவாக்கு.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-center mt-4" style={`font-family: var(--font-heading); font-size: 1.8rem; font-weight: 800; color: ${chapter.accent}; letter-spacing: -0.02em;`}>
        Ship செய்.
      </p>
    </FadeInBlock>
  </section>

</ChapterLayout>
