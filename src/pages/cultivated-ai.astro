    }
    .after-card.advisory .stage-num { color: var(--color-purple); }
    .after-card.sovereignty .stage-num { color: var(--color-navy); }
    .after-card.simulation .stage-num { color: var(--color-accent-red); }
    .after-card .after-title {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 1.6rem;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin: 0 0 0.85rem;
      color: var(--color-deep);
    }
    .after-card.advisory .after-title { color: var(--color-purple); }
    .after-card.sovereignty .after-title { color: var(--color-navy); }
    .after-card.simulation .after-title { color: var(--color-accent-red); }
    .after-card .after-body {
      font-family: var(--font-body);
      font-size: 0.98rem;
      line-height: 1.5;
      color: var(--color-deep);
      margin: 0;
    }
    .after-card .after-body em { color: var(--color-navy); font-style: italic; }

    /* ══════════════════════════════════════════════════════
       SLIDE 19 — Why this works (founder credibility)
       ══════════════════════════════════════════════════════ */
    .slide-why { justify-content: center; }
    .why-content { max-width: 1100px; margin: 0 auto; width: 100%; }
    .why-eyebrow { margin-bottom: 1rem; }
    .why-headline {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 5vw, 3.75rem);
      letter-spacing: -0.03em;
      line-height: 1.1;
      margin: 0 0 2rem;
      color: var(--color-deep);
    }
    .why-headline em { color: var(--color-amber); font-style: italic; }
    .why-thesis {
      font-family: var(--font-body);
      font-size: 1.3rem;
      line-height: 1.6;
      color: var(--color-deep);
      max-width: 64ch;
      margin: 0 0 1.5rem;
    }
    .why-thesis strong { font-weight: 700; color: var(--color-navy); }
    .why-thesis em { color: var(--color-amber); font-style: italic; font-weight: 600; }
    .why-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem 0.85rem;
      margin-top: 1rem;
    }
    .why-badge {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      padding: 6px 12px;
      border-radius: 100px;
      border: 1px solid;
      background: var(--color-warm-white);
    }
    .why-badge.b1 { color: var(--color-accent-red); border-color: rgba(233,69,96,0.3); }
    .why-badge.b2 { color: var(--color-purple); border-color: rgba(123,97,255,0.3); }
    .why-badge.b3 { color: var(--color-teal); border-color: rgba(22,199,154,0.3); }
    .why-badge.b4 { color: var(--color-amber); border-color: rgba(245,166,35,0.4); }
    .why-badge.b5 { color: var(--color-sky); border-color: rgba(14,165,233,0.3); }
    .why-badge.b6 { color: var(--color-navy); border-color: rgba(15,52,96,0.3); }

    /* ══════════════════════════════════════════════════════
       SLIDE 21 — Close
       ══════════════════════════════════════════════════════ */
    .slide-close {
      align-items: center;
      justify-content: center;
      text-align: center;
    }
    .close-eyebrow {
      font-family: 'Caveat', cursive;
      font-size: 1.6rem;
      color: var(--color-teal);
      transform: rotate(-2deg);
      margin-bottom: 1rem;
      display: inline-block;
    }
    .close-wordmark {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(4.5rem, 11vw, 9rem);
      line-height: 1;
      letter-spacing: -0.03em;
      margin: 0;
      color: var(--color-deep);
    }
    .close-wordmark .ai { color: var(--color-amber); font-style: italic; }
    .close-verb {
      font-family: var(--font-heading);
      font-weight: 700;
      font-style: italic;
      font-size: clamp(1.6rem, 2.8vw, 2.25rem);
      color: var(--color-deep);
      margin: 2rem 0 3rem;
    }
    .close-verb .grow { color: var(--color-teal); }
    .close-verb .chase { color: var(--color-accent-red); text-decoration: line-through; text-decoration-thickness: 2px; text-decoration-color: rgba(233,69,96,0.5); }
    .close-cta {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-subtle);
    }
    .close-email {
      font-family: var(--font-mono);
      font-size: 1rem;
      color: var(--color-navy);
      margin-top: 0.6rem;
    }

    /* ══════════════════════════════════════════════════════
       Responsive — laptops at 1280+
       ══════════════════════════════════════════════════════ */
    @media (max-width: 1100px) {
      .about-grid { grid-template-columns: 1fr; gap: 2.5rem; text-align: center; }
      .about-credits li { justify-content: flex-start; text-align: left; }
      .about-portrait { width: 240px; height: 240px; }
      .stages-grid { grid-template-columns: repeat(4, 1fr); gap: 0.75rem; }
      .stage-card { padding: 1rem 0.85rem; }
      .stage-title { font-size: 1.15rem; }
      .stage-tag { font-size: 0.85rem; }
      .failures-grid { grid-template-columns: 1fr; gap: 1.5rem; }
      .shift-grid { grid-template-columns: 1fr; gap: 1rem; }
      .winners-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
      .rampcase-content { grid-template-columns: 1fr; gap: 2rem; }
      .programme-spec { grid-template-columns: 1fr; }
      .bundle-grid { grid-template-columns: 1fr; gap: 1.5rem; }
      .after-grid { grid-template-columns: 1fr; gap: 1rem; }
      .example-content { grid-template-columns: 1fr; gap: 2rem; }
    }
    @media (max-width: 768px) {
      .deck-slide { padding: 3rem 2rem; }
    }
  </style>
</head>
<body class="card-deck-page">

  <!-- Progress rail -->
  <div class="progress-rail" id="rail">
    {slides.map((_, i) => <div class="progress-dot" data-idx={i}></div>)}
  </div>

  <!-- Keyboard hint -->
  <div class="kbd-hint" id="kbd-hint">
    <kbd>←</kbd> <kbd>→</kbd> navigate · <kbd>space</kbd> next · <kbd>n</kbd> presenter notes
  </div>

  <!-- Deck -->
  <div class="card-deck-container" id="deck">

    <!-- ═══ 01 · Cover ═══ -->
    <section class="card-deck-card deck-slide slide-cover" data-slide="cover">
      <div class="stagger">
        <h1 class="wordmark">Cultivated <span class="ai">AI</span></h1>
        <p class="verb-pair"><span class="grow">Grow</span>, don't <span class="chase">Chase</span>.</p>
      </div>
      <div class="brand-mark">Cultivated AI · <span class="b-grow">Grow, don't Chase.</span></div>
      <div class="slide-num">01 · Cover</div>
    </section>

    <!-- ═══ 02 · Positioning ═══ -->
    <section class="card-deck-card deck-slide slide-positioning" data-slide="positioning">
      <div class="positioning-content stagger">
        <h1 class="positioning-statement">We train <span class="p-who">business leaders</span> to <span class="p-what">shape AI adoption</span> in their teams, without depending on <span class="p-against">vendors</span> who don't understand your business.</h1>
      </div>
      <div class="brand-mark">Cultivated AI · <span class="b-grow">Grow, don't Chase.</span></div>
      <div class="slide-num">02 · Positioning</div>
    </section>

    <!-- ═══ 03 · Licensing isn't adoption ═══ -->
    <section class="card-deck-card deck-slide slide-licensing" data-slide="licensing">
      <div class="licensing-content stagger">
        <h1 class="licensing-title"><span class="strike">Licensing</span> isn't adoption.</h1>
        <ul class="licensing-beats">
          <li>Companies are spending heavily on AI tools <em>their teams aren't using</em>.</li>
          <li>Meanwhile, individuals can't get the tools they <em>actually want</em> approved by IT.</li>
          <li>Critically, there's no plan for the AI advances that landed <em>yesterday</em>, ship <em>today</em>, and arrive <em>six months from now</em>.</li>
        </ul>
      </div>
      <div class="brand-mark">Cultivated AI · <span class="b-grow">Grow, don't Chase.</span></div>
      <div class="slide-num">03 · Licensing</div>
    </section>

    <!-- ═══ 04 · Two failure modes ═══ -->
    <section class="card-deck-card deck-slide slide-failures" data-slide="failures">
      <div class="failures-content stagger">
        <h1 class="failures-headline">The two failure modes happening too often.</h1>
        <div class="failures-grid">
          <div class="failure-card under">
            <div class="failure-mode">Under-adoption</div>
            <h2 class="failure-name">Microsoft Copilot</h2>
            <div class="failure-stat">~5% scaled.</div>
            <p class="failure-body">Gartner: <em>~40% of enterprises piloting Copilot, only ~5% have scaled it.</em> Tens of millions of paid seats. Most sit unused. Licensing isn't adoption.</p>
          </div>
          <div class="failure-card over">
            <div class="failure-mode">Over-replacement</div>
            <h2 class="failure-name">Klarna</h2>
            <div class="failure-stat">Walked it back.</div>
            <p class="failure-body">2024: replaced customer service with AI. May 2025: CEO publicly walked it back. Now hybrid: <em>AI handles routine, humans handle empathy</em>. Replacement isn't adoption either.</p>
          </div>
        </div>
        <p class="failures-summary">Cultivated AI is the path <span class="accent">between</span>.</p>
      </div>
      <div class="brand-mark">Cultivated AI · <span class="b-grow">Grow, don't Chase.</span></div>
      <div class="slide-num">04 · Failure modes</div>
    </section>

    <!-- ═══ 05 · Ground is moving ═══ -->
    <section class="card-deck-card deck-slide slide-shift" data-slide="shift">
      <div class="shift-content stagger">
        <h1 class="shift-headline">The ground is <em>moving</em> anyway.</h1>
        <div class="shift-grid">
          <div class="shift-card">
            <p class="shift-card-num">01</p>
            <p class="shift-card-text">Your <em>competitors</em> are quietly redesigning around AI.</p>
          </div>
          <div class="shift-card">
            <p class="shift-card-num">02</p>
            <p class="shift-card-text">Your <em>buyers and partners</em> are modelling your business better than you can model theirs.</p>
          </div>
          <div class="shift-card">
            <p class="shift-card-num">03</p>
            <p class="shift-card-text">The <em>unit economics</em> of your category are shifting under you.</p>
          </div>
        </div>
      </div>
      <div class="brand-mark">Cultivated AI · <span class="b-grow">Grow, don't Chase.</span></div>
      <div class="slide-num">05 · Ground</div>
    </section>

    <!-- ═══ 06 · NBIM · the most accountable money is moving ═══ -->
    <section class="card-deck-card deck-slide slide-example nbim" data-slide="nbim">
      <div class="example-content stagger">
        <div>
          <div class="example-eyebrow">The most accountable money on earth</div>
          <h2 class="example-name">NBIM.</h2>
          <p class="example-tagline">Norway's sovereign wealth fund. The world's largest. Public accountability. Fiduciary duty. ~$2.1 trillion AUM.</p>
          <p class="example-body">This is not a tech company. This is not a startup. This is the most scrutinised pool of money on the planet, and they are <em>all in</em>. If they cannot afford to wait, your business cannot either.</p>
        </div>
        <div class="example-stats">
          <div class="example-stat-card">
            <p class="example-stat-num">213,000 hrs</p>
            <p class="example-stat-label">Saved per year. <em>600+ staff using Claude weekly.</em> ~20% productivity gains.</p>
          </div>
          <div class="example-stat-card">
            <p class="example-quote">"If you don't use it, you will never be promoted."</p>
            <p class="example-quote-attr">— Nicolai Tangen, CEO, NBIM</p>
          </div>
        </div>
      </div>
      <div class="brand-mark">Cultivated AI · <span class="b-grow">Grow, don't Chase.</span></div>
      <div class="slide-num">06 · NBIM</div>
    </section>

    <!-- ═══ 07 · Ramp case study ═══ -->
    <section class="card-deck-card deck-slide slide-rampcase" data-slide="ramp">
      <div class="rampcase-content stagger">
        <div class="rampcase-left">
          <div class="rampcase-eyebrow">Case study · all in</div>
          <h2 class="rampcase-name"><em>Ramp.</em></h2>
          <p class="rampcase-tagline">$22B fintech. ~1,200 people. The CPO published a public mandate.</p>
          <blockquote class="rampcase-quote">
            "If you're not using Claude Code this year, no matter your role, you're <em>underperforming</em>. The people still in L0 will most likely <em>not be at the company</em>."
            <cite>Geoff Charles, CPO · April 2026</cite>
          </blockquote>
          <div class="rampcase-stats">
            <div class="rampcase-stat">
              <span class="rampcase-stat-num">99.5%</span>
              <span class="rampcase-stat-label">of <em>~1,200 employees</em> are weekly AI users.</span>
            </div>
            <div class="rampcase-stat">
              <span class="rampcase-stat-num">~30%</span>
              <span class="rampcase-stat-label">of <em>merged PRs</em> written by their internal coding agent.</span>
            </div>
          </div>
        </div>

        <div class="rampcase-right">
          <div class="rampcase-ladder-label">The ladder Ramp measures everyone on</div>
          <ol class="rampcase-ladder">
            <li class="rung r0">
              <span class="tier">L0</span>
              <div class="rung-text">
                <h5>Occasional chat.</h5>
                <p>"Tried it once."</p>
              </div>
            </li>
            <li class="rung r1">
              <span class="tier">L1</span>
              <div class="rung-text">
                <h5>Daily basics.</h5>
                <p>Drafts. Quick answers.</p>
              </div>
            </li>
            <li class="rung r2">
              <span class="tier">L2</span>
              <div class="rung-text">
                <h5>Embedded in workflow.</h5>
                <p>3+ AI-assisted tasks daily.</p>
              </div>
            </li>
            <li class="rung r3">
              <span class="tier">L3</span>
              <div class="rung-text">
                <h5>Systems do the work.</h5>
                <p>Agents run, humans direct.</p>
              </div>
            </li>
          </ol>
          <p class="rampcase-pull">Ramp didn't license a tool. They built a <em>principle</em>, and held the company to it.</p>
        </div>
      </div>
      <div class="brand-mark">Cultivated AI · <span class="b-grow">Grow, don't Chase.</span></div>
      <div class="slide-num">07 · Ramp</div>
    </section>

    <!-- ═══ 08 · What the winners did ═══ -->
    <section class="card-deck-card deck-slide slide-winners" data-slide="winners">
      <div class="winners-content stagger">
        <h1 class="winners-headline">The leaders winning learned to <em>think clearly</em>.</h1>
        <p class="winners-sub">About AI, in the context of <strong>their own</strong> business. With principles that hold up as the tools change.</p>
        <div class="winners-grid">
          <div class="winners-card">
            <span class="winners-num">01</span>
            <p class="winners-q">What to <em>deploy</em>.</p>
          </div>
          <div class="winners-card">
            <span class="winners-num">02</span>
            <p class="winners-q">What to <em>ignore</em>.</p>
          </div>
          <div class="winners-card">
            <span class="winners-num">03</span>
            <p class="winners-q">Where it <em>fits</em>.</p>
          </div>
          <div class="winners-card">
            <span class="winners-num">04</span>
            <p class="winners-q">Where it <em>doesn't</em>.</p>
          </div>
        </div>
      </div>
      <div class="brand-mark">Cultivated AI · <span class="b-grow">Grow, don't Chase.</span></div>
      <div class="slide-num">08 · The winners</div>
    </section>

    <!-- ═══ 09 · Cultivated AI · five stages ═══ -->
    <section class="card-deck-card deck-slide slide-stages" data-slide="stages">
      <div class="stages-content stagger">
        <h1 class="stages-headline stages-wordmark">Cultivated <em>AI</em></h1>
        <div class="stages-grid">
          <div class="stage-card s1">
            <div class="stage-num">Stage 1</div>
            <h3 class="stage-title">Approach</h3>
            <p class="stage-tag">Principles install. Stop chasing tools.</p>
          </div>
          <div class="stage-card s2">
            <div class="stage-num">Stage 2</div>
            <h3 class="stage-title">Distillation</h3>
            <p class="stage-tag">SOPs become AI playbooks.</p>
          </div>
          <div class="stage-card s3">
            <div class="stage-num">Stage 3</div>
            <h3 class="stage-title">Compounding</h3>
            <p class="stage-tag">Best playbooks spread company-wide.</p>
          </div>
          <div class="stage-card s4">
            <div class="stage-num">Stage 4</div>
            <h3 class="stage-title">Simulation</h3>
            <p class="stage-tag">Synthetic environments for strategy.</p>
          </div>
        </div>
      </div>
      <div class="brand-mark">Cultivated AI · <span class="b-grow">Grow, don't Chase.</span></div>
      <div class="slide-num">09 · Cultivated AI</div>
    </section>

    <!-- ═══ 08 · Stage 1 · Approach ═══ -->
    <section class="card-deck-card deck-slide slide-stage s1" data-slide="approach">
      <div class="stage-big-num">01</div>
      <div class="stage-content stagger">
        <span class="stage-pill">Stage 1</span>
        <h1 class="stage-name">Approach.</h1>
        <p class="stage-body">The leader sees what AI is, what it does well, what it does badly, and where it's heading. The principles get installed. Mental models start working. By the end of this stage, the leader stops chasing tools and starts thinking about AI as a <em>discipline</em>.</p>
        <span class="stage-payoff">Tools change every quarter. Principles outlive them.</span>
      </div>
      <div class="brand-mark">Cultivated AI · <span class="b-grow">Grow, don't Chase.</span></div>
      <div class="slide-num">10 · Approach</div>
    </section>

    <!-- ═══ Priya · after Approach ═══ -->
    <section class="card-deck-card deck-slide slide-priya s1" data-slide="priya-approach">
      <div class="priya-content stagger">
        <div class="priya-eyebrow">Stage 1 · Priya, Head of Procurement</div>
        <h1 class="priya-headline">She stops chasing demos. She builds a <em>frame</em>.</h1>
        <p class="priya-body">Twelve AI tool pitches forwarded last month. Her team's anxious. After Stage 1, she has a working mental model. She can read any new AI announcement and place it in 30 seconds: what it does, where it fits in procurement, where it doesn't.</p>
        <div class="priya-artefact">
          <span class="priya-artefact-label">Tangible gain</span>
