              <span class="credit-dot" style="background: #E94560;"></span>
              <div class="credit-body">
                <strong>Pixar Animation Studios</strong>
                <span class="credit-detail">6 feature films · 3 Academy Awards</span>
              </div>
            </li>
            <li>
              <span class="credit-dot" style="background: #7B61FF;"></span>
              <div class="credit-body">
                <strong>Electronic Arts — Spore</strong>
                <span class="credit-detail">BAFTA Award for Technical Achievement</span>
              </div>
            </li>
            <li>
              <span class="credit-dot" style="background: #16C79A;"></span>
              <div class="credit-body">
                <strong>Lumosity</strong>
                <span class="credit-detail">Principal Game Developer · tens of millions of users</span>
              </div>
            </li>
            <li>
              <span class="credit-dot" style="background: #F5A623;"></span>
              <div class="credit-body">
                <strong>Masala Games — Founder</strong>
                <span class="credit-detail">Detective Dotson · Word Mess (#1 in 21 countries)</span>
              </div>
            </li>
            <li>
              <span class="credit-dot" style="background: #0EA5E9;"></span>
              <div class="credit-body">
                <strong>Carnegie Mellon University</strong>
                <span class="credit-detail">MET — Entertainment Technology</span>
              </div>
            </li>
            <li>
              <span class="credit-dot" style="background: #0F3460;"></span>
              <div class="credit-body">
                <strong>Talking to Machines</strong>
                <span class="credit-detail">Author · the consumer course on AI fluency</span>
              </div>
            </li>
          </ul>
        </div>
        <div>
          <div class="about-portrait">
            <img src="/images/shalin.png" alt="Shalin Shodhan" />
          </div>
          <div class="about-email">shalin@ocrelabs.com</div>
