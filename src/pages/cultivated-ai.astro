---
export const prerender = true;
import '../styles/global.css';

const slides = [
  'cover',
  'positioning',
  'licensing',
  'failures',
  'shift',
  'discipline',
  'stages',
  'approach',
  'distillation',
  'bajaj',
  'compounding',
  'sovereignty',
  'nbim',
  'simulation',
  'programme',
  'bundle',
  'after',
  'thesis',
  'close',
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Cultivated AI · Pitch</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Caveat:wght@500;600;700&display=swap" />
  <style>
    /* ══════════════════════════════════════════════════════
       Cultivated AI · pitch deck
       Inherits global tokens (cream / deep / accent / etc).
       ══════════════════════════════════════════════════════ */
    body.card-deck-page { background: var(--color-cream); }

    .deck-slide {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 5rem;
      box-sizing: border-box;
    }

    /* ─── Progress rail ─── */
    .progress-rail {
      position: fixed;
      top: 20px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 6px;
      z-index: 50;
      padding: 8px 14px;
      background: rgba(250, 248, 245, 0.75);
      backdrop-filter: blur(10px);
      border-radius: 100px;
      border: 1px solid rgba(26,26,46,0.05);
    }
    .progress-dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: rgba(26,26,46,0.15);
      transition: all 0.3s ease;
    }
    .progress-dot.active {
      background: var(--color-amber);
      width: 16px;
      border-radius: 100px;
    }
    .progress-dot.visited { background: rgba(26,26,46,0.35); }

    /* ─── Slide number ─── */
    .slide-num {
      position: absolute;
      bottom: 28px;
      right: 40px;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      color: var(--color-subtle);
      opacity: 0.5;
    }

    /* ─── Brand mark in corner ─── */
    .brand-mark {
      position: absolute;
      bottom: 28px;
      left: 40px;
      font-family: var(--font-heading);
      font-size: 0.85rem;
      letter-spacing: 0.02em;
      color: var(--color-subtle);
      opacity: 0.55;
    }
    .brand-mark .b-grow { font-style: italic; color: var(--color-amber); }

    /* ─── Keyboard hint ─── */
    .kbd-hint {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-subtle);
      opacity: 0.55;
      z-index: 50;
      transition: opacity 0.5s ease;
      pointer-events: none;
    }
    .kbd-hint.hidden { opacity: 0; }
    .kbd-hint kbd {
      font-family: var(--font-mono);
      background: rgba(26,26,46,0.06);
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 0.7rem;
      margin: 0 2px;
    }

    /* ─── Staggered entrance ─── */
    .stagger > * {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1);
    }
    .deck-slide.is-active .stagger > * { opacity: 1; transform: translateY(0); }
    .deck-slide.is-active .stagger > *:nth-child(1) { transition-delay: 0.1s; }
    .deck-slide.is-active .stagger > *:nth-child(2) { transition-delay: 0.2s; }
    .deck-slide.is-active .stagger > *:nth-child(3) { transition-delay: 0.3s; }
    .deck-slide.is-active .stagger > *:nth-child(4) { transition-delay: 0.4s; }
    .deck-slide.is-active .stagger > *:nth-child(5) { transition-delay: 0.5s; }
    .deck-slide.is-active .stagger > *:nth-child(6) { transition-delay: 0.6s; }
    .deck-slide.is-active .stagger > *:nth-child(7) { transition-delay: 0.7s; }
    .deck-slide.is-active .stagger > *:nth-child(8) { transition-delay: 0.8s; }

    /* ─── Print / export-to-PDF ─── */
    @media print {
      @page { size: 1600px 900px; margin: 0; }
      html, body {
        background: var(--color-cream) !important;
        width: 1600px !important;
        height: auto !important;
      }
      body.card-deck-page::before { display: none !important; }
      .progress-rail, .kbd-hint { display: none !important; }
      .card-deck-container {
        height: auto !important;
        max-height: none !important;
        overflow: visible !important;
        scroll-snap-type: none !important;
      }
      .card-deck-card, .deck-slide {
        width: 1600px !important;
        height: 900px !important;
        scroll-snap-align: none !important;
        page-break-after: always !important;
        break-after: page !important;
        overflow: hidden !important;
      }
      .card-deck-card:last-child, .deck-slide:last-child {
        page-break-after: auto !important;
        break-after: auto !important;
      }
      .stagger > * {
        opacity: 1 !important;
        transform: none !important;
        transition: none !important;
      }
      * { animation: none !important; }

      .stages-grid { grid-template-columns: repeat(4, 1fr) !important; gap: 1.25rem !important; }
      .failures-grid { grid-template-columns: 1fr 1fr !important; gap: 3rem !important; }
      .shift-grid { grid-template-columns: repeat(3, 1fr) !important; gap: 2rem !important; }
      .winners-grid { grid-template-columns: repeat(4, 1fr) !important; gap: 1.25rem !important; }
      .rampcase-content { grid-template-columns: 1.05fr 1fr !important; gap: 3rem !important; }
      .rampcase-stats { grid-template-columns: 1fr 1fr !important; gap: 1rem !important; }
      .bundle-grid { grid-template-columns: 1fr 1fr !important; gap: 2.5rem !important; }
      .after-grid { grid-template-columns: repeat(2, 1fr) !important; gap: 1.75rem !important; }
      .deck-slide { padding: 4rem 5rem !important; }
    }

    /* ─── Utilities ─── */
    .caveat { font-family: 'Caveat', cursive; font-weight: 600; }
    /* Override global p max-width (65ch) on slides so paragraphs span their
       container and text-align:center actually centers within the slide. */
    .deck-slide p { max-width: none; }
    .mono-label {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-subtle);
    }

    /* ══════════════════════════════════════════════════════
       SLIDE 01 — Cover
       ══════════════════════════════════════════════════════ */
    .slide-cover {
      align-items: center;
      justify-content: center;
      text-align: center;
    }
    .slide-cover .wordmark {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(5rem, 12vw, 10rem);
      line-height: 1;
      letter-spacing: -0.03em;
      margin: 0;
      color: var(--color-deep);
    }
    .slide-cover .wordmark .ai {
      color: var(--color-amber);
      font-style: italic;
    }
    .slide-cover .verb-pair {
      font-family: var(--font-heading);
      font-weight: 700;
      font-style: italic;
      font-size: clamp(1.75rem, 3vw, 2.5rem);
      color: var(--color-deep);
      margin: 2.5rem 0 0;
      letter-spacing: -0.01em;
    }
    .slide-cover .verb-pair .grow { color: var(--color-teal); }
    .slide-cover .verb-pair .chase { color: var(--color-accent-red); text-decoration: line-through; text-decoration-thickness: 2px; text-decoration-color: rgba(233,69,96,0.5); }
    .slide-cover .firm {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--color-subtle);
      margin-top: 3.5rem;
    }

    /* ══════════════════════════════════════════════════════
       SLIDE 02 — Positioning (Erhart-framework one-liner)
       ══════════════════════════════════════════════════════ */
    .slide-positioning { justify-content: center; }
    .positioning-content {
      max-width: 900px;
      margin: 0 auto;
      width: 100%;
    }
    .positioning-eyebrow {
      display: block;
      margin-bottom: 1.75rem;
    }
    .positioning-statement {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: clamp(2.4rem, 4.4vw, 3.55rem);
      letter-spacing: -0.02em;
      line-height: 1.32;
      margin: 0;
      color: var(--color-deep);
    }
    .positioning-statement .p-who { color: var(--color-teal); }
    .positioning-statement .p-what { color: var(--color-amber); }
    .positioning-statement .p-against { color: var(--color-accent-red); }

    .positioning-key {
      display: flex;
      gap: 2rem;
      margin-top: 2.75rem;
      flex-wrap: wrap;
    }
    .positioning-key-item {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-subtle);
    }
    .positioning-key-dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .positioning-key-item.who .positioning-key-dot { background: var(--color-teal); }
    .positioning-key-item.what .positioning-key-dot { background: var(--color-amber); }
    .positioning-key-item.against .positioning-key-dot { background: var(--color-accent-red); }
    .positioning-key-item.who .label { color: var(--color-teal); }
    .positioning-key-item.what .label { color: var(--color-amber); }
    .positioning-key-item.against .label { color: var(--color-accent-red); }

    /* ══════════════════════════════════════════════════════
       SLIDE 03 — Thesis
       ══════════════════════════════════════════════════════ */
    .slide-thesis {
      justify-content: center;
    }
    .thesis-content {
      max-width: 1100px;
      margin: 0 auto;
      width: 100%;
    }
    .thesis-eyebrow {
      font-family: 'Caveat', cursive;
      font-size: 1.7rem;
      color: var(--color-accent-red);
      transform: rotate(-2deg);
      display: inline-block;
      margin-bottom: 1.5rem;
    }
    .thesis-headline {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(3.25rem, 6.5vw, 5.25rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin: 0 0 2.5rem;
      color: var(--color-deep);
    }
    .thesis-headline em { color: var(--color-amber); font-style: italic; font-weight: 800; }
    .thesis-body {
      font-family: var(--font-body);
      font-size: 1.4rem;
      line-height: 1.55;
      color: var(--color-deep);
      max-width: 56ch;
      margin: 0;
    }
    .thesis-body em { color: var(--color-navy); font-style: italic; }
    .thesis-credit {
      margin-top: 2rem;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      letter-spacing: 0.1em;
      color: var(--color-subtle);
    }

    /* ══════════════════════════════════════════════════════
       SLIDE 03 — About
       ══════════════════════════════════════════════════════ */
    .slide-about { justify-content: center; }
    .about-grid {
      display: grid;
      grid-template-columns: 1.3fr 1fr;
      gap: 5rem;
      align-items: center;
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
    }
    .about-name {
      font-family: var(--font-heading);
      font-size: clamp(3rem, 5.5vw, 4.5rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1;
      margin: 0.5rem 0 0.75rem;
    }
    .about-subtitle {
      font-family: var(--font-body);
      font-style: italic;
      font-size: 1.15rem;
      color: var(--color-subtle);
      margin: 0 0 2rem;
    }
    .about-credits {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .about-credits li {
      display: flex;
      gap: 14px;
      padding: 0.65rem 0;
      border-bottom: 1px solid rgba(26,26,46,0.06);
    }
    .about-credits li:last-child { border-bottom: none; }
    .credit-dot {
      flex-shrink: 0;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      margin-top: 0.55rem;
    }
    .credit-body strong {
      font-family: var(--font-body);
      font-weight: 700;
      color: var(--color-deep);
      font-size: 1.02rem;
    }
    .credit-body .credit-detail {
      display: block;
      font-family: var(--font-body);
      font-size: 0.92rem;
      color: var(--color-subtle);
      font-style: italic;
      margin-top: 2px;
    }
    .about-portrait {
      position: relative;
      width: 320px;
      height: 320px;
      margin: 0 auto;
      border-radius: 50%;
      overflow: hidden;
      box-shadow:
        0 20px 60px rgba(15,52,96,0.18),
        0 0 0 6px var(--color-cream),
        0 0 0 7px rgba(245,166,35,0.18);
    }
    .about-portrait img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(0.15) contrast(1.02);
    }
    .about-email {
      text-align: center;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      color: var(--color-navy);
      margin-top: 1.5rem;
      letter-spacing: 0.02em;
    }

    /* ══════════════════════════════════════════════════════
       SLIDE 04 — Licensing isn't adoption
       ══════════════════════════════════════════════════════ */
    .slide-licensing { justify-content: center; }
    .licensing-content {
      max-width: 1000px;
      margin: 0 auto;
      width: 100%;
    }
    .licensing-eyebrow { margin-bottom: 1.5rem; }
    .licensing-title {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(3.5rem, 7vw, 6rem);
      letter-spacing: -0.04em;
      line-height: 1;
      margin: 0 0 2.5rem;
      color: var(--color-deep);
    }
    .licensing-title .strike { text-decoration: line-through; text-decoration-color: rgba(233,69,96,0.65); text-decoration-thickness: 4px; color: var(--color-accent-red); }
    .licensing-beats {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .licensing-beats li {
      font-family: var(--font-body);
      font-size: 1.4rem;
      line-height: 1.5;
      color: var(--color-deep);
      padding-left: 1.6rem;
      position: relative;
    }
    .licensing-beats li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.85rem;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--color-amber);
    }
    .licensing-beats em { color: var(--color-navy); font-style: italic; font-weight: 600; }

    /* ══════════════════════════════════════════════════════
       SLIDE 05 — Two failure modes
       ══════════════════════════════════════════════════════ */
    .slide-failures { justify-content: center; }
    .failures-content {
      max-width: 1300px;
      margin: 0 auto;
      width: 100%;
    }
    .failures-headline {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 4.5vw, 3.5rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0 0 2.5rem;
      color: var(--color-deep);
      text-align: center;
    }
    .failures-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
    .failure-card {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.08);
      border-radius: 14px;
      padding: 2rem 2rem 1.75rem;
      position: relative;
      overflow: hidden;
    }
    .failure-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
    }
    .failure-card.under::before { background: var(--color-sky); }
    .failure-card.over::before { background: var(--color-accent-red); }
    .failure-mode {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      margin-bottom: 0.85rem;
    }
    .failure-card.under .failure-mode { color: var(--color-sky); }
    .failure-card.over .failure-mode { color: var(--color-accent-red); }
    .failure-name {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 2.1rem;
      letter-spacing: -0.02em;
      margin: 0 0 0.85rem;
      color: var(--color-deep);
    }
    .failure-stat {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 2.4rem;
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: var(--color-deep);
      margin: 0.4rem 0 0.85rem;
    }
    .failure-card.under .failure-stat { color: var(--color-sky); }
    .failure-card.over .failure-stat { color: var(--color-accent-red); }
    .failure-body {
      font-family: var(--font-body);
      font-size: 1rem;
      line-height: 1.55;
      color: var(--color-deep);
      margin: 0;
    }
    .failure-body em { color: var(--color-navy); font-style: italic; }
    .failures-summary {
      font-family: 'Caveat', cursive;
      font-size: 1.6rem;
      color: var(--color-subtle);
      text-align: center;
      margin: 2.5rem 0 0;
      transform: rotate(-1deg);
    }
    .failures-summary .accent { color: var(--color-amber); }

    /* ══════════════════════════════════════════════════════
       SLIDE 06 — Ground is moving
       ══════════════════════════════════════════════════════ */
    .slide-shift { justify-content: center; }
    .shift-content { max-width: 1200px; margin: 0 auto; width: 100%; }
    .shift-headline {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 5vw, 4rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0 0 2.5rem;
      color: var(--color-deep);
      text-align: center;
    }
    .shift-headline em { color: var(--color-accent-red); font-style: italic; }
    .shift-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
    .shift-card {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.07);
      border-radius: 12px;
      padding: 1.75rem 1.5rem;
    }
    .shift-card-num {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 2.2rem;
      line-height: 1;
      color: var(--color-amber);
      margin: 0 0 0.65rem;
      opacity: 0.75;
    }
    .shift-card-text {
      font-family: var(--font-body);
      font-size: 1.1rem;
      line-height: 1.5;
      color: var(--color-deep);
      margin: 0;
    }
    .shift-card-text em { color: var(--color-navy); font-style: italic; font-weight: 600; }

    /* ══════════════════════════════════════════════════════
       SLIDE 06 — What the winners did
       ══════════════════════════════════════════════════════ */
    .slide-winners { justify-content: center; }
    .winners-content { max-width: 1200px; margin: 0 auto; width: 100%; }
    .winners-headline {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 5vw, 4rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0 0 1.25rem;
      color: var(--color-deep);
      text-align: center;
    }
    .winners-headline em { color: var(--color-teal); font-style: italic; }
    .winners-sub {
      font-family: var(--font-body);
      font-size: 1.25rem;
      line-height: 1.55;
      color: var(--color-subtle);
      text-align: center;
      max-width: 60ch;
      margin: 0 auto 2.75rem;
    }
    .winners-sub strong { color: var(--color-navy); font-weight: 700; }
    .winners-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.25rem;
    }
    .winners-card {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.08);
      border-radius: 12px;
      padding: 1.6rem 1.5rem;
      position: relative;
    }
    .winners-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: var(--color-teal);
      border-radius: 12px 12px 0 0;
    }
    .winners-num {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      color: var(--color-teal);
      display: block;
      margin-bottom: 0.85rem;
    }
    .winners-q {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 1.5rem;
      line-height: 1.2;
      letter-spacing: -0.02em;
      color: var(--color-deep);
      margin: 0;
    }
    .winners-q em { color: var(--color-amber); font-style: italic; font-weight: 800; }

    /* ══════════════════════════════════════════════════════
       SLIDE 07 — Ramp case study
       ══════════════════════════════════════════════════════ */
    .slide-rampcase { justify-content: center; }
    .rampcase-content {
      max-width: 1320px;
      margin: 0 auto;
      width: 100%;
      display: grid;
      grid-template-columns: 1.05fr 1fr;
      gap: 3rem;
      align-items: center;
