      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.75rem;
      max-width: 900px;
      margin: 0 auto;
    }
    .after-card {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.08);
