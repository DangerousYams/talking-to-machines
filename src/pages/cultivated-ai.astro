      color: var(--color-subtle);
      margin: 1rem 0 2.5rem;
    }
    .price-explainer {
      font-family: var(--font-body);
      font-size: 1.1rem;
      line-height: 1.55;
      color: var(--color-deep);
      max-width: 56ch;
      margin: 0 auto;
    }
    .price-explainer em { color: var(--color-navy); font-style: italic; }

    /* ══════════════════════════════════════════════════════
       SLIDE 19 — After (optional engagements)
       ══════════════════════════════════════════════════════ */
    .slide-after { justify-content: center; }
    .after-content { max-width: 1300px; margin: 0 auto; width: 100%; }
    .after-headline {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 4.5vw, 3.5rem);
      letter-spacing: -0.03em;
