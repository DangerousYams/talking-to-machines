---
export const prerender = true;
import '../styles/global.css';

const slides = [
  'cover',
  'thesis',
  'about',
  'licensing',
  'failures',
  'shift',
  'discipline',
  'stages',
  'approach',
  'distillation',
  'bajaj',
  'compounding',
  'sovereignty',
  'nbim',
  'simulation',
  'programme',
  'bundle',
  'price',
  'after',
  'why-ocre',
  'close',
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Cultivated AI · Pitch</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Caveat:wght@500;600;700&display=swap" />
  <style>
    /* ══════════════════════════════════════════════════════
       Cultivated AI · pitch deck
       Inherits global tokens (cream / deep / accent / etc).
       ══════════════════════════════════════════════════════ */
    body.card-deck-page { background: var(--color-cream); }

    .deck-slide {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 5rem;
      box-sizing: border-box;
    }

    /* ─── Progress rail ─── */
    .progress-rail {
      position: fixed;
      top: 20px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 6px;
      z-index: 50;
      padding: 8px 14px;
      background: rgba(250, 248, 245, 0.75);
      backdrop-filter: blur(10px);
      border-radius: 100px;
      border: 1px solid rgba(26,26,46,0.05);
    }
    .progress-dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: rgba(26,26,46,0.15);
      transition: all 0.3s ease;
    }
    .progress-dot.active {
      background: var(--color-amber);
      width: 16px;
      border-radius: 100px;
    }
    .progress-dot.visited { background: rgba(26,26,46,0.35); }

    /* ─── Slide number ─── */
    .slide-num {
      position: absolute;
      bottom: 28px;
      right: 40px;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      color: var(--color-subtle);
      opacity: 0.5;
    }

    /* ─── Brand mark in corner ─── */
    .brand-mark {
      position: absolute;
      bottom: 28px;
      left: 40px;
      font-family: var(--font-heading);
      font-size: 0.85rem;
      letter-spacing: 0.02em;
      color: var(--color-subtle);
      opacity: 0.55;
    }
    .brand-mark .b-grow { font-style: italic; color: var(--color-amber); }

    /* ─── Keyboard hint ─── */
    .kbd-hint {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-subtle);
      opacity: 0.55;
      z-index: 50;
      transition: opacity 0.5s ease;
      pointer-events: none;
    }
    .kbd-hint.hidden { opacity: 0; }
    .kbd-hint kbd {
      font-family: var(--font-mono);
      background: rgba(26,26,46,0.06);
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 0.7rem;
      margin: 0 2px;
    }

    /* ─── Staggered entrance ─── */
    .stagger > * {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1);
    }
    .deck-slide.is-active .stagger > * { opacity: 1; transform: translateY(0); }
    .deck-slide.is-active .stagger > *:nth-child(1) { transition-delay: 0.1s; }
    .deck-slide.is-active .stagger > *:nth-child(2) { transition-delay: 0.2s; }
    .deck-slide.is-active .stagger > *:nth-child(3) { transition-delay: 0.3s; }
    .deck-slide.is-active .stagger > *:nth-child(4) { transition-delay: 0.4s; }
    .deck-slide.is-active .stagger > *:nth-child(5) { transition-delay: 0.5s; }
    .deck-slide.is-active .stagger > *:nth-child(6) { transition-delay: 0.6s; }
    .deck-slide.is-active .stagger > *:nth-child(7) { transition-delay: 0.7s; }
    .deck-slide.is-active .stagger > *:nth-child(8) { transition-delay: 0.8s; }

    /* ─── Print / export-to-PDF ─── */
    @media print {
      @page { size: 1600px 900px; margin: 0; }
      html, body {
        background: var(--color-cream) !important;
        width: 1600px !important;
        height: auto !important;
      }
      body.card-deck-page::before { display: none !important; }
      .progress-rail, .kbd-hint { display: none !important; }
      .card-deck-container {
        height: auto !important;
        max-height: none !important;
        overflow: visible !important;
        scroll-snap-type: none !important;
      }
      .card-deck-card, .deck-slide {
        width: 1600px !important;
        height: 900px !important;
        scroll-snap-align: none !important;
        page-break-after: always !important;
        break-after: page !important;
        overflow: hidden !important;
      }
      .card-deck-card:last-child, .deck-slide:last-child {
        page-break-after: auto !important;
        break-after: auto !important;
      }
      .stagger > * {
        opacity: 1 !important;
        transform: none !important;
        transition: none !important;
      }
      * { animation: none !important; }

      .stages-grid { grid-template-columns: repeat(5, 1fr) !important; gap: 1.25rem !important; }
      .failures-grid { grid-template-columns: 1fr 1fr !important; gap: 3rem !important; }
      .shift-grid { grid-template-columns: repeat(3, 1fr) !important; gap: 2rem !important; }
      .bundle-grid { grid-template-columns: 1fr 1fr !important; gap: 2.5rem !important; }
      .after-grid { grid-template-columns: repeat(3, 1fr) !important; gap: 1.5rem !important; }
      .deck-slide { padding: 4rem 5rem !important; }
    }

    /* ─── Utilities ─── */
    .caveat { font-family: 'Caveat', cursive; font-weight: 600; }
    .mono-label {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-subtle);
    }

    /* ══════════════════════════════════════════════════════
       SLIDE 01 — Cover
       ══════════════════════════════════════════════════════ */
    .slide-cover {
      align-items: center;
      justify-content: center;
      text-align: center;
    }
    .slide-cover .wordmark {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(5rem, 12vw, 10rem);
      line-height: 1;
      letter-spacing: -0.03em;
      margin: 0;
      color: var(--color-deep);
    }
    .slide-cover .wordmark .ai {
      color: var(--color-amber);
      font-style: italic;
    }
    .slide-cover .verb-pair {
      font-family: var(--font-heading);
      font-weight: 700;
      font-style: italic;
      font-size: clamp(1.75rem, 3vw, 2.5rem);
      color: var(--color-deep);
      margin: 2.5rem 0 0;
      letter-spacing: -0.01em;
    }
    .slide-cover .verb-pair .grow { color: var(--color-teal); }
    .slide-cover .verb-pair .chase { color: var(--color-accent-red); text-decoration: line-through; text-decoration-thickness: 2px; text-decoration-color: rgba(233,69,96,0.5); }
    .slide-cover .firm {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--color-subtle);
      margin-top: 3.5rem;
    }

    /* ══════════════════════════════════════════════════════
       SLIDE 02 — Thesis
       ══════════════════════════════════════════════════════ */
    .slide-thesis {
      justify-content: center;
    }
    .thesis-content {
      max-width: 1100px;
      margin: 0 auto;
      width: 100%;
    }
    .thesis-eyebrow {
      font-family: 'Caveat', cursive;
      font-size: 1.7rem;
      color: var(--color-accent-red);
      transform: rotate(-2deg);
      display: inline-block;
      margin-bottom: 1.5rem;
    }
    .thesis-headline {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(3.25rem, 6.5vw, 5.25rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin: 0 0 2.5rem;
      color: var(--color-deep);
    }
    .thesis-headline .pipeline { color: var(--color-amber); font-style: italic; }
    .thesis-body {
      font-family: var(--font-body);
      font-size: 1.4rem;
      line-height: 1.55;
      color: var(--color-deep);
      max-width: 56ch;
      margin: 0;
    }
    .thesis-body em { color: var(--color-navy); font-style: italic; }
    .thesis-credit {
      margin-top: 2rem;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      letter-spacing: 0.1em;
      color: var(--color-subtle);
    }

    /* ══════════════════════════════════════════════════════
       SLIDE 03 — About
       ══════════════════════════════════════════════════════ */
    .slide-about { justify-content: center; }
    .about-grid {
      display: grid;
      grid-template-columns: 1.3fr 1fr;
      gap: 5rem;
      align-items: center;
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
    }
    .about-name {
      font-family: var(--font-heading);
      font-size: clamp(3rem, 5.5vw, 4.5rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1;
      margin: 0.5rem 0 0.75rem;
    }
    .about-subtitle {
      font-family: var(--font-body);
      font-style: italic;
      font-size: 1.15rem;
      color: var(--color-subtle);
      margin: 0 0 2rem;
    }
    .about-credits {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .about-credits li {
      display: flex;
      gap: 14px;
      padding: 0.65rem 0;
      border-bottom: 1px solid rgba(26,26,46,0.06);
    }
    .about-credits li:last-child { border-bottom: none; }
    .credit-dot {
      flex-shrink: 0;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      margin-top: 0.55rem;
    }
    .credit-body strong {
      font-family: var(--font-body);
      font-weight: 700;
      color: var(--color-deep);
      font-size: 1.02rem;
    }
    .credit-body .credit-detail {
      display: block;
      font-family: var(--font-body);
      font-size: 0.92rem;
      color: var(--color-subtle);
      font-style: italic;
      margin-top: 2px;
    }
    .about-portrait {
      position: relative;
      width: 320px;
      height: 320px;
      margin: 0 auto;
      border-radius: 50%;
      overflow: hidden;
      box-shadow:
        0 20px 60px rgba(15,52,96,0.18),
        0 0 0 6px var(--color-cream),
        0 0 0 7px rgba(245,166,35,0.18);
    }
    .about-portrait img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(0.15) contrast(1.02);
    }
    .about-email {
      text-align: center;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      color: var(--color-navy);
      margin-top: 1.5rem;
      letter-spacing: 0.02em;
    }

    /* ══════════════════════════════════════════════════════
       SLIDE 04 — Licensing isn't adoption
       ══════════════════════════════════════════════════════ */
    .slide-licensing { justify-content: center; }
    .licensing-content {
      max-width: 1000px;
      margin: 0 auto;
      width: 100%;
    }
    .licensing-eyebrow { margin-bottom: 1.5rem; }
    .licensing-title {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(3.5rem, 7vw, 6rem);
      letter-spacing: -0.04em;
      line-height: 1;
      margin: 0 0 2.5rem;
      color: var(--color-deep);
    }
    .licensing-title .strike { text-decoration: line-through; text-decoration-color: rgba(233,69,96,0.65); text-decoration-thickness: 4px; color: var(--color-accent-red); }
    .licensing-beats {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .licensing-beats li {
      font-family: var(--font-body);
      font-size: 1.4rem;
      line-height: 1.5;
      color: var(--color-deep);
      padding-left: 1.6rem;
      position: relative;
    }
    .licensing-beats li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.85rem;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--color-amber);
    }
    .licensing-beats em { color: var(--color-navy); font-style: italic; font-weight: 600; }

    /* ══════════════════════════════════════════════════════
       SLIDE 05 — Two failure modes
       ══════════════════════════════════════════════════════ */
    .slide-failures { justify-content: center; }
    .failures-content {
      max-width: 1300px;
      margin: 0 auto;
      width: 100%;
    }
    .failures-headline {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 4.5vw, 3.5rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0 0 2.5rem;
      color: var(--color-deep);
      text-align: center;
    }
    .failures-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
    .failure-card {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.08);
      border-radius: 14px;
      padding: 2rem 2rem 1.75rem;
      position: relative;
      overflow: hidden;
    }
    .failure-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
    }
    .failure-card.under::before { background: var(--color-sky); }
    .failure-card.over::before { background: var(--color-accent-red); }
    .failure-mode {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      margin-bottom: 0.85rem;
    }
    .failure-card.under .failure-mode { color: var(--color-sky); }
    .failure-card.over .failure-mode { color: var(--color-accent-red); }
    .failure-name {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 2.1rem;
      letter-spacing: -0.02em;
      margin: 0 0 0.85rem;
      color: var(--color-deep);
    }
    .failure-stat {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 2.4rem;
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: var(--color-deep);
      margin: 0.4rem 0 0.85rem;
    }
    .failure-card.under .failure-stat { color: var(--color-sky); }
    .failure-card.over .failure-stat { color: var(--color-accent-red); }
    .failure-body {
      font-family: var(--font-body);
      font-size: 1rem;
      line-height: 1.55;
      color: var(--color-deep);
      margin: 0;
    }
    .failure-body em { color: var(--color-navy); font-style: italic; }
    .failures-summary {
      font-family: 'Caveat', cursive;
      font-size: 1.6rem;
      color: var(--color-subtle);
      text-align: center;
      margin: 2.5rem 0 0;
      transform: rotate(-1deg);
    }
    .failures-summary .accent { color: var(--color-amber); }

    /* ══════════════════════════════════════════════════════
       SLIDE 06 — Ground is moving
       ══════════════════════════════════════════════════════ */
    .slide-shift { justify-content: center; }
    .shift-content { max-width: 1200px; margin: 0 auto; width: 100%; }
    .shift-headline {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 5vw, 4rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0 0 2.5rem;
      color: var(--color-deep);
      text-align: center;
    }
    .shift-headline em { color: var(--color-accent-red); font-style: italic; }
    .shift-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
    .shift-card {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.07);
      border-radius: 12px;
      padding: 1.75rem 1.5rem;
    }
    .shift-card-num {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 2.2rem;
      line-height: 1;
      color: var(--color-amber);
      margin: 0 0 0.65rem;
      opacity: 0.75;
    }
    .shift-card-text {
      font-family: var(--font-body);
      font-size: 1.1rem;
      line-height: 1.5;
      color: var(--color-deep);
      margin: 0;
    }
    .shift-card-text em { color: var(--color-navy); font-style: italic; font-weight: 600; }

    /* ══════════════════════════════════════════════════════
       SLIDE 07 — Discipline introduction
       ══════════════════════════════════════════════════════ */
    .slide-discipline { justify-content: center; align-items: center; text-align: center; }
    .discipline-eyebrow { margin-bottom: 1.25rem; }
    .discipline-name {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(4rem, 9vw, 7rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin: 0;
      color: var(--color-deep);
    }
    .discipline-name .ai { color: var(--color-amber); font-style: italic; }
    .discipline-tag {
      font-family: var(--font-body);
      font-style: italic;
      font-size: 1.4rem;
      color: var(--color-subtle);
      margin: 1.5rem 0 0;
      max-width: 56ch;
    }

    /* ══════════════════════════════════════════════════════
       SLIDE 08 — Five stages overview
       ══════════════════════════════════════════════════════ */
    .slide-stages { justify-content: center; }
    .stages-content { max-width: 1400px; margin: 0 auto; width: 100%; }
    .stages-headline {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 4.5vw, 3.5rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0 0 2.5rem;
      color: var(--color-deep);
      text-align: center;
    }
    .stages-headline em { font-style: italic; color: var(--color-amber); }
    .stages-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 1.25rem;
    }
    .stage-card {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.07);
      border-radius: 12px;
      padding: 1.5rem 1.25rem;
      position: relative;
      overflow: hidden;
    }
    .stage-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
    }
    .stage-card.s1::before { background: var(--color-amber); }
    .stage-card.s2::before { background: var(--color-teal); }
    .stage-card.s3::before { background: var(--color-purple); }
    .stage-card.s4::before { background: var(--color-navy); }
    .stage-card.s5::before { background: var(--color-accent-red); }
    .stage-num {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-subtle);
      margin-bottom: 0.5rem;
    }
    .stage-title {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 1.4rem;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin: 0 0 0.65rem;
    }
    .stage-card.s1 .stage-title { color: var(--color-amber); }
    .stage-card.s2 .stage-title { color: var(--color-teal); }
    .stage-card.s3 .stage-title { color: var(--color-purple); }
    .stage-card.s4 .stage-title { color: var(--color-navy); }
    .stage-card.s5 .stage-title { color: var(--color-accent-red); }
    .stage-tag {
      font-family: var(--font-body);
      font-size: 0.92rem;
      line-height: 1.45;
      color: var(--color-deep);
      margin: 0;
    }
    .stages-rule {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 1rem;
      margin-top: 2.5rem;
      font-family: var(--font-mono);
      font-size: 0.78rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-subtle);
    }
    .stages-rule .programme { color: var(--color-amber); font-weight: 700; }
    .stages-rule .graduation { color: var(--color-navy); font-weight: 700; }

    /* ══════════════════════════════════════════════════════
       SLIDES 09–10, 12–13, 15 — Individual stage slides
       ══════════════════════════════════════════════════════ */
    .slide-stage { justify-content: center; }
    .stage-big-num {
      position: absolute;
      right: 4rem;
      top: 50%;
      transform: translateY(-50%);
      font-family: var(--font-heading);
      font-weight: 900;
      font-size: clamp(18rem, 34vw, 32rem);
      line-height: 1;
      opacity: 0.07;
      user-select: none;
      pointer-events: none;
      letter-spacing: -0.05em;
    }
    .slide-stage.s1 .stage-big-num { color: var(--color-amber); }
    .slide-stage.s2 .stage-big-num { color: var(--color-teal); }
    .slide-stage.s3 .stage-big-num { color: var(--color-purple); }
    .slide-stage.s4 .stage-big-num { color: var(--color-navy); }
    .slide-stage.s5 .stage-big-num { color: var(--color-accent-red); }
    .stage-content {
      max-width: 900px;
      margin: 0 auto;
      width: 100%;
      position: relative;
      z-index: 2;
    }
    .stage-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 6px 12px;
      border-radius: 100px;
      margin-bottom: 1.5rem;
    }
    .slide-stage.s1 .stage-pill { background: rgba(245,166,35,0.12); color: var(--color-amber); }
    .slide-stage.s2 .stage-pill { background: rgba(22,199,154,0.12); color: var(--color-teal); }
    .slide-stage.s3 .stage-pill { background: rgba(123,97,255,0.12); color: var(--color-purple); }
    .slide-stage.s4 .stage-pill { background: rgba(15,52,96,0.10); color: var(--color-navy); }
    .slide-stage.s5 .stage-pill { background: rgba(233,69,96,0.10); color: var(--color-accent-red); }
    .stage-name {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(3.5rem, 7vw, 5.5rem);
      letter-spacing: -0.03em;
      line-height: 1;
      margin: 0 0 1.5rem;
      color: var(--color-deep);
    }
    .slide-stage.s1 .stage-name { color: var(--color-amber); }
    .slide-stage.s2 .stage-name { color: var(--color-teal); }
    .slide-stage.s3 .stage-name { color: var(--color-purple); }
    .slide-stage.s4 .stage-name { color: var(--color-navy); }
    .slide-stage.s5 .stage-name { color: var(--color-accent-red); }
    .stage-body {
      font-family: var(--font-body);
      font-size: 1.4rem;
      line-height: 1.55;
      color: var(--color-deep);
      max-width: 58ch;
      margin: 0;
    }
    .stage-body em { color: var(--color-navy); font-style: italic; }
    .stage-body strong { font-weight: 700; color: var(--color-deep); }
    .stage-payoff {
      font-family: 'Caveat', cursive;
      font-size: 1.6rem;
      color: var(--color-subtle);
      margin: 2rem 0 0;
      transform: rotate(-1deg);
      display: inline-block;
    }
    .slide-stage.s1 .stage-payoff { color: var(--color-amber); }
    .slide-stage.s2 .stage-payoff { color: var(--color-teal); }
    .slide-stage.s3 .stage-payoff { color: var(--color-purple); }
    .slide-stage.s4 .stage-payoff { color: var(--color-navy); }
    .slide-stage.s5 .stage-payoff { color: var(--color-accent-red); }

    /* ══════════════════════════════════════════════════════
       SLIDES 11, 14 — Example slides (Bajaj, NBIM)
       ══════════════════════════════════════════════════════ */
    .slide-example { justify-content: center; }
    .example-content {
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 4rem;
      align-items: center;
    }
    .example-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }
    .slide-example.bajaj .example-eyebrow { color: var(--color-teal); }
    .slide-example.nbim .example-eyebrow { color: var(--color-navy); }
    .example-name {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 5vw, 3.75rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0 0 1.5rem;
      color: var(--color-deep);
    }
    .example-tagline {
      font-family: var(--font-body);
      font-style: italic;
      font-size: 1.2rem;
      color: var(--color-subtle);
      margin: 0 0 1.5rem;
    }
    .example-body {
      font-family: var(--font-body);
      font-size: 1.05rem;
      line-height: 1.6;
      color: var(--color-deep);
      margin: 0;
    }
    .example-body em { color: var(--color-navy); font-style: italic; }
    .example-stats {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .example-stat-card {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.08);
      border-radius: 14px;
      padding: 1.5rem 1.75rem;
      position: relative;
    }
    .example-stat-card::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 4px;
      border-radius: 4px 0 0 4px;
    }
    .slide-example.bajaj .example-stat-card::before { background: var(--color-teal); }
    .slide-example.nbim .example-stat-card::before { background: var(--color-navy); }
    .example-stat-num {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 2.6rem;
      line-height: 1;
      letter-spacing: -0.02em;
      margin: 0 0 0.4rem;
      color: var(--color-deep);
    }
    .slide-example.bajaj .example-stat-num { color: var(--color-teal); }
    .slide-example.nbim .example-stat-num { color: var(--color-navy); }
    .example-stat-label {
      font-family: var(--font-body);
      font-size: 0.95rem;
      line-height: 1.5;
      color: var(--color-subtle);
      margin: 0;
    }
    .example-quote {
      font-family: var(--font-heading);
      font-style: italic;
      font-size: 1.4rem;
      line-height: 1.4;
      color: var(--color-deep);
      margin: 0;
    }
    .example-quote-attr {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      letter-spacing: 0.1em;
      color: var(--color-subtle);
      margin-top: 0.6rem;
    }

    /* ══════════════════════════════════════════════════════
       SLIDE 16 — Programme overview
       ══════════════════════════════════════════════════════ */
    .slide-programme { justify-content: center; }
    .programme-content { max-width: 1100px; margin: 0 auto; width: 100%; }
    .programme-eyebrow { margin-bottom: 1.25rem; }
    .programme-headline {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.75rem, 5.5vw, 4.5rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0 0 2.5rem;
      color: var(--color-deep);
    }
    .programme-headline em { color: var(--color-amber); font-style: italic; }
    .programme-spec {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem 2.5rem;
    }
    .programme-spec li {
      font-family: var(--font-body);
      font-size: 1.15rem;
      line-height: 1.5;
      color: var(--color-deep);
      padding-left: 1.5rem;
      position: relative;
    }
    .programme-spec li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.7rem;
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--color-amber);
    }
    .programme-spec strong { font-weight: 700; color: var(--color-navy); display: block; font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; font-family: var(--font-mono); margin-bottom: 0.2rem; }

    /* ══════════════════════════════════════════════════════
       SLIDE 17 — Bundle (two artefacts)
       ══════════════════════════════════════════════════════ */
    .slide-bundle { justify-content: center; }
    .bundle-content { max-width: 1200px; margin: 0 auto; width: 100%; }
    .bundle-headline {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 4.5vw, 3.5rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0 0 2.5rem;
      color: var(--color-deep);
      text-align: center;
    }
    .bundle-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
    .bundle-card {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.08);
      border-radius: 14px;
      padding: 2.25rem 2rem;
      position: relative;
      overflow: hidden;
    }
    .bundle-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
    }
    .bundle-card.one::before { background: var(--color-teal); }
    .bundle-card.two::before { background: var(--color-amber); }
    .bundle-num {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 4rem;
      line-height: 1;
      opacity: 0.15;
      margin: 0 0 0.5rem;
    }
    .bundle-card.one .bundle-num { color: var(--color-teal); }
    .bundle-card.two .bundle-num { color: var(--color-amber); }
    .bundle-title {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 1.85rem;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin: 0 0 1rem;
      color: var(--color-deep);
    }
    .bundle-card.one .bundle-title { color: var(--color-teal); }
    .bundle-card.two .bundle-title { color: var(--color-amber); }
    .bundle-body {
      font-family: var(--font-body);
      font-size: 1.05rem;
      line-height: 1.55;
      color: var(--color-deep);
      margin: 0 0 1rem;
    }
    .bundle-body em { color: var(--color-navy); font-style: italic; }
    .bundle-tag {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-subtle);
      margin: 0;
    }

    /* ══════════════════════════════════════════════════════
       SLIDE 18 — Price
       ══════════════════════════════════════════════════════ */
    .slide-price { justify-content: center; align-items: center; text-align: center; }
    .price-eyebrow { margin-bottom: 1rem; }
    .price-mega {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(7rem, 18vw, 16rem);
      line-height: 1;
      letter-spacing: -0.05em;
      margin: 0;
      color: var(--color-deep);
    }
    .price-mega .ru { color: var(--color-amber); }
    .price-tag {
      font-family: var(--font-body);
      font-style: italic;
      font-size: 1.4rem;
      color: var(--color-subtle);
      margin: 1rem 0 2.5rem;
    }
    .price-explainer {
      font-family: var(--font-body);
      font-size: 1.1rem;
      line-height: 1.55;
      color: var(--color-deep);
      max-width: 56ch;
      margin: 0 auto;
    }
    .price-explainer em { color: var(--color-navy); font-style: italic; }

    /* ══════════════════════════════════════════════════════
       SLIDE 19 — After (optional engagements)
       ══════════════════════════════════════════════════════ */
    .slide-after { justify-content: center; }
    .after-content { max-width: 1300px; margin: 0 auto; width: 100%; }
    .after-headline {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 4.5vw, 3.5rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0 0 2.5rem;
      color: var(--color-deep);
      text-align: center;
    }
    .after-headline em { color: var(--color-amber); font-style: italic; }
    .after-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    .after-card {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.08);
      border-radius: 12px;
      padding: 1.85rem 1.5rem;
      position: relative;
      overflow: hidden;
    }
    .after-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
    }
    .after-card.advisory::before { background: var(--color-purple); }
    .after-card.sovereignty::before { background: var(--color-navy); }
    .after-card.simulation::before { background: var(--color-accent-red); }
    .after-card .stage-num {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }
    .after-card.advisory .stage-num { color: var(--color-purple); }
    .after-card.sovereignty .stage-num { color: var(--color-navy); }
    .after-card.simulation .stage-num { color: var(--color-accent-red); }
    .after-card .after-title {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 1.6rem;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin: 0 0 0.85rem;
      color: var(--color-deep);
    }
    .after-card.advisory .after-title { color: var(--color-purple); }
    .after-card.sovereignty .after-title { color: var(--color-navy); }
    .after-card.simulation .after-title { color: var(--color-accent-red); }
    .after-card .after-body {
      font-family: var(--font-body);
      font-size: 0.98rem;
      line-height: 1.5;
      color: var(--color-deep);
      margin: 0;
    }
    .after-card .after-body em { color: var(--color-navy); font-style: italic; }

    /* ══════════════════════════════════════════════════════
       SLIDE 20 — Why Ocre (founder credibility)
       ══════════════════════════════════════════════════════ */
    .slide-why { justify-content: center; }
    .why-content { max-width: 1100px; margin: 0 auto; width: 100%; }
    .why-eyebrow { margin-bottom: 1rem; }
    .why-headline {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 5vw, 3.75rem);
      letter-spacing: -0.03em;
      line-height: 1.1;
      margin: 0 0 2rem;
      color: var(--color-deep);
    }
    .why-headline em { color: var(--color-amber); font-style: italic; }
    .why-thesis {
      font-family: var(--font-body);
      font-size: 1.3rem;
      line-height: 1.6;
      color: var(--color-deep);
      max-width: 64ch;
      margin: 0 0 1.5rem;
    }
    .why-thesis strong { font-weight: 700; color: var(--color-navy); }
    .why-thesis em { color: var(--color-amber); font-style: italic; font-weight: 600; }
    .why-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem 0.85rem;
      margin-top: 1rem;
    }
    .why-badge {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      padding: 6px 12px;
      border-radius: 100px;
      border: 1px solid;
      background: var(--color-warm-white);
    }
    .why-badge.b1 { color: var(--color-accent-red); border-color: rgba(233,69,96,0.3); }
    .why-badge.b2 { color: var(--color-purple); border-color: rgba(123,97,255,0.3); }
    .why-badge.b3 { color: var(--color-teal); border-color: rgba(22,199,154,0.3); }
    .why-badge.b4 { color: var(--color-amber); border-color: rgba(245,166,35,0.4); }
    .why-badge.b5 { color: var(--color-sky); border-color: rgba(14,165,233,0.3); }
    .why-badge.b6 { color: var(--color-navy); border-color: rgba(15,52,96,0.3); }

    /* ══════════════════════════════════════════════════════
       SLIDE 21 — Close
       ══════════════════════════════════════════════════════ */
    .slide-close {
      align-items: center;
      justify-content: center;
      text-align: center;
    }
    .close-eyebrow {
      font-family: 'Caveat', cursive;
      font-size: 1.6rem;
      color: var(--color-teal);
      transform: rotate(-2deg);
      margin-bottom: 1rem;
      display: inline-block;
    }
    .close-wordmark {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(4.5rem, 11vw, 9rem);
      line-height: 1;
      letter-spacing: -0.03em;
      margin: 0;
      color: var(--color-deep);
    }
    .close-wordmark .ai { color: var(--color-amber); font-style: italic; }
    .close-verb {
      font-family: var(--font-heading);
      font-weight: 700;
      font-style: italic;
      font-size: clamp(1.6rem, 2.8vw, 2.25rem);
      color: var(--color-deep);
      margin: 2rem 0 3rem;
    }
    .close-verb .grow { color: var(--color-teal); }
    .close-verb .chase { color: var(--color-accent-red); text-decoration: line-through; text-decoration-thickness: 2px; text-decoration-color: rgba(233,69,96,0.5); }
    .close-cta {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-subtle);
    }
    .close-email {
      font-family: var(--font-mono);
      font-size: 1rem;
      color: var(--color-navy);
      margin-top: 0.6rem;
    }

    /* ══════════════════════════════════════════════════════
       Responsive — laptops at 1280+
       ══════════════════════════════════════════════════════ */
    @media (max-width: 1100px) {
      .about-grid { grid-template-columns: 1fr; gap: 2.5rem; text-align: center; }
      .about-credits li { justify-content: flex-start; text-align: left; }
      .about-portrait { width: 240px; height: 240px; }
      .stages-grid { grid-template-columns: repeat(5, 1fr); gap: 0.75rem; }
      .stage-card { padding: 1rem 0.85rem; }
      .stage-title { font-size: 1.15rem; }
      .stage-tag { font-size: 0.85rem; }
      .failures-grid { grid-template-columns: 1fr; gap: 1.5rem; }
      .shift-grid { grid-template-columns: 1fr; gap: 1rem; }
      .programme-spec { grid-template-columns: 1fr; }
      .bundle-grid { grid-template-columns: 1fr; gap: 1.5rem; }
      .after-grid { grid-template-columns: 1fr; gap: 1rem; }
      .example-content { grid-template-columns: 1fr; gap: 2rem; }
    }
    @media (max-width: 768px) {
      .deck-slide { padding: 3rem 2rem; }
    }
  </style>
</head>
<body class="card-deck-page">

  <!-- Progress rail -->
  <div class="progress-rail" id="rail">
    {slides.map((_, i) => <div class="progress-dot" data-idx={i}></div>)}
  </div>

  <!-- Keyboard hint -->
  <div class="kbd-hint" id="kbd-hint">
    <kbd>←</kbd> <kbd>→</kbd> navigate · <kbd>space</kbd> next · <kbd>n</kbd> presenter notes
  </div>

  <!-- Deck -->
  <div class="card-deck-container" id="deck">

    <!-- ═══ 01 · Cover ═══ -->
    <section class="card-deck-card deck-slide slide-cover" data-slide="cover">
      <div class="stagger">
        <h1 class="wordmark">Cultivated <span class="ai">AI</span></h1>
        <p class="verb-pair"><span class="grow">Grow</span>, don't <span class="chase">Chase</span>.</p>
        <p class="firm">A discipline by Ocre Labs</p>
      </div>
      <div class="brand-mark">Cultivated AI · <span class="b-grow">Grow, don't Chase.</span></div>
      <div class="slide-num">01 · Cover</div>
    </section>

    <!-- ═══ 02 · Thesis ═══ -->
    <section class="card-deck-card deck-slide slide-thesis" data-slide="thesis">
      <div class="thesis-content stagger">
        <span class="thesis-eyebrow caveat">The line we want you to remember</span>
        <h1 class="thesis-headline">AI adoption is a <span class="pipeline">pipeline</span> problem.</h1>
        <p class="thesis-body">For twenty years Shalin has built the production pipelines behind the world's biggest entertainment products at <em>Pixar, EA, Lumosity, and Masala Games</em>. And what he has learnt is that resilient pipelines are built by cultivating the approach, not chasing technology.</p>
        <p class="thesis-credit">— Shalin Shodhan · Ocre Labs</p>
      </div>
      <div class="brand-mark">Cultivated AI · <span class="b-grow">Grow, don't Chase.</span></div>
      <div class="slide-num">02 · Thesis</div>
    </section>

    <!-- ═══ 03 · About ═══ -->
    <section class="card-deck-card deck-slide slide-about" data-slide="about">
      <div class="about-grid stagger">
        <div>
