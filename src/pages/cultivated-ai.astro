  <script is:inline>
    // ════════════════════════════════════════════════════════
    // Deck behavior: keyboard nav + active slide tracking
    // Modeled on /workshop-day1.
    // ════════════════════════════════════════════════════════
    (function() {
      const deck = document.getElementById('deck');
      const slides = Array.from(deck.querySelectorAll('.deck-slide'));
      const dots = Array.from(document.querySelectorAll('.progress-dot'));
      const kbdHint = document.getElementById('kbd-hint');
      let current = 0;
      let scrolling = false;

      // ─── Presenter sync ───
      let channel = null;
      try { channel = new BroadcastChannel('cultivated-ai'); } catch (e) {}

      function broadcastSlide(idx) {
        if (channel) channel.postMessage({ type: 'slide', index: idx });
      }
      if (channel) {
        channel.addEventListener('message', (ev) => {
          if (ev.data && ev.data.type === 'goto' && typeof ev.data.index === 'number') {
            goTo(ev.data.index);
          }
          if (ev.data && ev.data.type === 'request-state') {
            broadcastSlide(current);
          }
        });
        setInterval(() => { if (channel) channel.postMessage({ type: 'ping' }); }, 1500);
      }

      function goTo(idx) {
        idx = Math.max(0, Math.min(slides.length - 1, idx));
        if (idx === current) return;
        scrolling = true;
        slides[idx].scrollIntoView({ behavior: 'smooth' });
        setTimeout(() => { scrolling = false; }, 700);
      }

      function updateActive(idx) {
        slides.forEach((s, i) => s.classList.toggle('is-active', i === idx));
        dots.forEach((d, i) => {
          d.classList.toggle('active', i === idx);
          d.classList.toggle('visited', i < idx);
        });
        current = idx;
        broadcastSlide(idx);
      }

      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && entry.intersectionRatio > 0.5) {
            const idx = slides.indexOf(entry.target);
            if (idx !== -1 && idx !== current) updateActive(idx);
          }
        });
      }, { threshold: [0.5, 0.75, 1] });

      slides.forEach((s) => io.observe(s));

      let hintHidden = false;
      document.addEventListener('keydown', (e) => {
        if (!hintHidden) {
          kbdHint.classList.add('hidden');
          hintHidden = true;
        }
        switch (e.key) {
          case 'ArrowRight':
          case 'ArrowDown':
          case 'PageDown':
          case ' ':
            e.preventDefault();
            goTo(current + 1);
            break;
          case 'ArrowLeft':
          case 'ArrowUp':
          case 'PageUp':
            e.preventDefault();
            goTo(current - 1);
            break;
          case 'Home':
            e.preventDefault();
            goTo(0);
            break;
          case 'End':
            e.preventDefault();
            goTo(slides.length - 1);
            break;
          case 'n':
          case 'N':
            e.preventDefault();
            window.open('/cultivated-ai/presenter', 'presenter', 'width=1100,height=800,menubar=no,toolbar=no,location=no');
            break;
        }
      });

      dots.forEach((d, i) => {
        d.style.cursor = 'pointer';
        d.addEventListener('click', () => goTo(i));
      });

      document.addEventListener('click', (e) => {
        if (e.target.closest('a, button, input, .progress-dot')) return;
        if (scrolling) return;
        const x = e.clientX;
        const w = window.innerWidth;
        if (x > w * 0.7) goTo(current + 1);
        else if (x < w * 0.3) goTo(current - 1);
      });

      updateActive(0);
    })();
  </script>
</body>
