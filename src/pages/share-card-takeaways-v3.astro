    <div style="width: 6px; height: 6px; border-radius: 50%; background: #D4A574; opacity: 0.80;"></div>
    <div style="width: 6px; height: 6px; border-radius: 50%; background: #D4A574; opacity: 0.80;"></div>
    <div style="width: 50px; height: 1px; background: rgba(245, 238, 223, 0.35);"></div>
  </div>

  <!-- Sessions — compressed to fit -->
  <div class="el" style="top: 680px; left: 60px; width: 960px;">
    <div style="display: flex; align-items: center; gap: 22px; margin-bottom: 20px;">
      <span style="font-family: 'JetBrains Mono', monospace; font-size: 24px; font-weight: 600; color: #D4A574; letter-spacing: 4px;">APRIL 20</span>
      <div style="flex: 1; height: 1px; background: linear-gradient(to right, rgba(212, 165, 116, 0.40) 0%, rgba(212, 165, 116, 0) 100%);"></div>
    </div>
    <div style="font-family: 'Playfair Display', Georgia, serif; font-size: 56px; font-weight: 600; line-height: 1.12; color: #F5EEDF; letter-spacing: -1.2px; white-space: nowrap;">
      <em style="font-style: italic; color: #F5EEDF; font-weight: 500;">Great answers</em> from AI.
    </div>
  </div>

  <div class="el" style="top: 880px; left: 60px; width: 960px;">
    <div style="display: flex; align-items: center; gap: 22px; margin-bottom: 20px;">
      <span style="font-family: 'JetBrains Mono', monospace; font-size: 24px; font-weight: 600; color: #D4A574; letter-spacing: 4px;">APRIL 22</span>
      <div style="flex: 1; height: 1px; background: linear-gradient(to right, rgba(212, 165, 116, 0.40) 0%, rgba(212, 165, 116, 0) 100%);"></div>
