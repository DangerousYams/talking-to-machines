<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Workshop Takeaways v3</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,400;1,500;1,600&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    astro-dev-toolbar { display: none !important; }
    body { width: 1080px; height: 1350px; overflow: hidden; background: #0B0E16; }
    .canvas { position: relative; width: 1080px; height: 1350px; overflow: hidden; }
    .el { position: absolute; }
  </style>
</head>
<body>
<div class="canvas">

  <div class="el" style="top: -250px; left: 50%; transform: translateX(-50%); width: 1200px; height: 1000px; border-radius: 50%; background: radial-gradient(circle, rgba(233, 69, 96, 0.10) 0%, rgba(233, 69, 96, 0) 55%); pointer-events: none;"></div>
