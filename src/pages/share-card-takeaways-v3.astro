    <span style="font-family: 'Playfair Display', Georgia, serif; font-weight: 700; font-size: 76px; line-height: 1.0; color: #F5EEDF; letter-spacing: -1.5px;">
      Shalin Shodhan
    </span>
  </div>

  <!-- Bio line -->
  <div class="el" style="top: 490px; left: 80px; width: 920px; text-align: center;">
    <span style="font-family: 'Source Serif 4', Georgia, serif; font-style: italic; font-weight: 400; font-size: 24px; line-height: 1.45; color: #F5EEDF; opacity: 0.72;">
      Author of the first interactive AI curriculum,
      <em style="font-style: italic; color: #FF6B85; opacity: 0.95;">Talking to Machines.</em>
