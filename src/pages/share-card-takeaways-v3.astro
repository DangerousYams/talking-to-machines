    <line x1="60" y1="1060" x2="190" y2="1170" stroke="#E94560" stroke-width="1" opacity="0.18"/>
    <line x1="1040" y1="1050" x2="900" y2="1160" stroke="#F5A623" stroke-width="1" opacity="0.18"/>
    <line x1="190" y1="1170" x2="110" y2="1280" stroke="#16C79A" stroke-width="1" opacity="0.16"/>
    <line x1="900" y1="1160" x2="1000" y2="1280" stroke="#E94560" stroke-width="1" opacity="0.16"/>
    <circle cx="55" cy="25" r="3" fill="#E94560" opacity="0.42"/>
    <circle cx="200" cy="60" r="5" fill="#F5A623" opacity="0.36"/>
    <circle cx="850" cy="35" r="5" fill="#16C79A" opacity="0.36"/>
    <circle cx="1010" cy="80" r="3" fill="#E94560" opacity="0.42"/>
