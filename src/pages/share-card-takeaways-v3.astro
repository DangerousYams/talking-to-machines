    <line x1="55" y1="25" x2="200" y2="60" stroke="#E94560" stroke-width="1" opacity="0.18"/>
    <line x1="200" y1="60" x2="130" y2="155" stroke="#F5A623" stroke-width="1" opacity="0.16"/>
    <line x1="850" y1="35" x2="1010" y2="80" stroke="#16C79A" stroke-width="1" opacity="0.18"/>
