    <circle cx="1000" cy="1280" r="3" fill="#16C79A" opacity="0.40"/>
  </svg>

  <!-- Photo -->
  <div class="el" style="top: 100px; left: 50%; transform: translateX(-50%);">
    <img src="/images/shalin.png" alt="Shalin Shodhan" width="220" height="220" style="border-radius: 50%; object-fit: cover; border: 2px solid rgba(255, 107, 133, 0.35); box-shadow: 0 0 50px rgba(233, 69, 96, 0.15);" />
  </div>

  <!-- Eyebrow "Learn from" -->
  <div class="el" style="top: 345px; left: 0; width: 1080px; text-align: center;">
