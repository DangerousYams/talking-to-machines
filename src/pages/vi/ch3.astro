---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ContextWindowViz from '../../components/widgets/ch3/ContextWindowViz';
import VibeCheck from '../../components/breaks/VibeCheck';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[2];
---

<ChapterLayout chapter={chapter} locale="vi">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>3</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Chương ba
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Context<br />Engineering
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          AI không quên &mdash; ngay từ đầu<br />nó chẳng hề nhớ gì cả.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Mỗi lần bạn gửi tin nhắn cho AI, nó đọc <em>toàn bộ cuộc trò chuyện</em> từ đầu &mdash; mọi tin nhắn bạn gửi, mọi câu trả lời nó đưa ra &mdash; tạo phản hồi, rồi quên hết. Lượt tiếp theo, lặp lại y chang. Toàn bộ bản ghi được nạp vào lần nữa. Nó là độc giả siêng năng nhất nhưng mất trí nhớ nhất thế giới: đọc kỹ từng lần, bắt đầu từ số không mỗi lượt.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONCEPT SETUP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Cửa sổ có giới hạn
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10" style="margin-top: 0;">
        Bản ghi mà AI đọc lại mỗi lượt nằm trong thứ gọi là <strong>cửa sổ ngữ cảnh</strong> &mdash; đo bằng <strong>token</strong> (khoảng một token cho ba phần tư từ). Cửa sổ của Claude chứa khoảng 200.000 token &mdash; tương đương một cuốn sách 500 trang. Nghe có vẻ nhiều, nhưng mỗi tin nhắn bạn gửi, mỗi câu trả lời bạn nhận, và mọi hướng dẫn hệ thống ẩn đều ăn vào cùng một ngân sách. Nó đầy nhanh hơn bạn nghĩ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Khi ngân sách hết, những tin nhắn cũ nhất rơi khỏi mép cửa sổ. Bạn nhắc đến chế độ ăn kiêng ở tin nhắn thứ ba? Đến tin nhắn thứ mười lăm, AI có thể không còn nhìn thấy nó nữa. Nó không cẩu thả &mdash; nó đúng là không thể nhìn thấy thứ không còn trước mắt. AI chỉ giỏi bằng thông tin hiện có trong cửa sổ của nó.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Đây là lý do những người dùng AI giỏi nhất không chỉ viết prompt hay &mdash; họ quản lý những gì đi <em>vào</em> cửa sổ. Tóm tắt định kỳ để giữ chi tiết quan trọng luôn hiển thị. Đặt thứ quan trọng lên đầu. Bắt đầu cuộc trò chuyện mới khi chủ đề thay đổi. Dùng định dạng có cấu trúc để AI phân tích ngữ cảnh hiệu quả hơn. <strong>Context engineering là prompt engineering thế hệ mới.</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Điểm mấu chốt</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Viết prompt hay là bước một. Quyết định đưa thông tin gì vào trước mắt AI &mdash; và cấu trúc nó như thế nào &mdash; mới là nơi tạo ra đòn bẩy thực sự. Prompt hay nhất thế giới cũng thất bại nếu ngữ cảnh sai.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Xem cửa sổ ngữ cảnh đầy lên, tràn ra, và quên &mdash; theo thời gian thực.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ContextWindowViz client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="Cuối cùng cũng hiểu vì sao AI 'quên' mọi thứ giữa cuộc trò chuyện. Không phải bộ nhớ — mà là cửa sổ ngữ cảnh. Khóa học này giải thích cực kỳ rõ ràng với demo trực tiếp." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Giờ bạn đã nhìn thấy tấm bảng trắng. Bạn cảm nhận được mép cửa sổ. Điều đó thay đổi mọi cuộc trò chuyện của bạn với AI.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Đến giờ ta mới làm việc với chatbot. Tiếp theo, ta sẽ phóng tầm nhìn ra &mdash; hàng trăm công cụ AI tồn tại ngoài cửa sổ chat, và biết toàn cảnh sẽ thay đổi những gì bạn nghĩ là có thể.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Vibe Check" client:visible>
        <VibeCheck client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
