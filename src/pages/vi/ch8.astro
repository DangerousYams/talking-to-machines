---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import ProjectOrchestrator from '../../components/widgets/ch8/ProjectOrchestrator';
import ContextPacking from '../../components/widgets/ch8/ContextPacking';

const chapter = chapters[7];
---

<ChapterLayout chapter={chapter} locale="vi">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>8</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Chương Tám
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Điều phối<br />sự phức tạp
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Quản lý AI trong các dự án lớn hơn<br />bất kỳ context window nào.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        Đây là khoảnh khắc mà mọi người mới bắt đầu đầy tham vọng đều gặp phải: bạn yêu cầu AI xây dựng thứ gì đó thật sự — một game hoàn chỉnh, một website có backend, một bài nghiên cứu có trích dẫn — và mọi thứ sụp đổ. Không phải vì AI không đủ thông minh. Mà vì dự án quá lớn cho một cuộc hội thoại đơn lẻ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        Bạn paste một bức tường yêu cầu vào, AI đưa ra câu trả lời nghe rất tự tin, và hai mươi phút sau bạn nhận ra nó quên một nửa những gì bạn yêu cầu, tự mâu thuẫn về kiến trúc, và hallucinate một thư viện không tồn tại. Bạn thử lại. Kết quả tương tự, hallucination khác.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        Đây không phải vấn đề của AI. Đây là vấn đề <strong>điều phối</strong>. Và học cách giải quyết nó là sự khác biệt giữa người dùng AI cho các tác vụ lẻ tẻ và người dùng nó để xây dựng thứ thật sự.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE ONE-PROMPT TRAP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Cái bẫy một-prompt
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Khi bạn mới học dùng AI, bạn tự nhiên cố làm mọi thứ trong một lần. Một prompt khổng lồ. Một cuộc hội thoại. Một lần thử. Và cho các tác vụ đơn giản — viết email, brainstorm ý tưởng, giải thích một khái niệm — điều đó hoạt động tốt.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Nhưng sự phức tạp phá vỡ cách tiếp cận một-prompt theo ba cách:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 2.5rem;">
        {[
          { num: '1', title: 'Tràn context', text: 'AI chỉ có thể giữ một lượng thông tin nhất định cùng lúc. Một dự án hoàn chỉnh vượt quá giới hạn đó, nên AI bắt đầu "quên" các yêu cầu trước đó của bạn.' },
          { num: '2', title: 'Phân tán sự chú ý', text: 'Ngay cả trong context window, yêu cầu AI xử lý cùng lúc mười hai vấn đề khác nhau có nghĩa là mỗi vấn đề nhận được ít sự tập trung hơn. Chất lượng giảm toàn diện.' },
          { num: '3', title: 'Lỗi chồng lỗi', text: 'Một sai lầm nhỏ trong output phức tạp sẽ lan rộng. Nếu AI thiết kế sai database schema, mọi thứ xây trên schema đó đều sai — và rất khó phát hiện khi chìm trong một bức tường code được tạo ra.' },
        ].map((item, i) => (
          <FadeInBlock client:visible delay={0.2 + i * 0.08}>
            <div style="display: flex; gap: 1.25rem; align-items: flex-start;">
              <div style={`flex-shrink: 0; width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 0.8rem; font-weight: 700; color: white; background: ${chapter.accent};`}>
                {item.num}
              </div>
              <div style="flex: 1;">
                <p style={`font-family: var(--font-heading); font-size: 1rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.3rem; line-height: 1.3;`}>
                  {item.title}
                </p>
                <p style="font-size: 0.95rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                  {item.text}
                </p>
              </div>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.5}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        Giải pháp không phải là một prompt tốt hơn. Mà là một quy trình tốt hơn.
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ DECOMPOSITION: THE MASTER SKILL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Phân rã: kỹ năng bậc thầy
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Các lập trình viên chuyên nghiệp không xây dựng toàn bộ ứng dụng trong một lần ngồi. Họ chia chúng thành các phần — module, component, function — mỗi phần có mục đích rõ ràng, đầu vào rõ ràng, và đầu ra rõ ràng. Sau đó họ lắp ráp chúng lại.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Làm việc với AI trong các dự án phức tạp đòi hỏi cùng một kỷ luật. Bạn cần <strong>phân rã</strong> dự án thành các tác vụ đủ nhỏ để một cuộc hội thoại AI tập trung duy nhất có thể xử lý tốt.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        Phân rã tốt tuân theo ba quy tắc:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
        <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
        {[
          { word: 'Trách nhiệm đơn lẻ.', desc: 'Mỗi tác vụ làm một việc. "Thiết kế database VÀ xây API VÀ viết frontend" là ba tác vụ, không phải một.' },
          { word: 'Giao diện rõ ràng.', desc: 'Mỗi tác vụ có đầu vào được định nghĩa (cái nó cần để bắt đầu) và đầu ra được định nghĩa (cái nó tạo ra). Đầu ra của tác vụ này trở thành đầu vào của tác vụ kế tiếp.' },
          { word: 'Phụ thuộc tối thiểu.', desc: 'Các tác vụ có thể làm song song thì nên làm song song. Chỉ tạo phụ thuộc khi một tác vụ thực sự cần đầu ra của tác vụ khác.' },
        ].map((step, i) => (
          <div style={`position: relative; padding-bottom: ${i < 2 ? '1.75rem' : '0'};`}>
            <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
            <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
              <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
              <span style="opacity: 0.7;"> {step.desc}</span>
            </p>
          </div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Phân rã là kỹ năng của con người, không phải kỹ năng của AI.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI có thể giúp bạn brainstorm cách phân chia công việc, nhưng quyết định chia công việc như thế nào, cái gì phụ thuộc vào cái gì, và ưu tiên cái gì — đó là việc của bạn. Đó là quản lý dự án, và đó là một trong những kỹ năng giá trị nhất bạn có thể phát triển.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO PROJECT ORCHESTRATOR -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Thử phân rã một dự án thực tế. Kéo các tác vụ, theo dõi phụ thuộc, xem kế hoạch hình thành.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: PROJECT ORCHESTRATOR ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ProjectOrchestrator client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE HANDOFF PATTERN ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Mô hình chuyển giao
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Khi bạn đã chia dự án thành các tác vụ, bạn cần cách kết nối chúng. Trong quy trình AI, kết nối này là <strong>chuyển giao</strong> — khoảnh khắc đầu ra của một cuộc hội thoại trở thành đầu vào của cuộc hội thoại kế tiếp.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: var(--color-navy);">
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Mô hình chuyển giao</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          Cuộc hội thoại 1 tạo ra một <strong>artifact</strong> — một tài liệu, một schema, một kế hoạch.<br />
          Artifact đó được paste vào Cuộc hội thoại 2 như <strong>context</strong>.<br />
          Cuộc hội thoại 2 xây dựng trên đó và tạo ra artifact tiếp theo.<br />
          Lặp lại cho đến khi dự án hoàn thành.
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        Hãy nghĩ nó như một cuộc chạy tiếp sức. Mỗi vận động viên (cuộc hội thoại) chạy phần của mình và chuyển gậy tiếp sức (artifact) cho người kế tiếp. Cây gậy là phần quan trọng nhất — nếu nó bị rơi hoặc méo mó, người chạy kế tiếp sẽ vấp.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        Điều này có nghĩa là các artifact chuyển giao của bạn cần phải <em>sắc nét</em>. Một database schema là bản chuyển giao tốt hơn so với một mô tả mơ hồ về data model. Một danh sách đánh số các API endpoint tốt hơn so với "tôi cần một backend xử lý mấy thứ của user." Artifact càng sắc nét, cuộc hội thoại tiếp theo hoạt động càng tốt.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        Chất lượng artifact chuyển giao quyết định chất lượng mọi thứ được xây dựng phía sau. Rác vào, rác ra — xuyên suốt các cuộc hội thoại.
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONTEXT PACKING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Nghệ thuật đóng gói context
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Mỗi lần bạn bắt đầu một cuộc hội thoại AI mới, bạn đang đưa ra một quyết định mà hầu hết mọi người thậm chí không nhận ra: <strong>bạn đưa vào context nào?</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Bạn có một ngân sách giới hạn — context window. Và bạn có một đống thông tin có thể liên quan: file code, tài liệu, các cuộc hội thoại trước, log lỗi, bản thiết kế. Không phải tất cả đều vừa. Và ngay cả nếu vừa, đổ hết mọi thứ vào sẽ pha loãng sự chú ý của AI.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        Đóng gói context giống như xếp vali cho chuyến đi. Bạn không thể mang cả tủ quần áo. Bạn cần nghĩ về nơi bạn đến (tác vụ), thứ bạn sẽ cần (thông tin liên quan), và thứ bạn có thể bỏ lại (mọi thứ khác).
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div style="display: flex; flex-direction: column; gap: 1.25rem; margin-bottom: 2.5rem;">
        {[
          { label: 'Quá ít context', color: '#E94560', text: 'AI không có cái nó cần và lấp đầy khoảng trống bằng hallucination. Nó nghe tự tin nhưng bịa ra chi tiết.' },
          { label: 'Quá nhiều context', color: '#F5A623', text: 'AI bị quá tải. Các chi tiết quan trọng bị mất trong đống nhiễu. Output trở nên chung chung và không tập trung.' },
          { label: 'Context vừa đủ', color: '#16C79A', text: 'AI có chính xác cái nó cần cho tác vụ cụ thể này. Output chính xác, liên quan, và có thể hành động.' },
        ].map((item, i) => (
          <FadeInBlock client:visible delay={0.25 + i * 0.08}>
            <div style={`padding: 1rem 1.25rem; border-radius: 10px; border-left: 3px solid ${item.color}; background: ${item.color}08;`}>
              <p style={`font-family: var(--font-heading); font-size: 0.9rem; font-weight: 700; color: ${item.color}; margin: 0 0 0.25rem;`}>
                {item.label}
              </p>
              <p style="font-size: 0.9rem; line-height: 1.7; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {item.text}
              </p>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Hãy nghĩ như biên tập viên, không phải người tích trữ.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Trước mỗi lần tương tác với AI, hãy tự hỏi: AI <em>cần biết gì</em> để làm tác vụ cụ thể này? Đưa cái đó vào. Bỏ hết mọi thứ khác. Đây là context engineering ứng dụng vào quản lý dự án.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO CONTEXT PACKING -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Đóng gói một chiếc vali context. Bạn có thể nhét vừa thứ quan trọng mà không bị tràn không?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: CONTEXT PACKING ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ContextPacking client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ VERSION CONTROL FOR AI WORK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Theo dõi những gì hiệu quả
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
