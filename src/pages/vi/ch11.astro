---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ProjectInstructionsBuilder from '../../components/widgets/ch11/ProjectInstructionsBuilder';

const chapter = chapters[10];
---

<ChapterLayout chapter={chapter} locale="vi">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>11</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Chương mười một
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Xây dựng<br />thứ thật
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Kiến thức mà không sáng tạo chỉ là phù phiếm.<br />Đã đến lúc ship.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Bạn đã đến đích. Qua mười chương, bạn đi từ "giúp mình viết bài luận" đến thiết kế context, xây dựng agent, và debug hallucination. Bạn đã học về AI nhiều hơn hầu hết người lớn. Nhưng đây là sự thật khó chịu: <strong>không gì trong số đó có ý nghĩa cho đến khi bạn xây thứ gì đó.</strong> Đọc về AI giống như đọc về bơi lội — bạn có thể nghiên cứu mọi kỹ thuật, nhưng cho đến khi nhảy xuống nước, bạn không <em>biết</em> gì cả. Bạn chỉ biết <em>về</em> nó.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ SET UP YOUR AI ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Thiết lập AI của bạn
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Trước khi viết prompt đầu tiên, có một nước đi mạnh mà đa số người mới bỏ qua: <strong>cho công cụ AI của bạn một file chỉ thị vĩnh viễn.</strong> Thay vì giải thích lại dự án mỗi phiên, bạn viết một lần và AI tự đọc. Claude Code đọc <code>CLAUDE.md</code>. Cursor đọc <code>.cursorrules</code>. GitHub Copilot đọc <code>.github/copilot-instructions.md</code>. Cùng khái niệm, khác tên file. Đây là context engineering từ Chương 3 — áp dụng ở cấp dự án.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Một file chỉ thị tốt trả lời ba câu hỏi: bạn đang xây gì, luật chơi là gì, và "tốt" trông như thế nào? Làm đúng ba điều đó và mọi cuộc trò chuyện với AI bắt đầu đi trước mười bước. Giới hạn phạm vi dự án đủ nhỏ để hoàn thành — một dự án cuối tuần hoàn chỉnh luôn thắng một kiệt tác bị bỏ dở.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style="font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;">Điểm mấu chốt</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Một file chỉ thị dự án tốt là sự khác biệt giữa AI giúp bạn và AI <em>hiểu</em> bạn. Viết một lần, hưởng lợi mỗi phiên.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Xây file chỉ thị dự án ngay tại đây. Điền các phần và xuất ra cho công cụ AI bạn chọn.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="project-instructions-builder" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ProjectInstructionsBuilder client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Công cụ không xây thứ gì. Con người với công cụ mới xây thứ gì đó. Và bạn đang có bộ công cụ tốt nhất mà thế hệ bạn từng được tiếp cận.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto mb-8" style="max-width: 55ch;">
        Mười một chương trước, bạn gõ "giúp mình viết bài luận" và hy vọng vào điều tốt nhất. Giờ bạn thiết kế context, xây dựng agent, kiểm chứng output, và mang phán đoán đến mọi bước. Khóa học kết thúc rồi. Việc học thật sự bắt đầu từ bây giờ — hãy tạo ra thứ mà chỉ bạn mới nghĩ ra.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-center mt-4" style={`font-family: var(--font-heading); font-size: 1.8rem; font-weight: 800; color: ${chapter.accent}; letter-spacing: -0.02em;`}>
        Ship nó.
      </p>
    </FadeInBlock>
  </section>

</ChapterLayout>
