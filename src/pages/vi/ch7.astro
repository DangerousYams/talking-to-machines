---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import WhatWouldYouBuild from '../../components/widgets/ch7/WhatWouldYouBuild';
import ShipIt from '../../components/breaks/ShipIt';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';
import ForYouCard from '../../components/ui/ForYouCard';

const chapter = chapters[6];
const conceptsSummary = chapter.concepts.map(c => c.name).join(', ');
---

<ChapterLayout chapter={chapter} locale="vi">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>7</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Chương bảy
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Ai cũng có thể<br />xây được
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Bạn không cần là lập trình viên.<br />Bạn cần một ý tưởng.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Một giáo viên ở Ohio xây ứng dụng chấm bài trong một cuối tuần. Một nhạc sĩ xây trình tối ưu setlist, sắp xếp bài hát theo năng lượng và tông nhạc. Một học sinh cấp ba xây công cụ chuẩn bị tranh biện, tự động tạo phản biện cho mọi luận đề. Không ai trong số họ là lập trình viên. Không ai từng học lớp code. Họ mô tả thứ mình muốn, và coding agent xây nó.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        Đây là bước đột phá không ai ngờ tới. Không phải coder nhanh hơn &mdash; mà là <strong>người không biết code cũng có thể xây phần mềm.</strong> Giống như spreadsheet dân chủ hóa phân tích dữ liệu và Canva dân chủ hóa thiết kế đồ họa, AI coding agent đang dân chủ hóa chính việc phát triển phần mềm.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ PERSONAL SOFTWARE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Cuộc cách mạng phần mềm cá nhân
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Đây là ý tưởng thay đổi tất cả: <strong>phần mềm cá nhân.</strong> Công cụ được xây cho đối tượng duy nhất là một người &mdash; bạn. Không cần nghiên cứu thị trường, không cần kế hoạch kinh doanh, không cần vốn đầu tư. Chỉ cần một vấn đề bạn gặp và một công cụ giải quyết nó. Trước AI, xây phần mềm cá nhân nghĩa là phải học code, mất hàng tháng hay hàng năm. Giờ chỉ mất một buổi chiều. Chi phí xây dựng vừa giảm xuống gần bằng không &mdash; nghĩa là thứ duy nhất còn quan trọng là có ý tưởng đáng xây.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Những công cụ làm điều này khả thi gọi là <strong>coding agent</strong>. Claude Code, Cursor, Antigravity, Replit &mdash; đây là các công cụ AI có thể đọc toàn bộ dự án, viết code xuyên nhiều file, chạy nó, gặp lỗi, sửa lỗi, rồi chạy lại. Tất cả mà bạn không chạm vào một dòng code. Chúng không phải autocomplete. Chúng là cộng tác viên AI biến mô tả của bạn thành phần mềm hoạt động.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Vai trò đạo diễn</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Bạn không viết code. Bạn <strong>đạo diễn</strong>. Nhiệm vụ của bạn là chỉ rõ cần xây gì, đánh giá kết quả, và lặp lại cho đến khi đúng. Agent lo phần kỹ thuật. Hãy nghĩ mình như đạo diễn phim &mdash; bạn không vận hành máy quay, nhưng không có tầm nhìn của bạn thì chẳng có gì được tạo ra.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE AGENT AS GUIDE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Agent biết mọi thứ bạn chưa biết
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        "Nhưng mình không biết database là gì." Tin vui: bạn không cần biết. Coding agent cũng là gia sư. Hỏi nó bất cứ gì. "React component là gì?" Nó sẽ giải thích. "Làm sao deploy lên internet?" Nó sẽ hướng dẫn từng bước. "Lỗi này nghĩa là gì?" Nó sẽ dịch thuật ngữ sang tiếng Việt bình thường.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Đây là lưới an toàn giúp mọi thứ khác khả thi. Bạn không cần thuộc lòng thuật ngữ kỹ thuật &mdash; bạn cần biết nó <em>tồn tại</em> để có thể hỏi về nó. Agent lấp đầy mọi khoảng trống. Giống như có một chuyên gia kiên nhẫn, không mệt mỏi ngồi cạnh bạn, không bao giờ phán xét bạn vì hỏi câu hỏi cơ bản.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Nghịch lý kỹ năng</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Bạn cần đủ kiến thức để <em>đánh giá</em> kết quả, không phải để viết từng dòng. Đạo diễn phim không cần biết cách chế tạo máy quay &mdash; nhưng cần biết cảnh quay có đẹp không. Ở đây cũng vậy: bạn cần biết ứng dụng có hoạt động không, chứ không cần biết code chạy như thế nào.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Xem những người không biết code đã xây gì &mdash; rồi tưởng tượng ý tưởng của riêng bạn.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="what-would-you-build" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <WhatWouldYouBuild client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <div class="py-8">
    <ForYouCard
      chapterSlug={chapter.slug}
      chapterTitle={chapter.title}
      chapterConcepts={conceptsSummary}
      accentColor={chapter.accent}
      client:load
    />
  </div>
  <SharePrompt text="Chương này thuyết phục mình rằng ai cũng có thể xây phần mềm với AI. Không phải kiểu nói chung chung — nó cho thấy chính xác người không biết code đang xây công cụ thật như thế nào." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Chi phí xây phần mềm vừa giảm xuống bằng không. Thứ duy nhất còn lại là có ý tưởng đáng xây.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Bạn có ý tưởng rồi. Nhưng trước khi mở coding agent, bạn cần nói ngôn ngữ của nó. Không phải code &mdash; chỉ là từ vựng của việc xây dựng. Phần tiếp theo.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Ship It" client:visible>
        <ShipIt client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
