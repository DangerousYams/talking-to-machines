---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import WhatWouldYouBuild from '../../components/widgets/ch7/WhatWouldYouBuild';
import ShipIt from '../../components/breaks/ShipIt';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[6];
---

<ChapterLayout chapter={chapter} locale="vi">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>7</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Chương bảy
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Thành thạo<br />Claude Code
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Đồng đội lập trình AI của bạn, từ lệnh<br />đầu tiên đến Skill tùy chỉnh.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Có một khoảnh khắc mà mọi lập trình viên đều nhớ. Bạn mở terminal, gõ yêu cầu bằng ngôn ngữ tự nhiên, và xem AI đọc file, hiểu kiến trúc, viết code xuyên nhiều file, chạy thử, gặp lỗi, sửa lỗi, và chạy lại — tất cả mà bạn không chạm vào một dòng nào. Claude Code không phải autocomplete. Nó là công cụ lập trình <em>agentic</em> có thể thấy toàn bộ dự án, thay đổi xuyên file, chạy lệnh shell, và tự sửa lỗi.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        Tuy nhiên, công cụ chỉ giỏi bằng người điều khiển. Claude Code có thể viết một nghìn dòng code hoàn hảo trong vài giây — hoặc một nghìn dòng rác trông hợp lý. Sự khác biệt là bạn.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE LOOP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Chỉ định, tạo, kiểm tra
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Khi bạn giao nhiệm vụ cho Claude Code, nó chạy agent loop: đọc codebase, lên kế hoạch thay đổi, viết sửa đổi, chạy code, sửa lỗi. Nó có thể lặp qua vòng đó ba, năm, mười lần — tất cả trong vài giây. Vai trò của bạn không còn là viết mọi dòng nữa. Mà là <strong>chỉ định</strong> cần xây gì, để AI <strong>tạo</strong> ra, rồi <strong>kiểm tra</strong> xem nó có thực sự đúng không. Đa số người mới bỏ qua bước cuối. Họ thấy code xuất hiện, trông hợp lý, rồi chuyển sang việc khác. Đừng như vậy. Code được tạo tự động là bản nháp đầu tiên. Việc kiểm tra của bạn mới là lần chỉnh sửa biến nó thành thứ xuất bản được.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Vũ khí bí mật là file <code>CLAUDE.md</code> — đặt nó ở thư mục gốc dự án và Claude Code đọc nó ngay đầu mỗi phiên làm việc. Tech stack, quy ước đặt tên, quy tắc phong cách, yêu cầu test — tất cả được mã hóa một lần để bạn không bao giờ phải lặp lại. Đó là context engineering áp dụng cho lập trình.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Mục tiêu không phải viết mọi dòng — mà là hiểu mọi dòng.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Nếu bạn không đọc được code Claude tạo ra, bạn không kiểm tra được nó. Người dùng Claude Code giỏi nhất không phải người tạo nhiều code nhất — họ là người đặt câu hỏi hay nhất và bắt lỗi tinh tế nhất.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Xem vòng lặp hoạt động. Gõ yêu cầu và xem Claude Code làm việc.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="terminal-playground" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <WhatWouldYouBuild client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="Chương về Claude Code này thật kinh ngạc — xem AI pair programmer suy nghĩ qua vấn đề, viết code, và tự debug. Tương lai lập trình đã ở đây." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Claude Code không viết code thay bạn — nó viết code cùng bạn.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Một cuộc trò chuyện xử lý được một nhiệm vụ. Nhưng dự án thực có hàng chục. Tiếp theo: cách chia tham vọng lớn thành mảnh AI có thể thực hiện.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Ship It" client:visible>
        <ShipIt client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
