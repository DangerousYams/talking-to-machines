---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import TrustThermometer from '../../components/widgets/ch5/TrustThermometer';
import WouldYouLetIt from '../../components/breaks/WouldYouLetIt';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';
import ForYouCard from '../../components/ui/ForYouCard';

const chapter = chapters[4];
const conceptsSummary = chapter.concepts.map(c => c.name).join(', ');
---

<ChapterLayout chapter={chapter} locale="vi">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>5</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Chương năm
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Trao cho nó<br />công cụ
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Bước nhảy từ "trả lời câu hỏi"<br />sang "thực hiện hành động."
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0; --drop-cap-color: #F5A623;">
        Cho đến giờ, mọi tương tác AI của bạn đều theo cùng một khuôn mẫu. Bạn gõ gì đó. AI gõ lại. Một autocomplete cực kỳ tinh vi. Nhưng nếu AI có thể <em>làm</em> mọi thứ thì sao? Không chỉ kể về thời tiết, mà thực sự kiểm tra dự báo. Không chỉ viết code, mà chạy nó. Không chỉ gợi ý nên Google gì, mà tự tìm kiếm web và mang về những gì tìm được.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE TRUST QUESTION ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Câu hỏi về niềm tin
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Khi bạn trao cho AI công cụ, bạn đưa cho nó hộp đồ nghề và nói: <em>"Đây là những gì bạn có thể làm. Bạn tự quyết khi nào dùng."</em> Nó có thể tìm kiếm web, chạy code, đọc file, gọi API. AI không thông minh hơn — nó được <strong>kết nối</strong>. Và điều đó đặt ra một câu hỏi chẳng liên quan gì đến công nghệ mà hoàn toàn liên quan đến bạn: AI nên tự làm bao nhiêu trước khi hỏi ý kiến bạn?
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-14">
        Câu trả lời phụ thuộc vào ba yếu tố. <strong>Mức độ nghiêm trọng</strong> — tệ nhất có thể xảy ra là gì? <strong>Khả năng hoàn tác</strong> — bạn có thể undo không? Và <strong>niềm tin</strong> — bạn biết công cụ này tốt cỡ nào? Máy tính bỏ túi bạn đã dùng cả trăm lần xứng đáng được tự do hơn plugin mới toanh chưa từng test.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Điểm mấu chốt</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Không phải tất cả hoặc không. Quy trình AI tốt nhất cho tự do ở việc nhỏ, có thể hoàn tác, đồng thời giữ con người kiểm soát ở việc lớn, không thể hoàn tác. Nhiệm vụ của bạn là thiết kế ranh giới.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Bạn sẽ vạch ranh giới ở đâu? Đặt mức tự chủ của riêng bạn.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <TrustThermometer client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <div class="py-8">
    <ForYouCard
      chapterSlug={chapter.slug}
      chapterTitle={chapter.title}
      chapterConcepts={conceptsSummary}
      accentColor={chapter.accent}
      client:load
    />
  </div>
  <SharePrompt text="Đang học về tool use và function calling theo cách thực hành nhất có thể. Khóa học này cho bạn tự tay xây và test, không chỉ đọc suông." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Công cụ biến AI từ cố vấn thành trợ lý — từ người bảo bạn nên làm gì, thành người thực sự làm luôn.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Bạn đã cho AI đôi tay. Tiếp theo, ta sẽ nối các công cụ thành thứ có thể tự theo đuổi mục tiêu — lên kế hoạch, thực hiện, phục hồi từ sai lầm. Đến lúc xây agent.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(245,166,35,0.06) 15%, rgba(245,166,35,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#F5A623" toolName="Would You Let It?" client:visible>
        <WouldYouLetIt client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
