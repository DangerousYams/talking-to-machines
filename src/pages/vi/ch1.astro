---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import BeatSection from '../../components/chapter/BeatSection';
import PromptMakeover from '../../components/widgets/ch1/PromptMakeover';
import GuessThePrompt from '../../components/widgets/ch1/GuessThePrompt';
import IterationLoop from '../../components/widgets/ch1/IterationLoop';
import PromptRoast from '../../components/widgets/ch1/PromptRoast';
import PromptComparison from '../../components/widgets/ch1/PromptComparison';
import BeatCompletionCard from '../../components/chapter/BeatCompletionCard';

const chapter = chapters[0];
const beats = chapter.beats!;
---

<ChapterLayout chapter={chapter} locale="vi">

  <!-- ═══ BEAT 1: The Communication Gap ═══ -->
  <BeatSection
    beatId={beats[0].id}
    beatNumber={1}
    totalBeats={beats.length}
    title="Khoảng cách giao tiếp"
    tldr="Prompt mơ hồ thì nhận câu trả lời mơ hồ. Khoảng cách giữa năng lực của AI và kết quả mà đa số mọi người nhận được — đó là vấn đề giao tiếp."
    estimatedMinutes={beats[0].estimatedMinutes}
    accentColor={chapter.accent}
    nextBeatTitle="Năm khối xây dựng"
    isFirst={true}
    client:load
  >
    <!-- HERO -->
    <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
      <div class="chapter-number" style={`color: ${chapter.accent};`}>1</div>

      <div class="max-w-[680px] mx-auto text-center relative z-10">
        <FadeInBlock client:visible>
          <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
            Chương Một
          </p>
        </FadeInBlock>

        <FadeInBlock client:visible delay={0.15}>
          <h1
            class="mb-8 leading-[1.08]"
            style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
          >
            Bạn đã biết<br />nói chuyện với AI
          </h1>
        </FadeInBlock>

        <FadeInBlock client:visible delay={0.3}>
          <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
            Bản nháp đầu tiên sẽ chẳng kỳ diệu đâu.<br />Nhưng bản thứ ba thì có thể.
          </p>
        </FadeInBlock>
      </div>

      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
        <div class="w-px h-10 bg-deep/40"></div>
      </div>
    </section>

    <!-- STORY OPENER -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
      <FadeInBlock client:visible>
        <p class="drop-cap text-lg leading-[1.85] mb-8">
          Bạn đã nói chuyện với AI cả đời rồi. Mỗi lần gõ gì đó vào thanh tìm kiếm, hỏi Siri một câu, hay nhận gợi ý phim trên Netflix — đều có một thuật toán đang lắng nghe. Nhưng có sự khác biệt giữa nói <em>với</em> máy và nói chuyện <em>cùng</em> máy.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-8">
          Ngay lúc này, hàng triệu người gõ prompt vào ChatGPT, nhận được câu trả lời tầm thường, rồi nghĩ: <em>"AI cũng chẳng thông minh lắm nhỉ."</em> Họ sai rồi. AI cực kỳ có năng lực. Chỉ là họ chưa biết cách hỏi thôi.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.2}>
        <p class="text-lg leading-[1.85]">
          Khoảng cách giữa <strong>những gì AI có thể làm</strong> và <strong>những gì đa số mọi người bắt nó làm</strong> là rất lớn. Và đây không phải vấn đề công nghệ — mà là vấn đề giao tiếp. Một vấn đề mà bạn hoàn toàn biết cách giải quyết.
        </p>
      </FadeInBlock>
    </section>

    <Divider accent={chapter.accent} client:load />

    <!-- THE VAGUE PROMPT PROBLEM -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
      <FadeInBlock client:visible>
        <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
        <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
          Vấn đề prompt mơ hồ
        </h2>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-12">
          Hai người cùng nhờ AI giúp viết bài luận. Một người nhận được câu trả lời vô dụng. Người kia nhận được thứ thực sự xuất sắc. Cùng một AI. Khác biệt duy nhất là cách họ hỏi.
        </p>
      </FadeInBlock>
    </section>

    <section class="max-w-[960px] mx-auto px-6 md:px-10 pb-16">
      <FadeInBlock client:visible delay={0.2}>
        <PromptComparison accentColor={chapter.accent} client:visible />
      </FadeInBlock>
    </section>
    <BeatCompletionCard beatId={beats[0].id} beatTitle="Khoảng cách giao tiếp" nextBeatTitle="Năm khối xây dựng" accentColor={chapter.accent} client:visible />
  </BeatSection>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BEAT 2: The Five Building Blocks ═══ -->
  <BeatSection
    beatId={beats[1].id}
    beatNumber={2}
    totalBeats={beats.length}
    title="Năm khối xây dựng"
    tldr="Mọi prompt tốt đều dùng một sự kết hợp nào đó của Vai trò, Nhiệm vụ, Định dạng, Ràng buộc và Ví dụ."
    estimatedMinutes={beats[1].estimatedMinutes}
    accentColor={chapter.accent}
    nextBeatTitle="Tư duy lặp lại"
    client:load
  >
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
      <FadeInBlock client:visible>
        <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
        <h2 class="mb-8" style="font-family: var(--font-heading);">
          Năm khối xây dựng
        </h2>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-6">
          Đây là thứ tạo ra sự khác biệt giữa người nhận được kết quả đỉnh cao từ AI và người chỉ nhận được thứ nhạt nhẽo. Không phải tài năng. Không phải công cụ bí mật nào cả. Đó là một công thức — năm khối xây dựng luôn hiệu quả.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.2}>
        <p class="text-lg leading-[1.85] mb-14">
          Không phải lúc nào bạn cũng cần cả năm. Nhưng biết chúng tồn tại giống như học nhìn thấu Matrix. Một khi nhìn ra pattern, bạn không thể không nhìn thấy nữa.
        </p>
      </FadeInBlock>

      <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
        {[
          { letter: 'R', name: 'Vai trò (Role)', color: '#E94560', text: 'AI nên đóng vai gì? "Bạn là một gia sư Văn chuyên luyện thi" thay đổi tất cả. Gia sư thì giải thích. Giáo sư thì giảng bài. Bạn bè thì nói thoải mái. Vai trò quyết định giọng điệu, từ vựng và độ sâu.' },
          { letter: 'T', name: 'Nhiệm vụ (Task)', color: '#0F3460', text: 'Cụ thể cần làm gì? Không phải "giúp mình viết bài" mà là "cải thiện luận điểm chính của mình." Hãy cụ thể tàn nhẫn. Một nhiệm vụ mỗi prompt gần như luôn tốt hơn ba nhiệm vụ.' },
          { letter: 'F', name: 'Định dạng (Format)', color: '#7B61FF', text: 'Câu trả lời nên trông như thế nào? "Cho mình 3 phương án" là một định dạng. "Dưới dạng danh sách gạch đầu dòng," "trong vòng 100 từ," hay "bảng so sánh ưu nhược điểm" cũng vậy. Định dạng ngăn AI lan man.' },
          { letter: 'C', name: 'Ràng buộc (Constraints)', color: '#16C79A', text: 'AI không được làm gì? "Đừng dùng sáo ngữ." "Giữ dưới 200 từ." Ràng buộc là lan can bảo vệ. Chúng ngăn AI đi lạc hướng.' },
          { letter: 'E', name: 'Ví dụ (Examples)', color: '#F5A623', text: 'Cho xem, đừng chỉ nói. Nếu bạn muốn một phong cách cụ thể, hãy cho một ví dụ về thứ "hay" trông như thế nào. Một ví dụ đáng giá hơn cả trăm từ mô tả.' },
        ].map((block, i) => (
          <FadeInBlock client:visible delay={i * 0.08}>
            <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
              <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${block.color};`}>
                {block.letter}
              </div>
              <div style="flex: 1;">
                <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${block.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                  {block.name}
                </p>
                <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                  {block.text}
                </p>
              </div>
            </div>
          </FadeInBlock>
        ))}
      </div>

      <FadeInBlock client:visible delay={0.5}>
        <div class="insight-box">
          <p style="font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;">Điểm mấu chốt</p>
          <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
            Không cần dùng cả năm mọi lúc. Một câu hỏi bình thường không cần ràng buộc hay ví dụ. Nhưng khi AI cho ra thứ tệ hại, hãy nhìn xem thiếu gì. Gần như lúc nào cũng là một trong năm thứ này.
          </p>
        </div>
      </FadeInBlock>
    </section>

    <!-- BRIDGE TO PROMPT MAKEOVER -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
      <FadeInBlock client:visible>
        <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
          Đủ lý thuyết rồi. Giờ xem các khối xây dựng hoạt động thực tế nào.
        </p>
      </FadeInBlock>
    </section>

    <!-- WIDGET: PROMPT MAKEOVER -->
    <section id="prompt-makeover" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
      <FadeInBlock client:visible>
        <PromptMakeover client:visible />
      </FadeInBlock>
    </section>
    <BeatCompletionCard beatId={beats[1].id} beatTitle="Năm khối xây dựng" nextBeatTitle="Tư duy lặp lại" accentColor={chapter.accent} client:visible />
  </BeatSection>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BEAT 3: The Iteration Mindset ═══ -->
  <BeatSection
    beatId={beats[2].id}
    beatNumber={3}
    totalBeats={beats.length}
    title="Tư duy lặp lại"
    tldr="Chẳng ai hoàn hảo ngay lần đầu. Viết prompt, đánh giá, chỉnh sửa, lặp lại — vòng lặp đó mới là kỹ năng thực sự."
    estimatedMinutes={beats[2].estimatedMinutes}
    accentColor={chapter.accent}
    nextBeatTitle="Kiểm tra kiến thức"
    client:load
  >
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
      <FadeInBlock client:visible>
        <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
        <h2 class="mb-8" style="font-family: var(--font-heading);">
          Lặp lại, không phải hoàn hảo
        </h2>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-10">
          Prompt đầu tiên gần như không bao giờ hiệu quả. Và điều đó hoàn toàn ổn. <strong>Thực ra đó mới là cốt lõi vấn đề.</strong>
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
          Khi bạn xem demo AI tạo ra thứ gì đó tuyệt vời, bạn đang xem prompt cuối cùng — prompt mà ai đó đã đạt được sau năm, mười, có khi hai mươi vòng chỉnh sửa. Bạn đang xem highlight, không phải buổi tập.
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.2}>
        <p class="text-lg leading-[1.85] mb-10">
          Quy trình thực tế trông như thế này:
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.25}>
        <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
          <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
          {[
            { word: 'Prompt.', desc: 'Viết bản nháp tốt nhất bạn có thể.' },
            { word: 'Đánh giá.', desc: 'Đọc câu trả lời. Cái gì ổn? Cái gì chưa đạt?' },
            { word: 'Chỉnh sửa.', desc: 'Điều chỉnh prompt. Cụ thể hơn ở chỗ nó sai.' },
            { word: 'Lặp lại.', desc: 'Cho đến khi kết quả là thứ bạn thực sự muốn dùng.' },
          ].map((step, i) => (
            <div style={`position: relative; padding-bottom: ${i < 3 ? '1.75rem' : '0'};`}>
              <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
              <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
                <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
                <span style="opacity: 0.7;"> {step.desc}</span>
              </p>
            </div>
          ))}
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg leading-[1.85] mb-10">
          Vòng lặp này — prompt, đánh giá, chỉnh sửa, lặp lại — chính là <em>kỹ năng thực sự</em> khi làm việc với AI. Không phải viết một prompt hoàn hảo ma thuật ngay lần đầu. Đó là huyền thoại.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.35}>
        <div class="insight-box">
          <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Kết quả tốt trung bình cần 3-5 lần lặp, không phải 1.</p>
          <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
            Nếu bạn thành công ngay lần đầu, có thể bạn chưa đẩy đủ xa. Kết quả tốt nhất đến từ quá trình trao đổi qua lại, nơi bạn và AI cùng tinh chỉnh.
          </p>
        </div>
      </FadeInBlock>
    </section>

    <!-- WIDGET: ITERATION LOOP -->
    <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
      <FadeInBlock client:visible>
        <IterationLoop client:visible />
      </FadeInBlock>
    </section>

    <Divider accent={chapter.accent} client:load />

    <!-- THE PROMPT SPECTRUM -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
      <FadeInBlock client:visible>
        <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
        <h2 class="mb-8" style="font-family: var(--font-heading);">
          Phổ prompt
        </h2>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-12">
          Hãy hình dung mỗi prompt nằm trên một phổ từ mơ hồ đến chính xác:
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <div style="margin-bottom: 3rem;">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 1.25rem;">
            <span style="font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600; letter-spacing: 0.08em; color: var(--color-subtle); opacity: 0.6;">MƠ HỒ</span>
            <div style="flex: 1; height: 4px; border-radius: 2px; background: linear-gradient(90deg, #CBD5E1 0%, #F5A623 40%, #E94560 70%, #16C79A 100%);"></div>
            <span style="font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600; letter-spacing: 0.08em; color: var(--color-subtle); opacity: 0.6;">CHÍNH XÁC</span>
          </div>
          <div class="grid grid-cols-3 gap-4 text-center">
            <div>
              <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-subtle); margin: 0 0 4px;">"giúp mình"</p>
              <p style="font-family: var(--font-body); font-size: 0.7rem; color: var(--color-subtle); opacity: 0.5; margin: 0;">câu trả lời chung chung</p>
            </div>
            <div>
              <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-amber); margin: 0 0 4px;">"viết về X"</p>
              <p style="font-family: var(--font-body); font-size: 0.7rem; color: var(--color-subtle); opacity: 0.5; margin: 0;">tạm ổn nhưng lan man</p>
            </div>
            <div>
              <p style={`font-family: var(--font-mono); font-size: 0.75rem; color: ${chapter.accent}; font-weight: 600; margin: 0 0 4px;`}>"cả năm khối"</p>
              <p style="font-family: var(--font-body); font-size: 0.7rem; color: var(--color-subtle); opacity: 0.5; margin: 0;">trọng tâm, hữu ích</p>
            </div>
          </div>
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.2}>
        <p class="text-lg leading-[1.85] mb-10">
          Mục tiêu không phải lúc nào cũng ở đầu "chính xác". Brainstorm thoải mái thì mơ hồ cũng được. Nhưng <strong>bạn nên chủ động chọn mình đang ở đâu trên phổ</strong>, chứ không phải rơi vào đó một cách tình cờ.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.25}>
        <p class="text-lg leading-[1.85]">
          Những người khai thác AI tốt nhất không thuộc lòng prompt thần kỳ. Họ phát triển cảm giác về <em>mức độ cụ thể cần thiết</em> — và khi câu trả lời đầu tiên chưa đủ tốt, họ biết chính xác nút nào cần vặn.
        </p>
      </FadeInBlock>
    </section>
    <BeatCompletionCard beatId={beats[2].id} beatTitle="Tư duy lặp lại" nextBeatTitle="Kiểm tra kiến thức" accentColor={chapter.accent} client:visible />
  </BeatSection>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BEAT 4: Test Yourself ═══ -->
  <BeatSection
    beatId={beats[3].id}
    beatNumber={4}
    totalBeats={beats.length}
    title="Kiểm tra kiến thức"
    tldr="Thử thách kỹ năng mới — đoán prompt đằng sau kết quả AI và để AI chấm điểm prompt của bạn."
    estimatedMinutes={beats[3].estimatedMinutes}
    accentColor={chapter.accent}
    client:load
  >
    <!-- WIDGET: GUESS THE PROMPT -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
      <FadeInBlock client:visible>
        <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
          Nắm hết chưa? Kiểm tra thử nào.
        </p>
      </FadeInBlock>
    </section>

    <section id="guess-the-prompt" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
      <FadeInBlock client:visible>
        <GuessThePrompt client:visible />
      </FadeInBlock>
    </section>

    <Divider accent={chapter.accent} client:load />

    <!-- PROMPT ROAST BRIDGE -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-12">
      <FadeInBlock client:visible>
        <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
          Nghĩ mình viết prompt giỏi rồi à? Chỉ có một cách kiểm chứng thôi.
        </p>
      </FadeInBlock>
    </section>

    <!-- WIDGET: PROMPT ROAST -->
    <section id="prompt-roast" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
      <FadeInBlock client:visible>
        <PromptRoast client:visible />
      </FadeInBlock>
    </section>

    <Divider accent={chapter.accent} client:load />

    <!-- CLOSING -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
      <FadeInBlock client:visible>
        <div class="pull-quote" style="border-color: var(--color-navy); max-width: 50ch; margin: 0 auto 2rem;">
          Bạn đã biết nói chuyện với AI. Giờ chỉ cần nói có chủ đích thôi.
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
          Tiếp theo: những kỹ thuật biến cuộc trao đổi qua lại đơn giản thành một cuộc trò chuyện thực sự — nơi AI không chỉ trả lời, mà <em>cùng bạn suy nghĩ</em>.
        </p>
      </FadeInBlock>
    </section>
    <BeatCompletionCard beatId={beats[3].id} beatTitle="Kiểm tra kiến thức" accentColor={chapter.accent} client:visible />
  </BeatSection>

</ChapterLayout>
