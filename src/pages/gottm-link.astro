---
// gottm.xyz link image generator — transparent background, brand fonts
// Open in browser and screenshot the version you like, or right-click the SVGs

const variations = [
  { label: "Deep", color: "#1A1A2E" },
  { label: "Coral Red", color: "#E94560" },
  { label: "Electric Purple", color: "#7B61FF" },
  { label: "Teal", color: "#16C79A" },
  { label: "Navy", color: "#0F3460" },
  { label: "Cream (for dark BG)", color: "#F8F6F3" },
  { label: "Amber", color: "#F5A623" },
  { label: "Sky Blue", color: "#0EA5E9" },
];

// Two-tone variations
const duotones = [
  { label: "Deep + Coral", left: "#1A1A2E", right: "#E94560" },
  { label: "Deep + Purple", left: "#1A1A2E", right: "#7B61FF" },
  { label: "Deep + Teal", left: "#1A1A2E", right: "#16C79A" },
  { label: "Navy + Coral", left: "#0F3460", right: "#E94560" },
  { label: "Purple + Coral", left: "#7B61FF", right: "#E94560" },
  { label: "Cream + Coral (dark BG)", left: "#F8F6F3", right: "#E94560" },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>gottm.xyz — Link Image</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,800;1,400&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #F8F6F3;
      font-family: -apple-system, sans-serif;
      padding: 40px;
    }
    h2 {
      font-size: 14px;
      font-weight: 600;
      color: #6B7280;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 12px;
      margin-top: 48px;
    }
    h2:first-of-type { margin-top: 0; }
    .note {
      font-size: 13px;
      color: #6B7280;
      margin-bottom: 32px;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
      margin-bottom: 16px;
    }
    .card {
      border: 1px solid #e5e5e5;
      border-radius: 12px;
      overflow: hidden;
    }
    .preview {
      padding: 32px 40px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .preview.checker {
      background-image:
        linear-gradient(45deg, #ddd 25%, transparent 25%),
        linear-gradient(-45deg, #ddd 25%, transparent 25%),
        linear-gradient(45deg, transparent 75%, #ddd 75%),
        linear-gradient(-45deg, transparent 75%, #ddd 75%);
      background-size: 16px 16px;
      background-position: 0 0, 0 8px, 8px -8px, -8px 0px;
    }
    .preview.dark-checker {
      background-image:
        linear-gradient(45deg, #2a2a3e 25%, transparent 25%),
        linear-gradient(-45deg, #2a2a3e 25%, transparent 25%),
        linear-gradient(45deg, transparent 75%, #2a2a3e 75%),
        linear-gradient(-45deg, transparent 75%, #2a2a3e 75%);
      background-size: 16px 16px;
      background-position: 0 0, 0 8px, 8px -8px, -8px 0px;
      background-color: #1A1A2E;
    }
    .card-label {
      font-size: 13px;
      color: #6B7280;
      padding: 8px 16px;
      background: #fff;
      border-top: 1px solid #e5e5e5;
    }
    .link-text {
      font-family: 'Playfair Display', Georgia, serif;
      font-weight: 800;
      font-size: 64px;
      letter-spacing: -0.01em;
      line-height: 1;
    }

    /* ── Exportable standalone images ── */
    .export-section {
      margin-top: 64px;
      padding-top: 40px;
      border-top: 2px solid #e5e5e5;
    }
    .standalone {
      display: inline-block;
      padding: 24px 0;
    }
    .standalone .link-text {
      font-size: 80px;
    }
  </style>
</head>
<body>

  <h2>Solid colors — transparent background</h2>
  <p class="note">Checkerboard = transparency. Right-click any text to inspect, or screenshot the standalone versions below.</p>

  <div class="grid">
    {variations.map(v => (
      <div class="card">
        <div class={`preview ${v.label.includes('dark BG') || v.label.includes('Cream') ? 'dark-checker' : 'checker'}`}>
          <span class="link-text" style={`color: ${v.color};`}>gottm.xyz</span>
        </div>
        <div class="card-label">{v.label} — {v.color}</div>
      </div>
    ))}
  </div>

  <h2>Two-tone — transparent background</h2>
  <p class="note">"gottm" in one color, ".xyz" in another.</p>

  <div class="grid">
    {duotones.map(d => (
      <div class="card">
        <div class={`preview ${d.label.includes('dark BG') || d.label.includes('Cream') ? 'dark-checker' : 'checker'}`}>
          <span class="link-text">
            <span style={`color: ${d.left};`}>gottm</span><span style={`color: ${d.right};`}>.xyz</span>
          </span>
        </div>
        <div class="card-label">{d.label}</div>
      </div>
    ))}
  </div>

  <div class="export-section">
    <h2>Standalone — screenshot these</h2>
    <p class="note">These are on a transparent (white for now) background at larger size. For true transparent PNGs, use the SVG files below.</p>

    {[
      { left: "#1A1A2E", right: "#E94560" },
      { left: "#1A1A2E", right: "#7B61FF" },
      { left: "#1A1A2E", right: "#16C79A" },
      { left: "#7B61FF", right: "#E94560" },
      { left: "#E94560", right: "#E94560" },
    ].map(d => (
      <div class="standalone" style="display: block; margin-bottom: 16px;">
        <span class="link-text" style="font-size: 96px;">
          <span style={`color: ${d.left};`}>gottm</span><span style={`color: ${d.right};`}>.xyz</span>
        </span>
      </div>
    ))}
  </div>

</body>
</html>
