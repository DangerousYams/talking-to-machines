---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import BeatSection from '../../components/chapter/BeatSection';
import PromptMakeover from '../../components/widgets/ch1/PromptMakeover';
import GuessThePrompt from '../../components/widgets/ch1/GuessThePrompt';
import IterationLoop from '../../components/widgets/ch1/IterationLoop';
import PromptRoast from '../../components/widgets/ch1/PromptRoast';
import PromptComparison from '../../components/widgets/ch1/PromptComparison';
import BeatCompletionCard from '../../components/chapter/BeatCompletionCard';

const chapter = chapters[0];
const beats = chapter.beats!;
---

<ChapterLayout chapter={chapter} locale="fr">

  <!-- ═══ BEAT 1: The Communication Gap ═══ -->
  <BeatSection
    beatId={beats[0].id}
    beatNumber={1}
    totalBeats={beats.length}
    title="Le fossé de communication"
    tldr="Des prompts vagues génèrent des réponses vagues. L'écart entre ce que l'IA peut faire et ce que la plupart des gens obtiennent est un problème de communication."
    estimatedMinutes={beats[0].estimatedMinutes}
    accentColor={chapter.accent}
    nextBeatTitle="Les cinq éléments de base"
    isFirst={true}
    client:load
  >
    <!-- HERO -->
    <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
      <div class="chapter-number" style={`color: ${chapter.accent};`}>1</div>

      <div class="max-w-[680px] mx-auto text-center relative z-10">
        <FadeInBlock client:visible>
          <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
            Chapitre Un
          </p>
        </FadeInBlock>

        <FadeInBlock client:visible delay={0.15}>
          <h1
            class="mb-8 leading-[1.08]"
            style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
          >
            Tu parles déjà<br />à l'IA
          </h1>
        </FadeInBlock>

        <FadeInBlock client:visible delay={0.3}>
          <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
            Ton premier essai ne sera pas magique.<br />Mais peut-être que le troisième le sera.
          </p>
        </FadeInBlock>
      </div>

      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
        <div class="w-px h-10 bg-deep/40"></div>
      </div>
    </section>

    <!-- STORY OPENER -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
      <FadeInBlock client:visible>
        <p class="drop-cap text-lg leading-[1.85] mb-8">
          Tu parles à l'IA depuis toujours. Chaque fois que tu as tapé quelque chose dans une barre de recherche, posé une question à Siri, ou reçu une recommandation Netflix, un algorithme t'écoutait. Mais il y a une différence entre parler <em>à</em> une machine et parler <em>avec</em> une machine.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-8">
          En ce moment, des millions de personnes tapent un prompt dans ChatGPT, reçoivent une réponse médiocre, et pensent : <em>« Je suppose que l'IA n'est pas si intelligente. »</em> Elles ont tort. L'IA est extraordinairement capable. Elles ne savent juste pas comment bien demander.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.2}>
        <p class="text-lg leading-[1.85]">
          L'écart entre <strong>ce que l'IA peut faire</strong> et <strong>ce que la plupart des gens arrivent à lui faire faire</strong> est énorme. Et ce n'est pas un problème de technologie — c'est un problème de communication. Un problème que tu sais déjà comment résoudre.
        </p>
      </FadeInBlock>
    </section>

    <Divider accent={chapter.accent} client:load />

    <!-- THE VAGUE PROMPT PROBLEM -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
      <FadeInBlock client:visible>
        <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
        <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
          Le problème du prompt vague
        </h2>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-12">
          Deux personnes demandent à la même IA de l'aide pour une dissertation. L'une reçoit une réponse inutile. L'autre obtient quelque chose de vraiment brillant. Même IA. La seule différence, c'est la façon dont elles ont demandé.
        </p>
      </FadeInBlock>
    </section>

    <section class="max-w-[960px] mx-auto px-6 md:px-10 pb-16">
      <FadeInBlock client:visible delay={0.2}>
        <PromptComparison accentColor={chapter.accent} client:visible />
      </FadeInBlock>
    </section>
    <BeatCompletionCard beatId={beats[0].id} beatTitle="Le fossé de communication" nextBeatTitle="Les cinq éléments de base" accentColor={chapter.accent} client:visible />
  </BeatSection>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BEAT 2: The Five Building Blocks ═══ -->
  <BeatSection
    beatId={beats[1].id}
    beatNumber={2}
    totalBeats={beats.length}
    title="Les cinq éléments de base"
    tldr="Tout bon prompt utilise une combinaison de Rôle, Tâche, Format, Contraintes, et Exemples."
    estimatedMinutes={beats[1].estimatedMinutes}
    accentColor={chapter.accent}
    nextBeatTitle="L'état d'esprit itératif"
    client:load
  >
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
      <FadeInBlock client:visible>
        <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
        <h2 class="mb-8" style="font-family: var(--font-heading);">
          Les cinq éléments de base
        </h2>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-6">
          Voici ce qui sépare les personnes qui obtiennent des résultats incroyables avec l'IA de celles qui obtiennent de la bouillie générique. Ce n'est pas le talent. Ce n'est pas un outil secret. C'est une formule — cinq éléments de base qui marchent à tous les coups.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.2}>
        <p class="text-lg leading-[1.85] mb-14">
          Tu n'as pas toujours besoin des cinq. Mais savoir qu'ils existent, c'est comme apprendre à voir la Matrix. Une fois que tu vois le schéma, tu ne peux plus le dé-voir.
        </p>
      </FadeInBlock>

      <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
        {[
          { letter: 'R', name: 'Rôle', color: '#E94560', text: 'Qui l\'IA doit-elle être ? « Tu es un tuteur d\'anglais » change tout. Un tuteur explique. Un professeur fait cours. Un ami débat. Le rôle façonne le ton, le vocabulaire et la profondeur.' },
          { letter: 'T', name: 'Tâche', color: '#0F3460', text: 'Qu\'est-ce qu\'elle doit faire exactement ? Pas « aide-moi avec ma dissertation » mais « renforce ma thèse principale ». Sois impitoyablement précis. Une tâche par prompt, c\'est presque toujours mieux que trois.' },
          { letter: 'F', name: 'Format', color: '#7B61FF', text: 'À quoi la réponse doit-elle ressembler ? « Donne-moi 3 alternatives » c\'est un format. Tout comme « sous forme de liste à puces », « en moins de 100 mots », ou « sous forme de tableau comparant les pour et les contre ». Le format évite les digressions.' },
          { letter: 'C', name: 'Contraintes', color: '#16C79A', text: 'Qu\'est-ce qu\'elle ne doit pas faire ? « N\'utilise pas de clichés. » « Reste sous 200 mots. » Les contraintes sont des garde-fous. Elles empêchent l\'IA d\'aller quelque part d\'inutile.' },
          { letter: 'E', name: 'Exemples', color: '#F5A623', text: 'Montre, ne dis pas. Si tu veux un style spécifique, donne un exemple de ce à quoi ressemble du « bon ». Un exemple vaut cent mots de description.' },
        ].map((block, i) => (
          <FadeInBlock client:visible delay={i * 0.08}>
            <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
              <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${block.color};`}>
                {block.letter}
              </div>
              <div style="flex: 1;">
                <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${block.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                  {block.name}
                </p>
                <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                  {block.text}
                </p>
              </div>
            </div>
          </FadeInBlock>
        ))}
      </div>

      <FadeInBlock client:visible delay={0.5}>
        <div class="insight-box">
          <p style="font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;">Idée clé</p>
          <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
            Tu n'as pas besoin des cinq à chaque fois. Une question décontractée n'a pas besoin de contraintes et d'exemples. Mais quand l'IA te donne du n'importe quoi, regarde ce qui manque. C'est presque toujours l'un de ces cinq.
          </p>
        </div>
      </FadeInBlock>
    </section>

    <!-- BRIDGE TO PROMPT MAKEOVER -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
      <FadeInBlock client:visible>
        <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
          Assez de théorie. Il est temps de voir les éléments de base en action.
        </p>
      </FadeInBlock>
    </section>

    <!-- WIDGET: PROMPT MAKEOVER -->
    <section id="prompt-makeover" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
      <FadeInBlock client:visible>
        <PromptMakeover client:visible />
      </FadeInBlock>
    </section>
    <BeatCompletionCard beatId={beats[1].id} beatTitle="Les cinq éléments de base" nextBeatTitle="L'état d'esprit itératif" accentColor={chapter.accent} client:visible />
  </BeatSection>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BEAT 3: The Iteration Mindset ═══ -->
  <BeatSection
    beatId={beats[2].id}
    beatNumber={3}
    totalBeats={beats.length}
    title="L'état d'esprit itératif"
    tldr="Personne ne réussit du premier coup. Prompt, évalue, affine, répète — cette boucle est la vraie compétence."
    estimatedMinutes={beats[2].estimatedMinutes}
    accentColor={chapter.accent}
    nextBeatTitle="Teste-toi"
    client:load
  >
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
      <FadeInBlock client:visible>
        <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
        <h2 class="mb-8" style="font-family: var(--font-heading);">
          Itération, pas perfection
        </h2>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-10">
          Le premier prompt ne marche presque jamais. Et c'est tant mieux. <strong>C'est en fait tout l'intérêt.</strong>
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
          Quand tu vois une démo d'IA produisant quelque chose d'extraordinaire, tu vois le prompt final — celui que quelqu'un a obtenu après cinq, dix, peut-être vingt tours d'affinement. Tu vois le best-of, pas les séances d'entraînement.
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.2}>
        <p class="text-lg leading-[1.85] mb-10">
          Le vrai processus ressemble à ça :
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.25}>
        <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
          <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
          {[
            { word: 'Prompt.', desc: 'Écris ta meilleure première tentative.' },
            { word: 'Évalue.', desc: 'Lis la réponse. Qu\'est-ce qui est bon ? Qu\'est-ce qui cloche ?' },
            { word: 'Affine.', desc: 'Ajuste le prompt. Sois plus précis là où ça a foiré.' },
            { word: 'Répète.', desc: 'Jusqu\'à ce que le résultat soit quelque chose que tu utiliserais vraiment.' },
          ].map((step, i) => (
            <div style={`position: relative; padding-bottom: ${i < 3 ? '1.75rem' : '0'};`}>
              <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
              <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
                <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
                <span style="opacity: 0.7;"> {step.desc}</span>
              </p>
            </div>
          ))}
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg leading-[1.85] mb-10">
          Cette boucle — prompt, évalue, affine, répète — c'est la <em>vraie compétence</em> pour travailler avec l'IA. Pas créer un prompt parfait magique du premier coup. C'est un mythe.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.35}>
        <div class="insight-box">
          <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Un bon résultat prend en moyenne 3 à 5 itérations, pas 1.</p>
          <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
            Si tu réussis du premier coup, c'est que tu ne pousses probablement pas assez loin. Les meilleurs résultats viennent d'un va-et-vient où toi et l'IA affinez ensemble.
          </p>
        </div>
      </FadeInBlock>
    </section>

    <!-- WIDGET: ITERATION LOOP -->
    <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
      <FadeInBlock client:visible>
        <IterationLoop client:visible />
      </FadeInBlock>
    </section>

    <Divider accent={chapter.accent} client:load />

    <!-- THE PROMPT SPECTRUM -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
      <FadeInBlock client:visible>
        <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
        <h2 class="mb-8" style="font-family: var(--font-heading);">
          Le spectre du prompt
        </h2>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-12">
          Imagine chaque prompt sur un spectre du vague au précis :
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <div style="margin-bottom: 3rem;">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 1.25rem;">
            <span style="font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600; letter-spacing: 0.08em; color: var(--color-subtle); opacity: 0.6;">VAGUE</span>
            <div style="flex: 1; height: 4px; border-radius: 2px; background: linear-gradient(90deg, #CBD5E1 0%, #F5A623 40%, #E94560 70%, #16C79A 100%);"></div>
            <span style="font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600; letter-spacing: 0.08em; color: var(--color-subtle); opacity: 0.6;">PRÉCIS</span>
          </div>
          <div class="grid grid-cols-3 gap-4 text-center">
            <div>
              <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-subtle); margin: 0 0 4px;">"aide-moi"</p>
              <p style="font-family: var(--font-body); font-size: 0.7rem; color: var(--color-subtle); opacity: 0.5; margin: 0;">réponse générique</p>
            </div>
            <div>
              <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-amber); margin: 0 0 4px;">"écris sur X"</p>
              <p style="font-family: var(--font-body); font-size: 0.7rem; color: var(--color-subtle); opacity: 0.5; margin: 0;">correct mais flou</p>
            </div>
            <div>
              <p style={`font-family: var(--font-mono); font-size: 0.75rem; color: ${chapter.accent}; font-weight: 600; margin: 0 0 4px;`}>"les cinq éléments"</p>
              <p style="font-family: var(--font-body); font-size: 0.7rem; color: var(--color-subtle); opacity: 0.5; margin: 0;">ciblé, utile</p>
            </div>
          </div>
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.2}>
        <p class="text-lg leading-[1.85] mb-10">
          Ton objectif n'est pas d'être toujours du côté « précis ». Un brainstorming décontracté peut être vague exprès. Mais <strong>tu devrais choisir consciemment où tu es sur le spectre</strong>, pas y atterrir par accident.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.25}>
        <p class="text-lg leading-[1.85]">
          Les gens qui tirent le maximum de l'IA ne mémorisent pas des prompts magiques. Ils développent une intuition pour <em>à quel point être spécifique</em> — et quand la première réponse n'est pas assez bonne, ils savent exactement quel bouton tourner.
        </p>
      </FadeInBlock>
    </section>
    <BeatCompletionCard beatId={beats[2].id} beatTitle="L'état d'esprit itératif" nextBeatTitle="Teste-toi" accentColor={chapter.accent} client:visible />
  </BeatSection>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BEAT 4: Test Yourself ═══ -->
  <BeatSection
    beatId={beats[3].id}
    beatNumber={4}
    totalBeats={beats.length}
    title="Teste-toi"
    tldr="Mets tes nouvelles compétences à l'épreuve — devine le prompt derrière les résultats d'IA et fais critiquer tes propres prompts."
    estimatedMinutes={beats[3].estimatedMinutes}
    accentColor={chapter.accent}
    client:load
  >
    <!-- WIDGET: GUESS THE PROMPT -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
      <FadeInBlock client:visible>
        <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
          Tu as tout compris ? Mettons ça à l'épreuve.
        </p>
      </FadeInBlock>
    </section>

    <section id="guess-the-prompt" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
      <FadeInBlock client:visible>
        <GuessThePrompt client:visible />
      </FadeInBlock>
    </section>

    <Divider accent={chapter.accent} client:load />

    <!-- PROMPT ROAST BRIDGE -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-12">
      <FadeInBlock client:visible>
        <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
          Tu penses pouvoir écrire un bon prompt maintenant ? Il n'y a qu'une façon de le savoir.
        </p>
      </FadeInBlock>
    </section>

    <!-- WIDGET: PROMPT ROAST -->
    <section id="prompt-roast" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
      <FadeInBlock client:visible>
        <PromptRoast client:visible />
      </FadeInBlock>
    </section>

    <Divider accent={chapter.accent} client:load />

    <!-- CLOSING -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
      <FadeInBlock client:visible>
        <div class="pull-quote" style="border-color: var(--color-navy); max-width: 50ch; margin: 0 auto 2rem;">
          Tu parles déjà à l'IA. Tu dois juste le faire avec intention.
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
          La suite : les techniques qui transforment un simple échange en vraie conversation — où l'IA ne fait pas que répondre, elle <em>réfléchit avec toi</em>.
        </p>
      </FadeInBlock>
    </section>
    <BeatCompletionCard beatId={beats[3].id} beatTitle="Teste-toi" accentColor={chapter.accent} client:visible />
  </BeatSection>

</ChapterLayout>