---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import PromptMakeover from '../../components/widgets/ch1/PromptMakeover';
import PromptRoast from '../../components/widgets/ch1/PromptRoast';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[0];
---

<ChapterLayout chapter={chapter} locale="fr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>1</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Chapitre un
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Tu parles d&eacute;j&agrave;<br />le langage de l'IA
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Ton premier jet ne sera pas magique.<br />Mais le troisi&egrave;me pourrait bien l'&ecirc;tre.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Tu parles &agrave; des IA depuis toujours &mdash; chaque recherche Google, chaque question &agrave; Siri, chaque recommandation Netflix. Mais il y a une diff&eacute;rence entre parler <em>&agrave;</em> une machine et parler <em>avec</em> elle. En ce moment, des millions de personnes &eacute;crivent un prompt, re&ccedil;oivent une r&eacute;ponse m&eacute;diocre et se disent : &laquo;&nbsp;L'IA, c'est pas si fort que &ccedil;a.&nbsp;&raquo; Ils ont tort. L'&eacute;cart entre ce que l'IA peut faire et ce que la plupart des gens obtiennent est &eacute;norme. Et ce n'est pas un probl&egrave;me de technologie &mdash; c'est un probl&egrave;me de communication.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE FIVE BUILDING BLOCKS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Les cinq briques de base
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Voici le secret : les gens qui obtiennent des r&eacute;sultats incroyables avec l'IA ne sont pas plus intelligents que toi. Ils utilisent une formule &mdash; cinq briques de base qui fonctionnent &agrave; tous les coups. Tu n'as pas toujours besoin des cinq. Mais savoir qu'elles existent, c'est comme apprendre &agrave; voir la Matrice.
      </p>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { letter: 'R', name: 'R\u00f4le', color: '#E94560', text: 'Qui doit \u00eatre l\u2019IA\u00a0? Un tuteur n\u2019explique pas comme un professeur d\u2019universit\u00e9. Le r\u00f4le change tout.' },
        { letter: 'T', name: 'T\u00e2che', color: '#0F3460', text: 'Que doit-elle faire exactement\u00a0? Pas \u00ab\u00a0aide-moi\u00a0\u00bb mais \u00ab\u00a0renforce ma th\u00e8se\u00a0\u00bb. Une t\u00e2che par prompt.' },
        { letter: 'F', name: 'Format', color: '#7B61FF', text: '\u00c0 quoi doit ressembler la r\u00e9ponse\u00a0? \u00ab\u00a0Donne-moi 3 alternatives en liste num\u00e9rot\u00e9e.\u00a0\u00bb Le format emp\u00eache le blabla.' },
        { letter: 'C', name: 'Contraintes', color: '#16C79A', text: 'Qu\u2019est-ce qu\u2019elle ne doit PAS faire\u00a0? \u00ab\u00a0\u00c9vite les clich\u00e9s. Reste sous 200 mots.\u00a0\u00bb Les garde-fous \u00e9vitent les mauvais r\u00e9sultats.' },
        { letter: 'E', name: 'Exemples', color: '#F5A623', text: 'Montre plut\u00f4t que d\u00e9crire. Un seul exemple de ce que \u00ab\u00a0bien\u00a0\u00bb veut dire vaut cent mots d\u2019explication.' },
      ].map((block, i) => (
        <FadeInBlock client:visible delay={i * 0.08}>
          <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${block.color};`}>
              {block.letter}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${block.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {block.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {block.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style="font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;">Id&eacute;e cl&eacute;</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Tu n'as pas besoin des cinq &agrave; chaque fois. Mais quand l'IA te sort n'importe quoi, regarde ce qui manque &mdash; c'est presque toujours l'une de ces cinq briques.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Assez de th&eacute;orie. Active les briques et regarde la r&eacute;ponse de l'IA se transformer en temps r&eacute;el.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="prompt-makeover" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <PromptMakeover client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="Je viens de d\u00e9couvrir les 5 briques d'un bon prompt IA. Ce cours interactif est vraiment bien fait \u2014 tu construis les prompts toi-m\u00eame et tu les vois s'am\u00e9liorer en temps r\u00e9el." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style="border-color: var(--color-navy); max-width: 50ch; margin: 0 auto 2rem;">
        Tu parles d&eacute;j&agrave; le langage de l'IA. Il te suffit de le parler avec intention.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        La suite : les techniques qui transforment un simple &eacute;change en vraie conversation &mdash; o&ugrave; l'IA ne se contente pas de r&eacute;pondre, elle <em>r&eacute;fl&eacute;chit avec toi</em>.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(233,69,96,0.06) 15%, rgba(233,69,96,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#E94560" toolName="Prompt Roast" client:visible>
        <PromptRoast client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
