---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import FlipTheScript from '../../components/widgets/ch2/FlipTheScript';
import SocraticSmackdown from '../../components/breaks/SocraticSmackdown';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';
import ForYouCard from '../../components/ui/ForYouCard';

const chapter = chapters[1];
const conceptsSummary = chapter.concepts.map(c => c.name).join(', ');
---

<ChapterLayout chapter={chapter} locale="fr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>2</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Chapitre deux
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          L'art de<br />questionner
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Le meilleur prompt est une question qui<br />pousse l'IA &agrave; t'interroger.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        La plupart des gens utilisent l'IA comme un distributeur automatique. On ins&egrave;re un prompt, on re&ccedil;oit une r&eacute;ponse. Mais les meilleurs r&eacute;sultats viennent de <em>conversations</em>, pas de commandes. La diff&eacute;rence entre quelqu'un qui tape un prompt et quelqu'un qui le construit, c'est la m&ecirc;me diff&eacute;rence qui anime les grands penseurs depuis 2&nbsp;400 ans : poser les bonnes questions.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SOCRATIC FLIP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Le retournement socratique
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Socrate ne r&eacute;pondait jamais directement. Il posait <em>encore plus</em> de questions jusqu'&agrave; ce que ses &eacute;l&egrave;ves acc&egrave;dent &agrave; une compr&eacute;hension plus profonde. Tu peux utiliser la m&ecirc;me astuce avec l'IA, mais invers&eacute;e : au lieu de demander une r&eacute;ponse, demande &agrave; l'IA de t'<em>interviewer</em>. Quand tu &eacute;cris &laquo;&nbsp;organise une f&ecirc;te d'anniversaire&nbsp;&raquo;, tu omets des dizaines de d&eacute;tails qui changent radicalement la r&eacute;ponse. L'IA ne les conna&icirc;t pas &mdash; mais elle peut les demander.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Cette simple technique &mdash; inverser qui pose les questions &mdash; transforme l'IA d'une machine &agrave; r&eacute;ponses en un v&eacute;ritable <strong>partenaire de r&eacute;flexion</strong>. Donne-lui la permission de creuser, de clarifier et de challenger. Le r&eacute;sultat apr&egrave;s cinq &eacute;changes sera m&eacute;connaissable compar&eacute; &agrave; une commande en un seul coup.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Id&eacute;e cl&eacute;</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Les meilleurs utilisateurs d'IA ne sont pas experts du sujet &mdash; ils sont experts en questionnement. Et la question la plus puissante que tu puisses poser est : &laquo;&nbsp;Avant de r&eacute;pondre, de quoi as-tu besoin comme informations&nbsp;?&nbsp;&raquo;
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Essaie par toi-m&ecirc;me. &Eacute;nonce un objectif &mdash; et regarde l'IA inverser les r&ocirc;les.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="flip-the-script" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FlipTheScript client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <div class="py-8">
    <ForYouCard
      chapterSlug={chapter.slug}
      chapterTitle={chapter.title}
      chapterConcepts={conceptsSummary}
      accentColor={chapter.accent}
      client:load
    />
  </div>
  <SharePrompt text="Ce cours sur l'IA a compl\u00e8tement chang\u00e9 ma fa\u00e7on de penser le prompting. Au lieu de dire \u00e0 l'IA quoi faire, on lui demande de NOUS interviewer d'abord. La diff\u00e9rence est flagrante." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Arr&ecirc;te de dire &agrave; l'IA quoi penser. Donne-lui l'espace de r&eacute;fl&eacute;chir avec toi.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Mais toutes les techniques que tu as apprises se heurtent au m&ecirc;me mur invisible : la <em>fen&ecirc;tre de contexte</em>. Prochaine &eacute;tape : on l'ouvre et on apprend &agrave; ma&icirc;triser ce que l'IA voit r&eacute;ellement.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(22,199,154,0.06) 15%, rgba(22,199,154,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#16C79A" toolName="Socratic Smackdown" client:visible>
        <SocraticSmackdown client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
