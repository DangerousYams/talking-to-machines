---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import DebugDetective from '../../components/widgets/ch9/DebugDetective';
import EvalFramework from '../../components/breaks/EvalFramework';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';
import ForYouCard from '../../components/ui/ForYouCard';

const chapter = chapters[8];
const conceptsSummary = chapter.concepts.map(c => c.name).join(', ');
---

<ChapterLayout chapter={chapter} locale="fr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>9</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Chapitre neuf
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          La boucle<br />de construction
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Attends-toi &agrave; l'imperfection. Savoure le raffinement.<br />La magie arrive &agrave; la troisi&egrave;me version.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        L'erreur la plus courante quand on construit avec l'IA, ce n'est pas un mauvais prompt. C'est une mauvaise attente. Tu tapes une longue description, tu appuies sur Entr&eacute;e et tu t'attends &agrave; un produit fini. &Ccedil;a ne marche pas. &Ccedil;a ne marche jamais. Les gens qui construisent des choses incroyables avec l'IA connaissent un secret : <strong>la premi&egrave;re version est toujours fausse.</strong> La troisi&egrave;me est bien. La cinqui&egrave;me est excellente. Et le processus pour passer de l'une &agrave; l'autre&nbsp;? C'est &ccedil;a, la vraie comp&eacute;tence.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        Chaque artiste it&egrave;re. Chaque architecte r&eacute;vise. Chaque cin&eacute;aste tourne plusieurs prises. Construire avec l'IA n'est pas diff&eacute;rent. Les gens qui appr&eacute;cient la boucle &mdash; au lieu de la subir &mdash; sont ceux qui construisent les meilleures choses.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE LOOP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Sp&eacute;cifier, g&eacute;n&eacute;rer, v&eacute;rifier
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Chaque session productive avec un agent de code suit le m&ecirc;me rythme. <strong>Sp&eacute;cifie</strong> ce que tu veux &mdash; sois concret, donne des exemples, d&eacute;cris &agrave; quoi ressemble le &laquo;&nbsp;fini&nbsp;&raquo;. Laisse l'agent le <strong>g&eacute;n&eacute;rer</strong>. Puis <strong>v&eacute;rifie</strong> : est-ce que &ccedil;a marche&nbsp;? Est-ce que &ccedil;a a l'air bien&nbsp;? Est-ce que &ccedil;a fait ce que tu as demand&eacute;&nbsp;? Si non, tu sp&eacute;cifies &agrave; nouveau, plus pr&eacute;cis&eacute;ment. C'est la boucle. Ce n'est pas un signe d'&eacute;chec. C'est le processus.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Le coup de ma&icirc;tre, c'est d'&eacute;crire tes <strong>crit&egrave;res d'acceptation</strong> avant de commencer &agrave; construire. &laquo;&nbsp;Le bouton doit devenir vert quand on clique.&nbsp;&raquo; &laquo;&nbsp;La liste doit persister quand je rafra&icirc;chis la page.&nbsp;&raquo; &laquo;&nbsp;Le formulaire d'inscription doit rejeter les e-mails sans @.&nbsp;&raquo; Ces descriptions en fran&ccedil;ais courant de ce que &laquo;&nbsp;termin&eacute;&nbsp;&raquo; veut dire deviennent ton cadre d'&eacute;valuation. Quand quelque chose ne va pas, tu recolles tes crit&egrave;res &agrave; l'agent en disant &laquo;&nbsp;&ccedil;a ne correspond pas&nbsp;&raquo;. L'agent peut tester selon <em>tes</em> standards.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ WHEN STUCK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Quoi faire quand tu es bloqu&eacute;
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10" style="margin-top: 0;">
        L'agent a g&eacute;n&eacute;r&eacute; quelque chose de cass&eacute;. Et maintenant&nbsp;? Cinq strat&eacute;gies, dans l'ordre de ce qu'il faut essayer d'abord :
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div style="display: grid; gap: 0.75rem; margin-bottom: 2rem;">
        <div style="padding: 1rem 1.25rem; background: rgba(22,199,154,0.04); border-radius: 8px; border: 1px solid rgba(22,199,154,0.1);">
          <p style="font-family: var(--font-heading); font-weight: 700; font-size: 0.9rem; margin: 0 0 0.25rem; color: #16C79A;">1. D&eacute;cris le sympt&ocirc;me, pas ton diagnostic</p>
          <p style="margin: 0; font-size: 0.95rem; line-height: 1.6;">&laquo;&nbsp;Le bouton ne r&eacute;agit pas quand je clique&nbsp;&raquo; vaut mieux que &laquo;&nbsp;je pense que le handler onClick est cass&eacute;&nbsp;&raquo;.</p>
        </div>
        <div style="padding: 1rem 1.25rem; background: rgba(123,97,255,0.04); border-radius: 8px; border: 1px solid rgba(123,97,255,0.1);">
          <p style="font-family: var(--font-heading); font-weight: 700; font-size: 0.9rem; margin: 0 0 0.25rem; color: #7B61FF;">2. Partage le message d'erreur tel quel</p>
          <p style="margin: 0; font-size: 0.95rem; line-height: 1.6;">Copie-colle l'erreur exacte. C'est la chose la plus utile que tu puisses donner &agrave; l'agent.</p>
        </div>
        <div style="padding: 1rem 1.25rem; background: rgba(14,165,233,0.04); border-radius: 8px; border: 1px solid rgba(14,165,233,0.1);">
          <p style="font-family: var(--font-heading); font-weight: 700; font-size: 0.9rem; margin: 0 0 0.25rem; color: #0EA5E9;">3. Demande &agrave; l'agent d'expliquer ce qu'il a fait</p>
          <p style="margin: 0; font-size: 0.95rem; line-height: 1.6;">&laquo;&nbsp;D&eacute;cris-moi ce que tu viens de modifier et pourquoi.&nbsp;&raquo; Comprendre r&eacute;v&egrave;le souvent le probl&egrave;me.</p>
        </div>
        <div style="padding: 1rem 1.25rem; background: rgba(245,166,35,0.04); border-radius: 8px; border: 1px solid rgba(245,166,35,0.1);">
          <p style="font-family: var(--font-heading); font-weight: 700; font-size: 0.9rem; margin: 0 0 0.25rem; color: #F5A623;">4. Demande une approche diff&eacute;rente</p>
          <p style="margin: 0; font-size: 0.95rem; line-height: 1.6;">&laquo;&nbsp;Cette approche ne marche pas. Tu peux essayer de r&eacute;soudre &ccedil;a d'une mani&egrave;re compl&egrave;tement diff&eacute;rente&nbsp;?&nbsp;&raquo;</p>
        </div>
        <div style="padding: 1rem 1.25rem; background: rgba(233,69,96,0.04); border-radius: 8px; border: 1px solid rgba(233,69,96,0.1);">
          <p style="font-family: var(--font-heading); font-weight: 700; font-size: 0.9rem; margin: 0 0 0.25rem; color: #E94560;">5. Repars &agrave; z&eacute;ro avec les le&ccedil;ons apprises</p>
          <p style="margin: 0; font-size: 0.95rem; line-height: 1.6;">Parfois, une nouvelle conversation est plus rapide que de d&eacute;boguer une conversation emm&ecirc;l&eacute;e. Emporte les d&eacute;cisions cl&eacute;s avec toi.</p>
        </div>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Les tests comme garde-fous</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Tu peux demander &agrave; l'agent d'&eacute;crire des tests automatis&eacute;s &mdash; en fran&ccedil;ais courant. &laquo;&nbsp;&Eacute;cris un test qui v&eacute;rifie que le formulaire d'inscription rejette les e-mails sans @.&nbsp;&raquo; L'agent &eacute;crit le test <em>et</em> le code qui le passe. C'est du d&eacute;veloppement pilot&eacute; par les tests, dirig&eacute; par quelqu'un qui n'a jamais &eacute;crit un test. Une fois qu'un bug est attrap&eacute; par un test, il ne peut plus jamais revenir.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Entra&icirc;ne-toi. Comment d&eacute;crirais-tu ces bugs &agrave; un agent de code&nbsp;?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <DebugDetective client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <div class="py-8">
    <ForYouCard
      chapterSlug={chapter.slug}
      chapterTitle={chapter.title}
      chapterConcepts={conceptsSummary}
      accentColor={chapter.accent}
      client:load
    />
  </div>
  <SharePrompt text="Ce chapitre sur la construction avec des agents de code est en or. Les 5 strat\u00e9gies de d\u00e9bogage \u00e0 elles seules valent le d\u00e9tour \u2014 d\u00e9crire les sympt\u00f4mes, partager les erreurs, demander des explications." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        La premi&egrave;re version est toujours fausse. La troisi&egrave;me est bien. La cinqui&egrave;me est excellente. Savoure la boucle.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Tu sais it&eacute;rer. Tu sais d&eacute;boguer. Mais comment savoir si ce que tu construis est vraiment <em>bon</em>&nbsp;? Pas juste fonctionnel &mdash; bon. &Ccedil;a demande quelque chose que l'IA ne peut pas te donner : le go&ucirc;t. C'est le prochain chapitre.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(233,69,96,0.06) 15%, rgba(233,69,96,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#E94560" toolName="Eval Framework" client:visible>
        <EvalFramework client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
