---
export const prerender = true;
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import PromptFramer from '../components/PromptFramer';
import FadeInBlock from '../components/scroll/FadeInBlock';
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Field Guide — Talking to Machines</title>
  <meta name="description" content="Prompt recipes for every AI tool type. Image, video, music, code, research, writing, slides." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;0,800;1,400&family=Lora:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- Nav -->
  <nav style="max-width: 720px; margin: 0 auto; padding: 1.5rem 1.5rem 0;">
    <a href="/" style="display: inline-flex; align-items: center; gap: 8px; text-decoration: none; color: var(--color-subtle); font-family: var(--font-mono); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.04em; opacity: 0.6;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      Back to course
    </a>
  </nav>

  <!-- Hero -->
  <header style="max-width: 680px; margin: 0 auto; padding: 3rem 1.5rem 1rem; text-align: center;">
    <FadeInBlock client:visible>
      <p style="font-family: 'Caveat', cursive; font-size: 1.3rem; font-weight: 600; color: #F5A623; margin: 0 0 0.25rem; transform: rotate(-2deg); display: inline-block;">
        Between chapters 6 & 7
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <h1 style="font-family: var(--font-heading); font-size: clamp(2.5rem, 8vw, 3.5rem); font-weight: 800; color: var(--color-deep); margin: 0 0 0.75rem; line-height: 1.08; letter-spacing: -0.03em;">
        The Field Guide
      </h1>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p style="font-family: var(--font-body); font-size: 1rem; color: var(--color-subtle); margin: 0 0 0.25rem; line-height: 1.6; max-width: 440px; margin-left: auto; margin-right: auto;">
        Every tool speaks a different language. Fill in your details,<br />get a prompt built for the tool you're using.
      </p>
    </FadeInBlock>
  </header>

  <!-- Prompt Framer -->
  <section style="max-width: 900px; margin: 0 auto; padding: 1rem 1.5rem 2.5rem;">
    <PromptFramer client:load />
  </section>

  <!-- Actions -->
  <section style="max-width: 720px; margin: 0 auto; padding: 1rem 1.5rem 3rem;">
    <FadeInBlock client:visible>
      <div style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;">
        <a
          href="https://x.com/intent/tweet?text=The%20Field%20Guide%20%E2%80%94%20prompt%20recipes%20for%20every%20AI%20tool%20type.%20Image%2C%20video%2C%20music%2C%20code%2C%20research%2C%20writing%2C%20slides.&url=https%3A%2F%2Fwww.talkingtomachines.xyz%2Ffield-guide"
          target="_blank" rel="noopener noreferrer"
          style="display: inline-flex; align-items: center; gap: 8px; padding: 11px 22px; border-radius: 100; font-family: var(--font-mono); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.04em; cursor: pointer; transition: all 0.3s; text-decoration: none; border: 1px solid rgba(26,26,46,0.12); background: transparent; color: var(--color-deep); min-height: 44px;"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          Share on X
        </a>

        <a href="/ch7"
          style="display: inline-flex; align-items: center; gap: 8px; padding: 11px 22px; border-radius: 100; font-family: var(--font-mono); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.04em; cursor: pointer; transition: all 0.3s; text-decoration: none; border: none; background: #F5A623; color: white; min-height: 44px;"
        >
          Continue to Chapter 7 &rarr;
        </a>
      </div>
    </FadeInBlock>
  </section>

  <!-- Footer -->
  <footer style="text-align: center; padding: 1.5rem 1.5rem 2.5rem; border-top: 1px solid rgba(26,26,46,0.06);">
    <p style="font-family: var(--font-mono); font-size: 0.62rem; color: var(--color-subtle); letter-spacing: 0.06em; opacity: 0.4;">
      www.talkingtomachines.xyz
    </p>
  </footer>

  <Analytics />
</body>
</html>
