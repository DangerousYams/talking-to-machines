---
export const prerender = true;
import InterludeLayout from '../layouts/InterludeLayout.astro';
import PromptFramer from '../components/PromptFramer';
import FadeInBlock from '../components/scroll/FadeInBlock';
---

<InterludeLayout title="The Field Guide" description="Prompt recipes for every AI tool type. Image, video, music, code, research, writing, slides." accent="#F5A623" slug="field-guide">

  <!-- Hero -->
  <header style="max-width: 680px; margin: 0 auto; padding: 3rem 1.5rem 1rem; text-align: center;">
    <FadeInBlock client:visible>
      <p style="font-family: 'Caveat', cursive; font-size: 1.3rem; font-weight: 600; color: #F5A623; margin: 0 0 0.25rem; transform: rotate(-2deg); display: inline-block;">
        Between chapters 6 & 7
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <h1 style="font-family: var(--font-heading); font-size: clamp(2.5rem, 8vw, 3.5rem); font-weight: 800; color: var(--color-deep); margin: 0 0 0.75rem; line-height: 1.08; letter-spacing: -0.03em;">
        The Field Guide
      </h1>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p style="font-family: var(--font-body); font-size: 1rem; color: var(--color-subtle); margin: 0 0 0.25rem; line-height: 1.6; max-width: 440px; margin-left: auto; margin-right: auto;">
        Every tool speaks a different language. Fill in your details,<br />get a prompt built for the tool you're using.
      </p>
    </FadeInBlock>
  </header>

  <!-- Prompt Framer -->
  <section style="max-width: 900px; margin: 0 auto; padding: 1rem 1.5rem 2.5rem;">
    <PromptFramer client:load />
  </section>

  <!-- Actions -->
  <section style="max-width: 720px; margin: 0 auto; padding: 1rem 1.5rem 3rem;">
    <FadeInBlock client:visible>
      <div style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;">
        <a
          href="/ch6"
          style="display: inline-flex; align-items: center; gap: 8px; padding: 11px 22px; border-radius: 100; font-family: var(--font-mono); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.04em; cursor: pointer; transition: all 0.3s; text-decoration: none; border: 1px solid rgba(26,26,46,0.12); background: transparent; color: var(--color-deep); min-height: 44px;"
        >
          &larr; Chapter 6
        </a>

        <a href="/ch7"
          style="display: inline-flex; align-items: center; gap: 8px; padding: 11px 22px; border-radius: 100; font-family: var(--font-mono); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.04em; cursor: pointer; transition: all 0.3s; text-decoration: none; border: none; background: #F5A623; color: white; min-height: 44px;"
        >
          Chapter 7 &rarr;
        </a>
      </div>
    </FadeInBlock>
  </section>

</InterludeLayout>
