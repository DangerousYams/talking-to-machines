---
export const prerender = true;
import InterludeLayout from '../layouts/InterludeLayout.astro';
import PlaybookCard from '../components/PlaybookCard';
import FadeInBlock from '../components/scroll/FadeInBlock';
import Divider from '../components/ui/Divider';
---

<InterludeLayout title="The Playbook" description="9 power prompts that change how you work with AI. Copy, adapt, and use them immediately." accent="#16C79A" slug="playbook">

  <style>
    @keyframes pb-card-in {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @media print {
      nav, .pb-actions, .no-print { display: none !important; }
      [style*="animation"] { animation: none !important; opacity: 1 !important; transform: none !important; }
    }
  </style>

  <!-- Hero -->
  <header style="max-width: 680px; margin: 0 auto; padding: 3rem 1.5rem 2rem; text-align: center;">
    <!-- Dots -->
    <FadeInBlock client:visible>
      <div style="display: flex; justify-content: center; gap: 12px; margin-bottom: 1.5rem;">
        {['#E94560', '#7B61FF', '#16C79A', '#F5A623', '#0EA5E9'].map((c) => (
          <div style={`width: 7px; height: 7px; border-radius: 50%; background: ${c}; opacity: 0.55;`}></div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p style="font-family: 'Caveat', cursive; font-size: 1.3rem; font-weight: 600; color: #16C79A; margin: 0 0 0.25rem; transform: rotate(-2deg); display: inline-block;">
        Between chapters 3 & 4
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <h1 style="font-family: var(--font-heading); font-size: clamp(2.5rem, 8vw, 3.5rem); font-weight: 800; color: var(--color-deep); margin: 0 0 0.75rem; line-height: 1.08; letter-spacing: -0.03em;">
        The Playbook
      </h1>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p style="font-family: var(--font-body); font-size: 1.05rem; color: var(--color-subtle); margin: 0; line-height: 1.6; max-width: 420px; margin-left: auto; margin-right: auto;">
        9 prompts that change how you work with AI.<br />Copy any card. Use them immediately.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="no-print" style="font-family: var(--font-mono); font-size: 0.68rem; color: var(--color-subtle); margin-top: 1.25rem; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.4; text-align: center;">
        Tap any card to copy
      </p>
    </FadeInBlock>
  </header>

  <!-- Cards -->
  <section style="max-width: 720px; margin: 0 auto; padding: 0 1.5rem 2rem; display: flex; flex-direction: column; gap: 1rem;">
    <PlaybookCard client:visible number={1} title="The Research Prompt" subtitle="Make AI do homework — real homework, not surface-level."
      prompt={"Before answering, research this thoroughly. Don't just check the official source — find independent reviews, benchmarks, and opinions that confirm or contradict it. Cross-reference at least 3 credible perspectives. Summarize what you learn from each, note where they disagree, then give me your recommendation based on the weight of evidence. Show your reasoning."}
      color="#7B61FF" delay={0.1} />

    <PlaybookCard client:visible number={2} title="The Interview Prompt" subtitle="Make AI ask YOU before it builds."
      prompt={"Before you build, write, or plan anything — interview me first. Ask me 5 specific questions to understand exactly what I need, one at a time. Don't start working until you have all my answers."}
      color="#16C79A" delay={0.15} />

    <PlaybookCard client:visible number={3} title="The Reference Prompt" subtitle="Give AI the right examples to learn from."
      prompt={"Here's an example of the quality and style I want:\n\n[paste your example here]\n\nMatch this tone, structure, and level of detail. Don't copy it — use it as a reference for what \"good\" looks like. Explain what you're borrowing from it."}
      color="#0EA5E9" delay={0.2} />

    <PlaybookCard client:visible number={4} title="The Improvement Prompt" subtitle="Find the single highest-leverage change."
      prompt={"Look at what we have so far. What is the single most impactful improvement you could make right now? Not a list of 10 things — one move that makes the biggest difference. Explain why this one matters most."}
      color="#F5A623" delay={0.25} />

    <PlaybookCard client:visible number={5} title="The Stress-Test Prompt" subtitle="Shoot holes in your own plan."
      prompt={"Act as a skeptical critic. What are the 3 weakest parts of this? Where will it break? What am I not seeing? Be honest and specific — I need the hard truth, not encouragement."}
      color="#E94560" delay={0.3} />

    <PlaybookCard client:visible number={6} title="The Explain Yourself Prompt" subtitle="Make AI justify its choices."
      prompt={"Explain why you chose this approach over the alternatives. What are the tradeoffs? What would you do differently if you had different constraints? If I asked you to start over with a completely different strategy, what would it be and why?"}
      color="#7B61FF" delay={0.35} />

    <PlaybookCard client:visible number={7} title="The Ship-It Prompt" subtitle="Define what 'done' looks like before you start."
      prompt={"Write acceptance criteria for this project. What specific conditions must be true for this to be considered done? List them as checkboxes I can verify. Include edge cases that would catch a sloppy version."}
      color="#16C79A" delay={0.4} />
  </section>

  <div style="max-width: 720px; margin: 0 auto; padding: 0 1.5rem;">
    <Divider accent="#16C79A" client:load />
  </div>

  <!-- Bonus section -->
  <section style="max-width: 720px; margin: 0 auto; padding: 1.5rem 1.5rem 2rem;">
    <FadeInBlock client:visible>
      <div style="text-align: center; margin-bottom: 1.5rem;">
        <p style="font-family: 'Caveat', cursive; font-size: 1.15rem; font-weight: 600; color: #F5A623; margin: 0 0 0.15rem; transform: rotate(-1.5deg); display: inline-block;">
          Bonus
        </p>
        <h2 style="font-family: var(--font-heading); font-size: 1.4rem; font-weight: 800; color: var(--color-deep); margin: 0; letter-spacing: -0.02em;">
          Build Your Own Playbook
        </h2>
      </div>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 1rem;">
      <PlaybookCard client:visible number={8} title="The SOP Prompt" subtitle="Turn your best work into a reusable template."
        prompt={"Look at this project I'm proud of:\n\n[paste or describe your best work]\n\nIdentify the patterns that made it good. What decisions, structures, or approaches could I reuse? Turn those patterns into a reusable prompt template I can apply to future projects."}
        color="#F5A623" delay={0.1} />

      <PlaybookCard client:visible number={9} title="The Devlog Prompt" subtitle="Turn your work into shareable updates."
        prompt={"Summarize what I just built / wrote / created in a way I could share publicly. Write it as a short, engaging update — like a devlog or LinkedIn post. Focus on what's interesting about the approach, not just what was done. Keep it under 150 words."}
        color="#E94560" delay={0.15} />
    </div>
  </section>

  <!-- Actions -->
  <section class="pb-actions no-print" style="max-width: 720px; margin: 0 auto; padding: 1.5rem 1.5rem 3rem;">
    <FadeInBlock client:visible>
      <div style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;">
        <a
          href="/ch3"
          style="display: inline-flex; align-items: center; gap: 8px; padding: 11px 22px; border-radius: 100; font-family: var(--font-mono); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.04em; cursor: pointer; transition: all 0.3s; text-decoration: none; border: 1px solid rgba(26,26,46,0.12); background: transparent; color: var(--color-deep); min-height: 44px;"
        >
          &larr; Chapter 3
        </a>

        <button
          onclick="window.print()"
          style="display: inline-flex; align-items: center; gap: 8px; padding: 11px 22px; border-radius: 100; font-family: var(--font-mono); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.04em; cursor: pointer; transition: all 0.3s; text-decoration: none; border: 1px solid rgba(26,26,46,0.12); background: transparent; color: var(--color-deep); min-height: 44px;"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" />
          </svg>
          Save as PDF
        </button>

        <a
          href="/ch4"
          style="display: inline-flex; align-items: center; gap: 8px; padding: 11px 22px; border-radius: 100; font-family: var(--font-mono); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.04em; cursor: pointer; transition: all 0.3s; text-decoration: none; border: none; background: #16C79A; color: white; min-height: 44px;"
        >
          Chapter 4 &rarr;
        </a>
      </div>
    </FadeInBlock>
  </section>

</InterludeLayout>
