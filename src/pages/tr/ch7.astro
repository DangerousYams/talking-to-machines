---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import WhatWouldYouBuild from '../../components/widgets/ch7/WhatWouldYouBuild';
import ShipIt from '../../components/breaks/ShipIt';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[6];
---

<ChapterLayout chapter={chapter} locale="tr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>7</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Yedinci Bölüm
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Claude Code'da<br />Ustalaşmak
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Yapay zeka eş programcın, ilk<br />komuttan özel Skill'lere kadar.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Her kodcunun hatırladığı bir an vardır. Terminali açıyorsun, doğal dilde bir istek yazıyorsun ve bir yapay zekanın dosyalarını okuyup, mimarisini anlayıp, birden fazla dosyaya kod yazıp, çalıştırıp, hata alıp, hatayı düzeltip ve yeniden çalıştırmasını izliyorsun — tek bir satıra dokunmadan. Claude Code otomatik tamamlama değil. Tüm projeni gören, dosyalar arası değişiklik yapan, shell komutları çalıştıran ve kendi hatalarını düzeltip yineleyen <em>ajantik</em> bir kodlama aracı.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        Ama araç ancak onu yönlendiren insan kadar iyi. Claude Code saniyeler içinde bin satır kusursuz kod yazabilir — ya da bin satır inandırıcı görünen çöp. Aradaki fark sensin.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE LOOP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Belirle, Üret, Doğrula
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Claude Code'a bir görev verdiğinde, bir ajan döngüsü çalıştırır: kod tabanını oku, neyi değiştireceğini planla, düzenlemeleri yaz, kodu çalıştır, bozulanı düzelt. Bu döngüyü üç, beş, on kez tekrarlayabilir — hepsi saniyeler içinde. Senin işin artık her satırı yazmak değil. Ne inşa edileceğini <strong>belirlemek</strong>, yapay zekanın <strong>üretmesine</strong> izin vermek ve sonra gerçekten doğru olduğunu <strong>doğrulamak</strong>. Çoğu yeni başlayan bu son adımı atlar. Kod belirir, makul görünür ve devam ederler. O kişi olma. Üretilmiş kod bir ilk taslaktır. Senin doğrulaman onu yayınlanabilir yapan düzenlemedir.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Gizli silah <code>CLAUDE.md</code> dosyasıdır — projenin köküne bırak ve Claude Code her oturumun başında okur. Teknoloji yığınını, adlandırma kurallarını, stil kurallarını, test beklentilerini — hepsini bir kere kodlarsın ve kendini asla tekrarlaman gerekmez. Bu, kodlamaya uygulanmış bağlam mühendisliğidir.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Amaç her satırı yazmak değil — her satırı anlamak.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Claude'un ürettiği kodu okuyamıyorsan, doğrulayamazsın. En iyi Claude Code kullanıcıları en çok kodu üretenler değil — en iyi soruları sorup en ince hataları yakalayanlardır.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Döngüyü çalışırken gör. Bir istek yaz ve Claude Code'un nasıl çalıştığını izle.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="terminal-playground" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <WhatWouldYouBuild client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="Bu Claude Code bölümü çok etkileyici — bir yapay zeka eş programcının bir problemi düşünüp, kod yazıp ve kendi hatasını ayıkladığını izledim. Kodlamanın geleceği burada." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Claude Code senin için kod yazmıyor — seninle birlikte yazıyor.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Tek bir sohbet tek bir görevi halledebilir. Ama gerçek projelerin düzinelercesi var. Sırada: büyük hedefleri yapay zekanın gerçekten uygulayabileceği parçalara nasıl bölünür.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Ship It" client:visible>
        <ShipIt client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
