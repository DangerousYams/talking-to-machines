---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ContextPacking from '../../components/widgets/ch8/ContextPacking';
import ComplexityScore from '../../components/breaks/ComplexityScore';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[7];
---

<ChapterLayout chapter={chapter} locale="tr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>8</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Sekizinci Bölüm
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Karmaşıklığı<br />Orkestra Etmek
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Herhangi bir bağlam penceresinden<br />büyük projelerde yapay zekayı yönetmek.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Her hırslı yeni başlayanın çarptığı an şu: yapay zekadan gerçek bir şey inşa etmesini istiyorsun — tam bir oyun, backend'li bir web sitesi, kaynaklı bir araştırma makalesi — ve her şey dağılıyor. Yapay zeka yeterince akıllı olmadığı için değil. Proje tek bir sohbete sığamayacak kadar büyük olduğu için. Bir duvar dolusu gereksinim yapıştırıyorsun ve yirmi dakika sonra istediğinin yarısını unuttuğunu fark ediyorsun.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        Bu bir yapay zeka sorunu değil. Bu bir <strong>orkestrasyon sorunu</strong>. Ve bunu çözmeyi öğrenmek, yapay zekayı tek seferlik görevler için kullanan biriyle gerçek şeyler inşa etmek için kullanan biri arasındaki farktır.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONTEXT PACKING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Bağlam Paketleme Sanatı
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Karmaşık projeler tek prompt yaklaşımını kırar. Bağlam taşar, dikkat dağılır, hatalar birikir. Çözüm daha iyi bir prompt değil — <strong>ayrıştırma</strong>dır. Projeyi odaklı görevlere böl, sonra her görev için yapay zekanın gerçekten ihtiyaç duyduğu bağlamı dikkatle seç. Çok az verirsen halüsinasyon yapar. Çok fazla verirsen odağını kaybeder. Tatlı nokta cerrahi hassasiyettir.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Bunu bavul hazırlamak gibi düşün. Tüm gardırobunu götüremezsin. Nereye gittiğini (görev), neye ihtiyacın olacağını (ilgili bilgi) ve neyi geride bırakabileceğini (geri kalan her şey) düşünmen gerekiyor. Her sohbet tam olarak ihtiyaç duyduğu bağlamı alır — ne fazla, ne eksik.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style="font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;">Önemli nokta</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Teslim belgenin kalitesi, sonrasında inşa edilen her şeyin kalitesini belirler. Net bir şema her zaman belirsiz bir açıklamayı yener. Çöp girerse, çöp çıkar — sohbetler arası da dahil.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Bir bağlam bavulu hazırla. Önemli olanları taşırmadan sığdırabilecek misin?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ContextPacking client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="Yapay zekanın en zor kısmı prompt yazmak değil — karmaşık projeleri birden fazla sohbet arasında orkestra etmek. Bu kurs sonunda nasıl yapılacağını açıklıyor." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style="border-color: var(--color-navy); max-width: 50ch; margin: 0 auto 2rem;">
        Karmaşık projeler korkutucu değil. Sadece net belgelerle birbirine bağlanan bir dizi odaklı sohbet.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Sırada: yapay zekanın ne zaman <em>yanlış</em> olduğunu bilmek. Halüsinasyonlar, dalkavukluk ve seni dürüst tutan doğrulama alışkanlıkları.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(15,52,96,0.06) 15%, rgba(15,52,96,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#0F3460" toolName="Complexity Score" client:visible>
        <ComplexityScore client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
