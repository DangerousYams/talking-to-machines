---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import TasteTest from '../../components/widgets/ch10/TasteTest';
import IrreplaceableYou from '../../components/breaks/IrreplaceableYou';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';
import ForYouCard from '../../components/ui/ForYouCard';

const chapter = chapters[9];
const conceptsSummary = chapter.concepts.map(c => c.name).join(', ');
---

<ChapterLayout chapter={chapter} locale="tr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>10</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Onuncu Bölüm
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Zevk Ürünün<br />Kendisidir
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Yapay zeka seçenekler üretiyor. Doğru olanı<br />sen seçiyorsun. Beceri bu.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Yapay zeka otuz saniyede bir web sitesi üretebilir. Çoğu aynı görünüyor: yuvarlak köşeler, gradient arka planlar, jenerik hero bölümleri, yer tutucu stok ifadeler. Bu <strong>yapay zeka çöp çıktısı</strong> — kimse zevk kullanmadığında ortaya çıkan varsayılan çıktı. Teknik olarak çalışıyor. Estetik olarak unutulabilir. Ve yapay zekanın verdiğini daha iyisini zorlamadan kabul ettiğinde aldığın şey bu.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        Panzehir daha fazla prompt yazmak değil. Standartların olması. İyinin neye benzediğini bilmek. Ve yapay zekaya doğru tahminde bulunmasını ummak yerine ne istediğini göstermek.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ REFERENCES ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Tarifler Yerine Referanslar
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        "Modern ve temiz görünsün" demek yapay zekaya neredeyse hiçbir şey söylemiyor. "stripe.com gibi görünsün — minimal, bol boşluk, tek vurgu rengi, büyük kalın başlıklar" her şeyi söylüyor. <strong>Referanslar her zaman tariflerden üstündür.</strong> Bir ekran görüntüsü bin kelimelik prompt'a bedeldir. Sevdiğin şeylerin örneklerini topla — web siteleri, uygulamalar, tasarımlar — ve ajana ver. "Bu düzeni istiyorum ama şu renklerle." "Bu tipografiyi ama bir panoya uygulayarak."
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Zevk doğuştan gelmiyor. Maruziyet artı yargıdır. Harika şeylere bakarak ve <em>neden</em> harika olduklarını anlayarak geliştirirsin. Ne kadar çok referans toplarsan, gözün o kadar keskinleşir. Ve gözün ne kadar keskinse, ajana verdiğin talimatlar o kadar iyi olur.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Üç değerlendirme merceği</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Ajanın inşa ettiğini üç mercekten değerlendir. <strong>Görsel:</strong> referanslarım gibi mi görünüyor? <strong>Fonksiyonel:</strong> belirttiğim şeyi yapıyor mu? <strong>Kullanıcı:</strong> bunu gerçekten kullanmak ister miyim? Bunlardan herhangi birine cevap hayırsa, tekrarla. Bu mercekleri uygulamak için kodu okumana gerek yok.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ HUMAN EDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        İnsan Avantajı
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Yapay zeka seçenekler üretiyor. Doğru olanı sen seçiyorsun. O yargı — zevk, empati, vizyon — senin avantajın. Yapay zeka bir dakikada on logo varyantı üretebilir. Ama markan için hangisinin <em>doğru hissettirdiğini</em> sadece sen bilirsin. Yapay zeka bir açılış sayfasının on versiyonunu yazabilir. Ama kitlenle hangisinin rezonans yaratacağını sadece sen bilirsin. Kıt olan beceri üretim değil. <strong>Kürasyon</strong>.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Yapay zekanın temelden yapamadığı şeyler: <em>ne</em> inşa edileceğini seçmek. <em>Kimin</em> için olduğuna karar vermek. <em>Neden</em> önemli olduğunu belirlemek. Yaratıcı vizyonu koymak. Odayı okumak. Nedenini dile getiremeseniz bile bir şeyin "yanlış" olduğunu bilmek. Bunlar yapay zekadaki hatalar değil — insan olmanın özellikleri. Ve üretimin bedava olduğu bir dünyada, her zamankinden daha değerli.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Bu seçenekleri en iyiden en kötüye sırala. Sonra uzmanların nasıl puanladığını &mdash; ve nedenini gör.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <TasteTest client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <div class="py-8">
    <ForYouCard
      chapterSlug={chapter.slug}
      chapterTitle={chapter.title}
      chapterConcepts={conceptsSummary}
      accentColor={chapter.accent}
      client:load
    />
  </div>
  <SharePrompt text="'Yapay zeka seçenekler üretiyor. Doğru olanı sen seçiyorsun.' Zevk, referanslar ve insan avantajı üzerine bu bölüm, yapay zekayla inşa etmenin en önemli dersi." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Üretimin bedava olduğu bir dünyada, önemli olan tek şey zevk.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Bir bölüm kaldı. Artık teori yok. Öğrendiğin her şeyi birleştirip gerçek bir şey inşa etme zamanı &mdash; sadece senin düşünebileceği bir şey.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(22,199,154,0.06) 15%, rgba(22,199,154,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#16C79A" toolName="Irreplaceable You" client:visible>
        <IrreplaceableYou client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
