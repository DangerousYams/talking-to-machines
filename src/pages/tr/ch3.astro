---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ContextWindowViz from '../../components/widgets/ch3/ContextWindowViz';
import VibeCheck from '../../components/breaks/VibeCheck';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[2];
---

<ChapterLayout chapter={chapter} locale="tr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>3</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Üçüncü Bölüm
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Bağlam<br />Mühendisliği
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Yapay zeka unutmaz &mdash; zaten<br />hiçbir zaman hatırlamıyordu.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Yapay zekaya her mesaj gönderdiğinde, <em>tüm sohbetini</em> baştan okur &mdash; gönderdiğin her mesajı, verdiği her yanıtı &mdash; bir cevap üretir ve sonra her şeyi unutur. Bir sonraki turda aynı şey. Tüm kayıt yeniden beslenir. Dünyanın en özverili ama amnezili okuyucu gibi: her seferinde tamamen kapsamlı, ama her turda sıfırdan başlayan.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONCEPT SETUP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Pencerenin Sınırları Var
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10" style="margin-top: 0;">
        Yapay zekanın her turda yeniden okuduğu kayıt, <strong>bağlam penceresi</strong> denilen bir şeyin içinde yaşar &mdash; <strong>token</strong>'larla ölçülür (kabaca her token bir kelimenin dörtte üçüne denk gelir). Claude'un penceresi yaklaşık 200.000 token alıyor &mdash; 500 sayfalık bir kitap. Kulağa büyük geliyor ama gönderdiğin her mesaj, aldığın her yanıt ve gizli tüm sistem talimatları aynı bütçeden yiyor. Düşündüğünden daha hızlı dolar.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Bütçe tükendiğinde, en eski mesajlar kenardan düşer. Üçüncü mesajda diyet kısıtlamalarını mı belirtmiştin? On beşinci mesaja geldiğinde yapay zeka artık onları görmüyor olabilir. Dikkatsizlik etmiyor &mdash; önünde olmayanı kelimenin tam anlamıyla <em>göremiyor</em>. Yapay zeka ancak şu an penceresinde bulunan bilgi kadar iyi.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Bu yüzden en iyi yapay zeka kullanıcıları sadece iyi prompt yazmaz &mdash; pencerenin <em>içine</em> ne girdiğini yönetir. Önemli detayların görünür kalması için düzenli olarak özetle. Önemli olanı öne koy. Konu değiştiğinde sıfırdan başla. Yapay zekanın bağlamını verimli şekilde işleyebilmesi için yapılandırılmış formatlar kullan. <strong>Bağlam mühendisliği, yeni prompt mühendisliğidir.</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Önemli nokta</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Harika bir prompt yazmak birinci adım. Yapay zekanın önüne hangi bilgiyi koyacağına &mdash; ve nasıl yapılandıracağına &mdash; karar vermek, asıl kaldıracın olduğu yerdir. Dünyanın en iyi prompt'u, bağlam yanlışsa başarısız olur.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Bağlam penceresinin dolmasını, taşmasını ve unutmasını &mdash; gerçek zamanlı izle.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ContextWindowViz client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="Sonunda yapay zekanın neden sohbet sırasında şeyleri 'unuttuğunu' anladım. Bu bir hafıza değil — bağlam penceresi. Bu kurs canlı demolarla çok net açıklıyor." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Artık beyaz tahtayı görüyorsun. Pencerenin kenarlarını hissediyorsun. Bu, yapay zekayla yaptığın her sohbeti değiştirir.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Şimdiye kadar sohbet botlarıyla çalıştık. Sırada görüşü genişletiyoruz &mdash; sohbet penceresinin ötesinde yüzlerce yapay zeka aracı var ve manzarayı bilmek, neyin mümkün olduğuna dair düşünceni değiştiriyor.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Vibe Check" client:visible>
        <VibeCheck client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
