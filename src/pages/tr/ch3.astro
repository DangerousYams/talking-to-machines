---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ContextWindowViz from '../../components/widgets/ch3/ContextWindowViz';
import ForgettingExperiment from '../../components/widgets/ch3/ForgettingExperiment';
import VibeCheck from '../../components/breaks/VibeCheck';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';
import ForYouCard from '../../components/ui/ForYouCard';

const chapter = chapters[2];
const conceptsSummary = chapter.concepts.map(c => c.name).join(', ');
---

<ChapterLayout chapter={chapter} locale="tr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>3</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Üçüncü Bölüm
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Bağlam<br />Mühendisliği
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Yapay zeka unutmuyor &mdash; zaten<br />hiç hatırlamıyordu.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Yapay zekaya her mesaj gönderdiğinde, <em>tüm konuşmayı</em> baştan okuyor &mdash; gönderdiği her mesaj, verdiği her yanıt &mdash; bir cevap üretiyor ve sonra her şeyi unutuyor. Sonraki turda aynı şey. Tüm metin yeniden besleniyor. Dünyanın en gayretli ama hafıza kaybına uğramış okuyucusu: her seferinde tastamam, ama her seferinde sıfırdan başlıyor.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONCEPT SETUP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Pencerenin Kenarları Var
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10" style="margin-top: 0;">
        Yapay zekanın her turda yeniden okuduğu o metin, <strong>bağlam penceresi</strong> denen bir şeyin içinde yaşıyor &mdash; <strong>token</strong>'larla ölçülüyor (kabaca her token, bir kelimenin dörtte üçü kadar). Claude'un penceresi yaklaşık 200.000 token tutuyor &mdash; 500 sayfalık bir kitap. Büyük görünüyor, ama gönderdiğin her mesaj, aldığın her yanıt ve gizli tüm sistem talimatları aynı bütçeden yiyor. Sandığından daha hızlı doluyor.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Bütçe tükendiği zaman en eski mesajlar kenardan düşüyor. Üçüncü mesajında diyet kısıtlamalarından mı bahsettin? On beşinci mesaja kadar yapay zeka onları artık görmüyor olabilir. Dikkatsiz değildir &mdash; önünde olmayanı kelimenin tam anlamıyla göremiyor. Yapay zeka yalnızca şu anda penceresinde bulunan bilgi kadar iyi.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Bu yüzden en iyi yapay zeka kullanıcıları sadece iyi prompt yazmakla kalmıyorlar &mdash; pencerenin <em>içine</em> ne girdiğini yönetiyorlar. Önemli detaylar görünür kalsın diye düzenli olarak özetle. Önemli olanı öne koy. Konu değiştiğinde yeni bir konuşmaya başla. Yapay zekanın bağlamını verimli bir şekilde işlemesi için yapılandırılmış formatlar kullan. <strong>Bağlam mühendisliği, yeni prompt mühendisliği.</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Temel fikir</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Harika bir prompt yazmak birinci adım. Yapay zekanın önüne hangi bilgiyi koyacağına &mdash; ve onu nasıl yapılandırdığına &mdash; karar vermek, asıl kaldıracın olduğu yer. Dünyanın en iyi prompt'u bile bağlam yanlış olduğunda başarısız olur.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Bağlam penceresinin dolmasını, taşmasını ve unutmasını &mdash; gerçek zamanlı izle.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ContextWindowViz client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONTEXT ENGINEERING STRATEGIES ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Bağlam Yönetimi Stratejileri
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14">
        Şimdi pencereyi anladığın için, onu bir profesyonel gibi nasıl yöneteceğini öğrenelim. Bunlar "yapay zeka kullanan" insanları ondan olağanüstü sonuçlar alan insanlardan ayıran teknikler.
      </p>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      <FadeInBlock client:visible delay={0.16}>
        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: #7B61FF;">1</div>
          <div style="flex: 1;">
            <p style="font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: #7B61FF; margin: 0 0 0.35rem; line-height: 1.3;">İlerledikçe özetle</p>
            <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">Her 5-10 mesajda yapay zekadan temel kararların ve detayların kısa bir özetini yazmasını iste. Sonra o özeti bir sonraki mesajına yapıştır. Bu, bağlamı en önemli bilgiyi öne koyarak "sıfırlar."</p>
          </div>
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.24}>
        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: #16C79A;">2</div>
          <div style="flex: 1;">
            <p style="font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: #16C79A; margin: 0 0 0.35rem; line-height: 1.3;">Önemliyi başa koy</p>
            <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">En kritik bilgiyi mesajının başına koy, sonuna gömme. Yapay zeka ilk ve son gelene daha fazla dikkat eder &mdash; orta kısım kaybolabilir, özellikle uzun prompt'larda.</p>
          </div>
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.32}>
        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: #0EA5E9;">3</div>
          <div style="flex: 1;">
            <p style="font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: #0EA5E9; margin: 0 0 0.35rem; line-height: 1.3;">Stratejik olarak sıfırdan başla</p>
            <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">Konu önemli ölçüde değiştiğinde yeni bir konuşma başlatmaktan korkma. Aldığı kararların özetini taşı, tüm geçmişi değil. Temiz bir bağlam, dağılmış olandan genellikle daha iyidir.</p>
          </div>
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.40}>
        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: #F5A623;">4</div>
          <div style="flex: 1;">
            <p style="font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: #F5A623; margin: 0 0 0.35rem; line-height: 1.3;">Neyi hatırlaması gerektiğini açıkça belirt</p>
            <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">"Önemli: kullanıcı vejetaryen. Bunu unutma." Saçma görünüyor, ama işe yarıyor. Açık hatırlatmalar, yapay zekanın daha fazla ağırlık verdiği çapalar gibi çalışır.</p>
          </div>
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.48}>
        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: #E94560;">5</div>
          <div style="flex: 1;">
            <p style="font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: #E94560; margin: 0 0 0.35rem; line-height: 1.3;">Yapılandırılmış formatlar kullan</p>
            <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">Madde işaretli listeler, başlıklar ve net etiketler yapay zekanın bağlamını daha verimli işlemesine yardımcı olur. İyi organize edilmiş bir prompt, bir metin duvarına kıyasla token değerinin iki katını eder.</p>
          </div>
        </div>
      </FadeInBlock>
    </div>
  </section>

  <!-- ═══ THE FORGETTING EXPERIMENT ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ForgettingExperiment client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <div class="py-8">
    <ForYouCard
      chapterSlug={chapter.slug}
      chapterTitle={chapter.title}
      chapterConcepts={conceptsSummary}
      accentColor={chapter.accent}
      client:load
    />
  </div>
  <SharePrompt text="Sonunda yapay zekanın neden konuşma ortasında şeyleri 'unuttuğunu' anlıyorum. Hafıza değil — bağlam penceresi. Bu kurs canlı demolarla o kadar net açıklıyor ki." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Artık beyaz tahtayı görüyorsun. Pencerenin kenarlarını hissediyorsun. Bu, yapay zekayla yaptığın her konuşmayı değiştirir.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Temelleri öğrendin &mdash; prompt yazma, soru sorma ve bağlam. Sırada: yanınızda götüreceğiniz güçlü prompt'lar pusulası.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Vibe Check" client:visible>
        <VibeCheck client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
