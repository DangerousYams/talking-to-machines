---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import AgentBlueprint from '../../components/widgets/ch6/AgentBlueprint';
import AgentTakeover from '../../components/breaks/AgentTakeover';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[5];
---

<ChapterLayout chapter={chapter} locale="id">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>6</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Bab Enam
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Membangun<br />Agent
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Perbedaan antara kalkulator<br />dan rekan kerja.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Chatbot menunggu kamu berbicara. Agent tidak. Beri dia tujuan — "riset kolonisasi Mars dan tulis laporan" — dan dia akan memecah pekerjaan jadi langkah-langkah, memilih tool yang tepat, menjalankannya satu per satu, memeriksa hasilnya sendiri, dan terus bekerja sampai selesai. Perbedaan itu — antara <em>merespons instruksi</em> dan <em>mengejar tujuan</em> — adalah perbedaan antara kalkulator dan rekan kerja.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        Agent berjalan dalam siklus: terima tujuan, rencanakan langkah, eksekusi dengan tool, amati hasil, evaluasi progres, sesuaikan. Mereka tidak merencanakan sekali lalu menjalankan secara membabi buta — yang terbaik pulih dengan anggun ketika langkah ketiga berantakan. Tapi kekuatan itu punya sisi gelap: agent tidak hanya memberi jawaban buruk, mereka <em>bertindak</em> berdasarkannya, lalu menggunakan hasil yang rusak untuk membuat keputusan berikutnya. Kegagalan terakumulasi.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE ANATOMY OF AN AGENT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Siklus Agent
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Setiap agent berjalan pada siklus lima langkah yang sama. Memahami langkah-langkah ini adalah perbedaan antara membangun sesuatu yang berguna dan membangun sesuatu yang menghabiskan kredit API-mu dalam loop tak terbatas.
      </p>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { letter: 'G', name: 'Goal (Tujuan)', color: '#E94560', text: 'Terima tujuan yang jelas. "Riset Mars" bukan tujuan. "Tulis ringkasan 500 kata tentang tantangan kolonisasi Mars, dengan sumber" baru tujuan.' },
        { letter: 'P', name: 'Plan (Rencana)', color: '#7B61FF', text: 'Pecah tujuan jadi langkah konkret. Perencana yang baik membuat rencana fleksibel. Perencana yang buruk membuat skrip kaku yang hancur pada kejutan pertama.' },
        { letter: 'T', name: 'Execute (Eksekusi)', color: '#0EA5E9', text: 'Jalankan setiap langkah menggunakan tool yang tepat — mesin pencari, interpreter kode, pembaca file, API. Agent tidak cuma berpikir. Mereka bertindak.' },
        { letter: 'M', name: 'Observe (Amati)', color: '#16C79A', text: 'Catat apa yang terjadi dan periksa hasilnya. Tanpa memori, agent bisa mengulangi tindakan gagal yang sama selamanya.' },
        { letter: 'E', name: 'Evaluate (Evaluasi)', color: '#F5A623', text: 'Apakah ini berhasil? Apakah aku lebih dekat ke tujuan? Kalau ada yang salah, sesuaikan rencana dan ulangi. Ini yang memisahkan agent dari skrip biasa.' },
      ].map((block, i) => (
        <FadeInBlock client:visible delay={i * 0.08}>
          <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${block.color};`}>
              {block.letter}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${block.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {block.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {block.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Poin penting</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Chatbot adalah satu giliran. Agent adalah percakapan utuh — dengan dirinya sendiri, tool-nya, dan dunia. Pembuat agent terbaik bukan yang memaksimalkan otonomi. Mereka merancang pos pemeriksaan yang bijaksana di mana agent berhenti dan membiarkan manusia memutuskan apakah harus melanjutkan.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Saatnya membangun satu. Rancang agent-mu sendiri dari nol.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <AgentBlueprint client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="Baru saja merancang agent AI pertamaku dari nol. Kursus ini memandu arsitekturnya langkah demi langkah dengan demo langsung. Tanpa hype, murni membangun." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Tujuannya bukan mencegah semua kegagalan — tapi membuat kegagalan bisa dipulihkan.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Selanjutnya: kamu akan menggunakan agent nyata — yang membaca kodemu, menulis perubahan, menjalankan tes, dan memperbaiki kesalahannya sendiri. Kenalan dengan Claude Code.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(233,69,96,0.06) 15%, rgba(233,69,96,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#E94560" toolName="Agent Takeover" client:visible>
        <AgentTakeover client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
