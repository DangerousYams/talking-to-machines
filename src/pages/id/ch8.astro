---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ContextPacking from '../../components/widgets/ch8/ContextPacking';
import ComplexityScore from '../../components/breaks/ComplexityScore';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[7];
---

<ChapterLayout chapter={chapter} locale="id">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>8</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Bab Delapan
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Mengorkestrasi<br />Kompleksitas
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Mengelola AI untuk proyek yang lebih besar<br />dari context window mana pun.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Inilah momen ketika setiap pemula ambisius terhantam: kamu meminta AI membangun sesuatu yang nyata — game utuh, website dengan backend, paper penelitian dengan sitasi — dan semuanya berantakan. Bukan karena AI-nya tidak cukup pintar. Tapi karena proyeknya terlalu besar untuk satu percakapan. Kamu menempel daftar persyaratan panjang dan dua puluh menit kemudian sadar AI-nya lupa separuh dari yang kamu minta.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        Ini bukan masalah AI. Ini masalah <strong>orkestrasi</strong>. Dan belajar menyelesaikannya adalah perbedaan antara orang yang menggunakan AI untuk tugas sekali jalan dan orang yang menggunakannya untuk membangun hal-hal nyata.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONTEXT PACKING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Seni Context Packing
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Proyek kompleks memecahkan pendekatan satu prompt. Context meluap, perhatian terencerkan, kesalahan terakumulasi. Solusinya bukan prompt yang lebih baik — tapi <strong>dekomposisi</strong>. Pecah proyek jadi tugas-tugas terfokus, lalu untuk setiap tugas, pilih konteks apa yang benar-benar AI butuhkan. Terlalu sedikit dan dia berhalusinasi. Terlalu banyak dan dia kehilangan fokus. Sweet spot-nya adalah presisi bedah.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Pikirkan seperti mengemas koper. Kamu tidak bisa bawa seluruh lemari. Kamu perlu memikirkan ke mana kamu pergi (tugas), apa yang kamu butuhkan (informasi relevan), dan apa yang bisa ditinggalkan (sisanya). Setiap percakapan mendapat persis konteks yang dibutuhkan — tidak lebih, tidak kurang.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style="font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;">Poin penting</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Kualitas artefak handoff-mu menentukan kualitas semua yang dibangun downstream. Schema yang tajam selalu mengalahkan deskripsi yang kabur. Garbage in, garbage out — lintas percakapan.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Kemas koper konteks. Bisakah kamu memuat yang penting tanpa meluap?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ContextPacking client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="Bagian tersulit dari AI bukan prompting — tapi mengorkestrasi proyek kompleks di banyak percakapan. Kursus ini akhirnya menjelaskan caranya." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style="border-color: var(--color-navy); max-width: 50ch; margin: 0 auto 2rem;">
        Proyek kompleks tidak menakutkan. Mereka hanya serangkaian percakapan terfokus yang dihubungkan oleh artefak yang tajam.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Selanjutnya: mengetahui kapan AI <em>salah</em>. Halusinasi, sikofansi, dan kebiasaan verifikasi yang membuatmu tetap jujur.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(15,52,96,0.06) 15%, rgba(15,52,96,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#0F3460" toolName="Complexity Score" client:visible>
        <ComplexityScore client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
