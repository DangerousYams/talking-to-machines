---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import ProjectOrchestrator from '../../components/widgets/ch8/ProjectOrchestrator';
import ContextPacking from '../../components/widgets/ch8/ContextPacking';

const chapter = chapters[7];
---

<ChapterLayout chapter={chapter} locale="id">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>8</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Bab Delapan
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Mengorkestrasi<br />Kompleksitas
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Mengelola AI untuk proyek yang lebih besar<br />dari context window apapun.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        Inilah momen ketika setiap pemula ambisius terhantam: kamu meminta AI membangun sesuatu yang nyata — game lengkap, website dengan backend, paper penelitian dengan sitasi — dan semuanya berantakan. Bukan karena AI-nya tidak cukup pintar. Tapi karena proyeknya terlalu besar untuk satu percakapan saja.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        Kamu menempel daftar persyaratan panjang, AI memberikan respons yang terdengar yakin, dan dua puluh menit kemudian kamu sadar AI-nya lupa setengah dari yang kamu minta, kontradiksi sendiri soal arsitektur, dan berhalusinasi library yang tidak ada. Kamu coba lagi. Hasil sama, halusinasi berbeda.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        Ini bukan masalah AI. Ini masalah <strong>orkestrasi</strong>. Dan belajar menyelesaikannya adalah perbedaan antara orang yang menggunakan AI untuk tugas sekali jalan dengan orang yang menggunakannya untuk membangun hal-hal nyata.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE ONE-PROMPT TRAP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Jebakan Satu Prompt
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Ketika pertama kali belajar menggunakan AI, kamu secara alami mencoba melakukan semuanya dalam satu kali coba. Satu prompt besar. Satu percakapan. Satu upaya. Dan untuk tugas sederhana — menulis email, brainstorming ide, menjelaskan konsep — itu bisa berfungsi.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Tapi kompleksitas memecah pendekatan satu-prompt dalam tiga cara:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 2.5rem;">
        {[
          { num: '1', title: 'Context overflow', text: 'AI hanya bisa menyimpan informasi dalam jumlah terbatas sekaligus. Proyek penuh melebihi batas itu, jadi AI mulai "melupakan" persyaratan awal kamu.' },
          { num: '2', title: 'Pengenceran perhatian', text: 'Bahkan dalam context window, meminta AI menyeimbangkan dua belas hal berbeda sekaligus berarti masing-masing mendapat perhatian lebih sedikit. Kualitas turun di semua aspek.' },
          { num: '3', title: 'Kesalahan beruntun', text: 'Satu kesalahan kecil dalam output kompleks menjalar. Jika AI salah dengan database schema, semua yang dibangun di atasnya juga salah — dan sulit dideteksi dalam tembok kode yang dihasilkan.' },
        ].map((item, i) => (
          <FadeInBlock client:visible delay={0.2 + i * 0.08}>
            <div style="display: flex; gap: 1.25rem; align-items: flex-start;">
              <div style={`flex-shrink: 0; width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 0.8rem; font-weight: 700; color: white; background: ${chapter.accent};`}>
                {item.num}
              </div>
              <div style="flex: 1;">
                <p style={`font-family: var(--font-heading); font-size: 1rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.3rem; line-height: 1.3;`}>
                  {item.title}
                </p>
                <p style="font-size: 0.95rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                  {item.text}
                </p>
              </div>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.5}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        Solusinya bukan prompt yang lebih baik. Tapi proses yang lebih baik.
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ DECOMPOSITION: THE MASTER SKILL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Dekomposisi: Skill Utama
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Software engineer profesional tidak membangun aplikasi utuh dalam sekali duduk. Mereka memecahnya menjadi potongan — modul, komponen, fungsi — masing-masing dengan tujuan jelas, input jelas, dan output jelas. Lalu mereka merakitnya.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Bekerja dengan AI di proyek kompleks membutuhkan disiplin yang sama. Kamu perlu <strong>mendekomposisi</strong> proyekmu menjadi tugas-tugas yang cukup kecil untuk ditangani dengan baik oleh satu percakapan AI yang terfokus.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        Dekomposisi yang baik mengikuti tiga aturan:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
        <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
        {[
          { word: 'Tanggung jawab tunggal.', desc: 'Setiap tugas mengerjakan satu hal. "Desain database DAN bangun API DAN tulis frontend" itu tiga tugas, bukan satu.' },
          { word: 'Interface yang jelas.', desc: 'Setiap tugas memiliki input terdefinisi (apa yang dibutuhkan untuk mulai) dan output terdefinisi (apa yang dihasilkan). Output dari satu tugas menjadi input tugas berikutnya.' },
          { word: 'Dependensi minimal.', desc: 'Tugas yang bisa dikerjakan paralel harus paralel. Hanya buat dependensi ketika satu tugas benar-benar butuh output tugas lain.' },
        ].map((step, i) => (
          <div style={`position: relative; padding-bottom: ${i < 2 ? '1.75rem' : '0'};`}>
            <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
            <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
              <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
              <span style="opacity: 0.7;"> {step.desc}</span>
            </p>
          </div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Dekomposisi adalah skill manusia, bukan skill AI.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI bisa membantu kamu brainstorming breakdown tugas, tapi memutuskan bagaimana membagi pekerjaan, apa yang bergantung pada apa, dan apa yang diprioritaskan — itu tugasmu. Ini manajemen proyek, dan ini salah satu skill paling berharga yang bisa kamu kembangkan.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO PROJECT ORCHESTRATOR -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Coba dekomposisi proyek nyata. Tarik tugas, lacak dependensi, lihat rencana terbentuk.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: PROJECT ORCHESTRATOR ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ProjectOrchestrator client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE HANDOFF PATTERN ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Pola Handoff
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Setelah kamu memecah proyek menjadi tugas-tugas, kamu butuh cara untuk menghubungkannya. Dalam workflow AI, koneksi ini adalah <strong>handoff</strong> — momen ketika output dari satu percakapan menjadi input percakapan berikutnya.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: var(--color-navy);">
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Pola Handoff</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          Percakapan 1 menghasilkan sebuah <strong>artefak</strong> — dokumen, schema, rencana.<br />
          Artefak itu dipaste ke Percakapan 2 sebagai <strong>konteks</strong>.<br />
          Percakapan 2 membangun di atasnya dan menghasilkan artefak berikutnya.<br />
          Ulangi sampai proyek selesai.
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        Pikirkan seperti lari estafet. Setiap pelari (percakapan) menyelesaikan bagiannya dan memberikan tongkat (artefak) ke pelari berikutnya. Tongkat adalah bagian kritis — jika jatuh atau kacau, pelari berikutnya tersandung.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        Ini berarti artefak handoff-mu harus <em>tajam</em>. Database schema adalah handoff yang lebih baik daripada deskripsi kabur tentang model data. Daftar bernomor endpoint API lebih baik daripada "saya butuh backend yang menangani hal-hal user." Semakin tajam artefaknya, semakin baik performa percakapan berikutnya.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        Kualitas artefak handoff-mu menentukan kualitas semua yang dibangun downstream. Garbage in, garbage out — lintas percakapan.
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONTEXT PACKING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Seni Context Packing
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Setiap kali kamu memulai percakapan AI baru, kamu membuat keputusan yang kebanyakan orang bahkan tidak sadari: <strong>konteks apa yang kamu sertakan?</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Kamu punya budget terbatas — context window. Dan kamu punya tumpukan informasi yang berpotensi relevan: file kode, dokumentasi, percakapan sebelumnya, log error, spek desain. Tidak semuanya akan muat. Dan bahkan jika bisa, menumpahkan semuanya akan mengencerkan perhatian AI.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        Context packing seperti mengemas koper untuk perjalanan. Kamu tidak bisa membawa seluruh lemari. Kamu perlu memikirkan kemana kamu pergi (tugas), apa yang kamu butuhkan (informasi relevan), dan apa yang bisa ditinggalkan (sisanya).
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div style="display: flex; flex-direction: column; gap: 1.25rem; margin-bottom: 2.5rem;">
        {[
          { label: 'Konteks terlalu sedikit', color: '#E94560', text: 'AI tidak punya yang dibutuhkan dan mengisi celah dengan halusinasi. Terdengar yakin tapi mengarang detail.' },
          { label: 'Konteks terlalu banyak', color: '#F5A623', text: 'AI kewalahan. Detail penting hilang dalam kebisingan. Output jadi generik dan tidak fokus.' },
          { label: 'Konteks yang tepat', color: '#16C79A', text: 'AI punya persis yang dibutuhkan untuk tugas spesifik ini. Output presisi, relevan, dan actionable.' },
        ].map((item, i) => (
          <FadeInBlock client:visible delay={0.25 + i * 0.08}>
            <div style={`padding: 1rem 1.25rem; border-radius: 10px; border-left: 3px solid ${item.color}; background: ${item.color}08;`}>
              <p style={`font-family: var(--font-heading); font-size: 0.9rem; font-weight: 700; color: ${item.color}; margin: 0 0 0.25rem;`}>
                {item.label}
              </p>
              <p style="font-size: 0.9rem; line-height: 1.7; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {item.text}
              </p>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Berpikir seperti editor, bukan kolektor.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Sebelum setiap interaksi AI, tanya diri sendiri: apa yang AI <em>perlu tahu</em> untuk melakukan tugas spesifik ini? Sertakan itu. Tinggalkan yang lain. Ini context engineering yang diterapkan pada manajemen proyek.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO CONTEXT PACKING -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Kemas koper konteks. Bisakah kamu memuat yang penting tanpa overflow?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: CONTEXT PACKING ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ContextPacking client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ VERSION CONTROL FOR AI WORK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Melacak Apa yang Berhasil
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Ini skenario yang terjadi pada semua orang: kamu punya percakapan AI yang bagus yang menghasilkan output persis seperti yang kamu butuhkan. Seminggu kemudian, kamu butuh sesuatu yang mirip. Kamu tidak ingat apa yang kamu katakan. Kamu coba merekonstruksi. Hasilnya lebih buruk.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Proyek AI kompleks menghasilkan banyak artefak — prompt yang berhasil, output yang bagus, keputusan yang dibuat, pendekatan yang gagal. Tanpa sistem untuk melacak ini, kamu akan buang waktu berjam-jam menemukan ulang hal yang sudah kamu ketahui.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        Developer profesional menggunakan version control (seperti Git) untuk melacak setiap perubahan dalam codebase mereka. Kamu harus menerapkan mindset yang sama pada pekerjaan AI-mu:
      </p>
    </FadeInBlock>

    <!-- Tracking habits list -->
    <FadeInBlock client:visible delay={0.25}>
      <div style="display: flex; flex-direction: column; gap: 1.25rem; margin-bottom: 3rem;">
        {[
          { icon: '01', title: 'Simpan prompt-mu', desc: 'Ketika prompt menghasilkan output bagus, simpan di suatu tempat. Aplikasi notes sederhana, file markdown, library prompt. Kata-kata persisnya penting.' },
          { icon: '02', title: 'Simpan output-nya', desc: 'Simpan artefak yang dihasilkan AI yang kamu bangun. Database schema, desain API, outline. Ini dokumen handoff-mu dan kamu akan butuh lagi.' },
          { icon: '03', title: 'Dokumentasikan keputusanmu', desc: 'Ketika kamu dan AI mengeksplorasi dua pendekatan dan pilih satu, tulis kenapa. Future-you akan berterima kasih pada present-you ketika proyek berubah.' },
          { icon: '04', title: 'Lacak yang gagal', desc: 'Prompt yang menghasilkan sampah adalah informasi berharga. Tahu apa yang tidak berhasil adalah setengah dari pertempuran. Simpan "log kegagalan" agar tidak mengulangi kesalahan.' },
        ].map((item, i) => (
          <FadeInBlock client:visible delay={0.25 + i * 0.08}>
            <div style="display: flex; gap: 1rem; align-items: flex-start;">
              <span style={`font-family: var(--font-mono); font-size: 0.7rem; font-weight: 700; color: ${chapter.accent}; flex-shrink: 0; padding-top: 3px;`}>
                {item.icon}
              </span>
              <div>
                <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.2rem;`}>
                  {item.title}
                </p>
                <p style="font-size: 0.9rem; line-height: 1.7; color: var(--color-deep); opacity: 0.75; margin: 0;">
                  {item.desc}
                </p>
              </div>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.6}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        Library prompt-mu seperti buku latihan musisi. Semakin banyak kamu kumpulkan, semakin cepat kamu jadi, dan semakin sedikit kamu mulai dari nol.
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CLOSING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto mb-8" style="max-width: 55ch;">
        Kamu telah beralih dari pemikiran satu-prompt ke dekomposisi, pola handoff, dan context packing. Proyek kompleks tidak lagi menakutkan &mdash; mereka hanya serangkaian percakapan terfokus yang dihubungkan oleh artefak tajam.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Ada satu skill lagi yang lebih penting dari semua ini: tahu kapan AI <em>salah</em>. Halusinasi, sikofansi, dan kebiasaan verifikasi yang membuatmu tetap jujur. Itu selanjutnya.
      </p>
    </FadeInBlock>
  </section>

</ChapterLayout>