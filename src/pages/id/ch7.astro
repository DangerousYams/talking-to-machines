---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import WhatWouldYouBuild from '../../components/widgets/ch7/WhatWouldYouBuild';
import ShipIt from '../../components/breaks/ShipIt';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[6];
---

<ChapterLayout chapter={chapter} locale="id">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>7</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Bab Tujuh
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Menguasai<br />Claude Code
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          AI pair programmer-mu, dari perintah<br />pertama sampai custom Skills.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Ada momen yang selalu diingat setiap coder. Kamu buka terminal, ketik permintaan dalam bahasa sehari-hari, dan lihat AI membaca file-mu, memahami arsitektur project, menulis kode di beberapa file sekaligus, menjalankannya, menemukan error, memperbaiki error, dan menjalankan lagi — semuanya tanpa kamu menyentuh satu baris pun. Claude Code bukan autocomplete. Dia adalah coding tool <em>agentic</em> yang melihat seluruh project-mu, membuat perubahan di banyak file, menjalankan shell command, dan mengiterasi kesalahannya sendiri.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        Tapi tool ini hanya sebaik manusia yang mengarahkannya. Claude Code bisa menulis ribuan baris kode sempurna dalam hitungan detik — atau ribuan baris sampah yang keliatan masuk akal. Bedanya adalah kamu.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE LOOP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Spesifikasi, Generate, Verifikasi
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Ketika kamu memberi Claude Code tugas, dia menjalankan agent loop: baca codebase, rencanakan perubahan, tulis editnya, jalankan kode, perbaiki yang rusak. Siklus ini bisa terjadi tiga, lima, sepuluh kali — semuanya dalam hitungan detik. Tugasmu bukan lagi menulis setiap baris. Tugasmu adalah <strong>menspesifikasikan</strong> apa yang mau dibangun, biarkan AI <strong>meng-generate</strong>, lalu <strong>memverifikasi</strong> bahwa hasilnya benar. Kebanyakan pemula melewati langkah terakhir itu. Mereka lihat kode muncul, keliatan wajar, lalu lanjut. Jangan jadi orang itu. Kode yang di-generate adalah draft pertama. Verifikasimu adalah edit yang membuatnya layak dipublikasikan.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Senjata rahasianya adalah file <code>CLAUDE.md</code> — taruh di root project-mu dan Claude Code akan membacanya di awal setiap sesi. Tech stack, konvensi penamaan, aturan style, ekspektasi testing — semuanya ditulis sekali supaya kamu tidak perlu mengulang. Ini context engineering yang diterapkan untuk coding.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Tujuannya bukan menulis setiap baris — tapi memahami setiap baris.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Kalau kamu tidak bisa membaca kode yang Claude generate, kamu tidak bisa memverifikasinya. User Claude Code terbaik bukan yang generate kode paling banyak — mereka yang mengajukan pertanyaan terbaik dan menangkap bug paling halus.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Lihat loop-nya beraksi. Ketik permintaan dan saksikan Claude Code bekerja.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="terminal-playground" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <WhatWouldYouBuild client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="Bab tentang Claude Code ini gila — lihat AI pair programmer berpikir tentang masalah, menulis kode, dan men-debug dirinya sendiri. Masa depan coding sudah di sini." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Claude Code tidak menulis kode untukmu — dia menulis kode bersamamu.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Satu percakapan bisa menangani satu tugas. Tapi project nyata punya puluhan. Selanjutnya: cara memecah ambisi besar jadi potongan yang bisa AI eksekusi.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Ship It" client:visible>
        <ShipIt client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
