---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import TrustThermometer from '../../components/widgets/ch5/TrustThermometer';
import WouldYouLetIt from '../../components/breaks/WouldYouLetIt';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[4];
---

<ChapterLayout chapter={chapter} locale="id">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>5</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Bab Lima
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Beri Dia<br />Tool
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Lompatan dari "menjawab pertanyaan"<br />ke "mengambil tindakan."
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0; --drop-cap-color: #F5A623;">
        Sampai sekarang, setiap interaksi AI-mu mengikuti pola yang sama. Kamu mengetik sesuatu. AI mengetik balasan. Autocomplete yang sangat canggih. Tapi bagaimana kalau AI bisa <em>melakukan sesuatu</em>? Bukan cuma memberitahu cuaca, tapi mengecek prakiraan. Bukan cuma menulis kode, tapi menjalankannya. Bukan cuma menyarankan apa yang perlu di-Google, tapi mencari sendiri di web dan membawa hasilnya.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE TRUST QUESTION ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Pertanyaan Kepercayaan
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Ketika kamu memberi AI tool, kamu menyerahkan kotak peralatan dan bilang: <em>"Ini hal-hal yang bisa kamu lakukan. Kamu yang putuskan kapan memakainya."</em> Dia bisa mencari di web, menjalankan kode, membaca file, memanggil API. AI-nya tidak jadi lebih pintar — dia jadi <strong>terhubung</strong>. Dan itu menimbulkan pertanyaan yang tidak ada hubungannya dengan teknologi dan segalanya tentang kamu: seberapa banyak yang harus AI lakukan sendiri sebelum mengecek denganmu?
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-14">
        Jawabannya tergantung pada tiga hal. <strong>Risiko</strong> — apa yang terburuk bisa terjadi? <strong>Reversibilitas</strong> — bisakah kamu membatalkannya? Dan <strong>kepercayaan</strong> — seberapa baik kamu mengenal tool ini? Kalkulator yang sudah kamu pakai ratusan kali pantas mendapat lebih banyak kebebasan daripada plugin baru yang belum pernah kamu tes.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Poin penting</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Bukan semua-atau-tidak-sama-sekali. Workflow AI terbaik memberi kebebasan pada tugas berisiko rendah dan reversibel sambil menjaga manusia tetap dalam loop untuk tugas berisiko tinggi dan ireversibel. Tugasmu adalah mendesain batasnya.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Di mana kamu akan menarik garis? Atur tingkat otonomi milikmu sendiri.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <TrustThermometer client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="Belajar tentang tool use dan function calling AI dengan cara paling hands-on. Kursus ini mengajakmu benar-benar membangun dan menguji, bukan cuma membaca." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Tool mengubah AI dari penasihat jadi asisten — dari seseorang yang memberitahu apa yang harus dilakukan, jadi seseorang yang benar-benar melakukannya.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Kamu sudah memberi AI tangan. Selanjutnya, kita menghubungkan tool-tool itu menjadi sesuatu yang bisa mengejar tujuan sendiri — merencanakan, mengeksekusi, pulih dari kesalahan. Saatnya membangun agent.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(245,166,35,0.06) 15%, rgba(245,166,35,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#F5A623" toolName="Would You Let It?" client:visible>
        <WouldYouLetIt client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
