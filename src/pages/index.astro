---
export const prerender = true;
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import GtagHead from '../components/analytics/GtagHead.astro';
import HeadSEO from '../components/seo/HeadSEO.astro';
import { chapters } from '../data/chapters';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="An interactive, visual guide to AI. 11 chapters of scrollytelling, live demos, and hands-on projects." />
    <meta property="og:title" content="Talking to Machines" />
    <meta property="og:description" content="A hands-on guide to AI. Interactive, visual, project-based." />
    <title>Talking to Machines — A Hands-On Guide to AI</title>
    <HeadSEO
      title="Talking to Machines — A Hands-On Guide to AI"
      description="An interactive, visual guide to AI. 11 chapters of scrollytelling, live demos, and hands-on projects. Learn prompt engineering, AI agents, and how to build real projects with AI."
      path="/"
      type="course"
    />
    <GtagHead />
  </head>
  <body class="bg-cream text-deep min-h-screen">

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- HERO — cinematic, typographic, scroll-inviting     -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="min-h-screen flex flex-col items-center justify-center px-6 relative overflow-hidden">
      <!-- Warm gradient atmosphere -->
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(233, 69, 96, 0.04) 0%, transparent 70%);"></div>
        <div class="absolute inset-0" style="background: radial-gradient(ellipse 50% 50% at 80% 70%, rgba(123, 97, 255, 0.03) 0%, transparent 70%);"></div>
        <div class="absolute inset-0" style="background: radial-gradient(ellipse 40% 40% at 20% 80%, rgba(22, 199, 154, 0.02) 0%, transparent 70%);"></div>
      </div>

      <div class="relative z-10 text-center max-w-[700px]">
        <!-- Eyebrow -->
        <p class="text-[11px] tracking-[0.25em] uppercase text-subtle/70 mb-10" style="font-family: var(--font-mono);">
          A scrollytelling curriculum
        </p>

        <!-- Title -->
        <h1 class="mb-8" style="font-family: var(--font-heading);">
          <span class="block text-deep leading-[1.05]" style="font-size: clamp(3rem, 8vw, 5.5rem); font-weight: 800;">
            Talking to
          </span>
          <span class="block leading-[1.05]" style="font-size: clamp(3rem, 8vw, 5.5rem); font-weight: 800; color: var(--color-accent-red);">
            Machines
          </span>
        </h1>

        <!-- Animated subtitle -->
        <div class="mb-14 h-8 md:h-9 relative overflow-hidden" aria-label="A hands-on guide to AI">
          <p
            class="text-xl md:text-2xl leading-relaxed text-deep/70"
            style="font-family: var(--font-body); font-weight: 400;"
          >
            <span
              id="cycling-part"
              class="inline-block transition-all duration-500 ease-in-out"
            >Write</span><span
              id="cycling-suffix"
              class="inline-block transition-opacity duration-500 ease-in-out opacity-100"
            >&nbsp;better with AI</span>
          </p>
        </div>

        <!-- CTA -->
        <a
          href="/ch1"
          class="group inline-flex items-center gap-3 no-underline"
        >
          <span
            class="px-8 py-3.5 rounded-full text-[15px] font-medium transition-all duration-300 group-hover:shadow-lg group-hover:shadow-accent-red/10"
            style="background: var(--color-deep); color: var(--color-cream); font-family: var(--font-body);"
          >
            Begin Chapter One
          </span>
          <span class="w-10 h-10 rounded-full border border-deep/10 flex items-center justify-center transition-all duration-300 group-hover:bg-deep group-hover:text-cream group-hover:border-deep">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>

      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 opacity-30 animate-pulse">
        <div class="w-px h-8 bg-deep/30"></div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- CHAPTERS — editorial table of contents             -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="max-w-[900px] mx-auto px-6 md:px-10 pb-32">
      <!-- Section heading -->
      <div class="flex items-center gap-4 mb-20">
        <div class="flex-1 h-px bg-deep/15"></div>
        <p class="text-[11px] tracking-[0.2em] uppercase text-subtle/70" style="font-family: var(--font-mono);">
          The Curriculum
        </p>
        <div class="flex-1 h-px bg-deep/15"></div>
      </div>

      {[
        { label: 'Part I', title: 'The Fundamentals', color: 'var(--color-accent-red)', chapters: chapters.slice(0, 3), playbook: { slug: 'workshop', title: 'The Workshop', hook: 'Everything you\'ve learned, in one conversation' } },
        { label: 'Part II', title: 'The Toolkit', color: 'var(--color-sky)', chapters: chapters.slice(3, 6), playbook: { slug: 'field-guide', title: 'The Field Guide', hook: 'Prompt recipes for every tool type' } },
        { label: 'Part III', title: 'The Builder\'s Path', color: 'var(--color-teal)', chapters: chapters.slice(6, 11) },
      ].map((part) => (
        <div class="mb-16">
          <div class="mb-6 flex items-baseline gap-4">
            <span class="text-[11px] tracking-[0.2em] uppercase font-medium" style={`font-family: var(--font-mono); color: ${part.color};`}>
              {part.label}
            </span>
            <span class="text-[15px] text-deep/40" style="font-family: var(--font-body); font-style: italic;">
              {part.title}
            </span>
            <div class="flex-1 h-px bg-deep/8"></div>
          </div>
          <div class="grid gap-1">
            {part.chapters.map((ch) => (
              <a
                href={`/${ch.slug}`}
                class="group flex items-baseline gap-4 py-3 px-1 rounded-lg transition-all duration-200 hover:bg-deep/[0.02]"
                style="text-decoration: none;"
              >
                <span
                  class="text-[12px] font-semibold tabular-nums flex-shrink-0 w-6 text-right"
                  style={`font-family: var(--font-mono); color: ${ch.accent}; opacity: 0.5;`}
                >
                  {String(ch.number).padStart(2, '0')}
                </span>
                <h3
                  class="text-[17px] md:text-[18px] font-bold leading-tight transition-colors duration-200"
                  style={`font-family: var(--font-heading); color: ${ch.accent};`}
                >
                  {ch.title}
                </h3>
                <span class="text-[15px] text-deep/45 leading-snug hidden md:inline" style="font-family: var(--font-body); font-style: italic;">
                  {ch.hook}
                </span>
                <svg
                  width="14" height="14" viewBox="0 0 16 16" fill="none"
                  class="flex-shrink-0 opacity-0 -translate-x-2 transition-all duration-200 group-hover:opacity-30 group-hover:translate-x-0 ml-auto"
                >
                  <path d="M4 8h8M9 5l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            ))}
          </div>

          {/* Playbook interlude (if this part has one) */}
          {part.playbook && (
            <a
              href={`/${part.playbook.slug}`}
              class="group flex items-center gap-4 mt-3 py-3 px-4 rounded-lg transition-all duration-200 hover:bg-deep/[0.02]"
              style="text-decoration: none; border: 1px dashed rgba(26,26,46,0.1);"
            >
              <span class="text-[12px] font-semibold flex-shrink-0 w-6 text-right" style="font-family: var(--font-mono); color: var(--color-teal); opacity: 0.6;">
                &#9830;
              </span>
              <span class="text-[17px] md:text-[18px] font-bold leading-tight" style={`font-family: var(--font-heading); color: var(--color-teal);`}>
                {part.playbook.title}
              </span>
              <span class="text-[15px] text-deep/45 leading-snug hidden md:inline" style="font-family: var(--font-body); font-style: italic;">
                {part.playbook.hook}
              </span>
              <svg
                width="14" height="14" viewBox="0 0 16 16" fill="none"
                class="flex-shrink-0 opacity-0 -translate-x-2 transition-all duration-200 group-hover:opacity-30 group-hover:translate-x-0 ml-auto"
              >
                <path d="M4 8h8M9 5l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          )}
        </div>
      ))}

      <!-- Bonus chapter -->
      <a
        href="/absolutely-youre-right"
        class="group flex items-center gap-4 py-3 px-4 rounded-lg transition-all duration-200 hover:bg-deep/[0.02] mb-3"
        style="text-decoration: none; border: 1px dashed rgba(245,166,35,0.2);"
      >
        <span class="text-[12px] font-semibold flex-shrink-0 w-6 text-right" style="font-family: var(--font-mono); color: var(--color-amber); opacity: 0.6;">
          &#9733;
        </span>
        <span class="text-[17px] md:text-[18px] font-bold leading-tight" style="font-family: var(--font-heading); color: var(--color-amber);">
          "Absolutely, You're Right!"
        </span>
        <span class="text-[15px] text-deep/45 leading-snug hidden md:inline" style="font-family: var(--font-body); font-style: italic;">
          The hilarious truth about AI sycophancy
        </span>
        <svg
          width="14" height="14" viewBox="0 0 16 16" fill="none"
          class="flex-shrink-0 opacity-0 -translate-x-2 transition-all duration-200 group-hover:opacity-30 group-hover:translate-x-0 ml-auto"
        >
          <path d="M4 8h8M9 5l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>

      <!-- Appendix: The Playbook -->
      <a
        href="/playbook"
        class="group flex items-center gap-4 py-3 px-4 rounded-lg transition-all duration-200 hover:bg-deep/[0.02] mb-12"
        style="text-decoration: none; border: 1px dashed rgba(123,97,255,0.25);"
      >
        <span class="text-[12px] font-semibold flex-shrink-0 w-6 text-right" style="font-family: var(--font-mono); color: var(--color-purple); opacity: 0.7;">
          §
        </span>
        <span class="text-[17px] md:text-[18px] font-bold leading-tight" style="font-family: var(--font-heading); color: var(--color-purple);">
          The Playbook
        </span>
        <span class="text-[15px] text-deep/45 leading-snug hidden md:inline" style="font-family: var(--font-body); font-style: italic;">
          9 power prompts · copy &amp; keep
        </span>
        <svg
          width="14" height="14" viewBox="0 0 16 16" fill="none"
          class="flex-shrink-0 opacity-0 -translate-x-2 transition-all duration-200 group-hover:opacity-30 group-hover:translate-x-0 ml-auto"
        >
          <path d="M4 8h8M9 5l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>

      <!-- Toolbox + Guides + Course links -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-8">
        <a
          href="/toolbox"
          class="group flex items-center gap-4 no-underline rounded-2xl border border-deep/[0.06] bg-warm-white/60 p-6 transition-all duration-300 hover:border-deep/[0.12] hover:shadow-[0_4px_24px_rgba(0,0,0,0.04)]"
        >
          <span class="text-2xl" style="line-height: 1;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-purple)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" /></svg>
          </span>
          <div>
            <h3 class="text-[17px] font-bold leading-tight mb-0.5" style="font-family: var(--font-heading); color: var(--color-purple);">
              Toolbox
            </h3>
            <p class="text-[13px] text-deep/50 leading-relaxed" style="font-family: var(--font-body);">
              AI tools you unlock by completing chapters
            </p>
          </div>
        </a>
        <a
          href="/guides"
          class="group flex items-center gap-4 no-underline rounded-2xl border border-deep/[0.06] bg-warm-white/60 p-6 transition-all duration-300 hover:border-deep/[0.12] hover:shadow-[0_4px_24px_rgba(0,0,0,0.04)]"
        >
          <span class="text-2xl" style="line-height: 1;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-teal)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20" /><line x1="9" y1="10" x2="15" y2="10" /></svg>
          </span>
          <div>
            <h3 class="text-[17px] font-bold leading-tight mb-0.5" style="font-family: var(--font-heading); color: var(--color-teal);">
              Quick Guides
            </h3>
            <p class="text-[13px] text-deep/50 leading-relaxed" style="font-family: var(--font-body);">
              Beginner-friendly PDFs for tools and infrastructure
            </p>
          </div>
        </a>
        <a
          href="/course"
          class="group flex items-center gap-4 no-underline rounded-2xl border border-deep/[0.06] bg-warm-white/60 p-6 transition-all duration-300 hover:border-deep/[0.12] hover:shadow-[0_4px_24px_rgba(0,0,0,0.04)]"
        >
          <span class="text-2xl">🎓</span>
          <div>
            <h3 class="text-[17px] font-bold leading-tight mb-0.5" style="font-family: var(--font-heading); color: var(--color-accent-red);">
              Live Course
            </h3>
            <p class="text-[13px] text-deep/50 leading-relaxed" style="font-family: var(--font-body);">
              Hands-on workshops with small cohorts on Zoom
            </p>
          </div>
        </a>
      </div>

    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- FAQ — structured data for search + LLM discovery   -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 pb-32">
      <div class="flex items-center gap-4 mb-16">
        <div class="flex-1 h-px bg-deep/15"></div>
        <p class="text-[11px] tracking-[0.2em] uppercase text-subtle/70" style="font-family: var(--font-mono);">
          Common Questions
        </p>
        <div class="flex-1 h-px bg-deep/15"></div>
      </div>

      <div class="space-y-10">
        <div>
          <h3 class="text-[17px] font-bold text-deep mb-2" style="font-family: var(--font-heading);">
            Who is this for?
          </h3>
          <p class="text-[15px] text-deep/70 leading-relaxed" style="font-family: var(--font-body);">
            Anyone who wants to get genuinely good at using AI. No coding experience required. Whether you're a student, a professional, a creative, or just curious — if you've used ChatGPT a few times and want to go much deeper, this is for you. The curriculum takes you from basic prompting all the way to building real projects with AI coding agents.
          </p>
        </div>

        <div>
          <h3 class="text-[17px] font-bold text-deep mb-2" style="font-family: var(--font-heading);">
            Do I need to know how to code?
          </h3>
          <p class="text-[15px] text-deep/70 leading-relaxed" style="font-family: var(--font-body);">
            No. Chapters 1–6 are about prompting, AI tools, and agents — no code involved. Chapters 7–11 teach you to build software using AI coding agents like Claude Code and Cursor, where you describe what you want in plain English and the AI writes the code. You learn to direct, not to program.
          </p>
        </div>

        <div>
          <h3 class="text-[17px] font-bold text-deep mb-2" style="font-family: var(--font-heading);">
            What makes this different from other AI courses?
          </h3>
          <p class="text-[15px] text-deep/70 leading-relaxed" style="font-family: var(--font-body);">
            Three things. First, it's interactive — every chapter has live AI-powered widgets where you practice immediately, not just read. Second, it's honest — there's a whole chapter on when AI gets it wrong, and we don't oversell what it can do. Third, it's designed — this isn't a wall of text. It's a crafted reading experience with scroll-driven visuals and narrative storytelling.
          </p>
        </div>

        <div>
          <h3 class="text-[17px] font-bold text-deep mb-2" style="font-family: var(--font-heading);">
            How much does it cost?
          </h3>
          <p class="text-[15px] text-deep/70 leading-relaxed" style="font-family: var(--font-body);">
            Chapter 1 is completely free. Full access to all 11 chapters, interactive tools, and future content is a one-time payment of $29 — no subscriptions, no upsells.
          </p>
        </div>

        <div>
          <h3 class="text-[17px] font-bold text-deep mb-2" style="font-family: var(--font-heading);">
            What AI tools does this cover?
          </h3>
          <p class="text-[15px] text-deep/70 leading-relaxed" style="font-family: var(--font-body);">
            The curriculum covers prompt engineering techniques that work across all AI models, plus specific tools including Claude, ChatGPT, Midjourney, DALL-E, Stable Diffusion, Suno, Perplexity, Claude Code, Cursor, and 30+ more across image generation, video, music, research, and coding categories.
          </p>
        </div>

        <div>
          <h3 class="text-[17px] font-bold text-deep mb-2" style="font-family: var(--font-heading);">
            How long does it take to complete?
          </h3>
          <p class="text-[15px] text-deep/70 leading-relaxed" style="font-family: var(--font-body);">
            Each chapter takes about 20–40 minutes of reading and interaction. The full curriculum is roughly 6–8 hours at a comfortable pace, but you can go at your own speed. Chapter 11 includes a multi-week capstone project.
          </p>
        </div>

        <div>
          <h3 class="text-[17px] font-bold text-deep mb-2" style="font-family: var(--font-heading);">
            Is this available in other languages?
          </h3>
          <p class="text-[15px] text-deep/70 leading-relaxed" style="font-family: var(--font-body);">
            Yes. All 11 chapters are available in 19 languages including Hindi, Spanish, Portuguese, Arabic, French, Indonesian, Japanese, Korean, German, Chinese, and more.
          </p>
        </div>

        <div>
          <h3 class="text-[17px] font-bold text-deep mb-2" style="font-family: var(--font-heading);">
            Will I actually be able to build things after this?
          </h3>
          <p class="text-[15px] text-deep/70 leading-relaxed" style="font-family: var(--font-body);">
            Yes — that's the point. By Chapter 11 you'll have built a real project: a game, an interactive story, a research tool, a web app, or an AI agent. The curriculum teaches you to use AI coding agents to build functional software, even with zero prior coding experience.
          </p>
        </div>
      </div>
    </section>

    <!-- FAQ structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'Who is Talking to Machines for?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Anyone who wants to get genuinely good at using AI. No coding experience required. Whether you\'re a student, a professional, a creative, or just curious — if you\'ve used ChatGPT a few times and want to go much deeper, this is for you.',
          },
        },
        {
          '@type': 'Question',
          name: 'Do I need to know how to code to take this AI course?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No. Chapters 1–6 cover prompting, AI tools, and agents with no code. Chapters 7–11 teach you to build software using AI coding agents like Claude Code and Cursor, where you describe what you want in plain English and the AI writes the code.',
          },
        },
        {
          '@type': 'Question',
          name: 'What makes Talking to Machines different from other AI courses?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'It\'s interactive (live AI-powered practice widgets in every chapter), honest (covers AI limitations and failures, not just hype), and designed as a crafted editorial experience with scroll-driven visuals, not a wall of text.',
          },
        },
        {
          '@type': 'Question',
          name: 'How much does the Talking to Machines course cost?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Chapter 1 is completely free. Full access to all 11 chapters, interactive tools, and future content is a one-time payment of $29 — no subscriptions, no upsells.',
          },
        },
        {
          '@type': 'Question',
          name: 'What AI tools does this curriculum cover?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Prompt engineering techniques that work across all AI models, plus specific coverage of Claude, ChatGPT, Midjourney, DALL-E, Stable Diffusion, Suno, Perplexity, Claude Code, Cursor, and 30+ more tools across image, video, music, research, and coding categories.',
          },
        },
        {
          '@type': 'Question',
          name: 'How long does it take to complete the Talking to Machines curriculum?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Each chapter takes about 20–40 minutes. The full curriculum is roughly 6–8 hours at a comfortable pace. Chapter 11 includes a multi-week capstone project.',
          },
        },
        {
          '@type': 'Question',
          name: 'Is this AI course available in other languages?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. All 11 chapters are available in 19 languages including Hindi, Spanish, Portuguese, Arabic, French, Indonesian, Japanese, Korean, German, Chinese, and more.',
          },
        },
        {
          '@type': 'Question',
          name: 'Will I be able to build software after completing this course?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. By Chapter 11 you\'ll have built a real project: a game, an interactive story, a research tool, a web app, or an AI agent — using AI coding agents, even with zero prior coding experience.',
          },
        },
      ],
    })} />

    <script>
      const lines = [
        { verb: 'Write' },
        { verb: 'Code' },
        { verb: 'Research' },
        { verb: 'Create' },
        { verb: 'Solve problems' },
        { verb: 'Think' },
      ];

      const part = document.getElementById('cycling-part');
      if (part) {
        let i = 0;
        setInterval(() => {
          part.style.opacity = '0';
          part.style.transform = 'translateY(6px)';
          setTimeout(() => {
            i = (i + 1) % lines.length;
            part.textContent = lines[i].verb;
            part.style.transform = 'translateY(-6px)';
            void part.offsetHeight;
            part.style.opacity = '1';
            part.style.transform = 'translateY(0)';
          }, 400);
        }, 2800);
      }
    </script>
    <Analytics />
  </body>
</html>
