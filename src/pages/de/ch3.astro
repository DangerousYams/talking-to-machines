---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ContextWindowViz from '../../components/widgets/ch3/ContextWindowViz';
import VibeCheck from '../../components/breaks/VibeCheck';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[2];
---

<ChapterLayout chapter={chapter} locale="de">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>3</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Kapitel drei
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Context<br />Engineering
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          KI vergisst nicht &mdash; sie hat sich<br />von Anfang an nichts gemerkt.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Jedes Mal, wenn du einer KI eine Nachricht schickst, liest sie deine <em>gesamte Unterhaltung</em> von Grund auf neu &mdash; jede Nachricht, die du geschickt hast, jede Antwort, die sie gegeben hat &mdash; generiert eine Antwort und vergisst dann alles. Nächste Runde, dasselbe Spiel. Das komplette Transkript wird erneut eingespeist. Sie ist die fleißigste, aber vergesslichste Leserin der Welt: jedes Mal vollständig gründlich, jede Runde bei null startend.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONCEPT SETUP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Das Fenster hat Grenzen
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10" style="margin-top: 0;">
        Dieses Transkript, das die KI jede Runde neu liest? Es lebt in etwas, das sich <strong>Kontextfenster</strong> nennt &mdash; gemessen in <strong>Tokens</strong> (grob ein Token pro dreiviertel Wort). Claudes Fenster fasst etwa 200.000 Tokens &mdash; ein 500-seitiges Buch. Klingt riesig, aber jede Nachricht, die du sendest, jede Antwort, die du bekommst, und jede versteckte Systemanweisung essen vom selben Budget. Es füllt sich schneller, als du denkst.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Wenn das Budget aufgebraucht ist, fallen die ältesten Nachrichten über den Rand. Du hast deine Lebensmittelunverträglichkeiten in Nachricht drei erwähnt? Ab Nachricht fünfzehn sieht die KI sie vielleicht nicht mehr. Sie ist nicht nachlässig &mdash; sie kann buchstäblich nicht sehen, was nicht mehr vor ihr liegt. Die KI ist nur so gut wie die Informationen, die sich gerade in ihrem Fenster befinden.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Deshalb schreiben die besten KI-Nutzer nicht nur gute Prompts &mdash; sie managen, was <em>ins</em> Fenster kommt. Regelmäßig zusammenfassen, damit wichtige Details sichtbar bleiben. Das Wichtigste nach vorne packen. Neu starten, wenn das Thema wechselt. Strukturierte Formate verwenden, damit die KI deinen Kontext effizient verarbeiten kann. <strong>Context Engineering ist das neue Prompt Engineering.</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Wichtige Erkenntnis</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Einen großartigen Prompt zu schreiben ist Schritt eins. Zu entscheiden, welche Informationen du der KI vorsetzt &mdash; und wie du sie strukturierst &mdash; da liegt der wahre Hebel. Der beste Prompt der Welt scheitert, wenn der Kontext falsch ist.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Sieh zu, wie sich das Kontextfenster füllt, überläuft und vergisst &mdash; in Echtzeit.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ContextWindowViz client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="Endlich verstanden, warum KI mitten im Gespräch Dinge 'vergisst'. Es ist kein Gedächtnis -- es ist ein Kontextfenster. Dieser Kurs erklärt es super klar mit Live-Demos." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Du siehst jetzt das Whiteboard. Du spürst die Grenzen des Fensters. Das verändert jedes Gespräch, das du mit KI führst.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Bisher haben wir mit Chatbots gearbeitet. Als Nächstes zoomen wir raus &mdash; hunderte KI-Tools existieren jenseits des Chatfensters, und die Landschaft zu kennen verändert, was du für möglich hältst.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Vibe Check" client:visible>
        <VibeCheck client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
