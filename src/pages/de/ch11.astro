---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ProjectInstructionsBuilder from '../../components/widgets/ch11/ProjectInstructionsBuilder';

const chapter = chapters[10];
const conceptsSummary = chapter.concepts.map(c => c.name).join(', ');
---

<ChapterLayout chapter={chapter} locale="de">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>11</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Kapitel elf
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Bau etwas<br />Echtes
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Wissen ohne Schaffen ist Trivialwissen.<br />Es ist Zeit zu shippen.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Du hast es geschafft. In zehn Kapiteln bist du von "hilf mir bei meinem Aufsatz" zu Context Engineering, Agenten bauen, Software-Vokabular lernen, den Build-Loop meistern und Geschmack entwickeln gekommen. Aber hier ist die unbequeme Wahrheit: <strong>Nichts davon zählt, bis du etwas baust.</strong> Über KI zu lesen ist wie über Schwimmen zu lesen &mdash; du kannst jede Schwimmtechnik studieren, aber bis du ins Wasser gehst, <em>weißt</em> du nichts davon. Du weißt nur <em>darüber</em>.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ SET UP YOUR AI ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Richte deine KI ein
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Bevor du deinen ersten Prompt schreibst, gibt es einen Power-Move, den die meisten Anfänger überspringen: <strong>Gib deinem KI-Tool eine permanente Instruktionsdatei.</strong> Statt dein Projekt jede Sitzung neu zu erklären, schreibst du es einmal und deine KI liest es automatisch. Claude Code liest <code>CLAUDE.md</code>. Cursor liest <code>.cursorrules</code>. GitHub Copilot liest <code>.github/copilot-instructions.md</code>. Gleiches Konzept, verschiedene Dateinamen. Das ist Context Engineering aus Kapitel 3 &mdash; angewandt auf Projektebene.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Eine gute Instruktionsdatei beantwortet drei Fragen: Was baust du, was sind die Regeln und wie sieht "gut" aus? Wenn du die richtig hinbekommst, startet jedes Gespräch mit deiner KI zehn Schritte voraus. Halte den Projektumfang klein genug zum Fertigwerden &mdash; ein fertiger Wochenend-Hack schlägt ein aufgegebenes Meisterwerk jedes Mal.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style="font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;">Wichtige Erkenntnis</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Eine gute Projekt-Instruktionsdatei ist der Unterschied zwischen einer KI, die dir hilft, und einer KI, die dich <em>versteht</em>. Einmal schreiben, jede Sitzung profitieren.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Erstelle deine Projekt-Instruktionsdatei direkt hier. Füll die Abschnitte aus und exportiere sie für dein KI-Tool deiner Wahl.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="project-instructions-builder" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ProjectInstructionsBuilder client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Werkzeuge bauen keine Dinge. Menschen mit Werkzeugen bauen Dinge. Und du hast das beste Toolkit, das deine Generation je zur Verfügung hatte.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto mb-8" style="max-width: 55ch;">
        Vor elf Kapiteln hast du "hilf mir bei meinem Aufsatz" getippt und auf das Beste gehofft. Jetzt designst du Kontext, baust Agenten, sprichst die Sprache der Software, iterierst mit Selbstvertrauen und bringst Geschmack in alles ein, was du erschaffst. Der Kurs ist vorbei. Das echte Lernen beginnt jetzt &mdash; geh und mach etwas, auf das nur du kommen würdest.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-center mt-4" style={`font-family: var(--font-heading); font-size: 1.8rem; font-weight: 800; color: ${chapter.accent}; letter-spacing: -0.02em;`}>
        Ship it.
      </p>
    </FadeInBlock>
  </section>

</ChapterLayout>
