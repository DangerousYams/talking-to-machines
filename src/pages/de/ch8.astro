---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import StackDecoder from '../../components/widgets/ch8/StackDecoder';
import ComplexityScore from '../../components/breaks/ComplexityScore';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[7];
---

<ChapterLayout chapter={chapter} locale="de">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>8</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Kapitel acht
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Komplexität<br />orchestrieren
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          KI-Projekte managen, die größer sind<br />als jedes Kontextfenster.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Hier ist der Moment, an den jeder ambitionierte Anfänger stößt: Du bittest KI, etwas Echtes zu bauen -- ein ganzes Spiel, eine Website mit Backend, eine Forschungsarbeit mit Quellenangaben -- und das Ganze fällt auseinander. Nicht weil die KI nicht schlau genug ist. Sondern weil das Projekt zu groß für eine einzelne Unterhaltung ist. Du fügst eine Wand von Anforderungen ein und merkst zwanzig Minuten später, dass sie die Hälfte vergessen hat.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        Das ist kein KI-Problem. Es ist ein <strong>Orchestrierungsproblem</strong>. Und es lösen zu lernen ist der Unterschied zwischen jemandem, der KI für Einzelaufgaben nutzt, und jemandem, der damit echte Dinge baut.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONTEXT PACKING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Die Kunst des Kontextpackens
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Komplexe Projekte sprengen den Ein-Prompt-Ansatz. Der Kontext läuft über, die Aufmerksamkeit verwässert, Fehler potenzieren sich. Die Lösung ist kein besserer Prompt -- es ist <strong>Zerlegung</strong>. Zerlege das Projekt in fokussierte Aufgaben und wähle dann für jede Aufgabe sorgfältig aus, welchen Kontext die KI wirklich braucht. Zu wenig und sie halluziniert. Zu viel und sie verliert den Fokus. Der Sweet Spot ist chirurgische Präzision.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Stell es dir wie Kofferpacken vor. Du kannst nicht deinen ganzen Kleiderschrank mitnehmen. Du musst überlegen, wohin du fährst (die Aufgabe), was du brauchen wirst (relevante Informationen) und was du zurücklassen kannst (alles andere). Jede Unterhaltung bekommt genau den Kontext, den sie braucht -- nicht mehr und nicht weniger.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style="font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;">Wichtige Erkenntnis</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Die Qualität deines Übergabe-Artefakts bestimmt die Qualität von allem, was darauf aufbaut. Ein präzises Schema schlägt jedes Mal eine vage Beschreibung. Müll rein, Müll raus -- über Unterhaltungen hinweg.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Packe einen Kontext-Koffer. Schaffst du es, das Wichtige unterzubringen, ohne überzulaufen?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <StackDecoder client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="Das Schwierigste an KI ist nicht das Prompting -- es ist das Orchestrieren komplexer Projekte über mehrere Unterhaltungen hinweg. Dieser Kurs erklärt endlich, wie das geht." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style="border-color: var(--color-navy); max-width: 50ch; margin: 0 auto 2rem;">
        Komplexe Projekte sind nicht beängstigend. Sie sind nur eine Reihe fokussierter Unterhaltungen, verbunden durch präzise Artefakte.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Als Nächstes: erkennen, wann KI <em>falsch liegt</em>. Halluzinationen, Gefälligkeitsantworten und die Überprüfungsgewohnheiten, die dich ehrlich halten.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(15,52,96,0.06) 15%, rgba(15,52,96,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#0F3460" toolName="Complexity Score" client:visible>
        <ComplexityScore client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
