---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import StackDecoder from '../../components/widgets/ch8/StackDecoder';
import ComplexityScore from '../../components/breaks/ComplexityScore';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';
import ForYouCard from '../../components/ui/ForYouCard';

const chapter = chapters[7];
const conceptsSummary = chapter.concepts.map(c => c.name).join(', ');
---

<ChapterLayout chapter={chapter} locale="de">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>8</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Kapitel Acht
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Die Sprache<br />des Bauens
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Das Vokabular des Bauens &mdash;<br />kein Code, nur die Substantive und Verben.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Du bist kurz davor, dich mit einem Coding-Agenten hinzusetzen und etwas zu bauen. Er wird Wörter wie &bdquo;Deploy&ldquo;, &bdquo;Endpoint&ldquo;, &bdquo;Komponente&ldquo; und &bdquo;Schema&ldquo; benutzen. Wenn diese Wörter undurchsichtig sind, wirst du dich verloren fühlen &mdash; nicht weil du nicht bauen kannst, sondern weil du nicht <em>Regie führen</em> kannst. Dieses Kapitel gibt dir den Decoder-Ring. Nicht wie man programmiert. Wie man <strong>die Sprache des Bauens spricht</strong>.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        Stell es dir wie Autofahren vor. Du musst Verbrennungsmotoren, Übersetzungsverhältnisse oder Bremsflüssigkeitsdruck nicht verstehen. Du musst wissen: Gaspedal, Bremse, Lenkrad, Spiegel. Das Vokabular der <em>Steuerung</em>, nicht der Implementierung.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE STACK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Der Stack: ein Decoder-Ring
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Jede App &mdash; von Instagram bis zu einer einfachen To-Do-Liste &mdash; besteht aus vier Schichten. Entwickler nennen das &bdquo;den Stack.&ldquo; Hier ist das Ganze, entmystifiziert:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div style="display: grid; gap: 1rem; margin-bottom: 3rem;">
        <div style="padding: 1.25rem 1.5rem; border-left: 4px solid #7B61FF; background: rgba(123,97,255,0.04); border-radius: 0 8px 8px 0;">
          <p style="font-family: var(--font-heading); font-weight: 700; margin: 0 0 0.25rem; color: #7B61FF;">Frontend</p>
          <p style="margin: 0; line-height: 1.6;">Was die Leute sehen und anfassen. Buttons, Text, Bilder, Animationen. Der Gastraum eines Restaurants.</p>
        </div>
        <div style="padding: 1.25rem 1.5rem; border-left: 4px solid #0F3460; background: rgba(15,52,96,0.04); border-radius: 0 8px 8px 0;">
          <p style="font-family: var(--font-heading); font-weight: 700; margin: 0 0 0.25rem; color: #0F3460;">Backend</p>
          <p style="margin: 0; line-height: 1.6;">Die Logik hinter den Kulissen. Verarbeitet Anfragen, prüft Passwörter, verschickt E-Mails. Die Küche.</p>
        </div>
        <div style="padding: 1.25rem 1.5rem; border-left: 4px solid #16C79A; background: rgba(22,199,154,0.04); border-radius: 0 8px 8px 0;">
          <p style="font-family: var(--font-heading); font-weight: 700; margin: 0 0 0.25rem; color: #16C79A;">Datenbank</p>
          <p style="margin: 0; line-height: 1.6;">Wo deine App sich Dinge merkt. Benutzerkonten, Beiträge, Einstellungen. Die Vorratskammer und das Rezeptbuch.</p>
        </div>
        <div style="padding: 1.25rem 1.5rem; border-left: 4px solid #E94560; background: rgba(233,69,96,0.04); border-radius: 0 8px 8px 0;">
          <p style="font-family: var(--font-heading); font-weight: 700; margin: 0 0 0.25rem; color: #E94560;">Deployment</p>
          <p style="margin: 0; line-height: 1.6;">Wie es ins Internet kommt. Hosting, Domains, live gehen. Die Restauranttüren öffnen.</p>
        </div>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85] mb-14">
        Das war's. Jede App, die du je benutzt hast, ist irgendeine Kombination dieser vier Schichten. Wenn dein Coding-Agent sagt &bdquo;Ich richte das Backend ein&ldquo;, meint er &bdquo;Ich schreibe die Logik hinter den Kulissen.&ldquo; Wenn er sagt &bdquo;Lass uns deployen&ldquo;, meint er &bdquo;Lass uns das ins Internet stellen.&ldquo; Du musst nicht wissen, <em>wie</em> diese Schichten funktionieren. Du musst wissen, <em>dass</em> sie existieren und wofür sie da sind.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE AGENT AS TUTOR ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Der Agent als Tutor
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Hier ist der Teil, den niemand dir sagt: <strong>Der Coding-Agent ist auch dein Lehrer.</strong> Weißt du nicht, was &bdquo;npm&ldquo; bedeutet? Frag. Verwirrt von einer Fehlermeldung? Kopier sie rein und sag &bdquo;Erkläre das so, als wäre ich kein Entwickler.&ldquo; Willst du wissen, warum der Agent React statt etwas anderem gewählt hat? Frag. Er erklärt seine Überlegungen in einfacher Sprache, Schritt für Schritt, so oft du willst.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Deine ersten fünf Minuten</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Öffne dein Coding-Tool. Beschreibe dein Projekt in einfacher Sprache: &bdquo;Ich möchte einen Workout-Tracker bauen, wo ich meine Übungen eintrage und meinen Fortschritt sehen kann.&ldquo; Der Agent wird Rückfragen stellen, einen Stack vorschlagen und anfangen zu bauen. Dein erster Job ist es, <em>seine Fragen zu beantworten</em> und <em>zu beobachten, was er erstellt</em>.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Entdecke die vier Schichten einer Web-App. Klick, um das Vokabular zu lernen &mdash; dann teste dich selbst.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <StackDecoder client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <div class="py-8">
    <ForYouCard
      chapterSlug={chapter.slug}
      chapterTitle={chapter.title}
      chapterConcepts={conceptsSummary}
      accentColor={chapter.accent}
      client:load
    />
  </div>
  <SharePrompt text="Dieses Kapitel erklärt den Tech-Stack ohne Code. Frontend, Backend, Datenbank, Deployment &mdash; endlich ergibt alles Sinn. Hätte ich das vor Jahren gelesen." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style="border-color: var(--color-navy); max-width: 50ch; margin: 0 auto 2rem;">
        Du musst nicht wissen, wie der Motor funktioniert. Du musst wissen, wie man fährt.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Du kennst die Wörter. Du hast die Idee. Jetzt ist es Zeit, dich mit deinem Coding-Agenten hinzusetzen und tatsächlich zu bauen. Als Nächstes: die Kunst des Build-Loops &mdash; Iteration, Bewertung und was du tust, wenn etwas kaputtgeht.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(15,52,96,0.06) 15%, rgba(15,52,96,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#0F3460" toolName="Complexity Score" client:visible>
        <ComplexityScore client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
