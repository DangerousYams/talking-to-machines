---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import BeatSection from '../../components/chapter/BeatSection';
import PromptMakeover from '../../components/widgets/ch1/PromptMakeover';
import GuessThePrompt from '../../components/widgets/ch1/GuessThePrompt';
import IterationLoop from '../../components/widgets/ch1/IterationLoop';
import PromptRoast from '../../components/widgets/ch1/PromptRoast';
import PromptComparison from '../../components/widgets/ch1/PromptComparison';
import BeatCompletionCard from '../../components/chapter/BeatCompletionCard';

const chapter = chapters[0];
const beats = chapter.beats!;
---

<ChapterLayout chapter={chapter} locale="de">

  <!-- ═══ BEAT 1: The Communication Gap ═══ -->
  <BeatSection
    beatId={beats[0].id}
    beatNumber={1}
    totalBeats={beats.length}
    title="Die Kommunikationslücke"
    tldr="Vage Prompts bekommen vage Antworten. Die Lücke zwischen dem, was KI kann, und dem, was die meisten Leute rausholen, ist ein Kommunikationsproblem."
    estimatedMinutes={beats[0].estimatedMinutes}
    accentColor={chapter.accent}
    nextBeatTitle="Die fünf Bausteine"
    isFirst={true}
    client:load
  >
    <!-- HERO -->
    <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
      <div class="chapter-number" style={`color: ${chapter.accent};`}>1</div>

      <div class="max-w-[680px] mx-auto text-center relative z-10">
        <FadeInBlock client:visible>
          <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
            Kapitel eins
          </p>
        </FadeInBlock>

        <FadeInBlock client:visible delay={0.15}>
          <h1
            class="mb-8 leading-[1.08]"
            style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
          >
            Du sprichst bereits KI
          </h1>
        </FadeInBlock>

        <FadeInBlock client:visible delay={0.3}>
          <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
            Dein erster Entwurf wird kein Wunder.<br />Aber dein dritter könnte es sein.
          </p>
        </FadeInBlock>
      </div>

      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
        <div class="w-px h-10 bg-deep/40"></div>
      </div>
    </section>

    <!-- STORY OPENER -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
      <FadeInBlock client:visible>
        <p class="drop-cap text-lg leading-[1.85] mb-8">
          Du redest schon dein ganzes Leben mit KI. Jedes Mal, wenn du etwas in eine Suchleiste getippt, Siri eine Frage gestellt oder eine Netflix-Empfehlung bekommen hast, hat ein Algorithmus zugehört. Aber es gibt einen Unterschied, ob man <em>zu</em> einer Maschine redet oder <em>mit</em> ihr.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-8">
          Gerade jetzt tippen Millionen Menschen einen Prompt in ChatGPT, bekommen eine mittelmäßige Antwort und denken: <em>„KI ist wohl doch nicht so schlau."</em> Sie irren sich. KI ist außergewöhnlich leistungsfähig. Sie fragen nur nicht richtig.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.2}>
        <p class="text-lg leading-[1.85]">
          Die Lücke zwischen <strong>dem, was KI kann</strong> und <strong>dem, was die meisten Leute aus ihr rausholen</strong> ist riesig. Und es ist kein Technologieproblem — es ist ein Kommunikationsproblem. Eins, das du bereits lösen kannst.
        </p>
      </FadeInBlock>
    </section>

    <Divider accent={chapter.accent} client:load />

    <!-- THE VAGUE PROMPT PROBLEM -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
      <FadeInBlock client:visible>
        <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
        <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
          Das Problem mit dem vagen Prompt
        </h2>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-12">
          Zwei Leute bitten dieselbe KI um Hilfe bei einem Aufsatz. Einer bekommt eine nutzlose Antwort. Der andere bekommt etwas wirklich Geniales. Dieselbe KI. Der einzige Unterschied ist, wie sie gefragt haben.
        </p>
      </FadeInBlock>
    </section>

    <section class="max-w-[960px] mx-auto px-6 md:px-10 pb-16">
      <FadeInBlock client:visible delay={0.2}>
        <PromptComparison accentColor={chapter.accent} client:visible />
      </FadeInBlock>
    </section>
    <BeatCompletionCard beatId={beats[0].id} beatTitle="Die Kommunikationslücke" nextBeatTitle="Die fünf Bausteine" accentColor={chapter.accent} client:visible />
  </BeatSection>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BEAT 2: The Five Building Blocks ═══ -->
  <BeatSection
    beatId={beats[1].id}
    beatNumber={2}
    totalBeats={beats.length}
    title="Die fünf Bausteine"
    tldr="Jeder gute Prompt verwendet eine Kombination aus Rolle, Aufgabe, Format, Einschränkungen und Beispielen."
    estimatedMinutes={beats[1].estimatedMinutes}
    accentColor={chapter.accent}
    nextBeatTitle="Die Iterations-Denkweise"
    client:load
  >
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
      <FadeInBlock client:visible>
        <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
        <h2 class="mb-8" style="font-family: var(--font-heading);">
          Die fünf Bausteine
        </h2>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-6">
          Hier ist der Unterschied zwischen Leuten, die unglaubliche Ergebnisse von KI bekommen, und solchen, die generischen Brei kriegen. Es ist kein Talent. Es ist kein geheimes Tool. Es ist eine Formel — fünf Bausteine, die jedes Mal funktionieren.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.2}>
        <p class="text-lg leading-[1.85] mb-14">
          Du brauchst nicht immer alle fünf. Aber zu wissen, dass sie existieren, ist wie in der Matrix sehen zu lernen. Sobald du das Muster erkennst, kannst du es nicht mehr übersehen.
        </p>
      </FadeInBlock>

      <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
        {[
          { letter: 'R', name: 'Rolle', color: '#E94560', text: 'Wer soll die KI sein? „Du bist ein erfahrener Deutsch-Tutor" ändert alles. Ein Tutor erklärt. Ein Professor doziert. Ein Freund improvisiert. Die Rolle bestimmt Ton, Wortschatz und Tiefe.' },
          { letter: 'A', name: 'Aufgabe', color: '#0F3460', text: 'Was genau soll sie tun? Nicht „hilf mir bei meinem Aufsatz", sondern „stärke meine These". Sei gnadenlos konkret. Eine Aufgabe pro Prompt ist fast immer besser als drei.' },
          { letter: 'F', name: 'Format', color: '#7B61FF', text: 'Wie soll die Antwort aussehen? „Gib mir 3 Alternativen" ist ein Format. Genauso wie „als Stichpunktliste", „in unter 100 Wörtern" oder „als Tabelle, die Vor- und Nachteile vergleicht". Format verhindert Geschwurbel.' },
          { letter: 'E', name: 'Einschränkungen', color: '#16C79A', text: 'Was soll sie nicht tun? „Verwende keine Klischees." „Bleib unter 200 Wörtern." Einschränkungen sind Leitplanken. Sie verhindern, dass die KI irgendwohin abdriftet, wo es nichts bringt.' },
          { letter: 'B', name: 'Beispiele', color: '#F5A623', text: 'Zeigen, nicht beschreiben. Wenn du einen bestimmten Stil willst, gib ein Beispiel, wie „gut" aussieht. Ein Beispiel ist mehr wert als hundert Wörter Beschreibung.' },
        ].map((block, i) => (
          <FadeInBlock client:visible delay={i * 0.08}>
            <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
              <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${block.color};`}>
                {block.letter}
              </div>
              <div style="flex: 1;">
                <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${block.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                  {block.name}
                </p>
                <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                  {block.text}
                </p>
              </div>
            </div>
          </FadeInBlock>
        ))}
      </div>

      <FadeInBlock client:visible delay={0.5}>
        <div class="insight-box">
          <p style="font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;">Wichtige Erkenntnis</p>
          <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
            Du brauchst nicht jedes Mal alle fünf. Eine lockere Frage braucht keine Einschränkungen und Beispiele. Aber wenn die KI dir Müll liefert, schau, was fehlt. Es ist fast immer einer dieser fünf.
          </p>
        </div>
      </FadeInBlock>
    </section>

    <!-- BRIDGE TO PROMPT MAKEOVER -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
      <FadeInBlock client:visible>
        <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
          Genug Theorie. Zeit, die Bausteine in Aktion zu sehen.
        </p>
      </FadeInBlock>
    </section>

    <!-- WIDGET: PROMPT MAKEOVER -->
    <section id="prompt-makeover" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
      <FadeInBlock client:visible>
        <PromptMakeover client:visible />
      </FadeInBlock>
    </section>
    <BeatCompletionCard beatId={beats[1].id} beatTitle="Die fünf Bausteine" nextBeatTitle="Die Iterations-Denkweise" accentColor={chapter.accent} client:visible />
  </BeatSection>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BEAT 3: The Iteration Mindset ═══ -->
  <BeatSection
    beatId={beats[2].id}
    beatNumber={3}
    totalBeats={beats.length}
    title="Die Iterations-Denkweise"
    tldr="Niemand trifft es beim ersten Versuch. Prompten, bewerten, verfeinern, wiederholen — dieser Kreislauf ist die eigentliche Fähigkeit."
    estimatedMinutes={beats[2].estimatedMinutes}
    accentColor={chapter.accent}
    nextBeatTitle="Teste dein Wissen"
    client:load
  >
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
      <FadeInBlock client:visible>
        <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
        <h2 class="mb-8" style="font-family: var(--font-heading);">
          Iteration, nicht Perfektion
        </h2>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-10">
          Der erste Prompt funktioniert fast nie. Und das ist okay. <strong>Das ist tatsächlich der ganze Sinn.</strong>
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
          Wenn du eine Demo siehst, in der KI etwas Beeindruckendes produziert, siehst du den finalen Prompt — den, bei dem jemand nach fünf, zehn, vielleicht zwanzig Durchgängen gelandet ist. Du siehst die Highlights, nicht die Übungseinheiten.
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.2}>
        <p class="text-lg leading-[1.85] mb-10">
          Der echte Workflow sieht so aus:
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.25}>
        <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
          <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
          {[
            { word: 'Prompten.', desc: 'Schreib deinen besten ersten Versuch.' },
            { word: 'Bewerten.', desc: 'Lies die Antwort. Was ist gut? Was stimmt nicht?' },
            { word: 'Verfeinern.', desc: 'Passe den Prompt an. Sei spezifischer, wo es nicht geklappt hat.' },
            { word: 'Wiederholen.', desc: 'Bis das Ergebnis etwas ist, das du tatsächlich verwenden würdest.' },
          ].map((step, i) => (
            <div style={`position: relative; padding-bottom: ${i < 3 ? '1.75rem' : '0'};`}>
              <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
              <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
                <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
                <span style="opacity: 0.7;"> {step.desc}</span>
              </p>
            </div>
          ))}
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg leading-[1.85] mb-10">
          Dieser Kreislauf — prompten, bewerten, verfeinern, wiederholen — ist die <em>eigentliche Fähigkeit</em> im Umgang mit KI. Nicht irgendeinen magisch perfekten Prompt beim ersten Versuch zu schreiben. Das ist ein Mythos.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.35}>
        <div class="insight-box">
          <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Ein gutes Ergebnis braucht im Schnitt 3-5 Durchgänge, nicht einen.</p>
          <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
            Wenn es beim ersten Versuch klappt, forderst du wahrscheinlich nicht genug. Die besten Ergebnisse entstehen durch ein Hin und Her, bei dem du und die KI gemeinsam verfeinert.
          </p>
        </div>
      </FadeInBlock>
    </section>

    <!-- WIDGET: ITERATION LOOP -->
    <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
      <FadeInBlock client:visible>
        <IterationLoop client:visible />
      </FadeInBlock>
    </section>

    <Divider accent={chapter.accent} client:load />

    <!-- THE PROMPT SPECTRUM -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
      <FadeInBlock client:visible>
        <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
        <h2 class="mb-8" style="font-family: var(--font-heading);">
          Das Prompt-Spektrum
        </h2>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] mb-12">
          Denk an jeden Prompt als Punkt auf einem Spektrum von vage bis präzise:
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <div style="margin-bottom: 3rem;">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 1.25rem;">
            <span style="font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600; letter-spacing: 0.08em; color: var(--color-subtle); opacity: 0.6;">VAGE</span>
            <div style="flex: 1; height: 4px; border-radius: 2px; background: linear-gradient(90deg, #CBD5E1 0%, #F5A623 40%, #E94560 70%, #16C79A 100%);"></div>
            <span style="font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600; letter-spacing: 0.08em; color: var(--color-subtle); opacity: 0.6;">PRÄZISE</span>
          </div>
          <div class="grid grid-cols-3 gap-4 text-center">
            <div>
              <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-subtle); margin: 0 0 4px;">„hilf mir"</p>
              <p style="font-family: var(--font-body); font-size: 0.7rem; color: var(--color-subtle); opacity: 0.5; margin: 0;">generische Antwort</p>
            </div>
            <div>
              <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-amber); margin: 0 0 4px;">„schreib was über X"</p>
              <p style="font-family: var(--font-body); font-size: 0.7rem; color: var(--color-subtle); opacity: 0.5; margin: 0;">okay, aber unfokussiert</p>
            </div>
            <div>
              <p style={`font-family: var(--font-mono); font-size: 0.75rem; color: ${chapter.accent}; font-weight: 600; margin: 0 0 4px;`}>„alle fünf Bausteine"</p>
              <p style="font-family: var(--font-body); font-size: 0.7rem; color: var(--color-subtle); opacity: 0.5; margin: 0;">zielgerichtet, nützlich</p>
            </div>
          </div>
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.2}>
        <p class="text-lg leading-[1.85] mb-10">
          Dein Ziel ist nicht, immer am „präzisen" Ende zu sein. Ein lockeres Brainstorming darf absichtlich vage sein. Aber <strong>du solltest bewusst wählen, wo du auf dem Spektrum stehst</strong>, nicht zufällig dort landen.
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.25}>
        <p class="text-lg leading-[1.85]">
          Die Leute, die das Meiste aus KI rausholen, lernen keine magischen Prompts auswendig. Sie entwickeln ein Gespür dafür, <em>wie spezifisch sie sein müssen</em> — und wenn die erste Antwort nicht gut genug ist, wissen sie genau, an welchem Rädchen sie drehen müssen.
        </p>
      </FadeInBlock>
    </section>
    <BeatCompletionCard beatId={beats[2].id} beatTitle="Die Iterations-Denkweise" nextBeatTitle="Teste dein Wissen" accentColor={chapter.accent} client:visible />
  </BeatSection>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BEAT 4: Test Yourself ═══ -->
  <BeatSection
    beatId={beats[3].id}
    beatNumber={4}
    totalBeats={beats.length}
    title="Teste dein Wissen"
    tldr="Setz deine neuen Fähigkeiten auf die Probe — errate den Prompt hinter KI-Ergebnissen und lass deine eigenen Prompts bewerten."
    estimatedMinutes={beats[3].estimatedMinutes}
    accentColor={chapter.accent}
    client:load
  >
    <!-- WIDGET: GUESS THE PROMPT -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
      <FadeInBlock client:visible>
        <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
          Alles verstanden? Lass es uns auf die Probe stellen.
        </p>
      </FadeInBlock>
    </section>

    <section id="guess-the-prompt" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
      <FadeInBlock client:visible>
        <GuessThePrompt client:visible />
      </FadeInBlock>
    </section>

    <Divider accent={chapter.accent} client:load />

    <!-- PROMPT ROAST BRIDGE -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-12">
      <FadeInBlock client:visible>
        <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
          Glaubst du, du kannst jetzt einen guten Prompt schreiben? Es gibt nur einen Weg, das herauszufinden.
        </p>
      </FadeInBlock>
    </section>

    <!-- WIDGET: PROMPT ROAST -->
    <section id="prompt-roast" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
      <FadeInBlock client:visible>
        <PromptRoast client:visible />
      </FadeInBlock>
    </section>

    <Divider accent={chapter.accent} client:load />

    <!-- CLOSING -->
    <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
      <FadeInBlock client:visible>
        <div class="pull-quote" style="border-color: var(--color-navy); max-width: 50ch; margin: 0 auto 2rem;">
          Du sprichst bereits KI. Du musst es nur mit Absicht tun.
        </div>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.1}>
        <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
          Als Nächstes: die Techniken, die einen einfachen Austausch in ein echtes Gespräch verwandeln — in dem die KI nicht nur antwortet, sondern <em>mit dir denkt</em>.
        </p>
      </FadeInBlock>
    </section>
    <BeatCompletionCard beatId={beats[3].id} beatTitle="Teste dein Wissen" accentColor={chapter.accent} client:visible />
  </BeatSection>

</ChapterLayout>