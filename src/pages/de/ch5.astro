---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import TrustThermometer from '../../components/widgets/ch5/TrustThermometer';
import WouldYouLetIt from '../../components/breaks/WouldYouLetIt';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[4];
---

<ChapterLayout chapter={chapter} locale="de">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>5</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Kapitel fünf
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Gib ihr<br />Werkzeuge
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Der Sprung von "Fragen beantworten"<br />zu "Aktionen ausführen."
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0; --drop-cap-color: #F5A623;">
        Bis jetzt folgt jede KI-Interaktion, die du hattest, demselben Muster. Du tippst etwas. Die KI tippt etwas zurück. Eine wirklich ausgefeilte Autovervollständigung. Aber was wäre, wenn die KI <em>Dinge tun</em> könnte? Nicht nur über das Wetter reden, sondern die Wettervorhersage abrufen. Nicht nur Code schreiben, sondern ihn ausführen. Nicht nur vorschlagen, was du googeln sollst, sondern selbst das Web durchsuchen und dir die Ergebnisse mitbringen.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE TRUST QUESTION ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Die Vertrauensfrage
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Wenn du KI Werkzeuge gibst, überreichst du ihr einen Werkzeugkasten und sagst: <em>"Hier sind Dinge, die du tun kannst. Du entscheidest, wann du sie einsetzt."</em> Sie kann das Web durchsuchen, Code ausführen, Dateien lesen, APIs aufrufen. Die KI ist nicht schlauer geworden -- sie ist <strong>vernetzt</strong> worden. Und das wirft eine Frage auf, die nichts mit Technologie zu tun hat und alles mit dir: Wie viel soll die KI alleine machen, bevor sie bei dir nachfragt?
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-14">
        Die Antwort hängt von drei Dingen ab. <strong>Risiko</strong> -- was ist das Schlimmste, was passieren könnte? <strong>Umkehrbarkeit</strong> -- kann man es rückgängig machen? Und <strong>Vertrauen</strong> -- wie gut kennst du dieses Tool? Ein Taschenrechner, den du hundertmal benutzt hast, verdient mehr Freiheit als ein brandneues Plugin, das du noch nie getestet hast.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Wichtige Erkenntnis</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Es ist kein Alles-oder-nichts. Die besten KI-Workflows geben Freiheit bei risikoarmen, umkehrbaren Aufgaben und halten Menschen bei risikoreichen, unwiderruflichen Aufgaben in der Schleife. Dein Job ist es, die Grenze zu gestalten.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Wo würdest du die Grenze ziehen? Lege deine eigenen Autonomiestufen fest.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <TrustThermometer client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="Lerne über KI-Tool-Nutzung und Function Calling auf die praxisnaheste Art und Weise. Dieser Kurs lässt dich tatsächlich Dinge bauen und testen, statt nur darüber zu lesen." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Werkzeuge verwandeln KI von einem Berater in einen Assistenten -- von jemandem, der dir sagt, was zu tun ist, zu jemandem, der es tatsächlich tut.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Du hast der KI Hände gegeben. Als Nächstes verdrahten wir diese Werkzeuge zu etwas, das eigenständig ein Ziel verfolgen kann -- planen, ausführen, Fehler beheben. Zeit, Agenten zu bauen.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(245,166,35,0.06) 15%, rgba(245,166,35,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#F5A623" toolName="Would You Let It?" client:visible>
        <WouldYouLetIt client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
