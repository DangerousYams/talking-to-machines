---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import WhatWouldYouBuild from '../../components/widgets/ch7/WhatWouldYouBuild';
import ShipIt from '../../components/breaks/ShipIt';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[6];
---

<ChapterLayout chapter={chapter} locale="de">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>7</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          Kapitel sieben
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Claude Code<br />meistern
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Dein KI-Pair-Programmer, vom ersten<br />Befehl bis zu eigenen Skills.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Es gibt einen Moment, den jeder Coder kennt. Du öffnest ein Terminal, tippst eine Anfrage in natürlicher Sprache und siehst zu, wie eine KI deine Dateien liest, deine Architektur versteht, Code über mehrere Dateien schreibt, ihn ausführt, einen Fehler findet, den Fehler behebt und ihn erneut ausführt -- alles, ohne dass du eine einzige Zeile anfasst. Claude Code ist keine Autovervollständigung. Es ist ein <em>agentisches</em> Coding-Tool, das dein gesamtes Projekt sieht, Änderungen über Dateien hinweg vornimmt, Shell-Befehle ausführt und an seinen eigenen Fehlern iteriert.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        Das Tool ist allerdings nur so gut wie der Mensch, der es steuert. Claude Code kann tausend Zeilen perfekten Code in Sekunden schreiben -- oder tausend Zeilen plausibel aussehenden Müll. Der Unterschied bist du.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE LOOP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Spezifizieren, Generieren, Verifizieren
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Wenn du Claude Code eine Aufgabe gibst, läuft eine Agenten-Schleife: Codebase lesen, planen was zu ändern ist, die Änderungen schreiben, den Code ausführen, reparieren was kaputtgegangen ist. Es durchläuft diese Schleife vielleicht drei-, fünf-, zehnmal -- alles in Sekunden. Dein Job ist nicht mehr, jede Zeile zu schreiben. Dein Job ist, <strong>zu spezifizieren</strong>, was gebaut werden soll, die KI es <strong>generieren</strong> zu lassen und dann <strong>zu verifizieren</strong>, dass es wirklich stimmt. Die meisten Anfänger überspringen den letzten Schritt. Sie sehen Code erscheinen, er sieht vernünftig aus, und sie machen weiter. Sei nicht diese Person. Generierter Code ist ein erster Entwurf. Deine Überprüfung ist das Edit, das ihn veröffentlichungsreif macht.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Die Geheimwaffe ist die <code>CLAUDE.md</code>-Datei -- leg sie in dein Projekt-Stammverzeichnis und Claude Code liest sie zu Beginn jeder Sitzung. Dein Tech-Stack, Namenskonventionen, Stilregeln, Testerwartungen -- alles einmal festgehalten, damit du dich nie wiederholen musst. Es ist Context Engineering angewandt auf Coding.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Das Ziel ist nicht, jede Zeile zu schreiben -- sondern jede Zeile zu verstehen.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Wenn du den Code, den Claude generiert, nicht lesen kannst, kannst du ihn nicht überprüfen. Die besten Claude Code-Nutzer sind nicht die, die am meisten Code generieren -- sondern die, die die besten Fragen stellen und die subtilsten Bugs fangen.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Sieh die Schleife in Aktion. Tipp eine Anfrage und beobachte Claude Code bei der Arbeit.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="terminal-playground" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <WhatWouldYouBuild client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="Dieses Kapitel über Claude Code ist wild -- einer KI dabei zugesehen, wie sie ein Problem durchdenkt, Code schreibt und sich selbst debuggt. Die Zukunft des Codings ist da." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Claude Code schreibt keinen Code für dich -- es schreibt Code mit dir.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        Eine Unterhaltung kann eine Aufgabe bewältigen. Aber echte Projekte haben Dutzende. Als Nächstes: Wie du große Ambitionen in Stücke zerlegst, die KI tatsächlich ausführen kann.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Ship It" client:visible>
        <ShipIt client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
