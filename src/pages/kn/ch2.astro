---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import PromptLaboratory from '../../components/widgets/ch2/PromptLaboratory';
import FlipTheScript from '../../components/widgets/ch2/FlipTheScript';
import DebugThePrompt from '../../components/widgets/ch2/DebugThePrompt';

const chapter = chapters[1];
---

<ChapterLayout chapter={chapter} locale="kn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>2</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          ಅಧ್ಯಾಯ ಎರಡು
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          ಕೇಳೋ<br />ಕಲೆ
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Best prompt ಅಂದ್ರೆ AI ಗೆ<br />ನಿನ್ನನ್ನ questions ಕೇಳುವಂತೆ ಮಾಡೋ question.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        ಹಿಂದಿನ chapter ನಲ್ಲಿ ಒಳ್ಳೆ prompt ನ ಐದು building blocks ಕಲಿತ್ಯಲ್ಲ — Role, Task, Format, Constraints, Examples. ಅದು foundation. ಆದ್ರೆ ingredients ಗೊತ್ತಿದ್ರೆ chef ಆಗೋಲ್ಲ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        ಈ chapter <em>technique</em> ಬಗ್ಗೆ. Prompt type ಮಾಡೋನಿಗೂ prompt <em>craft</em> ಮಾಡೋನಿಗೂ ಇರೋ difference. Question ಕೇಳೋದಕ್ಕೂ <strong>right</strong> question ಕೇಳೋದಕ್ಕೂ ಇರೋ difference — genuinely useful ಏನೋ unlock ಮಾಡೋ question.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        Best AI users topic ನ experts ಅಲ್ಲ — <strong>ಅವ್ರು ಕೇಳೋದ್ರಲ್ಲಿ experts.</strong> ಮತ್ತು ಕೇಳೋದು ಕಲಿಯಬಹುದಾದ skill.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SOCRATIC FLIP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        The Socratic Flip
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ಹೆಚ್ಚಿನ ಜನ AI ನ vending machine ಥರ use ಮಾಡ್ತಾರೆ. Prompt ಹಾಕು, answer ಪಡೆ. ಆದ್ರೆ best results ಬರೋದು <em>conversations</em> ನಿಂದ, commands ಅಲ್ಲ. ಮತ್ತು ಅತ್ಯಂತ powerful conversation technique 2,400 ವರ್ಷ ಹಳೆಯದು.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Socrates ಯಾವತ್ತೂ question ಗೆ directly answer ಮಾಡ್ತಿರ್ಲಿಲ್ಲ. ಅವನು <em>ಇನ್ನಷ್ಟು</em> questions ಕೇಳ್ತಿದ್ದ — ಹುಡುಕೋ, ಸ್ಪಷ್ಟ ಮಾಡೋ, challenge ಮಾಡೋ — ಅವನ students ಸ್ವಂತವಾಗಿ deeper understanding ಗೆ ಬರೋ ತನಕ. ನೀನೂ AI ಜೊತೆ ಅದೇ approach use ಮಾಡಬಹುದು, ಆದ್ರೆ flipped.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AI ಹತ್ರ answer ಕೇಳೋ ಬದ್ಲು, AI ಗೆ ನಿನ್ನನ್ನ interview ಮಾಡು ಅಂತ ಹೇಳು. ನೀನು ಯೋಚಿಸಲೇ ಮರೆತ clarifying questions ಅದೇ ಕೇಳಲಿ.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        ಯೋಚಿಸು: "birthday party plan ಮಾಡು" ಅಂತ type ಮಾಡಿದಾಗ, answer ನ drastically change ಮಾಡೋ ಡಜನ್ಗಟ್ಲೆ details ಬಿಟ್ಟಿರ್ತೀಯ. ಎಷ್ಟು ಜನ? Budget ಎಷ್ಟು? Indoor ಆ outdoor ಆ? AI ಗೆ ಗೊತ್ತಿಲ್ಲ — ಆದ್ರೆ ಕೇಳಬಹುದು.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>The Socratic Prompt</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          "ನಾನು birthday party plan ಮಾಡಬೇಕು. Planning ಶುರು ಮಾಡೋ ಮೊದಲು, ನನ್ನ exact situation ಗೆ tailored plan ಮಾಡೋಕೆ help ಆಗೋ 5 specific questions ಕೇಳು. ಒಂದೊಂದಾಗಿ ಕೇಳು ಮತ್ತು ನನ್ನ answer ಗೆ wait ಮಾಡು."
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        ಈ ಒಂದೇ technique — ಯಾರು questions ಕೇಳ್ತಾರೆ ಅಂತ flip ಮಾಡೋದು — ನೀನು ಮಾಡಬಹುದಾದ ಅತ್ಯಂತ powerful upgrades ಲ್ಲಿ ಒಂದು. ಇದು AI ನ answer machine ಯಿಂದ <strong>thinking partner</strong> ಆಗಿ ಬದಲಾಯಿಸುತ್ತೆ.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FLIP THE SCRIPT ═══ -->
  <section id="flip-the-script" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <FlipTheScript client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ FEW-SHOT PROMPTING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Show ಮಾಡು, Tell ಅಲ್ಲ
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ಒಂದು style ನ friend ಗೆ explain ಮಾಡ್ತಾ ಇದ್ದೀಯ ಅಂತ imagine ಮಾಡು. ಐದು ನಿಮಿಷ words ನಲ್ಲಿ describe ಮಾಡಬಹುದು — "playful ಆಗಿರಬೇಕು ಆದ್ರೆ childish ಅಲ್ಲ, casual ಆದ್ರೆ sloppy ಅಲ್ಲ, short sentences ಮತ್ತು unexpected comparisons ಜೊತೆ." ಅಥ್ವಾ ಒಂದು example ತೋರ್ಸಬಹುದು: <em>"ಹೀಗೆ ಬರಿ."</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        ಅದೇ <strong>few-shot prompting</strong>. ನಿನಗೆ ಏನು ಬೇಕು ಅಂತ abstract ಆಗಿ describe ಮಾಡೋ ಬದ್ಲು, AI ಗೆ concrete examples ಕೊಡ್ತೀಯ. ಒಂದು example "one-shot" prompt. ಎರಡು ಅಥ್ವಾ ಮೂರು examples "few-shot." Zero examples — ಬರೀ describe ಮಾಡೋದು — "zero-shot."
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style="--accent: #6B7280;">
        <span class="prompt-block-label" style="color: #6B7280;">Zero-shot (describing)</span>
        <p class="m-0" style="color: var(--color-deep);">"Running shoes ಗೆ product description ಬರಿ. Punchy ಮತ್ತು conversational ಆಗಿರಲಿ, short sentences ಜೊತೆ. Marketing clichés ಬೇಡ."</p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Few-shot (showing)</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          "CloudRunner X1 running shoe ಗೆ product description ಬರಿ. ನನಗೆ ಬೇಕಿರೋ style ಇಲ್ಲಿದೆ:<br /><br />
          <em>Example: 'The Weekender Tote — ನಿನ್ನ laptop, lunch, ಮತ್ತು questionable life choices ಎಲ್ಲಾ fit ಆಗುತ್ತೆ. Water-resistant canvas ಯಾಕಂದ್ರೆ ಏನಾದ್ರೂ ಚೆಲ್ಲ್ತೀಯ ಅಂತ ಗೊತ್ತು. Five pockets, ಯಾವ್ದೂ ನೆನಪಾಗಲ್ಲ later.'</em><br /><br />
          ಈ tone match ಮಾಡು: short sentences, self-aware humor, buzzwords ಬದ್ಲು specificity."
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85] mb-10">
        Few-shot version dramatically better results ಕೊಡುತ್ತೆ. AI "smarter" ಆದ್ದರಿಂದ ಅಲ್ಲ — ನೀನು vague direction ಬದ್ಲು <strong>concrete target</strong> ಕೊಟ್ಟಿದ್ದಕ್ಕೆ. ಒಂದು ಒಳ್ಳೆ example ನೂರು words ನ description ಗೆ ಸಮ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Key insight</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI ನಿನಗೆ ಬೇಕಿರೋ style match ಮಾಡದೇ ಇದ್ದಾಗ, ಇನ್ನಷ್ಟು adjectives ಸೇರಿಸಬೇಡ. ಒಂದು example ಸೇರಿಸು. "Like this" ಯಾವಾಗ್ಲೂ "make it more punchy but also warm but not too casual" ಗಿಂತ better.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ MINI-CHALLENGE: Zero to Few-Shot ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-12">
    <FadeInBlock client:visible>
      <div style={`background: linear-gradient(135deg, ${chapter.accent}08, ${chapter.accent}04); border: 1px solid ${chapter.accent}20; border-radius: 12px; padding: 2rem 2rem 1.75rem;`}>
        <p style={`font-family: var(--font-mono); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: ${chapter.accent}; margin: 0 0 0.75rem;`}>
          Quick experiment
        </p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0 0 1rem; color: var(--color-deep);">
          Recently AI ಗೆ ಏನಾದ್ರೂ ಬರೆಯೋಕೆ ಹೇಳಿದ್ದ ನೆನಪಿಸ್ಕೋ — email, story, social media post. ಈಗ imagine ಮಾಡು ನಿನಗೆ ಬೇಕಿದ್ದ tone ನ ಒಂದು concrete example ಕೊಟ್ಟಿದ್ರೆ. Output ಹೇಗೆ ಬೇರೆ ಆಗ್ತಿತ್ತು?
        </p>
        <p style="font-size: 0.9rem; line-height: 1.7; margin: 0; color: var(--color-deep); opacity: 0.6;">
          ಅದನ್ನ ನೆನಪಿಟ್ಕೋ. ಕೆಳಗಿನ Prompt Laboratory ನಲ್ಲಿ real ಆಗಿ test ಮಾಡಬಹುದು.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CHAIN OF THOUGHT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Step by Step ಯೋಚಿಸು
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ಇಲ್ಲೊಂದು wild ವಿಷಯ: AI ಗೆ math problem solve ಮಾಡು ಅಂತ ಕೇಳಿದ್ರೆ, ತಪ್ಪಾಗಬಹುದು. ಆದ್ರೆ <em>step by step solve ಮಾಡು</em> ಅಂತ ಕೇಳಿದ್ರೆ, ಹೆಚ್ಚಾಗಿ ಸರಿ ಆಗುತ್ತೆ. Answer ಅದೇ. Question ಬೇರೆ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        ಈ technique ಗೆ <strong>chain-of-thought prompting</strong> ಅಂತ ಹೇಳ್ತಾರೆ. Directly answer ಕೇಳೋ ಬದ್ಲು, AI ಗೆ ತನ್ನ reasoning ತೋರ್ಸು ಅಂತ ಹೇಳ್ತೀಯ. "Step by step ಯೋಚಿಸು." "Answer ಮಾಡೋ ಮೊದ್ಲು break down ಮಾಡು." "Reasoning ನ explain ಮಾಡ್ತಾ ಹೋಗು."
      </p>
    </FadeInBlock>

    <!-- Before/After comparison -->
    <FadeInBlock client:visible delay={0.2}>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
        <div>
          <div class="prompt-block" style="--accent: #E94560; min-height: 100%;">
            <span class="prompt-block-label" style="color: #E94560;">Chain-of-thought ಇಲ್ಲದೆ</span>
            <p class="m-0" style="color: var(--color-deep); font-size: 0.85rem;">
              "Bat ಮತ್ತು ball ಸೇರಿ $1.10 ಆಗುತ್ತೆ. Bat ಗೆ ball ಗಿಂತ $1.00 ಜಾಸ್ತಿ. Ball ಎಷ್ಟು?"
            </p>
            <p style="color: #E94560; font-size: 0.8rem; margin: 1rem 0 0; font-weight: 600;">
              AI answer: $0.10 (ತಪ್ಪು)
            </p>
          </div>
        </div>
        <div>
          <div class="prompt-block" style={`--accent: ${chapter.accent}; min-height: 100%;`}>
            <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
            <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Chain-of-thought ಜೊತೆ</span>
            <p class="m-0" style="color: var(--color-deep); font-size: 0.85rem;">
              "Bat ಮತ್ತು ball ಸೇರಿ $1.10 ಆಗುತ್ತೆ. Bat ಗೆ ball ಗಿಂತ $1.00 ಜಾಸ್ತಿ. Ball ಎಷ್ಟು? Step by step ಯೋಚಿಸು."
            </p>
            <p style={`color: ${chapter.accent}; font-size: 0.8rem; margin: 1rem 0 0; font-weight: 600;`}>
              AI answer: $0.05 (ಸರಿ)
            </p>
          </div>
        </div>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        ಇದು ಯಾಕೆ work ಆಗುತ್ತೆ? AI ಗೆ step by step reasoning ತೋರ್ಸು ಅಂತ ಹೇಳಿದಾಗ, ಪ್ರತಿ step ಮುಂದಿನ step ಗೆ feed ಆಗುತ್ತೆ. AI ಗೆ scratch paper ಕೊಟ್ಟ ಥರ — ಎಷ್ಟು ಜಾಸ್ತಿ thinking ಬರೆಯುತ್ತೋ, final answer ಅಷ್ಟು better ಆಗುತ್ತೆ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        Chain-of-thought AI ನ smarter ಮಾಡಲ್ಲ. AI ನ slower ಮಾಡುತ್ತೆ — ಮತ್ತು slower thinking ಹೆಚ್ಚಾಗಿ better thinking.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        ಇದು ಬರೀ math ಗೆ ಅಲ್ಲ. Answer ಗೆ reasoning ಬೇಕಾದಾಗೆಲ್ಲ use ಮಾಡು: argument analyze ಮಾಡೋಕೆ, options compare ಮಾಡೋಕೆ, project plan ಮಾಡೋಕೆ, code debug ಮಾಡೋಕೆ. ಯಾವಾಗ human ಗೆ "show your work" ಅಂತ ಬೇಕೋ, AI ಗೂ ಅದೇ ಕೇಳು.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE PROMPT ASSEMBLY ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Techniques Assemble ಮಾಡೋದು
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Real power ಬರೋದು techniques combine ಮಾಡಿದಾಗ. Few-shot examples <em>plus</em> chain-of-thought. System role <em>plus</em> constraints <em>plus</em> format specification. ಪ್ರತಿ technique ಒಂದು lever, ಮತ್ತು ಒಂದಕ್ಕಿಂತ ಜಾಸ್ತಿ levers pull ಮಾಡಿದಾಗ ಯಾವೊಂದೂ ಒಂಟಿಯಾಗಿ ಮಾಡಲಾಗದ್ದು ಆಗುತ್ತೆ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
