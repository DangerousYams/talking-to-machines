---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ProjectInstructionsBuilder from '../../components/widgets/ch11/ProjectInstructionsBuilder';

const chapter = chapters[10];
---

<ChapterLayout chapter={chapter} locale="kn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>11</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          ಅಧ್ಯಾಯ ಹನ್ನೊಂದು
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          ನಿಜವಾದ ಏನೋ<br />Build ಮಾಡು
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Creation ಇಲ್ಲದ knowledge trivia.<br />Ship ಮಾಡೋ ಸಮಯ ಬಂತು.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        ನೀನು ಇಲ್ಲಿಗೆ ಬಂದೆ. ಹತ್ತು chapters ಒಳಗೆ ನೀನು "ನನ್ನ essay ಗೆ help ಮಾಡು" ನಿಂದ context engineering, agents building, ಮತ್ತು hallucinations debugging ವರೆಗೆ ಹೋದೆ. ಹೆಚ್ಚಿನ adults ಗೊತ್ತಿರೋದಕ್ಕಿಂತ ಹೆಚ್ಚು AI ಬಗ್ಗೆ ಕಲಿತೆ. ಆದ್ರೆ ಇಲ್ಲಿ uncomfortable truth ಇದೆ: <strong>ನೀನು ಏನಾದ್ರೂ build ಮಾಡೋ ತನಕ ಇದ್ಯಾವುದೂ matter ಆಗಲ್ಲ.</strong> AI ಬಗ್ಗೆ ಓದೋದು swimming ಬಗ್ಗೆ ಓದೋ ಥರ — ಪ್ರತಿ stroke technique study ಮಾಡಬಹುದು, ಆದ್ರೆ ನೀರಿಗೆ ಇಳಿಯೋ ತನಕ ನಿನಗೆ ಅದು <em>ಗೊತ್ತಿಲ್ಲ</em>. ಅದರ <em>ಬಗ್ಗೆ</em> ಗೊತ್ತಿರುತ್ತೆ ಅಷ್ಟೇ.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ SET UP YOUR AI ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        ನಿನ್ನ AI Setup ಮಾಡು
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        ಮೊದಲ prompt ಬರೆಯೋ ಮುಂಚೆ, ಹೆಚ್ಚಿನ beginners skip ಮಾಡೋ power move ಇದೆ: <strong>ನಿನ್ನ AI tool ಗೆ permanent instruction file ಕೊಡು.</strong> ಪ್ರತಿ session ನಲ್ಲಿ ನಿನ್ನ project ಬಗ್ಗೆ ಮತ್ತೆ explain ಮಾಡೋ ಬದ್ಲು, ಒಮ್ಮೆ ಬರಿ, ನಿನ್ನ AI automatically ಓದುತ್ತೆ. Claude Code <code>CLAUDE.md</code> ಓದುತ್ತೆ. Cursor <code>.cursorrules</code> ಓದುತ್ತೆ. GitHub Copilot <code>.github/copilot-instructions.md</code> ಓದುತ್ತೆ. ಅದೇ concept, ಬೇರೆ filenames. ಇದು Chapter 3 ನ context engineering — project level ನಲ್ಲಿ apply ಮಾಡಿದ್ದು.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        ಒಳ್ಳೆ instruction file ಮೂರು questions ಗೆ answer ಮಾಡುತ್ತೆ: ನೀನು ಏನು build ಮಾಡ್ತಿದ್ದೀಯ, rules ಏನು, ಮತ್ತು "good" ಹೇಗೆ ಕಾಣುತ್ತೆ? ಅವನ್ನ right ಮಾಡಿದ್ರೆ ನಿನ್ನ AI ಜೊತೆ ಪ್ರತಿ conversation ಹತ್ತು steps ಮುಂದೆ start ಆಗುತ್ತೆ. ನಿನ್ನ project ಮುಗಿಸೋಷ್ಟು small ಆಗಿ scope ಮಾಡು — completed weekend hack abandoned masterpiece ನ ಯಾವಾಗ್ಲೂ beat ಮಾಡುತ್ತೆ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style="font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;">ಪ್ರಮುಖ ಒಳನೋಟ</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          ಒಳ್ಳೆ project instruction file ನಿನಗೆ help ಮಾಡೋ AI ಮತ್ತು ನಿನ್ನ <em>ಅರ್ಥ ಮಾಡ್ಕೊಳ್ಳೋ</em> AI ನಡುವಿನ ವ್ಯತ್ಯಾಸ. ಒಮ್ಮೆ ಬರಿ, ಪ್ರತಿ session benefit ಆಗು.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        ನಿನ್ನ project instruction file ಇಲ್ಲೇ build ಮಾಡು. Sections fill ಮಾಡು ಮತ್ತು ನಿನ್ನ AI tool ಗೆ export ಮಾಡು.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="project-instructions-builder" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ProjectInstructionsBuilder client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Tools ಏನೂ build ಮಾಡಲ್ಲ. Tools ಜೊತೆ ಇರೋ ಜನ build ಮಾಡ್ತಾರೆ. ನಿನ್ನ generation ಗೆ ಎಂದೂ ಸಿಕ್ಕಿರದ ಅತ್ಯುತ್ತಮ toolkit ನಿನ್ನ ಹತ್ರ ಇದೆ.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto mb-8" style="max-width: 55ch;">
        ಹನ್ನೊಂದು chapters ಹಿಂದೆ, ನೀನು "ನನ್ನ essay ಗೆ help ಮಾಡು" ಅಂತ type ಮಾಡಿ best hope ಮಾಡ್ತಿದ್ದೆ. ಈಗ ನೀನು context engineer ಮಾಡ್ತೀಯ, agents design ಮಾಡ್ತೀಯ, outputs verify ಮಾಡ್ತೀಯ, ಮತ್ತು ಪ್ರತಿ step ಗೆ judgment ತರ್ತೀಯ. Course ಮುಗಿಯಿತು. ನಿಜವಾದ learning ಈಗ start ಆಗುತ್ತೆ — ನೀನು ಮಾತ್ರ ಯೋಚಿಸೋ ಥರದ್ದು ಏನೋ ಮಾಡು.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-center mt-4" style={`font-family: var(--font-heading); font-size: 1.8rem; font-weight: 800; color: ${chapter.accent}; letter-spacing: -0.02em;`}>
        Ship ಮಾಡು.
      </p>
    </FadeInBlock>
  </section>

</ChapterLayout>
