---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ToolWall from '../../components/widgets/ch4/ToolWall';
import WorkflowBuilder from '../../components/widgets/ch4/WorkflowBuilder';
import HeadToHead from '../../components/widgets/ch4/HeadToHead';

const chapter = chapters[3];
---

<ChapterLayout chapter={chapter} locale="kn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>4</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          ಅಧ್ಯಾಯ ನಾಲ್ಕು
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          AI<br />Landscape
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          ಈಗ actually use ಮಾಡಬಹುದಾದ<br />ಪ್ರತಿ AI tool ನ field guide.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        ಹೆಚ್ಚಿನ ಜನ "AI" ಅಂದ್ರೆ ChatGPT ಅಂತ ಅರ್ಥ ಮಾಡ್ಕೊಳ್ತಾರೆ. Maybe Google ನ Gemini, ಅಥ್ವಾ Claude mention ಕೇಳಿರಬಹುದು. ಅದು "internet" ಅಂದ್ರೆ Google ಅಂತ ಹೇಳೋ ಥರ. ತಪ್ಪಲ್ಲ. ಆದ್ರೆ ಅದು ತುಂಬಾ ದೊಡ್ಡ ವಿಷಯದ ಸಣ್ಣ ತುಂಡು.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        ಈಗ ನೂರಾರು AI tools ಇವೆ ನೀನು ಇಂದೇ use ಮಾಡಬಹುದಾದ — ಯಾವುದೋ theoretical future ಅಲ್ಲ, literally ಈಗ, ನಿನ್ನ browser ನಿಂದ. ಒಂದು sentence ನಿಂದ photorealistic images generate ಮಾಡೋ tools. Full songs compose ಮಾಡೋ tools. ನಿನ್ನ research topic ಬಗ್ಗೆ ಎಲ್ಲಾ academic papers ಓದಿ ಮೂರು paragraphs ನಲ್ಲಿ consensus summarize ಮಾಡೋ tools.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        ಈ chapter ನಿನ್ನ field guide. Exhaustive catalog ಅಲ್ಲ — ಅದು ಮುಂದಿನ Tuesday ಗೆ outdated ಆಗಿರ್ತಿತ್ತು — ಆದ್ರೆ <strong>terrain ನ map</strong>. Important ಆದ categories, ಗೊತ್ತಿರಬೇಕಾದ tools, ಮತ್ತು right tool pick ಮಾಡೋಕೆ help ಆಗೋ thinking framework.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BEYOND THE CHATBOT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Chatbot ನ ಆಚೆ
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Chatbot iceberg ನ tip ಮಾತ್ರ. Surface ಕೆಳಗೆ, AI ಹತ್ತಾರು specialized capabilities ಆಗಿ split ಆಗಿದೆ, ಪ್ರತಿಯೊಂದು ಬೇರೆ ಬೇರೆ work ಗೆ ಬೇರೆ ಬೇರೆ tool.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Musical instruments ಥರ ಯೋಚಿಸು. Piano ಮತ್ತು drum kit ಎರಡೂ "musical instruments," ಆದ್ರೆ pianist ಗೆ beat ಹಾಕು ಅಂತ ಹೇಳಲ್ಲ, drummer ಗೆ concerto play ಮಾಡು ಅಂತ ಹೇಳಲ್ಲ. AI tools ಕೂಡ ಅಷ್ಟೇ. Image generation ಗೆ build ಆದ tool code ಗೆ build ಆದ tool ಕ್ಕಿಂತ fundamentally different — different architecture, different training data, different strengths.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        10 AI tools ನ surface level ನಲ್ಲಿ ಗೊತ್ತಿರೋ ಮನುಷ್ಯ ಒಂದೇ tool ನ deeply ಗೊತ್ತಿರೋ ಮನುಷ್ಯನಿಗಿಂತ consistently outperform ಮಾಡ್ತಾನೆ. Breadth of awareness depth of expertise ನ beat ಮಾಡುತ್ತೆ — ಮೊದಲಿಗೆ.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        ಇಂದಿನ landscape ಇಲ್ಲಿದೆ, ಈ tools actually ಏನು <em>ಮಾಡುತ್ತೆ</em> ಅನ್ನೋ ಮೇರೆಗೆ organize ಮಾಡಿದೆ.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE EIGHT FAMILIES ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        ಎಂಟು Families
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14">
        ನೀನು ಕಾಣೋ ಪ್ರತಿ AI tool ಈ categories ಲ್ಲಿ ಒಂದರಲ್ಲಿ fit ಆಗುತ್ತೆ. ಕೆಲವು tools boundaries cross ಮಾಡುತ್ತೆ, ಆದ್ರೆ ಈ families ಅರ್ಥ ಮಾಡ್ಕೊಂಡ್ರೆ chaos ನ make sense ಮಾಡೋಕೆ mental map ಸಿಗುತ್ತೆ.
      </p>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { icon: '1', name: 'Image Generators', color: '#E94560', text: 'Text ಹೋಗುತ್ತೆ, images ಬರುತ್ತೆ. Photorealistic scenes ಯಿಂದ anime ಯಿಂದ oil paintings ವರೆಗೆ. Midjourney, DALL-E 3, Stable Diffusion, Flux, Ideogram. ಅತ್ಯಂತ democratizing category — ಯಾರು ಬೇಕಾದ್ರೂ words ನಿಂದ visual art create ಮಾಡಬಹುದು.' },
        { icon: '2', name: 'Image Editors', color: '#F5A623', text: 'Real image ನಿಂದ ಶುರು ಮಾಡಿ transform ಮಾಡು. Backgrounds remove, resolution upscale, objects replace, scenes relight. Photoshop AI, Magnific, Clipdrop. ಇವು human photographers ಮತ್ತು designers ನ replace ಅಲ್ಲ augment ಮಾಡುತ್ತೆ.' },
        { icon: '3', name: 'Video Creators', color: '#7B61FF', text: 'ಅತ್ಯಂತ ಹೊಸ frontier. Text ಅಥ್ವಾ still images ನಿಂದ video clips generate ಮಾಡು. Sora, Runway, Kling, Pika. ಇನ್ನೂ early — ಹೆಚ್ಚಿನ clips 30 seconds ಕೆಳಗೆ — ಆದ್ರೆ staggering pace ನಲ್ಲಿ improve ಆಗ್ತಿದೆ.' },
        { icon: '4', name: 'Music & Audio', color: '#16C79A', text: 'Text description ನಿಂದ full songs, 30-second sample ನಿಂದ voice cloning, on-demand sound effects. Suno, Udio, ElevenLabs. Studio ಮತ್ತು team ಬೇಕಿದ್ದದನ್ನ ಒಂದೇ prompt ಗೆ compress ಮಾಡೋ tools.' },
        { icon: '5', name: 'Research Agents', color: '#0EA5E9', text: 'ನಿನ್ನ ಪರವಾಗಿ internet (ಅಥ್ವಾ academic databases) ಓದೋ AI. Perplexity search ಮಾಡಿ cite ಮಾಡುತ್ತೆ. Elicit papers ಓದುತ್ತೆ. Consensus scientific agreement ಹುಡುಕುತ್ತೆ. NotebookLM ನಿನ್ನ documents ನ expert ಆಗಿ ಬದಲಾಯಿಸುತ್ತೆ.' },
        { icon: '6', name: 'AI Browsers', color: '#6B7280', text: 'Human ಥರ web navigate ಮಾಡಬಲ್ಲ agents. Buttons click, forms fill, pages ನಡುವೆ navigate. Arc, Operator, Claude Computer Use. "Questions answer ಮಾಡು" ಮತ್ತು "tasks ಮಾಡು" ನಡುವಿನ bridge.' },
        { icon: '7', name: 'Coding Tools', color: '#E94560', text: 'Code ಬರೆಯೋ, edit ಮಾಡೋ, run ಮಾಡೋ, debug ಮಾಡೋ AI. Claude Code terminal ನಿಂದ work ಮಾಡುತ್ತೆ. Cursor ಮತ್ತು Windsurf full editors. Copilot inline suggest ಮಾಡುತ್ತೆ. Replit Agent scratch ನಿಂದ entire apps build ಮಾಡುತ್ತೆ.' },
        { icon: '8', name: 'Chatbots & Assistants', color: '#0F3460', text: 'ನಿನಗೆ ಈಗಾಗ್ಲೇ ಗೊತ್ತಿರೋ general-purpose conversational AI: ChatGPT, Claude, Gemini. ಅವು Swiss army knives — ಹಲವಾರು ವಿಷಯಗಳಲ್ಲಿ good, prompt ಮಾಡೋದು ಗೊತ್ತಿದ್ರೆ best (Chapters 1-3 thanks ಗೆ ನಿನಗೆ ಗೊತ್ತಿದೆ).' },
      ].map((family, i) => (
        <FadeInBlock client:visible delay={i * 0.06}>
          <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${family.color};`}>
              {family.icon}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${family.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {family.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {family.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Key insight</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          ಈ categories converge ಆಗ್ತಿವೆ. Image generators video add ಮಾಡ್ತಿವೆ. Chatbots tool use gain ಮಾಡ್ತಿವೆ. Coding tools agents ಆಗ್ತಿವೆ. ಎರಡು ವರ್ಷದಲ್ಲಿ boundaries blur ಆಗುತ್ತೆ. ಆದ್ರೆ ಈಗ, specialists ಇನ್ನೂ ತಮ್ಮ specialty ಯಲ್ಲಿ generalists ನ beat ಮಾಡ್ತಾರೆ.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO TOOL WALL -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Full catalog explore ಮಾಡು. ಯಾವುದೇ tool click ಮಾಡಿ ಅದು ಏನು ಮಾಡುತ್ತೆ ಅಂತ ತಿಳ್ಕೋ.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: TOOL WALL ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ToolWall client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CHOOSING THE RIGHT TOOL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Right Tool Choose ಮಾಡೋದು
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ಇಷ್ಟು options ಇದ್ದಾಗ, hard part AI tool ಹುಡುಕೋದಲ್ಲ. <em>Right</em> AI tool ಹುಡುಕೋದು. ಇಲ್ಲಿದೆ work ಮಾಡೋ framework:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
        <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
        {[
          { word: 'Output ಏನು?', desc: 'Text? Image? Code? Video? Audio? ಇದು immediately 1-2 families ಗೆ narrow ಮಾಡುತ್ತೆ.' },
          { word: 'Quality bar ಎಷ್ಟು?', desc: 'ನಿನಗಾಗಿ quick draft, ಅಥ್ವಾ audience ಗೆ polished output? Different tools ಬೇರೆ ಬೇರೆ standards ಗೆ.' },
          { word: 'Budget ಎಷ್ಟು?', desc: 'ಬಹಳಷ್ಟು tools surprisingly capable ಆದ free tiers offer ಮಾಡುತ್ತೆ. Pay ಮಾಡೋ ಮೊದ್ಲು actually ಏನು ಬೇಕು ಅಂತ ತಿಳ್ಕೋ.' },
          { word: 'Workflow ಏನು?', desc: 'Standalone task, ಅಥ್ವಾ longer chain ನ ಒಂದು step? Raw power ಗಿಂತ integration ಜಾಸ್ತಿ matter ಮಾಡುತ್ತೆ.' },
        ].map((step, i) => (
          <FadeInBlock client:visible delay={0.15 + i * 0.08}>
            <div style={`position: relative; padding-bottom: ${i < 3 ? '1.75rem' : '0'};`}>
              <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
              <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
                <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
                <span style="opacity: 0.7;"> {step.desc}</span>
              </p>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.4}>
      <p class="text-lg leading-[1.85] mb-10">
        ಹೆಚ್ಚಿನ beginners ಅದೇ mistake ಮಾಡ್ತಾರೆ: ಒಂದೇ general-purpose AI ನ ಎಲ್ಲದಕ್ಕೂ use ಮಾಡ್ತಾರೆ. Technically work ಆಗುತ್ತೆ, ಆದ್ರೆ right specialized tools ಜೊತೆ ಬೇಗ better results ಸಿಗುತ್ತೆ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.45}>
      <p class="text-lg leading-[1.85]">
        ಆದ್ರೆ opposite trap ಗೂ ಬೀಳಬೇಡ. 47 AI subscriptions ಬೇಡ. <strong>ಬೇರೆ ಬೇರೆ categories ಲ್ಲಿ 3-4 tools pick ಮಾಡು, ಚೆನ್ನಾಗಿ ಕಲಿ, ಅಲ್ಲಿಂದ expand ಮಾಡು.</strong>
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE POWER OF PIPELINES ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Pipelines ನ Power
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ಇಲ್ಲಿ real unlock: <strong>tools ನ chain ಮಾಡಿದಾಗ exponentially more powerful ಆಗುತ್ತೆ.</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        ಒಂದೇ AI tool ನಿನಗೆ capability ಕೊಡುತ್ತೆ. AI tools ನ chain ನಿನಗೆ <em>workflow</em> ಕೊಡುತ್ತೆ. Perplexity research ಹುಡುಕುತ್ತೆ. Claude article ಬರೆಯುತ್ತೆ. Midjourney illustrations create ಮಾಡುತ್ತೆ. ಪ್ರತಿ tool ತನ್ನ best ಮಾಡುತ್ತೆ, ಒಂದ್ರ output ಮುಂದಿನದ್ರ input ಆಗುತ್ತೆ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        Online ನಲ್ಲಿ ನೋಡಿರೋ ಅತ್ಯಂತ impressive AI-generated work ಒಂದೇ tool ನಿಂದ ಆಗಿಲ್ಲ. ಐದು tools chain ಮಾಡಿ ಪ್ರತಿಯೊಂದು ಏನು best ಮಾಡುತ್ತೆ ಅಂತ ಅರ್ಥ ಮಾಡ್ಕೊಂಡ human ಮಾಡಿದ್ದು.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        ಅದಕ್ಕೇ landscape ಅರ್ಥ ಮಾಡ್ಕೊಳ್ಳೋದು matter ಮಾಡುತ್ತೆ. ಒಂದೇ tool ಗೊತ್ತಿದ್ರೆ pipeline build ಮಾಡೋಕಾಗಲ್ಲ. ಯಾವ specialists ಇದ್ದಾರೆ ಅಂತ ಗೊತ್ತಿಲ್ಲದೆ right specialist choose ಮಾಡೋಕಾಗಲ್ಲ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85]">
        ನೀನೇ ಒಂದು build ಮಾಡಿ ನೋಡು:
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: WORKFLOW BUILDER ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <WorkflowBuilder client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ NO BEST TOOL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        "Best" Tool ಅಂತ ಏನೂ ಇಲ್ಲ
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
