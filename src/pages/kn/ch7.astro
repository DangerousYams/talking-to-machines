---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import TerminalPlayground from '../../components/widgets/ch7/TerminalPlayground';
import SkillBuilder from '../../components/widgets/ch7/SkillBuilder';
import RefactorRace from '../../components/widgets/ch7/RefactorRace';

const chapter = chapters[6];
---

<ChapterLayout chapter={chapter} locale="kn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>7</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          ಅಧ್ಯಾಯ ಏಳು
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Claude Code<br />Master ಆಗೋದು
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          ನಿನ್ನ AI pair programmer, ಮೊದಲ<br />command ಇಂದ custom Skills ವರೆಗೆ.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        ಪ್ರತಿ coder ಗೂ ಆ ಒಂದು moment ನೆನಪಿರುತ್ತೆ. ನೀನು terminal open ಮಾಡ್ತೀಯ, natural-language request type ಮಾಡ್ತೀಯ, ಮತ್ತೆ ಒಂದು AI ನಿನ್ನ files ಓದೋದು, ನಿನ್ನ architecture ಅರ್ಥ ಮಾಡ್ಕೊಳ್ಳೋದು, multiple files ಅಲ್ಲಿ code ಬರೆಯೋದು, run ಮಾಡೋದು, error hit ಆಗೋದು, error fix ಮಾಡೋದು, ಮತ್ತೆ ಪುನಃ run ಮಾಡೋದು ನೋಡ್ತೀಯ — ನೀನು ಒಂದೇ line ಮುಟ್ಟದೆ. ಅದೇ Claude Code.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        ಇದು autocomplete ಅಲ್ಲ. Snippets ಬರೆಯೋ chatbot ಅಲ್ಲ. Claude Code ಒಂದು <em>agentic</em> coding tool — command-line partner ಅದು ನಿನ್ನ entire project ನೋಡಬಲ್ಲದು, files across ಬದಲಾವಣೆ ಮಾಡಬಲ್ಲದು, shell commands execute ಮಾಡಬಲ್ಲದು, ಮತ್ತೆ ತನ್ನ mistakes ಮೇಲೆ iterate ಮಾಡಬಲ್ಲದು. ಅದು code suggest ಮಾಡಲ್ಲ. ಅದು code <strong>ship</strong> ಮಾಡುತ್ತೆ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        ಆದ್ರೆ tool ಅದನ್ನ steer ಮಾಡೋ human ಅಷ್ಟೇ ಚೆನ್ನಾಗಿರುತ್ತೆ. Claude Code ಕೆಲವೇ seconds ಅಲ್ಲಿ ಸಾವಿರ lines perfect code ಬರೆಯಬಹುದು — ಅಥವಾ ಸಾವಿರ lines plausible-looking garbage. ವ್ಯತ್ಯಾಸ ನೀನು.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ HOW CLAUDE CODE THINKS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Claude Code ಹೇಗೆ ಯೋಚಿಸುತ್ತೆ
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ನೀನು Claude Code ಗೆ task ಕೊಟ್ಟಾಗ, ಅದು ತಕ್ಷಣ type ಮಾಡಕ್ಕೆ ಶುರು ಮಾಡಲ್ಲ. ಅದು Chapter 6 ನ agent loop ಅನ್ನ run ಮಾಡುತ್ತೆ, code ಗಾಗಿ specialized ಆಗಿ:
      </p>
    </FadeInBlock>

    <!-- Agent loop visualization -->
    <FadeInBlock client:visible delay={0.15}>
      <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
        <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
        {[
          { word: 'Read.', desc: 'Codebase scan ಮಾಡು — files, imports, tests, configs. ಏನಿದೆ ಅಂತ ಅರ್ಥ ಮಾಡ್ಕೋ.' },
          { word: 'Plan.', desc: 'ಏನು change ಮಾಡಬೇಕು, ಯಾವ files ಅಲ್ಲಿ, ಯಾವ order ಅಲ್ಲಿ ಅಂತ decide ಮಾಡು.' },
          { word: 'Write.', desc: 'Edits ಮಾಡು. Files create ಮಾಡು. Code modify ಮಾಡು.' },
          { word: 'Run.', desc: 'Commands execute ಮಾಡು — build, test, lint. ಏನಾಗುತ್ತೆ ಅಂತ ನೋಡು.' },
          { word: 'Fix.', desc: 'ಏನಾದ್ರೂ broke ಆದ್ರೆ, error ಓದು, adjust ಮಾಡು, ಮತ್ತೆ try ಮಾಡು.' },
        ].map((step, i) => (
          <div style={`position: relative; padding-bottom: ${i < 4 ? '1.75rem' : '0'};`}>
            <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
            <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
              <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
              <span style="opacity: 0.7;"> {step.desc}</span>
            </p>
          </div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        ಈ read-plan-write-run-fix loop Claude Code ಅನ್ನ simple code generator ಗಿಂತ ಬೇರೆ ಮಾಡುತ್ತೆ. ಅದು ನಿನಗೆ snippet ಕೊಟ್ಟು walk away ಮಾಡಲ್ಲ. ಅದು <em>loop ಅಲ್ಲೇ ಇರುತ್ತೆ</em> — code actually work ಆಗೋ ವರೆಗೂ iterate ಮಾಡ್ತಾ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85]">
        Pair programming ತರ ಯೋಚಿಸು. ನೀನು ಏನು ಬೇಕು ಅಂತ describe ಮಾಡ್ತೀಯ. Claude Code ಅದನ್ನ ಬರೆಯುತ್ತೆ. Tests fail ಆಗ್ತವೆ. Claude Code error ಓದುತ್ತೆ, adjust ಮಾಡುತ್ತೆ, re-run ಮಾಡುತ್ತೆ. ಈ cycle ಮೂರು, ಐದು, ಹತ್ತು ಸಾರಿ ಆಗಬಹುದು — ಎಲ್ಲ seconds ಅಲ್ಲಿ.
      </p>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO TERMINAL PLAYGROUND -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Loop ಅನ್ನ action ಅಲ್ಲಿ ನೋಡು. Request type ಮಾಡಿ Claude Code work ಮಾಡೋದನ್ನ ನೋಡು.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: TERMINAL PLAYGROUND ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <TerminalPlayground client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE CLAUDE.MD FILE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        CLAUDE.md File
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ಹೆಚ್ಚಿನ beginners ಇದನ್ನ miss ಮಾಡ್ತಾರೆ: <strong>Claude Code ಗೆ permanent instructions ಕೊಡಬಹುದು.</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        ನಿನ್ನ project ನ root ಅಲ್ಲಿ <code>CLAUDE.md</code> ಅಂತ file ಹಾಕು, ಆಮೇಲೆ Claude Code ಪ್ರತಿ session ಶುರುವಲ್ಲೇ ಅದನ್ನ ಓದುತ್ತೆ. ಇದು system prompt ತರ, ಆದ್ರೆ ನಿನ್ನ entire codebase ಗೆ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>CLAUDE.md</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep); font-family: var(--font-mono); font-size: 0.85rem;">
          # My Project<br /><br />
          Tech stack: Astro + React + Tailwind<br />
          Always use TypeScript with strict mode.<br />
          Put components in src/components/.<br />
          Write tests for every new function.<br />
          Use Prettier formatting — never change the config.<br /><br />
          ## Style Rules<br />
          - Prefer named exports over default exports<br />
          - Use CSS modules, not inline styles<br />
          - Keep components under 150 lines
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        CLAUDE.md ಇಲ್ಲದಿದ್ರೆ, ಪ್ರತಿ session ನ ಮೊದಲ ಕೆಲವು minutes ನಿನ್ನ preferences re-explain ಮಾಡೋದ್ರಲ್ಲೇ ಹೋಗುತ್ತೆ. ಅದಿದ್ರೆ, Claude Code ಗೆ ಈಗಾಗಲೇ ನಿನ್ನ stack, ನಿನ್ನ conventions, ನಿನ್ನ boundaries ಗೊತ್ತಿರುತ್ತೆ. ಇದು context engineering (Chapter 3) coding ಗೆ apply ಆದದ್ದು.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>CLAUDE.md ನಿನ್ನ project ನ constitution ಅಂತ ಯೋಚಿಸು.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          ಅದು ನೀನು ಈಗಾಗಲೇ ತಗೊಂಡ decisions ಅನ್ನ encode ಮಾಡುತ್ತೆ — ಹಾಗಾಗಿ AI actually new ಆಗಿರೋ decisions ಮೇಲೆ focus ಮಾಡಬಹುದು. ನಿನ್ನ CLAUDE.md ಎಷ್ಟು specific ಆಗಿರುತ್ತೋ, ಅಷ್ಟು ಕಡಿಮೆ ನೀನು repeat ಮಾಡಬೇಕು.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BUILDING SKILLS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Skills ಕಟ್ಟೋದು
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        CLAUDE.md Claude Code ಗೆ ನಿನ್ನ project ಬಗ್ಗೆ general knowledge ಕೊಡುತ್ತೆ. ಆದ್ರೆ specific, repeatable tasks ಬಗ್ಗೆ? ಅಲ್ಲಿ <strong>Skills</strong> ಬರುತ್ತವೆ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Skill ಅಂದ್ರೆ ನಿನ್ನ CLAUDE.md ಒಳಗಿರೋ instructions set — Claude Code ಗೆ particular kind ನ task ಹೇಗೆ handle ಮಾಡಬೇಕು ಅಂತ ಕಲಿಸೋದು. Recipe ತರ ಯೋಚಿಸು: "ಯಾರಾದ್ರೂ ಹೊಸ React component create ಮಾಡು ಅಂತ ಕೇಳಿದ್ರೆ, ಇದು exactly ಹೇಗೆ ಮಾಡಬೇಕು."
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        Skills ಇಲ್ಲದಿದ್ರೆ, ಪ್ರತಿ ಸಾರಿ ಅದೇ steps explain ಮಾಡ್ತೀಯ. Skills ಇದ್ರೆ, ಒಂದೇ ಸಾರಿ explain ಮಾಡು — AI ಯಾವಾಗ್ಲೂ ನೆನಪಿಟ್ಕೊಳ್ಳುತ್ತೆ.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        ಒಳ್ಳೆಯ skill ಗೆ ಮೂರು parts ಇರ್ತವೆ:
      </p>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { letter: 'T', name: 'Trigger', color: '#7B61FF', text: 'ಈ skill ಯಾವಾಗ activate ಆಗ್ಬೇಕು? "Component create ಮಾಡು ಅಂತ ಕೇಳಿದಾಗ..." ಅಥವಾ "Test failure fix ಮಾಡುವಾಗ..." Clear triggers ಇದ್ರೆ AI ತಪ್ಪಾದ recipe ಬಳಸಲ್ಲ.' },
        { letter: 'S', name: 'Steps', color: '#16C79A', text: 'ಅದು exactly ಏನು ಮಾಡಬೇಕು, ಯಾವ order ಅಲ್ಲಿ? Numbered steps best ಆಗಿ work ಮಾಡ್ತವೆ. File locations, naming conventions, ಮತ್ತೆ required patterns ಬಗ್ಗೆ specific ಆಗಿರು.' },
        { letter: 'E', name: 'Examples', color: '#F5A623', text: 'Successful result ಹೇಗಿರುತ್ತೆ ಅಂತ ತೋರಿಸು. Before-and-after, example file structure, ಅಥವಾ sample output. Examples ಇದ್ರೆ ambiguity ಸಾಯುತ್ತೆ.' },
      ].map((block, i) => (
        <FadeInBlock client:visible delay={0.3 + i * 0.08}>
          <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${block.color};`}>
              {block.letter}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${block.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {block.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {block.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>
  </section>

  <!-- BRIDGE TO SKILL BUILDER -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        ಒಂದು ಬರೆಯೋಕೆ try ಮಾಡು. Trigger ಇಂದ steps ಇಂದ examples ವರೆಗೆ skill build ಮಾಡು.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: SKILL BUILDER ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <SkillBuilder client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ SPECIFY, GENERATE, VERIFY ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Specify, Generate, Verify
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Claude Code ಜೊತೆ work ಮಾಡುವಾಗ, ನಿನ್ನ job ಬದಲಾಗುತ್ತೆ. ಪ್ರತಿ line ಬರೆಯೋ person ನೀನಲ್ಲ ಇನ್ಮೇಲೆ. ಏನು build ಮಾಡಬೇಕು ಅಂತ <strong>specify</strong> ಮಾಡೋರು ನೀನು, AI ಅದನ್ನ <strong>generate</strong> ಮಾಡಲಿ, ಆಮೇಲೆ ಅದು actually right ಇದೆಯಾ ಅಂತ <strong>verify</strong> ಮಾಡೋರು ನೀನು.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        ಈ loop — specify, generate, verify — ಇದೇ fundamental workflow:
      </p>
    </FadeInBlock>

    <!-- SGV Loop -->
    <FadeInBlock client:visible delay={0.2}>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12">
        {[
          { step: '01', title: 'Specify', desc: 'ನಿನಗೆ ಏನು ಬೇಕು ಅಂತ precise ಆಗಿ ಹೇಳು. ನಿನ್ನ request ಎಷ್ಟು clear ಆಗಿರುತ್ತೋ, output fix ಮಾಡೋಕೆ ಅಷ್ಟು ಕಡಿಮೆ time ಖರ್ಚಾಗುತ್ತೆ. Edge cases, file locations, expected behavior include ಮಾಡು.', color: '#7B61FF' },
          { step: '02', title: 'Generate', desc: 'Claude Code ಅದರ work ಮಾಡಲಿ. Agent loop ನೋಡು — reading, planning, writing, running, fixing. Mid-cycle interrupt ಮಾಡೋ urge ತಡ್ಕೋ.', color: '#0EA5E9' },
