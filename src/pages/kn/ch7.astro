---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import TerminalPlayground from '../../components/widgets/ch7/TerminalPlayground';
import ShipIt from '../../components/breaks/ShipIt';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[6];
---

<ChapterLayout chapter={chapter} locale="kn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>7</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          ಅಧ್ಯಾಯ ಏಳು
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Claude Code<br />Master ಮಾಡೋದು
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          ನಿನ್ನ AI pair programmer, ಮೊದಲ<br />command ನಿಂದ custom Skills ವರೆಗೆ.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        ಪ್ರತಿ coder ನೆನಪಿಡೋ ಒಂದು moment ಇದೆ. Terminal open ಮಾಡ್ತೀಯ, natural-language request type ಮಾಡ್ತೀಯ, ಮತ್ತೆ AI ನಿನ್ನ files ಓದೋದು, ನಿನ್ನ architecture ಅರ್ಥ ಮಾಡ್ಕೊಳ್ಳೋದು, multiple files ನಲ್ಲಿ code ಬರೆಯೋದು, run ಮಾಡೋದು, error ಹಿಡಿಯೋದು, error fix ಮಾಡೋದು, ಮತ್ತೆ run ಮಾಡೋದು ನೋಡ್ತೀಯ — ನೀನು ಒಂದೇ line touch ಮಾಡದೆ. Claude Code autocomplete ಅಲ್ಲ. ಅದು <em>agentic</em> coding tool, ನಿನ್ನ ಇಡೀ project ನೋಡುತ್ತೆ, files ನಲ್ಲಿ changes ಮಾಡುತ್ತೆ, shell commands execute ಮಾಡುತ್ತೆ, ಮತ್ತು ತನ್ನ mistakes ಮೇಲೆ iterate ಮಾಡುತ್ತೆ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        ಆದ್ರೆ tool ಅದನ್ನ steer ಮಾಡೋ human ಅಷ್ಟೇ good. Claude Code seconds ನಲ್ಲಿ ಸಾವಿರ lines perfect code ಬರೆಯಬಹುದು — ಅಥ್ವಾ ಸಾವಿರ lines plausible-looking garbage. ವ್ಯತ್ಯಾಸ ನೀನು.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE LOOP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Specify, Generate, Verify
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Claude Code ಗೆ task ಕೊಟ್ಟಾಗ, ಅದು agent loop run ಮಾಡುತ್ತೆ: codebase ಓದು, ಏನು change ಮಾಡಬೇಕು plan ಮಾಡು, edits ಬರಿ, code run ಮಾಡು, ಏನು broke ಆಯ್ತೋ fix ಮಾಡು. ಆ loop ಮೂರು, ಐದು, ಹತ್ತು ಸಲ cycle ಆಗಬಹುದು — ಎಲ್ಲಾ seconds ನಲ್ಲಿ. ನಿನ್ನ ಕೆಲ್ಸ ಈಗ ಪ್ರತಿ line ಬರೆಯೋದಲ್ಲ. ಏನು build ಮಾಡಬೇಕು ಅಂತ <strong>specify</strong> ಮಾಡೋದು, AI <strong>generate</strong> ಮಾಡಲಿ, ಮತ್ತೆ ಅದು ನಿಜವಾಗ್ಲೂ right ಇದೆಯಾ ಅಂತ <strong>verify</strong> ಮಾಡೋದು. ಹೆಚ್ಚಿನ beginners ಕೊನೆಯ step skip ಮಾಡ್ತಾರೆ. Code ಬಂತು, reasonable ಅನ್ಸುತ್ತೆ, move on. ಆ ವ್ಯಕ್ತಿ ಆಗಬೇಡ. Generated code ಒಂದು first draft. ನಿನ್ನ verification ಅದನ್ನ publishable ಮಾಡೋ edit.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Secret weapon ಅಂದ್ರೆ <code>CLAUDE.md</code> file — ನಿನ್ನ project root ನಲ್ಲಿ ಹಾಕು, Claude Code ಪ್ರತಿ session ಶುರುವಿನಲ್ಲಿ ಓದುತ್ತೆ. ನಿನ್ನ tech stack, naming conventions, style rules, testing expectations — ಎಲ್ಲಾ ಒಮ್ಮೆ encode ಮಾಡು, ಮತ್ತೆ ಯಾವತ್ತೂ repeat ಮಾಡಬೇಕಾಗಿಲ್ಲ. ಇದು Chapter 3 ನ context engineering — coding ಗೆ apply ಮಾಡಿದ್ದು.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Goal ಪ್ರತಿ line ಬರೆಯೋದಲ್ಲ — ಪ್ರತಿ line ಅರ್ಥ ಮಾಡ್ಕೊಳ್ಳೋದು.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Claude generate ಮಾಡಿದ code ಓದೋಕಾಗದಿದ್ರೆ, verify ಮಾಡೋಕಾಗಲ್ಲ. Best Claude Code users ಅತ್ಯಂತ ಹೆಚ್ಚು code generate ಮಾಡೋರಲ್ಲ — ಅತ್ಯುತ್ತಮ questions ಕೇಳೋರು ಮತ್ತು ಅತ್ಯಂತ subtle bugs catch ಮಾಡೋರು.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Loop action ನಲ್ಲಿ ನೋಡು. Request type ಮಾಡು, Claude Code work ಮಾಡೋದು ನೋಡು.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="terminal-playground" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <TerminalPlayground client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="ಈ Claude Code chapter wild ಆಗಿದೆ — AI pair programmer problem think through ಮಾಡೋದು, code ಬರೆಯೋದು, ಮತ್ತು ತಾನೇ debug ಮಾಡೋದು ನೋಡಿದೆ. Coding ನ future ಇಲ್ಲಿದೆ." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Claude Code ನಿನ್ನ ಪರವಾಗಿ code ಬರೆಯ್ತಾ ಇಲ್ಲ — ನಿನ್ನ ಜೊತೆ code ಬರೆಯ್ತಾ ಇದೆ.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        ಒಂದು conversation ಒಂದು task handle ಮಾಡಬಹುದು. ಆದ್ರೆ real projects ಗೆ dozens ಇರುತ್ತೆ. ಮುಂದೆ: big ambitions ನ AI actually execute ಮಾಡಬಹುದಾದ pieces ಆಗಿ break ಮಾಡೋದು ಹೇಗೆ.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Ship It" client:visible>
        <ShipIt client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
