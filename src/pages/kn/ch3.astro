---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ContextWindowViz from '../../components/widgets/ch3/ContextWindowViz';
import ForgettingExperiment from '../../components/widgets/ch3/ForgettingExperiment';
import SystemPromptSandbox from '../../components/widgets/ch3/SystemPromptSandbox';

const chapter = chapters[2];
---

<ChapterLayout chapter={chapter} locale="kn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>3</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          ಅಧ್ಯಾಯ ಮೂರು
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Context<br />Engineering
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          AI ಮರೆಯಲ್ಲ &mdash; ಅದು ಮೊದ್ಲಿಂದ<br />ನೆನಪಿಟ್ಟುಕೊಳ್ತಾನೇ ಇರ್ಲಿಲ್ಲ.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        ಒಬ್ಬ friend ಜೊತೆ ಮಾತಾಡ್ತಿದ್ದೀಯ ಅಂತ imagine ಮಾಡು, ಆದ್ರೆ ಪ್ರತಿ ಕೆಲವು ನಿಮಿಷಕ್ಕೆ ಯಾರೋ ನಿಮ್ಮಿಬ್ಬರ whiteboard erase ಮಾಡ್ತಾರೆ. ಮತ್ತೆ ಶುರು ಆಗ್ತೀರ. ನಿನ್ನ friend ಉಳಿದಿರೋದನ್ನ ನೋಡಿ ಏನೂ ಆಗಿಲ್ಲ ಅನ್ನೋ ಥರ ಮುಂದುವರಿಸಲು try ಮಾಡ್ತಾನೆ. Long conversation ನಲ್ಲಿ AI "brain" ಒಳಗೆ ಆಗೋದು ಅದೇ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        <strong>AI ಗೆ memory ಇಲ್ಲ.</strong> ನೀನು memory ಅಂತ ಯೋಚಿಸೋ ಥರ ಅಲ್ಲ. ನಿನ್ನೆಯ conversation ನೆನಪಿಲ್ಲ. ಉದ್ದವಾಗಿದ್ರೆ <em>ಈ</em> conversation ನ ಆರಂಭ ಕೂಡ ನೆನಪಿಲ್ಲ. ಪ್ರತಿ response ಅದು currently ನೋಡಬಹುದಾದ text ನ ಮೇಲೆ ಮಾತ್ರ based &mdash; <strong>context window</strong> ಅಂತ ಕರೆಯೋ text ನ window.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        ಈ window ನ ಅರ್ಥ ಮಾಡ್ಕೊಳ್ಳೋದು &mdash; ಅದ್ರಲ್ಲಿ ಏನು ಹೋಗುತ್ತೆ, ಅದು ಎಷ್ಟು ದೊಡ್ಡದು, ತುಂಬಿದಾಗ ಏನಾಗುತ್ತೆ &mdash; AI ಜೊತೆ work ಮಾಡೋದ್ರಲ್ಲಿ ಅತ್ಯಂತ important skills ಲ್ಲಿ ಒಂದು.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE WHITEBOARD METAPHOR ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Erase ಆಗೋ Whiteboard
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI ಗೆ message ಕಳಿಸಿದಾಗ actually ಏನಾಗುತ್ತೆ: system ನಿನ್ನ <em>ಇಡೀ conversation</em> &mdash; ನೀನು ಕಳಿಸಿದ ಪ್ರತಿ message, AI ಕೊಟ್ಟ ಪ್ರತಿ response &mdash; ಎಲ್ಲಾ ಒಂದೇ block text ಆಗಿ model ಗೆ feed ಮಾಡುತ್ತೆ. AI ಎಲ್ಲಾ ಓದುತ್ತೆ, next response generate ಮಾಡುತ್ತೆ, ಮತ್ತೆ... ಎಲ್ಲಾ ಮರೆತು ಬಿಡುತ್ತೆ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        ಮುಂದಿನ ಸಲ message ಕಳಿಸಿದಾಗ, ಇಡೀ process repeat ಆಗುತ್ತೆ. System ಇಡೀ conversation ಮತ್ತೆ paste ಮಾಡುತ್ತೆ, ನಿನ್ನ ಹೊಸ message add ಮಾಡುತ್ತೆ, AI ಎಲ್ಲಾ fresh ಆಗಿ ಓದುತ್ತೆ. World ನ ಅತ್ಯಂತ diligent ಆದ್ರೆ amnesiac reader ಥರ &mdash; ಪ್ರತಿ ಸಲ completely thorough, ಆದ್ರೆ ಪ್ರತಿ turn scratch ನಿಂದ ಶುರು.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AI generate ಮಾಡೋ ಪ್ರತಿ response ಆ ಕ್ಷಣದಲ್ಲಿ context window ನಲ್ಲಿ ಇರೋದ್ರ ಮೇಲೆ ಮಾತ್ರ based. ಬೇರೆ ಏನೂ ಇಲ್ಲ. Context window memory ಅಲ್ಲ. ಅದು whiteboard &mdash; ಮತ್ತು ಅದಕ್ಕೆ edges ಇವೆ.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        ಇದ್ರ implications ತುಂಬಾ ದೊಡ್ಡದು. AI ಅದರ ಮುಂದೆ currently ಇರೋ information ಎಷ್ಟು ಒಳ್ಳೆಯದೋ ಅಷ್ಟೇ ಒಳ್ಳೆಯದು. Critical detail ಬಿಟ್ಟಿದ್ಯಾ? AI magically ನೆನಪಿಸ್ಕೊಳ್ಳಲ್ಲ. Window ನ noise ನಿಂದ ತುಂಬಿಸಿದ್ಯಾ? AI confuse ಆಗುತ್ತೆ. <strong>Context window ನಿನ್ನ ಅತ್ಯಂತ important resource.</strong> ಅದನ್ನ manage ಮಾಡೋದು ಕಲಿಯೋದು casual users ನಿಂದ genuinely powerful results ಪಡೆಯೋ ಜನರನ್ನ ಬೇರ್ಪಡಿಸುತ್ತೆ.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ TOKENS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Tokens: AI ಯ Alphabet
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI ನೀನು ಓದೋ ಥರ words ಓದಲ್ಲ. ಅದು <strong>tokens</strong> ಓದುತ್ತೆ &mdash; text ನ chunks ಅವು ಸಾಮಾನ್ಯವಾಗಿ ಒಂದು word ನ ಮುಕ್ಕಾಲು ಭಾಗ. "incredible" ಅನ್ನೋ word ಎರಡು tokens. "AI" ಒಂದು token. Word ಮುಂದಿನ space ಸಾಮಾನ್ಯವಾಗಿ ಅದೇ token ಜೊತೆ bundle ಆಗುತ್ತೆ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: #7B61FF;">
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Quick math</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          1 token &asymp; 4 characters &asymp; 0.75 words<br />
          100 tokens &asymp; 75 words<br />
          ಒಂದು typical page text &asymp; 300 tokens<br />
          ಒಂದು full novel &asymp; 100,000 tokens
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        ಇದು ಯಾಕೆ important? ಯಾಕಂದ್ರೆ ಪ್ರತಿ AI model ಗೆ tokens ನಲ್ಲಿ measure ಮಾಡೋ <strong>context window size</strong> ಇದೆ. Claude ನ context window 200,000 tokens hold ಮಾಡಬಹುದು &mdash; ಅದು ಸುಮಾರು 500-page book. GPT-4o 128,000 hold ಮಾಡುತ್ತೆ. ಇವು enormous ಅನಿಸುತ್ತೆ, ಆದ್ರೆ ನೀನು ಅಂದ್ಕೊಂಡಿದ್ದಕ್ಕಿಂತ ಬೇಗ ತುಂಬಿಹೋಗುತ್ತೆ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        ನೀನು ಕಳಿಸೋ ಪ್ರತಿ message, AI ಬರೆಯೋ ಪ್ರತಿ response, behind the scenes work ಮಾಡೋ ಪ್ರತಿ system instruction &mdash; ಎಲ್ಲಾ ಅದೇ shared budget ನಿಂದ tokens consume ಮಾಡುತ್ತೆ. Budget ಮುಗಿದಾಗ, things edge ನಿಂದ ಬೀಳೋಕೆ ಶುರು ಆಗುತ್ತೆ.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: CONTEXT WINDOW VIZ ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ContextWindowViz client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ WHEN THE WINDOW OVERFLOWS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Window Overflow ಆದಾಗ
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ಹತ್ತು messages ಆದ conversation ನಲ್ಲಿ ಇದ್ದೀಯ. Message three ನಲ್ಲಿ ನಿನ್ನ dietary restrictions mention ಮಾಡಿದ್ದೆ. Message fifteen ಹೊತ್ತಿಗೆ restaurant recommendations deep ಆಗಿ discuss ಮಾಡ್ತಿದ್ದೀಯ. ಕೇಳ್ತೀಯ: <em>"ನಾನು ಯಾವ dietary restrictions mention ಮಾಡಿದ್ದೆ?"</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        AI ಹೇಳುತ್ತೆ: <em>"ನೀನು ಯಾವುದೇ specific dietary restrictions mention ಮಾಡಿಲ್ಲ ಅಂತ ಅನಿಸುತ್ತೆ."</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        Frustrate ಆಗ್ತೀಯ. <em>ಅಲ್ಲೇ ಇದ್ಯಲ್ಲ, ನಾನು ಹೇಳಿದ್ನಲ್ಲ!</em> ಆದ್ರೆ ವಿಷಯ ಏನಂದ್ರೆ: ಅದು ಅಲ್ಲೇ <strong>ಇಲ್ಲ</strong>. ಈಗ ಇಲ್ಲ. ಆ early message visible window ನಿಂದ ಹೊರಗೆ ಹೋಗಿರಬಹುದು, ಅಥ್ವಾ model recent context ಗೆ ಜಾಸ್ತಿ priority ಕೊಟ್ಟಿರಬಹುದು. AI careless ಆಗಿಲ್ಲ. ಅದರ ಮುಂದೆ ಇಲ್ಲದ್ದನ್ನ literally ನೋಡೋಕಾಗಲ್ಲ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>ಇದು bug ಅಲ್ಲ. ಇದು architecture.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI context window ನ human ಒಂದೇ sitting ನಲ್ಲಿ document ಓದೋ ಥರ process ಮಾಡುತ್ತೆ. Document 100 pages ಉದ್ದ ಇದ್ರೆ, page 3 ನ details page 95 ಹೊತ್ತಿಗೆ fuzzy ಆಗಬಹುದು. Solution bigger window ಅಲ್ಲ &mdash; ಅದ್ರೊಳಗೆ ಏನು ಹಾಕ್ತೀಯ ಅನ್ನೋದ್ರಲ್ಲಿ smarter ಆಗೋದು.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FORGETTING EXPERIMENT ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ForgettingExperiment client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SYSTEM PROMPT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        System Prompt: Hidden Instructions
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ಪ್ರತಿ AI conversation ನಲ್ಲಿ ನಿನಗೆ ಕಾಣದ ಒಂದು ಭಾಗ ಇದೆ. ನಿನ್ನ ಮೊದಲ message ಮೊದಲು, AI hello ಹೇಳೋ ಮೊದಲು, context window ನ ಅತ್ಯಂತ ಮೇಲೆ ಒಂದು block text ಇರುತ್ತೆ. ಅದಕ್ಕೆ <strong>system prompt</strong> ಅಂತ ಹೇಳ್ತಾರೆ, ಮತ್ತು ಅದು ಮುಂದಿನ ಎಲ್ಲಾ shape ಮಾಡುತ್ತೆ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        System prompt ನಲ್ಲಿ AI ಗೆ ತನ್ನ personality, rules, boundaries ಸಿಗುತ್ತೆ. ChatGPT weapon ಮಾಡೋಕೆ help ಮಾಡೋಕೆ refuse ಮಾಡಿದಾಗ, ಅದು system prompt. Claude "I'd be happy to help" ಅನ್ನೋಕೆ, ಅದು trained behavior system prompt ನಿಂದ reinforce ಆಗಿರೋದು. Customer service chatbot topic ನಲ್ಲೇ ಇರೋಕೆ &mdash; ಅದೂ system prompt.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style="--accent: #7B61FF;">
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Example system prompt</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          "ನೀನು helpful cooking assistant. Cooking ಮತ್ತು food preparation ಬಗ್ಗೆ ಮಾತ್ರ questions ಗೆ answer ಮಾಡು. ಬೇರೆ ಏನಾದ್ರೂ ಕೇಳಿದ್ರೆ, politely cooking topics ಗೆ redirect ಮಾಡು. Responses 150 words ಕೆಳಗೆ ಇರಲಿ. Warm, encouraging tone use ಮಾಡು."
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        System prompt special ಯಾಕಂದ್ರೆ ಅದು <strong>context window ನ ಮೇಲ್ಭಾಗದಲ್ಲಿ pinned ಆಗಿರುತ್ತೆ</strong>. Conversation ಎಷ್ಟೇ ಉದ್ದ ಆಗಲಿ, system prompt scroll away ಆಗಲ್ಲ. ಯಾವಾಗ್ಲೂ ಅಲ್ಲೇ ಇರುತ್ತೆ, ಯಾವಾಗ್ಲೂ AI behavior influence ಮಾಡ್ತಾ ಇರುತ್ತೆ. ಅದು ಇಡೀ context window ನ ಅತ್ಯಂತ valuable real estate.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        System prompt ನ AI ಯ job description ಅಂತ ಯೋಚಿಸು. ಅದು AI ಗೆ ಏನು ಹೇಳಬೇಕು ಅಂತ ಹೇಳಲ್ಲ &mdash; ಯಾರಾಗಿ <em>ಇರಬೇಕು</em> ಅಂತ ಹೇಳುತ್ತೆ.
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: SYSTEM PROMPT SANDBOX ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <SystemPromptSandbox client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONTEXT ENGINEERING STRATEGIES ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Context Manage ಮಾಡೋ Strategies
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14">
        ಈಗ window ಅರ್ಥ ಆಯ್ತಲ್ಲ, pro ಥರ manage ಮಾಡೋ ವಿಧಾನ ಇಲ್ಲಿದೆ. "AI use ಮಾಡ್ತೀನಿ" ಅನ್ನೋ ಜನರನ್ನ extraordinary results ಪಡೆಯೋ ಜನರಿಂದ ಬೇರ್ಪಡಿಸೋ techniques ಇವು.
      </p>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
