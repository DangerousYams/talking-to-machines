---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ContextWindowViz from '../../components/widgets/ch3/ContextWindowViz';
import VibeCheck from '../../components/breaks/VibeCheck';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[2];
---

<ChapterLayout chapter={chapter} locale="kn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>3</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          ಅಧ್ಯಾಯ ಮೂರು
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Context<br />Engineering
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          AI ಮರೆಯಲ್ಲ &mdash; ಅದು ಮೊದಲೇ<br />ನೆನಪಿಡ್ತಾ ಇರ್ಲಿಲ್ಲ.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        ನೀನು AI ಗೆ message ಕಳಿಸಿದ ಪ್ರತಿ ಸಲ, ಅದು ನಿನ್ನ <em>ಇಡೀ conversation</em> ಮೊದಲಿಂದ ಓದುತ್ತೆ &mdash; ನೀನು ಕಳಿಸಿದ ಪ್ರತಿ message, ಅದು ಕೊಟ್ಟ ಪ್ರತಿ response &mdash; reply generate ಮಾಡುತ್ತೆ, ಮತ್ತೆ ಎಲ್ಲಾ ಮರೆತುಬಿಡುತ್ತೆ. ಮುಂದಿನ turn ನಲ್ಲಿ, ಅದೇ ಕೆಲ್ಸ. ಪೂರ್ತಿ transcript ಮತ್ತೆ feed ಆಗುತ್ತೆ. ಇದು ಜಗತ್ತಿನ ಅತ್ಯಂತ dedicated ಆದ್ರೆ amnesiac reader: ಪ್ರತಿ ಸಲ ಪೂರ್ತಿ ಓದುತ್ತೆ, ಆದ್ರೆ ಪ್ರತಿ turn zero ನಿಂದ start.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONCEPT SETUP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Window ಗೆ ಅಂಚುಗಳಿವೆ
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10" style="margin-top: 0;">
        AI ಪ್ರತಿ turn ನಲ್ಲಿ ಓದೋ ಆ transcript ಇರೋದು <strong>context window</strong> ಅನ್ನೋ ಒಂದರ ಒಳಗೆ &mdash; ಅದನ್ನ <strong>tokens</strong> ನಲ್ಲಿ measure ಮಾಡ್ತಾರೆ (roughly ಒಂದು token ಅಂದ್ರೆ ಮುಕ್ಕಾಲು word). Claude ನ window ಸುಮಾರು 200,000 tokens hold ಮಾಡುತ್ತೆ &mdash; ಒಂದು 500-page book. ದೊಡ್ಡದು ಅನ್ಸುತ್ತೆ, ಆದ್ರೆ ನೀನು ಕಳಿಸೋ ಪ್ರತಿ message, ನಿನಗೆ ಸಿಗೋ ಪ್ರತಿ response, ಮತ್ತು ಪ್ರತಿ hidden system instruction ಎಲ್ಲಾ ಅದೇ budget ನಿಂದ ತಿನ್ನುತ್ತೆ. ನೀನು ಅಂದ್ಕೊಳ್ಳೋದಕ್ಕಿಂತ ಬೇಗ full ಆಗುತ್ತೆ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Budget ಮುಗಿದಾಗ, ಹಳೆಯ messages ಅಂಚಿನಿಂದ ಕೆಳಗೆ ಬೀಳುತ್ತೆ. ನೀನು message three ನಲ್ಲಿ ನಿನ್ನ dietary restrictions ಹೇಳಿದ್ಯಾ? Message fifteen ಹೊತ್ತಿಗೆ AI ಅದನ್ನ ನೋಡ್ತಾ ಇಲ್ಲ ಇರಬಹುದು. ಅದು careless ಆಗಿಲ್ಲ &mdash; ಅದರ ಮುಂದೆ ಇಲ್ಲದ್ದನ್ನ ಅದಕ್ಕೆ literally ನೋಡೋಕಾಗಲ್ಲ. AI ಈಗ ತನ್ನ window ನಲ್ಲಿ ಇರೋ information ಅಷ್ಟೇ good.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        ಅದಕ್ಕೇ best AI users ಒಳ್ಳೆ prompts ಬರೆಯೋದಷ್ಟೇ ಅಲ್ಲ &mdash; window <em>ಒಳಗೆ</em> ಏನು ಹೋಗುತ್ತೆ ಅನ್ನೋದನ್ನ manage ಮಾಡ್ತಾರೆ. Periodically summarize ಮಾಡು, key details visible ಇರಲಿ. ಮುಖ್ಯವಾದ್ದನ್ನ ಮೊದಲು ಹಾಕು. Topic ಬದಲಾದಾಗ fresh start ಮಾಡು. AI ನಿನ್ನ context efficiently parse ಮಾಡೋ ಥರ structured formats use ಮಾಡು. <strong>Context engineering ಅದೇ ಹೊಸ prompt engineering.</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>ಪ್ರಮುಖ ಒಳನೋಟ</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Great prompt ಬರೆಯೋದು step one. AI ಮುಂದೆ ಯಾವ information ಇಡಬೇಕು &mdash; ಮತ್ತು ಅದನ್ನ ಹೇಗೆ structure ಮಾಡಬೇಕು &mdash; ಅಲ್ಲಿ real leverage ಇದೆ. ಜಗತ್ತಿನ best prompt ಕೂಡ context ತಪ್ಪಿದ್ರೆ fail ಆಗುತ್ತೆ.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Context window fill ಆಗೋದು, overflow ಆಗೋದು, ಮತ್ತು ಮರೆಯೋದು &mdash; real time ನಲ್ಲಿ ನೋಡು.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ContextWindowViz client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="AI ಯಾಕೆ conversation ಮಧ್ಯದಲ್ಲಿ 'ಮರೆಯುತ್ತೆ' ಅಂತ ಈಗ ಅರ್ಥ ಆಯ್ತು. ಅದು memory ಅಲ್ಲ — ಅದು context window. ಈ course live demos ಜೊತೆ ತುಂಬಾ clearly explain ಮಾಡುತ್ತೆ." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        ಈಗ ನಿನಗೆ whiteboard ಕಾಣುತ್ತೆ. Window ನ ಅಂಚುಗಳು feel ಆಗುತ್ತೆ. ಅದು AI ಜೊತೆ ನಿನ್ನ ಪ್ರತಿ conversation ನ ಬದಲಾಯಿಸುತ್ತೆ.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        ಇಲ್ಲಿಯವರೆಗೆ ನಾವು chatbots ಜೊತೆ work ಮಾಡಿದ್ವಿ. ಮುಂದೆ, zoom out ಮಾಡೋಣ &mdash; chat window ಆಚೆ ನೂರಾರು AI tools ಇವೆ, ಮತ್ತು ಆ landscape ತಿಳಿದ್ರೆ ಏನೆಲ್ಲಾ possible ಅಂತ ನಿನ್ನ ಯೋಚನೆನೇ ಬದಲಾಗುತ್ತೆ.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Vibe Check" client:visible>
        <VibeCheck client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
