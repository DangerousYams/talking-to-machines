---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import AgentBlueprint from '../../components/widgets/ch6/AgentBlueprint';
import AgentTakeover from '../../components/breaks/AgentTakeover';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[5];
---

<ChapterLayout chapter={chapter} locale="kn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>6</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          ಅಧ್ಯಾಯ ಆರು
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Agents<br />Build ಮಾಡೋದು
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Calculator ಮತ್ತು coworker<br />ನಡುವಿನ ವ್ಯತ್ಯಾಸ.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Chatbot ನೀನು ಮಾತಾಡೋ ತನಕ wait ಮಾಡುತ್ತೆ. Agent ಮಾಡಲ್ಲ. ಅದಕ್ಕೆ goal ಕೊಡು — "Mars colonization ಬಗ್ಗೆ research ಮಾಡಿ report ಬರಿ" — ಅದು work ನ steps ಆಗಿ break ಮಾಡುತ್ತೆ, ಸರಿಯಾದ tools ಆಯ್ಕೆ ಮಾಡುತ್ತೆ, ಒಂದೊಂದಾಗಿ execute ಮಾಡುತ್ತೆ, ತನ್ನ results check ಮಾಡುತ್ತೆ, ಕೆಲ್ಸ ಮುಗಿಯೋ ತನಕ continue ಮಾಡುತ್ತೆ. ಆ distinction — <em>instructions ಗೆ respond ಮಾಡೋದಕ್ಕೂ</em> ಮತ್ತು <em>goal pursue ಮಾಡೋದಕ್ಕೂ</em> — ಅದೇ calculator ಮತ್ತು coworker ನಡುವಿನ ವ್ಯತ್ಯಾಸ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        Agents ಒಂದು loop ಮೇಲೆ run ಆಗ್ತಾವೆ: goal receive ಮಾಡು, steps plan ಮಾಡು, tools ಜೊತೆ execute ಮಾಡು, results observe ಮಾಡು, progress evaluate ಮಾಡು, adjust ಮಾಡು. ಅವು ಒಮ್ಮೆ plan ಮಾಡಿ blindly execute ಮಾಡಲ್ಲ — best ones step three sideways ಹೋದಾಗ gracefully recover ಆಗ್ತಾವೆ. ಆದ್ರೆ ಆ power ನಲ್ಲಿ dark side ಇದೆ: agents ಬರೀ bad answers ಕೊಡಲ್ಲ, ಅವು ಅವುಗಳ ಮೇಲೆ <em>act</em> ಮಾಡ್ತಾವೆ, ಮತ್ತೆ broken result use ಮಾಡಿ ಮುಂದಿನ decision ತಗೊಳ್ತಾವೆ. Failures compound ಆಗ್ತಾವೆ.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE ANATOMY OF AN AGENT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Agent Loop
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        ಪ್ರತಿ agent ಅದೇ five-step cycle ಮೇಲೆ run ಆಗುತ್ತೆ. ಈ steps ಅರ್ಥ ಮಾಡ್ಕೊಳ್ಳೋದು useful ಏನೋ build ಮಾಡೋದಕ್ಕೂ ನಿನ್ನ API credits ನ infinite loop ನಲ್ಲಿ ಸುಡೋ ಏನೋ build ಮಾಡೋದಕ್ಕೂ ಇರೋ ವ್ಯತ್ಯಾಸ.
      </p>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { letter: 'G', name: 'Goal', color: '#E94560', text: 'Clear objective receive ಮಾಡು. "Mars research ಮಾಡು" goal ಅಲ್ಲ. "Mars colonization challenges ಬಗ್ಗೆ 500-word summary, sources ಜೊತೆ ಬರಿ" ಅದು goal.' },
        { letter: 'P', name: 'Plan', color: '#7B61FF', text: 'Goal ನ concrete steps ಆಗಿ break ಮಾಡು. Good planners flexible plans create ಮಾಡ್ತಾರೆ. Bad planners ಮೊದಲ surprise ನಲ್ಲಿ ಒಡೆಯೋ rigid scripts create ಮಾಡ್ತಾರೆ.' },
        { letter: 'T', name: 'Execute', color: '#0EA5E9', text: 'ಪ್ರತಿ step ನ ಸರಿಯಾದ tool use ಮಾಡಿ run ಮಾಡು — search engines, code interpreters, file readers, APIs. Agents ಬರೀ think ಮಾಡಲ್ಲ. ಅವು act ಮಾಡ್ತಾವೆ.' },
        { letter: 'M', name: 'Observe', color: '#16C79A', text: 'ಏನಾಯ್ತು ಅಂತ record ಮಾಡು ಮತ್ತು results check ಮಾಡು. Memory ಇಲ್ಲದೆ, agent ಅದೇ failing action ಯನ್ನ forever repeat ಮಾಡಬಹುದು.' },
        { letter: 'E', name: 'Evaluate', color: '#F5A623', text: 'ಇದು work ಆಯ್ತಾ? Goal ಗೆ ಹತ್ತಿರ ಬಂದ್ನಾ? ಏನೋ off ಇದ್ರೆ, plan adjust ಮಾಡಿ ಮತ್ತೆ loop ಮಾಡು. ಇದೇ agent ನ script ನಿಂದ ಬೇರ್ಪಡಿಸೋದು.' },
      ].map((block, i) => (
        <FadeInBlock client:visible delay={i * 0.08}>
          <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${block.color};`}>
              {block.letter}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${block.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {block.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {block.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>ಪ್ರಮುಖ ಒಳನೋಟ</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Chatbot ಒಂದು single turn. Agent ಒಂದು ಇಡೀ conversation — ತನ್ನ ಜೊತೆ, ತನ್ನ tools ಜೊತೆ, ಮತ್ತು world ಜೊತೆ. Best agent builders autonomy maximize ಮಾಡಲ್ಲ. ಅವ್ರು thoughtful checkpoints design ಮಾಡ್ತಾರೆ, ಅಲ್ಲಿ agent pause ಆಗಿ human decide ಮಾಡಲಿ ಅಂತ ಬಿಡ್ತಾರೆ.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        ಈಗ ಒಂದು build ಮಾಡೋ ಸಮಯ. ನಿನ್ನದೇ agent scratch ನಿಂದ design ಮಾಡು.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <AgentBlueprint client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="ನನ್ನ ಮೊದಲ AI agent ನ scratch ನಿಂದ design ಮಾಡಿದೆ. ಈ course step by step architecture explain ಮಾಡುತ್ತೆ live demos ಜೊತೆ. Hype ಇಲ್ಲ, ಬರೀ building." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Goal ಎಲ್ಲ failure prevent ಮಾಡೋದಲ್ಲ — failure recoverable ಮಾಡೋದು.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        ಮುಂದೆ: ನೀನು real agent ಒಂದನ್ನ use ಮಾಡ್ತೀಯ — ನಿನ್ನ code ಓದೋ, changes ಬರೆಯೋ, tests run ಮಾಡೋ, ಮತ್ತು ತನ್ನ mistakes ತಾನೇ fix ಮಾಡೋ agent. Claude Code ಜೊತೆ ಭೇಟಿ.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(233,69,96,0.06) 15%, rgba(233,69,96,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#E94560" toolName="Agent Takeover" client:visible>
        <AgentTakeover client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
