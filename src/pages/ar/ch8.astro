---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import ProjectOrchestrator from '../../components/widgets/ch8/ProjectOrchestrator';
import ContextPacking from '../../components/widgets/ch8/ContextPacking';

const chapter = chapters[7];
---

<ChapterLayout chapter={chapter} locale="ar">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>8</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          الفصل الثامن
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          إدارة<br />التعقيد
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          إدارة الذكاء الاصطناعي عبر مشاريع أكبر<br />من أي نافذة سياق.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        هذه اللحظة التي يصطدم بها كل مبتدئ طموح: تطلب من الذكاء الاصطناعي بناء شيء حقيقي — لعبة كاملة، أو موقع ويب بواجهة خلفية، أو ورقة بحثية بمراجع — وكل شيء ينهار. ليس لأن الذكاء الاصطناعي ليس ذكيًا بما فيه الكفاية. بل لأن المشروع أكبر من أن تتحمله محادثة واحدة.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        تلصق جدارًا من المتطلبات، الذكاء الاصطناعي يعطيك ردًا يبدو واثقًا، وبعد عشرين دقيقة تدرك أنه نسي نصف ما طلبته، وناقض نفسه في البنية، وتخيل مكتبة غير موجودة. تحاول مرة أخرى. نفس النتيجة، هلوسات مختلفة.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        هذه ليست مشكلة ذكاء اصطناعي. إنها <strong>مشكلة إدارة</strong>. وتعلم حلها هو الفرق بين شخص يستخدم الذكاء الاصطناعي لمهام فردية وشخص يستخدمه لبناء أشياء حقيقية.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE ONE-PROMPT TRAP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        فخ التوجيه الواحد
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        عندما تتعلم استخدام الذكاء الاصطناعي لأول مرة، تحاول بشكل طبيعي فعل كل شيء بمحاولة واحدة. توجيه ضخم واحد. محادثة واحدة. محاولة واحدة. وللمهام البسيطة — كتابة إيميل، عصف ذهني، شرح مفهوم — هذا يعمل بشكل جيد.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        لكن التعقيد يكسر نهج التوجيه الواحد بثلاث طرق:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 2.5rem;">
        {[
          { num: '1', title: 'فيضان السياق', text: 'الذكاء الاصطناعي يستطيع حمل كمية محدودة من المعلومات في وقت واحد. المشروع الكامل يتجاوز ذلك الحد، فيبدأ الذكاء الاصطناعي "بنسيان" متطلباتك الأولى.' },
          { num: '2', title: 'تشتت الانتباه', text: 'حتى داخل نافذة السياق، طلب الذكاء الاصطناعي التوفيق بين اثنتي عشرة قضية مختلفة مرة واحدة يعني أن كل واحدة تحصل على تركيز أقل. الجودة تنخفض في كل الاتجاهات.' },
          { num: '3', title: 'تراكم الأخطاء', text: 'خطأ صغير واحد في نتاج معقد يتسلسل. إذا أخطأ الذكاء الاصطناعي في مخطط قاعدة البيانات، كل ما بُني على ذلك المخطط خاطئ أيضًا — ومن الصعب اكتشافه وسط جدار من الكود المولّد.' },
        ].map((item, i) => (
          <FadeInBlock client:visible delay={0.2 + i * 0.08}>
            <div style="display: flex; gap: 1.25rem; align-items: flex-start;">
              <div style={`flex-shrink: 0; width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 0.8rem; font-weight: 700; color: white; background: ${chapter.accent};`}>
                {item.num}
              </div>
              <div style="flex: 1;">
                <p style={`font-family: var(--font-heading); font-size: 1rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.3rem; line-height: 1.3;`}>
                  {item.title}
                </p>
                <p style="font-size: 0.95rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                  {item.text}
                </p>
              </div>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.5}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        الحل ليس توجيهًا أفضل. بل عملية أفضل.
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ DECOMPOSITION: THE MASTER SKILL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        التقسيم: المهارة الأساسية
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        مهندسو البرمجيات المحترفون لا يبنون تطبيقات كاملة في جلسة واحدة. يقسمونها إلى أجزاء — وحدات، ومكونات، ودوال — كل منها بغرض واضح، ومدخلات واضحة، ومخرجات واضحة. ثم يجمعونها.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        العمل مع الذكاء الاصطناعي على مشاريع معقدة يتطلب نفس الانضباط. تحتاج <strong>تقسيم</strong> مشروعك إلى مهام صغيرة بما يكفي لمحادثة ذكاء اصطناعي واحدة ومركزة لتتعامل معها جيدًا.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        التقسيم الجيد يتبع ثلاث قواعد:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
        <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
        {[
          { word: 'مسؤولية واحدة.', desc: 'كل مهمة تفعل شيئًا واحدًا. "صمم قاعدة البيانات وابنِ الـ API واكتب الواجهة" هي ثلاث مهام، وليست واحدة.' },
          { word: 'واجهات واضحة.', desc: 'كل مهمة لها مدخل محدد (ما تحتاجه للبدء) ومخرج محدد (ما تنتجه). مخرج مهمة يصبح مدخل التالية.' },
          { word: 'تبعيات بسيطة.', desc: 'المهام التي يمكن إنجازها بالتوازي يجب أن تُنجز كذلك. أنشئ تبعيات فقط عندما تحتاج مهمة فعلاً مخرج مهمة أخرى.' },
        ].map((step, i) => (
          <div style={`position: relative; padding-bottom: ${i < 2 ? '1.75rem' : '0'};`}>
            <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
            <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
              <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
              <span style="opacity: 0.7;"> {step.desc}</span>
            </p>
          </div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>التقسيم مهارة بشرية، وليست مهارة ذكاء اصطناعي.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          الذكاء الاصطناعي يمكنه مساعدتك في العصف الذهني لتقسيم المهام، لكن تحديد كيفية تقسيم العمل، وما يعتمد على ماذا، وما يجب تحديد أولويته — هذه وظيفتك. إنها إدارة المشاريع، وهي واحدة من أقيم المهارات التي يمكنك تطويرها.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO PROJECT ORCHESTRATOR -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        جرب تقسيم مشروع حقيقي. اسحب المهام، تتبع التبعيات، شاهد الخطة تتشكل.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: PROJECT ORCHESTRATOR ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ProjectOrchestrator client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE HANDOFF PATTERN ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        نمط التسليم
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        بمجرد أن تقسم مشروعًا إلى مهام، تحتاج طريقة لربطها. في سير عمل الذكاء الاصطناعي، هذا الرابط هو <strong>التسليم</strong> — اللحظة التي يصبح فيها مخرج محادثة مدخلاً للتالية.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: var(--color-navy);">
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>نمط التسليم</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          المحادثة الأولى تنتج <strong>مُنتَجًا</strong> — وثيقة، أو مخططًا، أو خطة.<br />
          ذلك المُنتَج يُلصق في المحادثة الثانية كـ <strong>سياق</strong>.<br />
          المحادثة الثانية تبني عليه وتنتج المُنتَج التالي.<br />
          كرر حتى يكتمل المشروع.
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        فكر فيه كسباق تتابع. كل عدّاء (محادثة) يغطي مرحلته ويمرر العصا (المُنتَج) للتالي. العصا هي القطعة الحاسمة — إذا سقطت أو تشوشت، العدّاء التالي يتعثر.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        هذا يعني أن مُنتَجات التسليم يجب أن تكون <em>واضحة</em>. مخطط قاعدة بيانات أفضل كتسليم من وصف غامض لنموذج البيانات. قائمة مرقمة من نقاط نهاية API أفضل من "أحتاج واجهة خلفية تتعامل مع أمور المستخدمين." كلما كان المُنتَج أوضح، كان أداء المحادثة التالية أفضل.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        جودة مُنتَج التسليم تحدد جودة كل ما يُبنى بعده. قمامة تدخل، قمامة تخرج — عبر المحادثات.
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONTEXT PACKING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        فن حزم السياق
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        كل مرة تبدأ محادثة جديدة مع الذكاء الاصطناعي، أنت تتخذ قرارًا لا يلاحظه معظم الناس: <strong>أي سياق تضمّن؟</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        لديك ميزانية محدودة — نافذة السياق. ولديك كومة من المعلومات المحتملة المفيدة: ملفات كود، وتوثيق، ومحادثات سابقة، وسجلات أخطاء، ومواصفات تصميم. ليس كلها سيتسع. وحتى لو اتسعت، تفريغ كل شيء سيشتت انتباه الذكاء الاصطناعي.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        حزم السياق مثل حزم حقيبة سفر لرحلة. لا تستطيع أخذ خزانتك بالكامل. تحتاج أن تفكر أين أنت ذاهب (المهمة)، ماذا ستحتاج (المعلومات المفيدة)، وماذا يمكنك تركه (كل شيء آخر).
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div style="display: flex; flex-direction: column; gap: 1.25rem; margin-bottom: 2.5rem;">
        {[
          { label: 'سياق قليل جدًا', color: '#E94560', text: 'الذكاء الاصطناعي لا يملك ما يحتاجه ويملأ الفجوات بالهلوسات. يبدو واثقًا لكنه يخترع التفاصيل.' },
          { label: 'سياق كثير جدًا', color: '#F5A623', text: 'الذكاء الاصطناعي يُغمر. التفاصيل المهمة تضيع في الضوضاء. النتاج يصبح عامًا وغير مركز.' },
          { label: 'السياق المناسب', color: '#16C79A', text: 'الذكاء الاصطناعي لديه بالضبط ما يحتاجه لهذه المهمة المحددة. النتاج دقيق، ومتعلق، وقابل للتنفيذ.' },
        ].map((item, i) => (
          <FadeInBlock client:visible delay={0.25 + i * 0.08}>
            <div style={`padding: 1rem 1.25rem; border-radius: 10px; border-left: 3px solid ${item.color}; background: ${item.color}08;`}>
              <p style={`font-family: var(--font-heading); font-size: 0.9rem; font-weight: 700; color: ${item.color}; margin: 0 0 0.25rem;`}>
                {item.label}
              </p>
              <p style="font-size: 0.9rem; line-height: 1.7; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {item.text}
              </p>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>فكر كمحرر، لا كمكتنز.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          قبل كل تفاعل مع الذكاء الاصطناعي، اسأل نفسك: ما الذي <em>يحتاج الذكاء الاصطناعي معرفته</em> لإنجاز هذه المهمة المحددة؟ ضمّن ذلك. اترك كل شيء آخر. هذه هندسة السياق مطبقة على إدارة المشاريع.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO CONTEXT PACKING -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        احزم حقيبة سياق. هل تستطيع وضع ما يهم دون أن تفيض؟
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: CONTEXT PACKING ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ContextPacking client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ VERSION CONTROL FOR AI WORK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        تتبع ما نجح
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        إليك سيناريو يحدث مع الجميع: لديك محادثة رائعة مع الذكاء الاصطناعي تنتج بالضبط النتيجة التي تحتاجها. بعد أسبوع، تحتاج شيئًا مشابهًا. لا تتذكر ماذا قلت. تحاول إعادة إنتاجها. النتائج أسوأ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
