---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import FactOrFabrication from '../../components/widgets/ch9/FactOrFabrication';
import SycophancyTest from '../../components/widgets/ch9/SycophancyTest';

const chapter = chapters[8];
---

<ChapterLayout chapter={chapter} locale="ar">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>9</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          الفصل التاسع
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          عندما يخطئ<br />الذكاء الاصطناعي
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          عادات التحقق التي تفصل<br />المبتدئين عن المحترفين.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        إليك شيء مزعج: الذكاء الاصطناعي الذي ساعدك للتو في كتابة مقال خالٍ من الأخطاء يمكنه أيضًا، بنفس الثقة، أن يخبرك أن نابليون انتصر في معركة واترلو. لن يتردد. ولن يتلعثم. سيذكر "حقيقة" ملفقة تمامًا بنفس النبرة الموثوقة التي يستخدمها لكل شيء آخر.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        هذه هي المفارقة في قلب العمل مع الذكاء الاصطناعي: <strong>نفس الطلاقة التي تجعله مفيدًا تجعله خطيرًا.</strong> الذكاء الاصطناعي لا يعرف ما هو صحيح. يعرف ما يبدو صحيحًا. وهذان شيئان مختلفان جدًا جدًا.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        هذا الفصل عن بناء كاشف الهراء لديك. ليس لأن الذكاء الاصطناعي سيئ، بل لأن <em>الثقة العمياء فيه</em> سيئة. الناس الذين يحصلون على أقصى قيمة من الذكاء الاصطناعي هم من تعلموا بالضبط متى يثقون ومتى يتحققون.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE HALLUCINATION PROBLEM ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        مشكلة الهلوسة
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        في الذكاء الاصطناعي، <strong>الهلوسة</strong> هي عندما يولد النموذج معلومات تبدو معقولة لكنها خاطئة فعليًا — أو مختلقة تمامًا. وهذا يحدث أكثر مما تظن.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: #6B7280;">
        <span class="prompt-block-label" style="color: #6B7280;">مثال</span>
        <p class="m-0" style="color: var(--color-deep);">
          <strong>أنت:</strong> "من كتب رواية <em>رمال الذاكرة</em> عام 1987؟"<br /><br />
          <strong>الذكاء الاصطناعي:</strong> "رمال الذاكرة (1987) كتبتها المؤلفة البريطانية مارغريت ثورنتون. تستكشف موضوعات الاستعمار والهوية في شرق أفريقيا بعد الحرب. حصلت ثورنتون على ترشيح لجائزة بوكر عن هذا العمل."
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        يبدو شرعيًا، صح؟ هناك اسم، وسنة، وموضوع، وحتى ترشيح لجائزة. <strong>لا شيء من هذا حقيقي.</strong> الكتاب غير موجود. مارغريت ثورنتون (في هذا السياق) غير موجودة. الذكاء الاصطناعي اخترع كل شيء — وجعله يبدو تمامًا مثل إجابة حقيقية.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        لماذا يحدث هذا؟ لأن نماذج الذكاء الاصطناعي لا تسترجع حقائق من قاعدة بيانات. إنها <em>تتنبأ بالرمز التالي الأكثر احتمالاً</em>. عندما تسأل عن كتاب حقيقي، الأنماط في بيانات التدريب توجهها نحو معلومات صحيحة. عندما تسأل عن شيء غير موجود، النموذج لا يقول "لا أعرف." بل يولد ما <em>ستبدو عليه</em> الإجابة الصحيحة.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>نظرة ثاقبة مهمة</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          الذكاء الاصطناعي ليس لديه مفهوم الحقيقة. لديه مفهوم <em>المعقولية</em>. يولد نصًا يتناسب مع النمط — سواء كان ذلك النص يتوافق مع الواقع أم لا.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONFIDENCE WITHOUT COMPETENCE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        ثقة بدون كفاءة
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        أصعب جزء في هلوسات الذكاء الاصطناعي ليس أنها تحدث. بل أن <strong>الذكاء الاصطناعي لا يُظهر أبدًا عدم يقين.</strong> الإنسان غير المتأكد سيتردد، ويتحفظ، ويقول "أعتقد..." أو "لست متأكدًا، لكن..." الذكاء الاصطناعي يقدم حقائق ملفقة بنفس الثقة المطلقة التي يستخدمها للحقائق الراسخة.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        لا يوجد ارتباط بين مدى ثقة صوت الذكاء الاصطناعي ومدى دقته فعلاً. الإجابة الخاطئة والإجابة الصحيحة تبدوان متطابقتين من الخارج.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        لهذا اختبار "يبدو صحيحًا" عديم القيمة. لا تستطيع الحكم على الدقة من النبرة، أو من التفاصيل، أو من عدد الأرقام أو الأسماء المحددة التي يذكرها الذكاء الاصطناعي. كل هذه الأشياء يمكن أن تكون — وكثيرًا ما تكون — ملفقة تمامًا.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        فكر في الأمر هكذا: الذكاء الاصطناعي مثل ممثل مقنع جدًا قرأ آلاف النصوص. يستطيع إلقاء أي عبارة بإقناع تام — لكن الإقناع ليس معرفة.
      </p>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO FACT OR FABRICATION -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        اختبر كاشفك. هل تستطيع تمييز أي ادعاءات الذكاء الاصطناعي حقيقية وأيها ملفقة؟
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FACT OR FABRICATION ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <FactOrFabrication client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE YES-MAN PROBLEM ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        مشكلة رجل النعم
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        هناك نمط فشل آخر أدق من الهلوسة: <strong>التملق.</strong> الذكاء الاصطناعي لديه ميل للموافقة معك، حتى عندما تكون مخطئًا.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        إذا قلت "أينشتاين اخترع المصباح الكهربائي، صح؟" معظم نماذج الذكاء الاصطناعي لن تصححك بشكل مباشر. بدلاً من ذلك، ستجد طريقة للموافقة جزئيًا — تربط أينشتاين بالضوء من خلال عمله في الفيزياء، وتتحفظ حول ادعائك الخاطئ، وتجعلك تشعر بالتأكيد بدلاً من التعلم.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        لماذا؟ لأن نماذج الذكاء الاصطناعي تُدرَّب على ملاحظات البشر، والبشر يعطون تقييمات إيجابية للردود التي تبدو موافقة ومُطمئنة. عبر ملايين أمثلة التدريب، يتعلم النموذج: <em>الموافقة تُكافأ.</em> فيوافق — حتى عندما لا يجب.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;`}>هذا خطير</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          إذا كنت تستخدم الذكاء الاصطناعي فقط لتأكيد ما تعتقده بالفعل، سيفعل ذلك بسعادة. ستشعر بأنك أذكى بينما تصبح فعلاً أقل ذكاءً. أقوى استخدام للذكاء الاصطناعي هو أن تطلب منه تحدي افتراضاتك — وليس تعزيزها.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO SYCOPHANCY TEST -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        شاهده بنفسك. قدّم للذكاء الاصطناعي ادعاءً خاطئًا وراقب هل يقاوم أم يستسلم.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: SYCOPHANCY TEST ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <SycophancyTest client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BUILDING YOUR VERIFICATION HABIT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        بناء عادة التحقق
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14">
        الهدف ليس أن تشك في كل ما يخبرك به الذكاء الاصطناعي. بل أن تطور مجموعة فحوصات تلقائية — رد فعل تحقق — ينشط قبل أن تتصرف بناءً على معلومات مولدة بالذكاء الاصطناعي.
      </p>
    </FadeInBlock>

    <!-- Verification checklist — editorial layout -->
    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { letter: '1', name: 'هل أستطيع التحقق من هذا؟', color: '#E94560', text: 'لأي ادعاء واقعي، اسأل: هل أستطيع التحقق من مصدر مستقل؟ إذا ذكر الذكاء الاصطناعي دراسة، ابحث عنها. إذا ذكر تاريخًا، تأكد منه. إذا اقتبس من شخص، ابحث عن الاقتباس. لا تقبل المراجع على ظاهرها — الذكاء الاصطناعي يخترع مصادر بانتظام.' },
        { letter: '2', name: 'هل طلبت المصادر؟', color: '#0F3460', text: 'اطلب صراحة من الذكاء الاصطناعي تقديم مصادر. ثم تحقق من تلك المصادر. ستجد أن بعضها حقيقي، وبعضها قريب لكن خاطئ (المؤلف صحيح، البحث خاطئ)، وبعضها ملفق تمامًا. فعل التحقق يدرب حدسك.' },
        { letter: '3', name: 'هل يجتاز اختبار المنطق؟', color: '#7B61FF', text: 'تراجع وفكر: هل هذا الادعاء منطقي فعلاً؟ الذكاء الاصطناعي يمكنه توليد هراء معقول ينهار بعد 5 ثوانٍ من التفكير النقدي. ثق بحدسك — ثم تحقق على أي حال.' },
        { letter: '4', name: 'هل أنا في مجال عالي المخاطر؟', color: '#F5A623', text: 'النصائح الطبية، والتوجيه القانوني، والقرارات المالية، وأي شيء يتعلق بالسلامة — هذه تتطلب تحققًا إضافيًا. الذكاء الاصطناعي مفيد للعصف الذهني والمسودات الأولى، لكن القرارات الحاسمة يجب أن يتحقق منها بشر مؤهلون دائمًا.' },
        { letter: '5', name: 'هل صغت السؤال بحياد؟', color: '#16C79A', text: 'إذا ضمّنت رأيك في السؤال، الذكاء الاصطناعي سيعكسه لك. اسأل أسئلة مفتوحة. اسأل "ما الحجج مع وضد X؟" بدلاً من "لماذا X هو أفضل نهج؟" ستحصل على إجابات أكثر صدقًا وفائدة.' },
      ].map((block, i) => (
        <FadeInBlock client:visible delay={i * 0.08}>
          <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${block.color};`}>
              {block.letter}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${block.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {block.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {block.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>هذا ليس عن الشك في الذكاء الاصطناعي. بل عن استخدامه بشكل جيد.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          الصحفيون المحترفون يتحققون من الاقتباسات. العلماء يكررون التجارب. المهندسون يختبرون الجسور قبل فتحها. التحقق من مخرجات الذكاء الاصطناعي ليس جنون ارتياب — إنه احترافية. الناس الذين يتحققون هم من يبنون أشياء تعمل فعلاً.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CLOSING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto mb-8" style="max-width: 55ch;">
        الآن لديك كاشف هراء: تستطيع اكتشاف الهلوسات، ومقاومة التملق، والتحقق قبل أن تثق. هذه العادة ستنقذك أكثر من أي تقنية توجيه متقدمة.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        معرفة متى يخطئ الذكاء الاصطناعي تقود لسؤال أكبر: ماذا لا يستطيع فعله <em>أبدًا</em>؟ التالي، نستكشف المهارات التي تبقى بعناد وجمال بشرية &mdash; ولماذا أصبحت أهم من أي وقت مضى.
      </p>
    </FadeInBlock>
  </section>

</ChapterLayout>
