---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import AgentBlueprint from '../../components/widgets/ch6/AgentBlueprint';
import FailureModesLab from '../../components/widgets/ch6/FailureModesLab';
import HandoffChain from '../../components/widgets/ch6/HandoffChain';

const chapter = chapters[5];
---

<ChapterLayout chapter={chapter} locale="ar">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>6</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          الفصل السادس
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          بناء<br />الوكلاء
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          صمم، واربط، وانشر وكيل ذكاء اصطناعي<br />من الصفر.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        روبوت المحادثة ينتظرك لتتكلم. الوكيل لا ينتظر. أعطه هدفًا — "ابحث عن استعمار المريخ واكتب تقريرًا" — وهو يقسم العمل إلى خطوات، يختار الأدوات المناسبة، ينفذها واحدة تلو الأخرى، يتحقق من نتائجه، ويستمر حتى ينتهي العمل. بدون حاجة لمسك يده.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        هذا الفرق — بين <em>الاستجابة للتعليمات</em> و<em>متابعة هدف</em> — هو الفرق بين آلة حاسبة وزميل عمل. روبوتات المحادثة تجيب على الأسئلة. الوكلاء يحلون المشاكل.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        هذا الفصل عن كيف يعمل الوكلاء فعلاً من الداخل — الحلقة التي تحركهم، والبنية التي تجعلهم موثوقين، وأنماط الفشل التي تجعلهم خطرين عندما يُبنون بإهمال.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE AGENT LOOP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        حلقة الوكيل
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        في الفصل الخامس، رأيت حلقة استخدام الأدوات الأساسية: لاحظ، فكر، نفّذ. الوكلاء يوسعون ذلك إلى شيء أكثر طموحًا — دورة من خمس خطوات، كل منها يعمل بمكون داخلي مختلف:
      </p>
    </FadeInBlock>

    <!-- Loop Steps with architecture component for each -->
    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { letter: 'G', word: 'الهدف', color: '#E94560', desc: 'استقبل هدفًا عالي المستوى من الإنسان. بدون هدف واضح، لا يستطيع الوكيل تحديد ما إذا كان قد انتهى. "ابحث عن المريخ" ليس هدفًا. "اكتب ملخصًا من 500 كلمة عن تحديات استعمار المريخ، مع المصادر" هو هدف.' },
        { letter: 'P', word: 'التخطيط', color: '#7B61FF', desc: 'قسم الهدف إلى خطوات ملموسة. أفضل المخططين ينشئون خططًا مرنة تتكيف عندما تفشل خطوة. المخططون السيئون ينشئون نصوصًا جامدة تنكسر عند أول مفاجأة.' },
        { letter: 'T', word: 'التنفيذ', color: '#0EA5E9', desc: 'شغّل كل خطوة باستخدام الأداة المناسبة — محركات البحث، مفسرات الكود، قارئات الملفات، واجهات API، الآلات الحاسبة. الوكلاء لا يفكرون فقط. إنهم يتصرفون.' },
        { letter: 'M', word: 'الملاحظة', color: '#16C79A', desc: 'سجل ما حدث وتحقق من النتائج. بدون ذاكرة لما فعله ووجده، قد يكرر الوكيل في الحلقة نفس الإجراء الفاشل للأبد.' },
        { letter: 'E', word: 'التقييم', color: '#F5A623', desc: 'هل نجح هذا؟ هل هذه البيانات موثوقة؟ هل أنا أقرب للهدف؟ المقيّم يفصل الوكيل عن نص برمجي يشتغل ويأمل الأفضل. إذا كان هناك خلل، عدّل الخطة وأعد الحلقة.' },
      ].map((step, i) => (
        <FadeInBlock client:visible delay={i * 0.08}>
          <div style={`display: flex; gap: 1.25rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1rem; font-weight: 800; color: white; background: ${step.color};`}>
              {step.letter}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.05rem; font-weight: 700; color: ${step.color}; margin: 0 0 0.3rem; line-height: 1.3;`}>
                {step.word}
              </p>
              <p style="font-size: 0.95rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {step.desc}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <p class="text-lg leading-[1.85] mb-10">
        الكلمة المفتاحية هي <em>حلقة</em>. الوكيل لا يخطط مرة واحدة وينفذ بشكل أعمى. يخطط، ينفذ، يلاحظ، يقيّم، ويعدّل. أفضل الوكلاء هم الذين يتعافون بسلاسة عندما تنحرف الخطوة الثالثة.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.55}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        روبوت المحادثة هو دور واحد. الوكيل هو محادثة كاملة — مع نفسه، وأدواته، والعالم.
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO AGENT BLUEPRINT -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        حان وقت البناء. صمم وكيلك الخاص من الصفر.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: AGENT BLUEPRINT ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <AgentBlueprint client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ WHEN AGENTS FAIL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        عندما يفشل الوكلاء
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        الوكلاء لا يفشلون مثل روبوتات المحادثة. روبوت المحادثة يعطيك إجابة سيئة وينتظر. الوكيل يعطي نفسه إجابة سيئة، <em>يتصرف بناءً عليها</em>، ثم يستخدم النتيجة المعطوبة لاتخاذ القرار التالي. الأخطاء تتراكم.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        هناك ثلاث طرق كلاسيكية لانحراف الوكلاء:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>نمط الفشل 1: الحلقة اللانهائية</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          الوكيل يعلق في تكرار نفس الإجراء. وكيل بحث يستمر في البحث عن "مصدر آخر" ولا يبدأ أبدًا في الكتابة. بدون شرط توقف، يستمر في العمل حتى تسحب القابس — أو تنفد رصيدك من API.
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="prompt-block mb-10" style={`--accent: #7B61FF;`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:#7B61FF;`}></div>
        <span class="prompt-block-label" style="color: #7B61FF;">نمط الفشل 2: الأداة الخاطئة</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          الوكيل يختار أداة لا تستطيع إنجاز المهمة. يحاول البحث في الويب عن ملف على قرصك الصلب، أو يستدعي آلة حاسبة لتلخيص مقال. ليس لأن الوكيل غبي — فقط اختار من صندوق أدواته دون التحقق من ملاءمة الأداة للمهمة.
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="prompt-block mb-10" style={`--accent: #F5A623;`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:#F5A623;`}></div>
        <span class="prompt-block-label" style="color: #F5A623;">نمط الفشل 3: الإجراءات المتخيلة</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          الوكيل يخترع أدوات أو واجهات API غير موجودة، ثم "يستدعيها" بنتائج وهمية. عندما يفشل الاستدعاء الوهمي، يفبرك أحيانًا البيانات التي كان من المفترض أن يحصل عليها. هلوسة مزدوجة: أداة وهمية، ونتيجة وهمية.
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        الحل دائمًا نفس المبدأ: <strong>صمم للمسار غير السعيد.</strong> حد أقصى للتكرارات، التحقق من الأدوات، التحقق من المخرجات، ونقاط تفتيش بشرية. الهدف ليس منع كل فشل — بل جعل الفشل قابلاً للتعافي.
      </p>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO FAILURE MODES LAB -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        هل تستطيع تشخيص وكيل معطل؟ اعثر على الخلل وأضف حاجز الحماية.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FAILURE MODES LAB ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <FailureModesLab client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE POWER OF MANY: MULTI-AGENT SYSTEMS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        قوة الأعداد
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        وكيل واحد مفيد. عدة وكلاء يعملون معًا يستطيعون معالجة مشاكل ستغمر أي نظام منفرد. السر هو التخصص.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        فكر في الأمر كغرفة أخبار. لا تطلب من نفس الشخص أن يحقق في القصة، ويكتب المقال، ويحرره للنشر. كل دور يتطلب عقلية مختلفة، وأدوات مختلفة، ومعايير مختلفة.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        أنظمة الوكلاء المتعددة تعمل بنفس الطريقة. وكيل <strong>الباحث</strong> يجمع المعلومات. وكيل <strong>الكاتب</strong> يحول الملاحظات الخام إلى نثر مصقول. وكيل <strong>المحرر</strong> يراجع، ويدقق الحقائق، ويقترح تحسينات. كل وكيل لديه توجيه النظام الخاص به، وأدواته الخاصة، ومعايير نجاحه الخاصة.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        السؤال الحاسم في تصميم الوكلاء المتعددين ليس "ما مدى ذكاء كل وكيل؟" بل <strong>"ما مدى جودة التسليم؟"</strong> عندما يمرر الباحث ملاحظات للكاتب، هل تلك الملاحظات منظمة بوضوح؟ عندما يمرر الكاتب مسودة للمحرر، هل لدى المحرر سياق كافٍ لتقديم ملاحظات مفيدة؟
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>نظرة ثاقبة مهمة</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          وثيقة التسليم هي أهم مُنتَج في نظام الوكلاء المتعددين. كاتب رائع لا يستطيع إنقاذ ملاحظات بحثية فوضوية. الواجهة بين الوكلاء هي حيث تُكسب الجودة أو تُخسر.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO HANDOFF CHAIN -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        شاهد ثلاثة وكلاء يتعاونون. انتبه لوثائق التسليم &mdash; هناك يحدث السحر.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: HANDOFF CHAIN ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <HandoffChain client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ HUMAN IN THE LOOP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        الإنسان في الحلقة
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        في الفصل الخامس، تعلمت إطار الثقة: المخاطر، وإمكانية التراجع، والثقة تحدد مقدار الاستقلالية الممنوحة. مع الوكلاء، يصبح هذا أكثر أهمية — لأن الوكلاء لا يجيبون على الأسئلة فقط. إنهم <em>يتخذون إجراءات</em>، ويربطونها ببعض، ويراكمون الأخطاء إذا تُركوا دون رقابة.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85]">
        أفضل بناة الوكلاء ليسوا من يزيدون الاستقلالية. إنهم يصممون <strong>نقاط تفتيش مدروسة</strong> — لحظات يتوقف فيها الوكيل، ويعرض عمله، ويدع إنسانًا يقرر هل يستمر أم لا. الوكيل الممتاز يعرف متى يسأل.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CLOSING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto mb-8" style="max-width: 55ch;">
        رأيت الوكلاء من الداخل: الحلقة التي تحركهم، والبنية التي تجعلهم يعملون، وأنماط الفشل التي تجعلهم خطرين عندما يُبنون بإهمال.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        النظرية شيء. التالي، ستستخدم وكيلاً حقيقيًا &mdash; واحد يقرأ كودك، ويكتب التعديلات، ويشغل الاختبارات، ويصلح أخطاءه بنفسه. تعرف على Claude Code.
      </p>
    </FadeInBlock>
  </section>

</ChapterLayout>
