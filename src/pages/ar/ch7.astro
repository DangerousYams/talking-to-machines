---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import TerminalPlayground from '../../components/widgets/ch7/TerminalPlayground';
import SkillBuilder from '../../components/widgets/ch7/SkillBuilder';
import RefactorRace from '../../components/widgets/ch7/RefactorRace';

const chapter = chapters[6];
---

<ChapterLayout chapter={chapter} locale="ar">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>7</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          الفصل السابع
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          إتقان<br />Claude Code
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          شريكك البرمجي بالذكاء الاصطناعي، من أول<br />أمر إلى المهارات المخصصة.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        هناك لحظة يتذكرها كل مبرمج. تفتح الطرفية، تكتب طلبًا بلغة طبيعية، وتشاهد الذكاء الاصطناعي يقرأ ملفاتك، ويفهم بنية مشروعك، ويكتب كودًا عبر ملفات متعددة، ويشغله، ويصطدم بخطأ، ويصلح الخطأ، ويشغله مرة أخرى — كل ذلك بدون أن تلمس سطرًا واحدًا. هذا هو Claude Code.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        ليس إكمالاً تلقائيًا. وليس روبوت محادثة يكتب مقتطفات. Claude Code هو أداة برمجة <em>وكيلية</em> — شريك في سطر الأوامر يستطيع رؤية مشروعك بالكامل، وإجراء تعديلات عبر الملفات، وتنفيذ أوامر الشِل، والتكرار على أخطائه. لا يقترح كودًا فقط. بل <strong>يُشحن</strong> كودًا.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        لكن الأداة لا تكون أفضل من الإنسان الذي يوجهها. Claude Code يستطيع كتابة ألف سطر من الكود المثالي في ثوانٍ — أو ألف سطر من الهراء الذي يبدو مقنعًا. الفرق هو أنت.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ HOW CLAUDE CODE THINKS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        كيف يفكر Claude Code
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        عندما تعطي Claude Code مهمة، لا يبدأ بالكتابة مباشرة. يشغّل حلقة الوكيل من الفصل السادس، متخصصة للكود:
      </p>
    </FadeInBlock>

    <!-- Agent loop visualization -->
    <FadeInBlock client:visible delay={0.15}>
      <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
        <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
        {[
          { word: 'اقرأ.', desc: 'افحص قاعدة الكود — الملفات، الاستيرادات، الاختبارات، الإعدادات. افهم ما هو موجود.' },
          { word: 'خطط.', desc: 'قرر ما يجب تغييره، في أي ملفات، وبأي ترتيب.' },
          { word: 'اكتب.', desc: 'أجرِ التعديلات. أنشئ ملفات. عدّل الكود.' },
          { word: 'شغّل.', desc: 'نفّذ الأوامر — بناء، اختبار، فحص. شاهد ماذا يحدث.' },
          { word: 'أصلح.', desc: 'إذا انكسر شيء، اقرأ الخطأ، عدّل، وحاول مرة أخرى.' },
        ].map((step, i) => (
          <div style={`position: relative; padding-bottom: ${i < 4 ? '1.75rem' : '0'};`}>
            <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
            <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
              <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
              <span style="opacity: 0.7;"> {step.desc}</span>
            </p>
          </div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        حلقة اقرأ-خطط-اكتب-شغّل-أصلح هي ما يجعل Claude Code مختلفًا عن مولد كود بسيط. لا يسلمك مقتطفًا ويمشي. يبقى <em>في الحلقة</em> — يكرر حتى يعمل الكود فعلاً.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85]">
        فكر فيه كبرمجة ثنائية. تصف ما تريد. Claude Code يكتبه. الاختبارات تفشل. Claude Code يقرأ الخطأ، يعدّل، يعيد التشغيل. هذه الدورة قد تحدث ثلاث، خمس، عشر مرات — كلها في ثوانٍ.
      </p>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO TERMINAL PLAYGROUND -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        شاهد الحلقة وهي تعمل. اكتب طلبًا وراقب Claude Code يعمل.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: TERMINAL PLAYGROUND ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <TerminalPlayground client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE CLAUDE.MD FILE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        ملف CLAUDE.md
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        معظم المبتدئين يفوتهم هذا: <strong>يمكنك إعطاء Claude Code تعليمات دائمة.</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        ضع ملفًا اسمه <code>CLAUDE.md</code> في جذر مشروعك، و Claude Code يقرأه في بداية كل جلسة. إنه مثل توجيه النظام، لكن لقاعدة كودك بالكامل.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>CLAUDE.md</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep); font-family: var(--font-mono); font-size: 0.85rem;">
          # My Project<br /><br />
          Tech stack: Astro + React + Tailwind<br />
          Always use TypeScript with strict mode.<br />
          Put components in src/components/.<br />
          Write tests for every new function.<br />
          Use Prettier formatting — never change the config.<br /><br />
          ## Style Rules<br />
          - Prefer named exports over default exports<br />
          - Use CSS modules, not inline styles<br />
          - Keep components under 150 lines
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        بدون CLAUDE.md، تقضي الدقائق الأولى من كل جلسة في إعادة شرح تفضيلاتك. معه، Claude Code يعرف مسبقًا تقنياتك، واتفاقياتك، وحدودك. إنه هندسة السياق (الفصل الثالث) مطبقة على البرمجة.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>فكر في CLAUDE.md كدستور مشروعك.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          يُشفّر القرارات التي اتخذتها بالفعل — حتى يتمكن الذكاء الاصطناعي من التركيز على القرارات الجديدة فعلاً. كلما كان CLAUDE.md أكثر تحديدًا، قلّ ما تحتاج لتكراره.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BUILDING SKILLS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        بناء المهارات
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        CLAUDE.md يعطي Claude Code معرفة عامة عن مشروعك. لكن ماذا عن المهام المحددة المتكررة؟ هنا تأتي <strong>المهارات</strong>.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        المهارة هي مجموعة تعليمات داخل CLAUDE.md تعلم Claude Code كيف يتعامل مع نوع معين من المهام. فكر فيها كوصفة: "عندما يطلب منك أحد إنشاء مكون React جديد، إليك كيف تفعلها بالضبط."
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        بدون مهارات، تشرح نفس الخطوات في كل مرة. مع المهارات، تشرح مرة واحدة والذكاء الاصطناعي يتذكر للأبد.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        المهارة الجيدة لها ثلاثة أجزاء:
      </p>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { letter: 'T', name: 'المُشغّل', color: '#7B61FF', text: 'متى تنشط هذه المهارة؟ "عندما يُطلب إنشاء مكون..." أو "عند إصلاح فشل اختبار..." المشغلات الواضحة تمنع الذكاء الاصطناعي من استخدام الوصفة الخاطئة.' },
        { letter: 'S', name: 'الخطوات', color: '#16C79A', text: 'ماذا يجب أن يفعل بالضبط، بالترتيب؟ الخطوات المرقمة تعمل أفضل. كن محددًا بشأن مواقع الملفات، واتفاقيات التسمية، والأنماط المطلوبة.' },
        { letter: 'E', name: 'الأمثلة', color: '#F5A623', text: 'أظهر كيف تبدو النتيجة الناجحة. قبل وبعد، أو بنية ملفات نموذجية، أو مخرج مثال. الغموض يموت في حضور الأمثلة.' },
      ].map((block, i) => (
        <FadeInBlock client:visible delay={0.3 + i * 0.08}>
          <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${block.color};`}>
              {block.letter}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${block.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {block.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {block.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>
  </section>

  <!-- BRIDGE TO SKILL BUILDER -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        جرب كتابة واحدة. ابنِ مهارة من المُشغّل إلى الخطوات إلى الأمثلة.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: SKILL BUILDER ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <SkillBuilder client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ SPECIFY, GENERATE, VERIFY ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        حدد، ولّد، تحقق
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        عندما تعمل مع Claude Code، تتغير وظيفتك. لم تعد الشخص الذي يكتب كل سطر. أنت الشخص الذي <strong>يحدد</strong> ما يجب بناؤه، ويدع الذكاء الاصطناعي <strong>يولّده</strong>، ثم <strong>يتحقق</strong> من صحته فعلاً.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        هذه الحلقة — حدد، ولّد، تحقق — هي سير العمل الأساسي:
      </p>
    </FadeInBlock>

    <!-- SGV Loop -->
    <FadeInBlock client:visible delay={0.2}>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12">
        {[
          { step: '01', title: 'حدد', desc: 'كن دقيقًا فيما تريد. كلما كان طلبك أوضح، قل الوقت الذي تقضيه في إصلاح النتائج. ضمّن الحالات الحدية، ومواقع الملفات، والسلوك المتوقع.', color: '#7B61FF' },
          { step: '02', title: 'ولّد', desc: 'دع Claude Code يفعل ما يجيده. راقب حلقة الوكيل — يقرأ، يخطط، يكتب، يشغل، يصلح. قاوم الرغبة في المقاطعة أثناء الدورة.', color: '#0EA5E9' },
          { step: '03', title: 'تحقق', desc: 'هذه أهم وظيفة لديك. اقرأ الكود. شغّل الاختبارات. تحقق من الحالات الحدية. هل يفعل فعلاً ما طلبته؟ هل هو كود تضع اسمك عليه؟', color: '#16C79A' },
        ].map((item) => (
          <div style={`background: ${item.color}06; border: 1px solid ${item.color}18; border-radius: 12px; padding: 1.25rem;`}>
            <div style={`font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700; color: ${item.color}; letter-spacing: 0.1em; margin-bottom: 0.5rem;`}>{item.step}</div>
            <div style={`font-family: var(--font-heading); font-size: 1rem; font-weight: 700; color: ${item.color}; margin-bottom: 0.5rem;`}>{item.title}</div>
            <p style="font-size: 0.85rem; line-height: 1.65; color: var(--color-deep); opacity: 0.7; margin: 0;">
              {item.desc}
            </p>
          </div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85] mb-10">
        معظم المبتدئين يتخطون الخطوة الثالثة. يرون كودًا يظهر، يبدو معقولاً، ويمضون قدمًا. لا تكن ذلك الشخص. <strong>الكود المولّد هو مسودة أولى.</strong> تحققك هو التحرير الذي يجعلها قابلة للنشر.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        المفارقة؟ كلما كان الذكاء الاصطناعي أسرع في توليد الكود، <em>أصبح تحققك أكثر أهمية</em>. السرعة بدون حكم هي مجرد أخطاء أسرع.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SKILL PARADOX ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        مفارقة المهارة
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        إليك الحقيقة المزعجة عن البرمجة بمساعدة الذكاء الاصطناعي: <strong>تحتاج أن تعرف ما يكفي للحكم على النتيجة، حتى لو لم تكتبها بنفسك.</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        إذا لم تستطع قراءة الكود الذي يولده Claude، لا تستطيع التحقق منه. وإذا لم تستطع التحقق منه، فأنت تشحن تخمينات شخص آخر إلى الإنتاج.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        هذا يخلق مفارقة: الأداة التي تساعد المبتدئين في كتابة الكود تتطلب أيضًا معرفة كافية لتقييم ذلك الكود. الطريق من خلال ذلك؟ استخدم Claude Code <em>للتعلم</em>، وليس فقط للإنتاج.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        عندما يكتب Claude Code شيئًا لا تفهمه، لا تقبله فقط. اسأل: "اشرح ماذا يفعل هذا الكود ولماذا اخترت هذا النهج." استخدم الذكاء الاصطناعي كمعلم، وليس فقط كطابع.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>الهدف ليس أن تكتب كل سطر — بل أن تفهم كل سطر.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          أفضل مستخدمي Claude Code ليسوا من يولدون أكبر كمية من الكود. إنهم من يطرحون أفضل الأسئلة ويلتقطون أدق الأخطاء. معرفتك هي مرشح الجودة لديك.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO REFACTOR RACE -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        أنت ضد Claude Code. نفس الكود الفوضوي، نفس الهدف. من يعيد هيكلته أفضل؟
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: REFACTOR RACE ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <RefactorRace client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CLOSING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto mb-8" style="max-width: 55ch;">
        لديك CLAUDE.md، ومهارات مخصصة، وإيقاع حدد-ولّد-تحقق. Claude Code لا يكتب كودًا <em>من أجلك</em> &mdash; بل يكتبه <em>معك</em>.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        محادثة واحدة تتعامل مع مهمة واحدة. لكن المشاريع الحقيقية فيها عشرات. التالي: كيف تقسم الطموحات الكبيرة إلى قطع يستطيع الذكاء الاصطناعي تنفيذها فعلاً.
      </p>
    </FadeInBlock>
  </section>

</ChapterLayout>
