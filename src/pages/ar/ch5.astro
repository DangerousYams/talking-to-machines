---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import ToolCatalog from '../../components/widgets/ch5/ToolCatalog';
import TrustThermometer from '../../components/widgets/ch5/TrustThermometer';

const chapter = chapters[4];
---

<ChapterLayout chapter={chapter} locale="ar">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>5</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          الفصل الخامس
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          أعطه<br />أدوات
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          القفزة من "أجب على الأسئلة"<br />إلى "نفّذ الإجراءات."
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8" style="--drop-cap-color: #F5A623;">
        حتى الآن، كل تفاعل لك مع الذكاء الاصطناعي يتبع نفس النمط. تكتب شيئًا. الذكاء الاصطناعي يكتب شيئًا بالمقابل. نص يدخل، نص يخرج. إكمال تلقائي متطور جدًا. لكن هذا ليس السقف. إنه مجرد الأرضية.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        ماذا لو كان الذكاء الاصطناعي يستطيع <em>فعل أشياء</em>؟ ليس فقط يخبرك عن الطقس، بل يتحقق فعلاً من التوقعات. ليس فقط يكتب كودًا، بل يشغله ويخبرك ماذا حصل. ليس فقط يقترح ما تبحث عنه في Google، بل يبحث في الإنترنت بنفسه ويعود بما وجده.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        هذا هو استخدام الأدوات. وهو يغير كل شيء عن ماهية الذكاء الاصطناعي.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BEYOND TEXT-IN TEXT-OUT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        ما وراء النص الداخل والنص الخارج
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        فكر فيما يحدث عندما تسأل روبوت محادثة: <em>"كم الساعة الآن في طوكيو؟"</em> الذكاء الاصطناعي لا يعرف فعلاً. تدرب على بيانات عمرها أشهر أو سنوات. لا يملك ساعة. فيفعل الشيء الوحيد الذي يستطيعه — يخمن، بناءً على أنماط في بيانات تدريبه. أحيانًا يكون قريبًا. وأحيانًا يكون مخطئًا بشكل مضحك.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: #6B7280;">
        <span class="prompt-block-label" style="color: #6B7280;">بدون أدوات</span>
        <p class="m-0" style="color: var(--color-deep);">
          <span style="font-style: italic; opacity: 0.6;">المستخدم:</span> كم الساعة في طوكيو؟<br />
          <span style="font-style: italic; opacity: 0.6;">الذكاء الاصطناعي:</span> يجب أن تكون حوالي 2:30 مساءً بتوقيت اليابان. <span style="color: var(--color-accent-red); font-size: 0.85em;">(مجرد تخمين)</span>
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        الآن أعط نفس الذكاء الاصطناعي <strong>أداة</strong> — دالة بسيطة تعيد الوقت الحالي في أي منطقة زمنية. فجأة:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="prompt-block mb-10" style="--accent: var(--color-amber);">
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>مع أدوات</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          <span style="font-style: italic; opacity: 0.6;">المستخدم:</span> كم الساعة في طوكيو؟<br />
          <span style="font-style: italic; opacity: 0.6;">الذكاء الاصطناعي يفكر:</span> <span style="color: var(--color-purple); font-size: 0.9em;">لديّ أداة المناطق الزمنية. دعني أستخدمها.</span><br />
          <span style="font-style: italic; opacity: 0.6;">الذكاء الاصطناعي يستدعي:</span> <code style="font-size: 0.85em;">get_time("Asia/Tokyo")</code><br />
          <span style="font-style: italic; opacity: 0.6;">الأداة تعيد:</span> <code style="font-size: 0.85em;">14:47 JST</code><br />
          <span style="font-style: italic; opacity: 0.6;">الذكاء الاصطناعي:</span> الساعة الآن 2:47 مساءً في طوكيو (JST). <span style="color: var(--color-teal); font-size: 0.85em;">(تم التحقق)</span>
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85]">
        نفس السؤال. موثوقية مختلفة تمامًا. الذكاء الاصطناعي لم يصبح أذكى — أصبح <strong>متصلاً</strong>. يستطيع الآن الوصول خارج عقله والتفاعل مع العالم الحقيقي.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ HOW TOOL USE ACTUALLY WORKS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        كيف يعمل استخدام الأدوات فعلاً
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        إليك النموذج الذهني. عندما تعطي الذكاء الاصطناعي وصولاً لأدوات، أنت تسلمه <strong>صندوق أدوات</strong> وتقول: <em>"هذه أشياء تستطيع فعلها. لكل أداة، هذا اسمها، وما تقبله، وما تعيده. أنت تقرر متى تستخدمها."</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-14">
        الذكاء الاصطناعي لا يستخدم كل أداة بشكل أعمى في كل طلب. يحلل أي الأدوات مناسبة، يقرر هل يستخدم واحدة، يصيغ المدخلات الصحيحة، يستدعي الأداة، يقرأ النتيجة، ثم يدمج تلك النتيجة في رده. هذه العملية تسمى <strong>استدعاء الدوال</strong> — وتتبع حلقة متسقة بشكل ملفت.
      </p>
    </FadeInBlock>

    <!-- The Agent Loop — editorial layout -->
    <FadeInBlock client:visible delay={0.2}>
      <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
        <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
        {[
          { word: 'لاحظ.', desc: 'اقرأ طلب المستخدم وأي سياق متاح.' },
          { word: 'فكر.', desc: 'قرر: "هل أحتاج أداة لهذا، أم أستطيع الإجابة مباشرة؟"' },
          { word: 'نفّذ.', desc: 'استدعِ الأداة المناسبة بالمعاملات الصحيحة.' },
          { word: 'لاحظ.', desc: 'اقرأ نتيجة الأداة.' },
          { word: 'أجب.', desc: 'اجمع كل شيء في إجابة مفيدة.' },
        ].map((step, i) => (
          <div style={`position: relative; padding-bottom: ${i < 4 ? '1.75rem' : '0'};`}>
            <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
            <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
              <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
              <span style="opacity: 0.7;"> {step.desc}</span>
            </p>
          </div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        الذكاء الاصطناعي لا ينفذ نصًا برمجيًا. إنه يتخذ قرارًا حكيمًا في كل مرة: "هل هذا موقف يجب أن أستخدم فيه أداة، أم أستطيع التعامل معه بنفسي؟"
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        هذه هي <strong>حلقة الوكيل</strong> — لاحظ، فكر، نفّذ، لاحظ، أجب. وهي نفس الحلقة سواء كان لدى الذكاء الاصطناعي أداة واحدة أو مئة. كلما أعطيته أدوات أكثر، أصبح أكثر قدرة. لكن أيضًا، تحتاج ثقة أكبر في حكمه بشأن <em>أي</em> أداة يستخدم و<em>متى</em>.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SEVEN TOOLS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        سبع أدوات تغير كل شيء
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        هناك مئات الأدوات المحددة التي يمكن للذكاء الاصطناعي استخدامها، لكنها تنقسم في الغالب إلى سبع فئات. كل واحدة توسع ما يستطيع الذكاء الاصطناعي فعله بطريقة مختلفة جذريًا. بعضها يعطيه <em>معرفة</em> (بحث الويب، قواعد البيانات). بعضها يعطيه <em>قدرات</em> (تنفيذ الكود، توليد الصور). وبعضها يعطيه <em>أيادٍ</em> (تحرير الملفات، استدعاءات API).
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        انقر على أي أداة أدناه لترى عملية تفكير الذكاء الاصطناعي الكاملة — من إدراكه أنه يحتاج أداة، إلى استدعائها، إلى استخدام النتيجة.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: TOOL CATALOG ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ToolCatalog client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE TRUST QUESTION ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        سؤال الثقة
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        بمجرد أن يستطيع الذكاء الاصطناعي <em>فعل</em> أشياء — وليس فقط التحدث عنها — يظهر سؤال جديد. سؤال لا علاقة له بالتقنية وكل العلاقة بك:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        كم يجب أن يفعل الذكاء الاصطناعي بمفرده قبل أن يستشيرك؟
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        هذا ليس سؤالاً تقنيًا — إنه سؤال إنساني. والإجابة تعتمد على ثلاثة أشياء:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
        {[
          { name: 'المخاطر', color: '#E94560', text: 'ما أسوأ ما يمكن أن يحدث؟ تلخيص مقال بشكل خاطئ أمر مزعج. حذف الملفات الخاطئة كارثة. المخاطر الأعلى تتطلب إشرافًا بشريًا أكبر.' },
          { name: 'إمكانية التراجع', color: '#F5A623', text: 'هل يمكنك التراجع عنه؟ تحرير ملف في مستودع Git يمكن عكسه بسهولة. إرسال بريد إلكتروني لمديرك لا يمكن عكسه. الإجراءات التي لا يمكن التراجع عنها يجب أن تتطلب موافقتك تقريبًا دائمًا.' },
          { name: 'الثقة', color: '#16C79A', text: 'ما مدى معرفتك بهذه الأداة؟ آلة حاسبة استخدمتها مئة مرة تستحق استقلالية أكبر من إضافة جديدة لم تختبرها أبدًا. الثقة تُكتسب، لا تُفترض.' },
        ].map((item, i) => (
          <FadeInBlock client:visible delay={0.25 + i * 0.08}>
            <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
              <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 0.85rem; font-weight: 800; color: white; background: ${item.color};`}>
                {i + 1}
              </div>
              <div style="flex: 1;">
                <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${item.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                  {item.name}
                </p>
                <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                  {item.text}
                </p>
              </div>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>طيف الاستقلالية</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          ليس الأمر كله أو لا شيء. أفضل سير عمل الذكاء الاصطناعي يمنحه حرية في المهام منخفضة المخاطر القابلة للتراجع، مع إبقاء البشر في الحلقة للمهام عالية المخاطر التي لا يمكن التراجع عنها. وظيفتك هي تصميم الحدود.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO TRUST THERMOMETER -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        أين ترسم الخط؟ حدد مستويات الاستقلالية الخاصة بك.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: TRUST THERMOMETER ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <TrustThermometer client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE TOOL-USE MINDSET ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        عقلية استخدام الأدوات
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        هناك تحول دقيق يحدث عندما تبدأ بالتفكير في الذكاء الاصطناعي كمستخدم أدوات بدلاً من مجرد مولد نصوص. تتوقف عن السؤال <em>"ماذا يمكن للذكاء الاصطناعي أن يقول عن هذا؟"</em> وتبدأ بالسؤال <em>"ماذا يمكن للذكاء الاصطناعي أن يفعل حيال هذا؟"</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        بدلاً من أن تطلب من الذكاء الاصطناعي أن <em>يصف</em> كيفية تحليل البيانات، تعطيه أداة تنفيذ كود وتشاهده يكتب التحليل ويشغله. بدلاً من أن تطلب <em>روابط</em> لأبحاث، تعطيه بحث الويب وتدعه يجد المعلومات ويلخصها بنفسه. النتاج يتحول من "هذا ما يمكنك فعله" إلى "هذا ما فعلته للتو."
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style="--accent: #6B7280;">
        <span class="prompt-block-label" style="color: #6B7280;">العقلية القديمة</span>
        <p class="m-0" style="color: var(--color-deep);">
          "اشرح لي كيف أحسب الفائدة المركبة على 5,000 دولار بنسبة 6.5% على مدى 10 سنوات."
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="prompt-block mb-10" style="--accent: var(--color-amber);">
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>عقلية استخدام الأدوات</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          "احسب الفائدة المركبة على 5,000 دولار بنسبة 6.5% سنويًا مركبة شهريًا لمدة 10 سنوات. أرني الرقم الدقيق."
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85]">
