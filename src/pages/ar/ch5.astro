---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import TrustThermometer from '../../components/widgets/ch5/TrustThermometer';
import WouldYouLetIt from '../../components/breaks/WouldYouLetIt';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';
import ForYouCard from '../../components/ui/ForYouCard';

const chapter = chapters[4];
const conceptsSummary = chapter.concepts.map(c => c.name).join(', ');
---

<ChapterLayout chapter={chapter} locale="ar">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>5</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          الفصل الخامس
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          أعطه<br />أدوات
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          القفزة من "أجب على الأسئلة"<br />إلى "اتخذ إجراءات."
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0; --drop-cap-color: #F5A623;">
        حتى الآن، كل تفاعل لك مع الذكاء الاصطناعي يتبع نفس النمط. تكتب شيئًا. الذكاء الاصطناعي يكتب شيئًا بالمقابل. إكمال تلقائي متطور للغاية. لكن ماذا لو كان الذكاء الاصطناعي يستطيع <em>فعل أشياء</em>؟ ليس فقط يخبرك عن الطقس، بل يتحقق من التوقعات. ليس فقط يكتب كودًا، بل يشغّله. ليس فقط يقترح ما تبحث عنه في Google، بل يبحث في الويب بنفسه ويعود بما وجده.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE TRUST QUESTION ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        سؤال الثقة
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        عندما تعطي الذكاء الاصطناعي أدوات، أنت تسلمه صندوق أدوات وتقول: <em>"هذه أشياء تستطيع فعلها. أنت تقرر متى تستخدمها."</em> يستطيع البحث في الويب، وتشغيل الكود، وقراءة الملفات، واستدعاء واجهات API. الذكاء الاصطناعي لم يصبح أذكى &mdash; أصبح <strong>متصلًا</strong>. وهذا يطرح سؤالًا لا علاقة له بالتقنية وكل العلاقة بك: كم يجب أن يفعل الذكاء الاصطناعي بمفرده قبل أن يستشيرك؟
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-14">
        الإجابة تعتمد على ثلاثة أشياء. <strong>المخاطر</strong> &mdash; ما أسوأ ما يمكن أن يحدث؟ <strong>إمكانية التراجع</strong> &mdash; هل يمكنك التراجع عنه؟ و<strong>الثقة</strong> &mdash; ما مدى معرفتك بهذه الأداة؟ آلة حاسبة استخدمتها مئة مرة تستحق حرية أكبر من إضافة جديدة لم تختبرها أبدًا.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>فكرة أساسية</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          ليس الأمر كله أو لا شيء. أفضل سلاسل عمل الذكاء الاصطناعي تمنح حرية في المهام منخفضة المخاطر القابلة للتراجع، مع إبقاء البشر في الحلقة للمهام عالية المخاطر التي لا يمكن التراجع عنها. وظيفتك هي تصميم الحدود.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        أين ترسم الخط؟ حدد مستويات الاستقلالية بنفسك.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <TrustThermometer client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <div class="py-8">
    <ForYouCard
      chapterSlug={chapter.slug}
      chapterTitle={chapter.title}
      chapterConcepts={conceptsSummary}
      accentColor={chapter.accent}
      client:load
    />
  </div>
  <SharePrompt text="Learning about AI tool use and function calling in the most hands-on way possible. This course lets you actually build and test things, not just read about them." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        الأدوات تحوّل الذكاء الاصطناعي من مستشار إلى مساعد &mdash; من شخص يخبرك ماذا تفعل، إلى شخص يفعله فعلًا.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        أعطيت الذكاء الاصطناعي يدين. التالي: سنربط هذه الأدوات في شيء يمكنه متابعة هدف بمفرده &mdash; التخطيط، والتنفيذ، والتعافي من الأخطاء. حان وقت بناء الوكلاء.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(245,166,35,0.06) 15%, rgba(245,166,35,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#F5A623" toolName="Would You Let It?" client:visible>
        <WouldYouLetIt client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
