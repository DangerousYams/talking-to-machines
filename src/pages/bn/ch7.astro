---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import WhatWouldYouBuild from '../../components/widgets/ch7/WhatWouldYouBuild';
import ShipIt from '../../components/breaks/ShipIt';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[6];
---

<ChapterLayout chapter={chapter} locale="bn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>৭</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          সপ্তম অধ্যায়
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Claude Code-এ<br />দক্ষতা অর্জন
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          তোমার AI পেয়ার প্রোগ্রামার, প্রথম<br />কমান্ড থেকে কাস্টম Skills পর্যন্ত।
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        এমন একটা মুহূর্ত আসে যা প্রতিটা কোডার মনে রাখে। তুমি একটা টার্মিনাল খুলেছ, সাধারণ ভাষায় একটা রিকোয়েস্ট টাইপ করেছ, আর দেখছ একটা AI তোমার ফাইল পড়ছে, তোমার আর্কিটেকচার বুঝছে, একাধিক ফাইলে কোড লিখছে, রান করছে, এরর পাচ্ছে, এরর ঠিক করছে, আর আবার রান করছে &mdash; তুমি একটা লাইনও ছুঁচ্ছ না। Claude Code অটোকমপ্লিট না। এটা একটা <em>এজেন্টিক</em> কোডিং টুল যে তোমার পুরো প্রজেক্ট দেখতে পায়, ফাইল জুড়ে পরিবর্তন করে, শেল কমান্ড চালায়, আর নিজের ভুল থেকে শেখে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        তবে টুলটা ততটাই ভালো যতটা ভালো মানুষটা যে স্টিয়ারিং করছে। Claude Code সেকেন্ডে হাজার লাইনের পারফেক্ট কোড লিখতে পারে &mdash; অথবা হাজার লাইনের বিশ্বাসযোগ্য দেখতে আবর্জনা। পার্থক্যটা তুমি।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ SPECIFY, GENERATE, VERIFY ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        স্পেসিফাই, জেনারেট, ভেরিফাই
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        তুমি যখন Claude Code-কে একটা কাজ দাও, সে একটা এজেন্ট লুপ চালায়: কোডবেস পড়ে, কি বদলাতে হবে প্ল্যান করে, এডিট লেখে, কোড রান করে, যা ভাঙে ঠিক করে। এই সাইকেলটা তিন, পাঁচ, দশবার ঘটতে পারে &mdash; সব কয়েক সেকেন্ডে। তোমার কাজ আর প্রতিটা লাইন লেখা না। তোমার কাজ হলো কি বানাতে হবে <strong>স্পেসিফাই</strong> করা, AI-কে সেটা <strong>জেনারেট</strong> করতে দেওয়া, আর তারপর <strong>ভেরিফাই</strong> করা সেটা আসলেই ঠিক কিনা। বেশিরভাগ নতুনরা শেষ ধাপটা বাদ দেয়। কোড দেখা যাচ্ছে, যুক্তিসঙ্গত লাগছে, আর তারা এগিয়ে যায়। সেই মানুষ হয়ো না। জেনারেটেড কোড হলো ফার্স্ট ড্রাফট। তোমার ভেরিফিকেশনই সেই এডিট যা এটাকে পাবলিশযোগ্য করে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        গোপন অস্ত্র হলো <code>CLAUDE.md</code> ফাইল &mdash; তোমার প্রজেক্টের রুটে রেখে দাও আর Claude Code প্রতিটা সেশনের শুরুতে সেটা পড়বে। তোমার টেক স্ট্যাক, নামকরণের কনভেনশন, স্টাইল রুল, টেস্টিং প্রত্যাশা &mdash; সব একবার এনকোড করো যাতে আর কখনো নিজেকে রিপিট করতে না হয়। এটা কনটেক্সট ইঞ্জিনিয়ারিং কোডিংয়ে প্রয়োগ করা।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>লক্ষ্য প্রতিটা লাইন লেখা না &mdash; প্রতিটা লাইন বোঝা।</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Claude যে কোড জেনারেট করে সেটা তুমি পড়তে না পারলে, ভেরিফাই করতে পারবে না। সেরা Claude Code ব্যবহারকারীরা তারা না যারা সবচেয়ে বেশি কোড জেনারেট করে &mdash; তারা সেই মানুষ যারা সবচেয়ে ভালো প্রশ্ন করে আর সবচেয়ে সূক্ষ্ম বাগগুলো ধরে।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        লুপটা কাজ করতে দেখো। একটা রিকোয়েস্ট টাইপ করো আর Claude Code-কে কাজ করতে দেখো।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="terminal-playground" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <WhatWouldYouBuild client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="Claude Code নিয়ে এই অধ্যায়টা অসাধারণ — একটা AI পেয়ার প্রোগ্রামারকে সমস্যা নিয়ে ভাবতে, কোড লিখতে, আর নিজেই ডিবাগ করতে দেখলাম। কোডিংয়ের ভবিষ্যৎ এসে গেছে।" client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Claude Code তোমার জন্য কোড লিখছে না &mdash; তোমার সাথে লিখছে।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        একটা কথোপকথন একটা কাজ সামলাতে পারে। কিন্তু আসল প্রজেক্টে ডজনখানেক কাজ থাকে। পরের পর্বে: বড় স্বপ্নকে কিভাবে টুকরোয় ভাঙবে যেগুলো AI আসলেই করতে পারে।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Ship It" client:visible>
        <ShipIt client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
