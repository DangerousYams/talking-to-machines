---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import TerminalPlayground from '../../components/widgets/ch7/TerminalPlayground';
import SkillBuilder from '../../components/widgets/ch7/SkillBuilder';
import RefactorRace from '../../components/widgets/ch7/RefactorRace';

const chapter = chapters[6];
---

<ChapterLayout chapter={chapter} locale="bn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>৭</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          অধ্যায় সাত
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Claude Code-এ<br />দক্ষতা অর্জন
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          তোমার AI পেয়ার প্রোগ্রামার, প্রথম<br />কমান্ড থেকে কাস্টম Skills পর্যন্ত।
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        এমন একটা মুহূর্ত আসে যা প্রতিটা কোডার মনে রাখে। তুমি একটা টার্মিনাল খুলেছ, সাধারণ ভাষায় একটা রিকোয়েস্ট টাইপ করেছ, আর দেখছ একটা AI তোমার ফাইল পড়ছে, তোমার আর্কিটেকচার বুঝছে, একাধিক ফাইলে কোড লিখছে, রান করছে, এরর পাচ্ছে, এরর ঠিক করছে, আর আবার রান করছে — তুমি একটা লাইনও ছুঁচ্ছ না। এটাই Claude Code।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        এটা অটোকমপ্লিট না। স্নিপেট লেখা চ্যাটবটও না। Claude Code হলো একটা <em>এজেন্টিক</em> কোডিং টুল — একটা কমান্ড-লাইন সঙ্গী যে তোমার পুরো প্রজেক্ট দেখতে পায়, ফাইল জুড়ে পরিবর্তন করতে পারে, শেল কমান্ড চালাতে পারে, আর নিজের ভুল থেকে নিজেই শিখতে পারে। সে শুধু কোড সাজেস্ট করে না। সে কোড <strong>শিপ</strong> করে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        তবে টুলটা ততটাই ভালো যতটা ভালো মানুষটা যে স্টিয়ারিং করছে। Claude Code সেকেন্ডে হাজার লাইনের পারফেক্ট কোড লিখতে পারে — অথবা হাজার লাইনের বিশ্বাসযোগ্য দেখতে আবর্জনা। পার্থক্যটা তুমি।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ HOW CLAUDE CODE THINKS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Claude Code কিভাবে ভাবে
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        তুমি যখন Claude Code-কে একটা কাজ দাও, সে সাথে সাথে টাইপ শুরু করে না। সে ষষ্ঠ অধ্যায়ের সেই এজেন্ট লুপটা চালায়, কোডিংয়ের জন্য বিশেষায়িত করে:
      </p>
    </FadeInBlock>

    <!-- Agent loop visualization -->
    <FadeInBlock client:visible delay={0.15}>
      <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
        <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
        {[
          { word: 'পড়ো।', desc: 'কোডবেস স্ক্যান করো — ফাইল, ইমপোর্ট, টেস্ট, কনফিগ। বোঝো কি আছে।' },
          { word: 'প্ল্যান করো।', desc: 'ঠিক করো কোথায় কি বদলাতে হবে, কোন ফাইলে, কোন ক্রমে।' },
          { word: 'লেখো।', desc: 'এডিট করো। ফাইল তৈরি করো। কোড বদলাও।' },
          { word: 'চালাও।', desc: 'কমান্ড এক্সিকিউট করো — build, test, lint। দেখো কি হয়।' },
          { word: 'ঠিক করো।', desc: 'কিছু ভাঙলে, এরর পড়ো, অ্যাডজাস্ট করো, আবার চেষ্টা করো।' },
        ].map((step, i) => (
          <div style={`position: relative; padding-bottom: ${i < 4 ? '1.75rem' : '0'};`}>
            <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
            <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
              <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
              <span style="opacity: 0.7;"> {step.desc}</span>
            </p>
          </div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        এই পড়ো-প্ল্যান-লেখো-চালাও-ঠিক করো লুপই Claude Code-কে সাধারণ কোড জেনারেটর থেকে আলাদা করে। সে তোমাকে একটা স্নিপেট ধরিয়ে দিয়ে চলে যায় না। সে <em>লুপে থাকে</em> — কোড সত্যিই কাজ না করা পর্যন্ত ঘষামাজা করতে থাকে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85]">
        এটাকে পেয়ার প্রোগ্রামিংয়ের মতো ভাবো। তুমি বর্ণনা করো কি চাও। Claude Code লেখে। টেস্ট ফেইল করে। Claude Code এরর পড়ে, অ্যাডজাস্ট করে, আবার রান করে। এই সাইকেলটা তিন, পাঁচ, দশবার ঘটতে পারে — সব কয়েক সেকেন্ডে।
      </p>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO TERMINAL PLAYGROUND -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        লুপটা কাজ করতে দেখো। একটা রিকোয়েস্ট টাইপ করো আর Claude Code-কে কাজ করতে দেখো।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: TERMINAL PLAYGROUND ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <TerminalPlayground client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE CLAUDE.MD FILE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        CLAUDE.md ফাইল
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        বেশিরভাগ নতুন ব্যবহারকারী এটা মিস করে: <strong>তুমি Claude Code-কে স্থায়ী নির্দেশনা দিতে পারো।</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        তোমার প্রজেক্টের রুটে <code>CLAUDE.md</code> নামে একটা ফাইল রাখো, আর Claude Code প্রতিটা সেশনের শুরুতে সেটা পড়বে। এটা সিস্টেম প্রম্পটের মতো, কিন্তু তোমার পুরো কোডবেসের জন্য।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>CLAUDE.md</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep); font-family: var(--font-mono); font-size: 0.85rem;">
          # My Project<br /><br />
          Tech stack: Astro + React + Tailwind<br />
          Always use TypeScript with strict mode.<br />
          Put components in src/components/.<br />
          Write tests for every new function.<br />
          Use Prettier formatting — never change the config.<br /><br />
          ## Style Rules<br />
          - Prefer named exports over default exports<br />
          - Use CSS modules, not inline styles<br />
          - Keep components under 150 lines
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        CLAUDE.md ছাড়া, তুমি প্রতিটা সেশনের শুরুতে কয়েক মিনিট ব্যয় করো তোমার পছন্দগুলো আবার বোঝাতে। CLAUDE.md থাকলে, Claude Code ইতিমধ্যেই তোমার স্ট্যাক, তোমার কনভেনশন, আর তোমার সীমানা জানে। এটা হলো কনটেক্সট ইঞ্জিনিয়ারিং (অধ্যায় ৩) কোডিংয়ে প্রয়োগ করা।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>CLAUDE.md-কে তোমার প্রজেক্টের সংবিধান মনে করো।</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          এটা তুমি ইতিমধ্যে যেসব সিদ্ধান্ত নিয়েছ সেগুলো এনকোড করে — যাতে AI সত্যিই নতুন যেসব সিদ্ধান্ত সেগুলোতে ফোকাস করতে পারে। তোমার CLAUDE.md যত নির্দিষ্ট, তত কম নিজেকে রিপিট করতে হবে।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BUILDING SKILLS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Skills তৈরি করা
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        CLAUDE.md Claude Code-কে তোমার প্রজেক্ট সম্পর্কে সাধারণ জ্ঞান দেয়। কিন্তু নির্দিষ্ট, বারবার করা কাজগুলোর জন্য? সেখানে <strong>Skills</strong> আসে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        একটা skill হলো তোমার CLAUDE.md-এর ভেতরে থাকা একগুচ্ছ নির্দেশনা যা Claude Code-কে শেখায় কিভাবে একটা নির্দিষ্ট ধরনের কাজ হ্যান্ডেল করতে হয়। এটাকে একটা রেসিপি ভাবো: "কেউ যখন নতুন React component বানাতে বলবে, এভাবে করো।"
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        Skills ছাড়া, তুমি প্রতিবার একই ধাপগুলো বোঝাও। Skills থাকলে, তুমি একবার বোঝাও আর AI চিরকাল মনে রাখে।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        একটা ভালো skill-এ তিনটা অংশ থাকে:
      </p>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { letter: 'T', name: 'Trigger (ট্রিগার)', color: '#7B61FF', text: 'এই skill কখন সক্রিয় হবে? "কেউ যখন component বানাতে বলবে..." বা "টেস্ট ফেইলার ঠিক করতে বলবে..." স্পষ্ট ট্রিগার AI-কে ভুল রেসিপি ব্যবহার থেকে আটকায়।' },
        { letter: 'S', name: 'Steps (ধাপ)', color: '#16C79A', text: 'ঠিক কি করতে হবে, কোন ক্রমে? নম্বরযুক্ত ধাপ সবচেয়ে ভালো কাজ করে। ফাইলের অবস্থান, নামকরণের কনভেনশন, আর প্রয়োজনীয় প্যাটার্ন সম্পর্কে নির্দিষ্ট হও।' },
        { letter: 'E', name: 'Examples (উদাহরণ)', color: '#F5A623', text: 'সফল ফলাফল দেখতে কেমন দেখাও। একটা before-and-after, একটা ফাইল স্ট্রাকচারের উদাহরণ, বা একটা স্যাম্পল আউটপুট। উদাহরণের সামনে দ্ব্যর্থতা টিকে থাকতে পারে না।' },
      ].map((block, i) => (
        <FadeInBlock client:visible delay={0.3 + i * 0.08}>
          <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${block.color};`}>
              {block.letter}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${block.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {block.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {block.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>
  </section>

  <!-- BRIDGE TO SKILL BUILDER -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        একটা লিখে দেখো। ট্রিগার থেকে ধাপ থেকে উদাহরণ পর্যন্ত একটা skill তৈরি করো।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: SKILL BUILDER ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <SkillBuilder client:visible />
    </FadeInBlock>
  </section>

