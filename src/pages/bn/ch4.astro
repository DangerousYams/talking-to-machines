---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ToolWall from '../../components/widgets/ch4/ToolWall';
import WorkflowBuilder from '../../components/widgets/ch4/WorkflowBuilder';
import HeadToHead from '../../components/widgets/ch4/HeadToHead';

const chapter = chapters[3];
---

<ChapterLayout chapter={chapter} locale="bn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>৪</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          অধ্যায় চার
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          AI-এর<br />বিস্তৃত জগৎ
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          এই মুহূর্তে তুমি যত AI টুল<br />ব্যবহার করতে পারো, তার একটি গাইড।
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        বেশিরভাগ মানুষ যখন "AI" বলে, তারা ChatGPT বোঝায়। হয়তো Google-এর Gemini বা Claude-এর নাম শুনেছে। এটা অনেকটা "ইন্টারনেট" বলে শুধু Google বোঝানোর মতো। ভুল নয়, কিন্তু বিশাল কিছুর খুবই ছোট একটা অংশ।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        এই মুহূর্তে শত শত AI টুল আছে যেগুলো তুমি আজই ব্যবহার করতে পারো -- কোনো কাল্পনিক ভবিষ্যতে নয়, আজ, তোমার ব্রাউজার থেকেই। এমন টুল যা একটা বাক্য থেকে ফটোরিয়েলিস্টিক ছবি বানায়। পুরো গান বানায়। তোমার রিসার্চ টপিকের উপর যতগুলো একাডেমিক পেপার আছে সব পড়ে তিন প্যারাগ্রাফে সামারি করে দেয়।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        এই অধ্যায়টা তোমার ফিল্ড গাইড। সব টুলের তালিকা না -- সেটা পরের মঙ্গলবারেই পুরনো হয়ে যাবে -- বরং <strong>এলাকার একটা ম্যাপ</strong>। কোন ক্যাটেগরিগুলো গুরুত্বপূর্ণ, কোন টুলগুলো জানার মতো, আর কোনটা বেছে নেওয়ার চিন্তাভাবনা।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BEYOND THE CHATBOT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        চ্যাটবটের বাইরে
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        চ্যাটবট হলো হিমশৈলের চূড়া। এর নিচে, AI ভেঙে গেছে ডজনখানেক বিশেষায়িত ক্ষমতায়, প্রতিটা আলাদা ধরনের কাজের জন্য আলাদা ধরনের টুল।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        সঙ্গীতের যন্ত্রের কথা ভেবে দেখো। পিয়ানো আর ড্রামস দুটোই "সঙ্গীতের যন্ত্র", কিন্তু তুমি একজন পিয়ানিস্টকে বিট দিতে বলবে না, আর একজন ড্রামারকে কনসার্টো বাজাতে বলবে না। AI টুলগুলোও একই রকম। ছবি বানানোর জন্য তৈরি টুল আর কোড লেখার জন্য তৈরি টুল সম্পূর্ণ আলাদা -- আলাদা আর্কিটেকচার, আলাদা ট্রেনিং ডেটা, আলাদা শক্তি।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        যে ব্যক্তি ১০টা AI টুল সাধারণ লেভেলে জানে, সে একটা টুল গভীরভাবে জানা কারো চেয়ে ধারাবাহিকভাবে ভালো করবে। জানার প্রশস্ততা দক্ষতার গভীরতাকে হারায় -- প্রথমে।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        আজকের দিনে এই জগৎটা কেমন দাঁড়িয়ে আছে, এই টুলগুলো আসলে <em>কী করে</em> সেই ভিত্তিতে সাজানো:
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE EIGHT FAMILIES ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        আট পরিবার
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14">
        যে AI টুলের সাথেই তুমি দেখা করবে, সেটা এই ক্যাটেগরিগুলোর মধ্যেই পড়বে। কিছু টুল সীমানা পার হয়, কিন্তু এই পরিবারগুলো বুঝলে তোমার মনে একটা ম্যাপ থাকবে এই বিশৃঙ্খলার মধ্যে অর্থ খুঁজে নিতে।
      </p>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { icon: '১', name: 'ইমেজ জেনারেটর', color: '#E94560', text: 'টেক্সট ঢুকে, ছবি বেরিয়ে আসে। ফটোরিয়েলিস্টিক দৃশ্য থেকে অ্যানিমে থেকে তেল রঙের পেইন্টিং। Midjourney, DALL-E 3, Stable Diffusion, Flux, Ideogram। সবচেয়ে গণতান্ত্রিক ক্যাটেগরি -- যে কেউ কথা থেকে ভিজুয়াল আর্ট বানাতে পারে।' },
        { icon: '২', name: 'ইমেজ এডিটর', color: '#F5A623', text: 'আসল ছবি দিয়ে শুরু করে সেটাকে বদলাও। ব্যাকগ্রাউন্ড সরাও, রেজোলিউশন বাড়াও, অবজেক্ট বদলাও, লাইটিং পরিবর্তন করো। Photoshop AI, Magnific, Clipdrop। এরা মানব ফটোগ্রাফার আর ডিজাইনারদের প্রতিস্থাপিত করার বদলে তাদের সাহায্য করে।' },
        { icon: '৩', name: 'ভিডিও ক্রিয়েটর', color: '#7B61FF', text: 'সবচেয়ে নতুন সীমানা। টেক্সট বা স্থির ছবি থেকে ভিডিও ক্লিপ তৈরি করো। Sora, Runway, Kling, Pika। এখনও প্রাথমিক -- বেশিরভাগ ক্লিপ ৩০ সেকেন্ডের নিচে -- কিন্তু চমকপ্রদ গতিতে উন্নতি হচ্ছে। ফিল্ম মেকিং আর আগের মতো থাকবে না।' },
        { icon: '৪', name: 'সঙ্গীত ও অডিও', color: '#16C79A', text: 'টেক্সট বর্ণনা থেকে পুরো গান, ৩০ সেকেন্ড নমুনা থেকে কণ্ঠস্বর ক্লোনিং, চাহিদামতো সাউন্ড এফেক্ট। Suno, Udio, ElevenLabs। এই টুলগুলো স্টুডিও আর টিমের দরকার যা ছিল সেটাকে একটা প্রম্পটে কমিয়ে এনেছে।' },
        { icon: '৫', name: 'রিসার্চ এজেন্ট', color: '#0EA5E9', text: 'যে AI তোমার জন্য ইন্টারনেট (বা একাডেমিক ডেটাবেস) পড়ে। Perplexity খুঁজে এবং উদ্ধৃত করে। Elicit পেপার পড়ে। Consensus বৈজ্ঞানিক মতৈক্য খুঁজে পায়। NotebookLM তোমার ডকুমেন্টগুলোকে এক্সপার্ট বানায়।' },
        { icon: '৬', name: 'AI ব্রাউজার', color: '#6B7280', text: 'এজেন্ট যারা মানুষের মতো ওয়েব নেভিগেট করতে পারে। বোতামে ক্লিক করে, ফর্ম ভরে, পেজের মধ্যে যায়। Arc, Operator, Claude Computer Use। "প্রশ্নের উত্তর দেওয়া" আর "কাজ করা"র মধ্যে সেতু।' },
        { icon: '৭', name: 'কোডিং টুল', color: '#E94560', text: 'AI যা কোড লেখে, এডিট করে, চালায়, আর ডিবাগ করে। Claude Code তোমার টার্মিনাল থেকে কাজ করে। Cursor আর Windsurf পূর্ণ এডিটর। Copilot ইনলাইন সাজেশন দেয়। Replit Agent স্ক্র্যাচ থেকে পুরো অ্যাপ বানায়।' },
        { icon: '৮', name: 'চ্যাটবট ও অ্যাসিস্ট্যান্ট', color: '#0F3460', text: 'সাধারণ উদ্দেশ্যের কথোপকথনমূলক AI যা তুমি আগে থেকেই চেনো: ChatGPT, Claude, Gemini। এরা সুইস আর্মি নাইফের মতো -- অনেক কিছুতে ভালো, যখন তুমি জানো কীভাবে প্রম্পট করতে হয় তখন সেরা (যা তুমি জানো, অধ্যায় ১-৩-এর জন্য ধন্যবাদ)।' },
      ].map((family, i) => (
        <FadeInBlock client:visible delay={i * 0.06}>
          <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${family.color};`}>
              {family.icon}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${family.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {family.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {family.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>মূল অন্তর্দৃষ্টি</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          এই ক্যাটেগরিগুলো মিশে যাচ্ছে। ইমেজ জেনারেটরে ভিডিও যোগ হচ্ছে। চ্যাটবট টুল ব্যবহার শিখছে। কোডিং টুল এজেন্ট হয়ে উঠছে। দুই বছরে সীমানাগুলো ঝাপসা হয়ে যাবে। কিন্তু এখনই, বিশেষজ্ঞরা তাদের বিশেষত্বে জেনারেলিস্টদের হারায়।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO TOOL WALL -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        পুরো ক্যাটালগ এক্সপ্লোর করো। যেকোনো টুলে ক্লিক করো জানতে সেটা কী করে।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: TOOL WALL ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ToolWall client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CHOOSING THE RIGHT TOOL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        সঠিক টুল বেছে নেওয়া
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        এত অপশন থাকলে কঠিন দিকটা AI টুল খুঁজে পাওয়া না। <em>সঠিক</em> AI টুল খুঁজে পাওয়া। এই ফ্রেমওয়ার্কটা কাজ করে:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
        <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
        {[
          { word: 'আউটপুট কী?', desc: 'টেক্সট? ইমেজ? কোড? ভিডিও? অডিও? এটাই তোমাকে সরাসরি ১-২ পরিবারে নিয়ে যাবে।' },
          { word: 'কোয়ালিটি বার কী?', desc: 'নিজের জন্য তাড়াতাড়ি ড্রাফট, নাকি অন্যদের জন্য পলিশড আউটপুট? ভিন্ন মানের জন্য ভিন্ন টুল।' },
          { word: 'বাজেট কী?', desc: 'অনেক টুলেই ফ্রি টায়ার আছে যেগুলো আশ্চর্যজনকভাবে সক্ষম। টাকা দেওয়ার আগে জানো আসলে কী দরকার।' },
