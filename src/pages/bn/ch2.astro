---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import PromptLaboratory from '../../components/widgets/ch2/PromptLaboratory';
import FlipTheScript from '../../components/widgets/ch2/FlipTheScript';
import DebugThePrompt from '../../components/widgets/ch2/DebugThePrompt';

const chapter = chapters[1];
---

<ChapterLayout chapter={chapter} locale="bn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>২</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          অধ্যায় দুই
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          জিজ্ঞেস করার<br />শিল্প
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          সেরা প্রম্পট হলো সেই প্রশ্ন যেটা<br />AI-কে তোমাকে প্রশ্ন করতে বাধ্য করে।
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        গত অধ্যায়ে তুমি শিখেছ একটা ভালো প্রম্পটের পাঁচটা বিল্ডিং ব্লক — Role, Task, Format, Constraints, Examples। সেটা ভিত্তি। কিন্তু উপকরণ চেনা মানেই শেফ হওয়া না।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        এই অধ্যায়টা <em>টেকনিক</em> নিয়ে। যে পার্থক্য একজন প্রম্পট টাইপ করা মানুষ আর একজন প্রম্পট <em>ক্র্যাফট</em> করা মানুষের মধ্যে। এটা একটা প্রশ্ন জিজ্ঞেস করা আর <strong>সঠিক</strong> প্রশ্ন জিজ্ঞেস করার মধ্যকার পার্থক্য — সেই প্রশ্ন যা সত্যিই কাজের কিছু unlock করে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        সেরা AI ব্যবহারকারীরা বিষয়ের এক্সপার্ট না — <strong>তারা জিজ্ঞেস করার এক্সপার্ট।</strong> আর জিজ্ঞেস করা একটা স্কিল যা শেখা যায়।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SOCRATIC FLIP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        সক্রেটিক ফ্লিপ
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        বেশিরভাগ মানুষ AI-কে ভেন্ডিং মেশিনের মতো ব্যবহার করে। প্রম্পট ঢোকাও, উত্তর বেরোয়। কিন্তু সেরা ফলাফল আসে <em>কথোপকথন</em> থেকে, কমান্ড থেকে না। আর সবচেয়ে শক্তিশালী কথোপকথনের টেকনিকটা ২,৪০০ বছর পুরোনো।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        সক্রেটিস কখনো সরাসরি উত্তর দিতেন না। তিনি <em>আরো</em> প্রশ্ন করতেন — খোঁচা দিতেন, স্পষ্ট করতেন, চ্যালেঞ্জ করতেন — যতক্ষণ না তাঁর ছাত্ররা নিজেরাই গভীর উপলব্ধিতে পৌঁছাত। তুমি AI-এর সাথে একই পদ্ধতি ব্যবহার করতে পারো, কিন্তু উল্টো করে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AI-কে উত্তর জিজ্ঞেস করার বদলে, AI-কে বলো তোমাকে ইন্টারভিউ করতে। সেই স্পষ্টকারী প্রশ্নগুলো করতে দাও যা তুমি ভাবতে ভুলে গেছ।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        ভেবে দেখো: যখন তুমি টাইপ করো "একটা জন্মদিনের পার্টি প্ল্যান করো," তুমি এমন ডজনখানেক ডিটেইল বাদ দিচ্ছ যা উত্তরটাকে আমূল বদলে দেয়। কতজন আসবে? বাজেট কত? ইনডোর না আউটডোর? AI জানে না — কিন্তু সে জিজ্ঞেস করতে পারে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>সক্রেটিক প্রম্পট</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          "আমি একটা জন্মদিনের পার্টি প্ল্যান করতে চাই। প্ল্যানিং শুরু করার আগে, আমাকে ৫টা নির্দিষ্ট প্রশ্ন করো যা তোমাকে আমার ঠিক পরিস্থিতি অনুযায়ী প্ল্যান বানাতে সাহায্য করবে। একটা একটা করে জিজ্ঞেস করো আর আমার উত্তরের জন্য অপেক্ষা করো।"
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        এই একটা টেকনিক — কে প্রশ্ন করবে সেটা উল্টে দেওয়া — তোমার সবচেয়ে শক্তিশালী আপগ্রেডগুলোর একটা। এটা AI-কে উত্তর দেওয়ার মেশিন থেকে একজন <strong>চিন্তার সঙ্গী</strong>-তে রূপান্তরিত করে।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FLIP THE SCRIPT ═══ -->
  <section id="flip-the-script" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <FlipTheScript client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ FEW-SHOT PROMPTING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        বলো না, দেখাও
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ভাবো তুমি একটা স্টাইল একজন বন্ধুকে বোঝাতে চাইছ। তুমি পাঁচ মিনিট ধরে শব্দে বর্ণনা করতে পারো — "আমি এমন কিছু চাই যা প্লেফুল কিন্তু বাচ্চাদের মতো না, ক্যাজুয়াল কিন্তু অগোছালো না, ছোট ছোট বাক্য আর অপ্রত্যাশিত তুলনা দিয়ে।" অথবা তুমি শুধু একটা উদাহরণ দেখাতে পারো: <em>"এরকম করে লেখো।"</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        এটাই <strong>few-shot prompting</strong>। তুমি কি চাও সেটা বিমূর্তভাবে বর্ণনা করার বদলে, AI-কে কংক্রিট উদাহরণ দাও। একটা উদাহরণ হলো "one-shot" প্রম্পট। দুই বা তিনটা হলো "few-shot"। শূন্য উদাহরণ — যেখানে তুমি শুধু বর্ণনা করো কি চাও — সেটা "zero-shot"।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style="--accent: #6B7280;">
        <span class="prompt-block-label" style="color: #6B7280;">Zero-shot (বর্ণনা করা)</span>
        <p class="m-0" style="color: var(--color-deep);">"রানিং শুজের জন্য একটা product description লেখো। পাঞ্চি আর conversational করো, ছোট বাক্যে। মার্কেটিং ক্লিশে এড়িয়ে যাও।"</p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Few-shot (দেখানো)</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          "CloudRunner X1 রানিং শুজের জন্য একটা product description লেখো। এই স্টাইলে চাই:<br /><br />
          <em>উদাহরণ: 'The Weekender Tote — তোমার ল্যাপটপ, তোমার লাঞ্চ, আর তোমার সন্দেহজনক লাইফ চয়েস সব ধরে। ওয়াটার-রেসিস্ট্যান্ট ক্যানভাস কারণ আমরা জানি তুমি কিছু ফেলবেই। পাঁচটা পকেট, কোনোটাই তুমি পরে মনে রাখবে না।'</em><br /><br />
          এই টোন ম্যাচ করো: ছোট বাক্য, সেলফ-অ্যাওয়ার হিউমার, বাজওয়ার্ডের চেয়ে নির্দিষ্টতা।"
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85] mb-10">
        Few-shot ভার্সন নাটকীয়ভাবে ভালো ফলাফল দেবে। AI "স্মার্ট" হয়ে গেছে বলে না — বরং তুমি একটা অস্পষ্ট দিকনির্দেশনার বদলে একটা <strong>কংক্রিট টার্গেট</strong> দিয়েছ। একটা ভালো উদাহরণ শত শব্দের বর্ণনার চেয়ে বেশি কাজের।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>মূল বিষয়</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI তোমার চাওয়া স্টাইলে লিখছে না? আরো বিশেষণ যোগ করো না। একটা উদাহরণ দাও। "এরকম করে" সবসময় হারায় "আরো পাঞ্চি কিন্তু উষ্ণও কিন্তু খুব ক্যাজুয়াল না"-কে।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ MINI-CHALLENGE: Zero to Few-Shot ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-12">
    <FadeInBlock client:visible>
      <div style={`background: linear-gradient(135deg, ${chapter.accent}08, ${chapter.accent}04); border: 1px solid ${chapter.accent}20; border-radius: 12px; padding: 2rem 2rem 1.75rem;`}>
        <p style={`font-family: var(--font-mono); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: ${chapter.accent}; margin: 0 0 0.75rem;`}>
          ছোট্ট পরীক্ষা
        </p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0 0 1rem; color: var(--color-deep);">
          সম্প্রতি তুমি AI-কে কি লিখতে বলেছিলে ভেবে দেখো — একটা ইমেইল, একটা গল্প, একটা সোশ্যাল মিডিয়া পোস্ট। এবার কল্পনা করো তুমি যদি চাওয়া টোনের একটা কংক্রিট উদাহরণ দিতে। আউটপুটটা কিভাবে বদলে যেত?
        </p>
        <p style="font-size: 0.9rem; line-height: 1.7; margin: 0; color: var(--color-deep); opacity: 0.6;">
          এটা মাথায় রাখো। নিচের Prompt Laboratory-তে সত্যিই টেস্ট করতে পারবে।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CHAIN OF THOUGHT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        ধাপে ধাপে ভাবো
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        একটা অবাক করা ব্যাপার: তুমি যদি AI-কে একটা গণিতের সমস্যা সমাধান করতে বলো, সে ভুল করতে পারে। কিন্তু তুমি যদি বলো <em>ধাপে ধাপে সমাধান করো</em>, সে অনেক বেশিবার সঠিক উত্তর দেয়। উত্তর একই। প্রশ্ন আলাদা।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        এই টেকনিকের নাম <strong>chain-of-thought prompting</strong>। সরাসরি উত্তর চাওয়ার বদলে, তুমি AI-কে বলো তার যুক্তি দেখাতে। "ধাপে ধাপে ভেবে দেখো।" "উত্তর দেওয়ার আগে ভেঙে দেখো।" "যুক্তি ব্যাখ্যা করো যেতে যেতে।"
      </p>
    </FadeInBlock>

    <!-- Before/After comparison -->
    <FadeInBlock client:visible delay={0.2}>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
        <div>
          <div class="prompt-block" style="--accent: #E94560; min-height: 100%;">
            <span class="prompt-block-label" style="color: #E94560;">Chain-of-thought ছাড়া</span>
            <p class="m-0" style="color: var(--color-deep); font-size: 0.85rem;">
              "একটা ব্যাট আর বল মিলে $1.10। ব্যাটের দাম বলের চেয়ে $1.00 বেশি। বলের দাম কত?"
            </p>
