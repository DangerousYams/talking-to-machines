---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ContextPacking from '../../components/widgets/ch8/ContextPacking';
import ComplexityScore from '../../components/breaks/ComplexityScore';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[7];
---

<ChapterLayout chapter={chapter} locale="bn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>৮</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          অষ্টম অধ্যায়
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          জটিলতার<br />অর্কেস্ট্রেশন
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          যেকোনো কনটেক্সট উইন্ডোর চেয়ে<br />বড় প্রজেক্টে AI ম্যানেজ করা।
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        প্রতিটা উচ্চাকাঙ্ক্ষী নতুন ব্যবহারকারী এই মুহূর্তে এসে আটকে যায়: তুমি AI-কে বলেছ সত্যিকারের কিছু বানাতে &mdash; একটা পুরো গেম, ব্যাকএন্ডসহ একটা ওয়েবসাইট, সাইটেশনসহ একটা রিসার্চ পেপার &mdash; আর পুরো জিনিসটা ভেঙে পড়ে। AI যথেষ্ট স্মার্ট না বলে না। প্রজেক্টটা একটা মাত্র কথোপকথনের জন্য অনেক বড় বলে। তুমি একগাদা requirements পেস্ট করেছ আর কুড়ি মিনিট পরে বুঝেছ সে তোমার অর্ধেক চাহিদা ভুলে গেছে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        এটা AI সমস্যা না। এটা একটা <strong>অর্কেস্ট্রেশন সমস্যা</strong>। আর এটা সমাধান করতে শেখাই আলাদা করে দেয় যে AI-কে ছোটখাটো কাজে ব্যবহার করে আর যে আসল জিনিস বানায়।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONTEXT PACKING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        কনটেক্সট প্যাকিংয়ের কলা
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        জটিল প্রজেক্ট ওয়ান-প্রম্পট পদ্ধতি ভেঙে দেয়। কনটেক্সট উপচে পড়ে, মনোযোগ পাতলা হয়, ভুল জমতে থাকে। সমাধান ভালো প্রম্পট না &mdash; <strong>ডিকম্পোজিশন</strong>। প্রজেক্টকে ফোকাসড কাজে ভাগ করো, তারপর প্রতিটা কাজের জন্য সাবধানে বেছে নাও AI-র আসলে কোন কনটেক্সট দরকার। খুব কম দিলে হ্যালুসিনেট করবে। খুব বেশি দিলে ফোকাস হারাবে। সুইট স্পট হলো সার্জিক্যাল প্রিসিশন।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        ট্রিপের জন্য সুটকেস গোছানোর মতো ভাবো। পুরো আলমারি নিয়ে যেতে পারবে না। ভাবতে হবে কোথায় যাচ্ছ (কাজটা), কি লাগবে (প্রাসঙ্গিক তথ্য), আর কি রেখে যেতে পারো (বাকি সব)। প্রতিটা কথোপকথনে ঠিক যতটুকু কনটেক্সট দরকার ততটুকুই দাও &mdash; এর বেশিও না, কমও না।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style="font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;">মূল বিষয়</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          তোমার হ্যান্ডঅফ আর্টিফ্যাক্টের মান ঠিক করে দেয় এরপরে বানানো সবকিছুর মান। একটা ঝকঝকে স্কিমা একটা অস্পষ্ট বর্ণনাকে প্রতিবার হারায়। আবর্জনা ঢোকালে আবর্জনা বেরোয় &mdash; কথোপকথন জুড়ে।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        একটা কনটেক্সটের সুটকেস গোছাও। উপচে না ফেলে দরকারি সব ঢোকাতে পারো?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ContextPacking client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="AI-এর সবচেয়ে কঠিন দিক প্রম্পটিং না — একাধিক কথোপকথন জুড়ে জটিল প্রজেক্ট অর্কেস্ট্রেট করা। এই কোর্সটা অবশেষে বোঝায় কিভাবে।" client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style="border-color: var(--color-navy); max-width: 50ch; margin: 0 auto 2rem;">
        জটিল প্রজেক্ট ভয়ের না। এগুলো শুধু ফোকাসড কথোপকথনের সিরিজ, ঝকঝকে আর্টিফ্যাক্ট দিয়ে সংযুক্ত।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        পরের পর্বে: জানা কখন AI <em>ভুল</em> করে। হ্যালুসিনেশন, সাইকোফ্যান্সি, আর সেই যাচাইয়ের অভ্যাস যা তোমাকে সৎ রাখে।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(15,52,96,0.06) 15%, rgba(15,52,96,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#0F3460" toolName="Complexity Score" client:visible>
        <ComplexityScore client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
