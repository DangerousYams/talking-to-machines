---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import SkillsSpectrum from '../../components/widgets/ch10/SkillsSpectrum';
import JobTransformer from '../../components/widgets/ch10/JobTransformer';
import TasteTest from '../../components/widgets/ch10/TasteTest';
import FirstPrinciplesLab from '../../components/widgets/ch10/FirstPrinciplesLab';

const chapter = chapters[9];
---

<ChapterLayout chapter={chapter} locale="bn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>১০</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          অধ্যায় দশ
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          মানুষের<br />এজ
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          AI কি বদলাতে পারে না &mdash;<br />আর কি ১০ গুণ সহজ করে দেয়।
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        প্রতিবার একটা নতুন AI ক্ষমতা আসলে, একই হেডলাইন ছাপা হয়: <em>"AI কি [এই চাকরি] রিপ্লেস করবে?"</em> এটা ভুল প্রশ্ন। এটা সবসময়ই ভুল প্রশ্ন ছিল। সঠিক প্রশ্ন হলো: <em>"এটা কি সম্ভব করে দিচ্ছে যা আগে সম্ভব ছিল না?"</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        AI মানুষকে রিপ্লেস করে না। সে <strong>কাজ</strong> রিপ্লেস করে। আর যখন তুমি যেকোনো চাকরিতে — যেকোনো ক্যারিয়ার, যেকোনো সৃজনশীল কাজ, যেকোনো পেশায় — জুম ইন করো, তুমি দেখবে একটা মিশ্রণ: কিছু কাজ AI দারুণ সামলায়, কিছুতে সে সহায়তা করে, আর কিছু একগুঁয়েভাবে, সুন্দরভাবে মানবিক থাকে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        এই অধ্যায় সেই সীমারেখা খুঁজে বের করার জন্য। ভয় পাওয়ার জন্য না, বরং <strong>সঠিক পাশে দাঁড়ানোর</strong> জন্য — সেই পাশে যেখানে তোমার অনন্য মানবিক দক্ষতা আরো মূল্যবান হয়ে ওঠে, কম না।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SPECTRUM, NOT THE CLIFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        স্পেকট্রাম, খাড়া পাহাড় না
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI আর চাকরি নিয়ে বেশিরভাগ আলোচনা বাইনারি হিসেবে দেখে: হয় AI তোমার চাকরি করতে পারে, নয় পারে না। রোবট সর্বনাশ অথবা সব ঠিক আছে। কিন্তু বাস্তবটা একটা স্পেকট্রাম।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        কিছু কাজ প্রায় পুরোপুরি অটোমেটযোগ্য। কিছু AI-তে উন্নত হয়। কিছু অপরিবর্তিত থাকে। আর সবচেয়ে মজার কাজগুলো — যেগুলোর দিকে নজর দেওয়া দরকার — মাঝখানে পড়ে, যেখানে মানুষ আর AI একসাথে কাজ করে।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        ডেটা এন্ট্রি? AI সামলায়। মিটিং শিডিউল করা? মোটামুটি সমাধান হয়ে গেছে। প্রথম ড্রাফট লেখা? AI আশ্চর্যরকম ভালো। কিন্তু <em>কি বানাতে হবে ঠিক করা</em>, <em>সংকটে পরিস্থিতি বোঝা</em>, <em>ডেটার মানে ঠিক করা</em> — এগুলোর জন্য এমন কিছু দরকার যা AI-এর নেই।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        প্রতিটা দক্ষতা আসলে কোথায় পড়ে? তোমার ইনটিউশন পরীক্ষা করো।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: SKILLS SPECTRUM ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <SkillsSpectrum client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ JOBS DON'T DISAPPEAR — THEY SHAPE-SHIFT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        চাকরি উধাও হয় না — রূপ বদলায়
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ১৯৭০-এর দশকে ATM আসলে সবাই ভেবেছিল ব্যাংক টেলাররা উধাও হয়ে যাবে। বরং, ব্যাংক টেলারের সংখ্যা <em>বেড়েছিল</em>। কেন? কারণ ATM নতুন শাখা খোলা সস্তা করে দিয়েছিল, আর টেলারের কাজ ক্যাশ গোনা থেকে বদলে গেছিল ফিন্যান্সিয়াল প্রোডাক্ট বিক্রি আর কাস্টমার সম্পর্ক তৈরিতে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        AI একই জিনিস করছে, কিন্তু দ্রুততর আর একসাথে সব ইন্ডাস্ট্রিতে। চাকরির টাইটেল একই থাকে। চাকরির <em>বিবরণ</em> নাটকীয়ভাবে বদলে যায়। ২০২৫-এর একজন সাংবাদিক ২০১৫-এর একজন সাংবাদিকের মতো কাজ করছে না, যদিও byline-টা একই দেখায়।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>নতুন ক্যারিয়ার গণিত</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          এটা "মানুষ vs. AI" না। এটা <strong>AI-সহ মানুষ vs. AI-ছাড়া মানুষ</strong>। যারা AI টুলের সাথে কাজ করতে শেখে তারা চাকরি হারায় না — তারা চাকরিটা দ্রুততর, ভালোভাবে, আর আগে না থাকা ক্ষমতা নিয়ে করে।
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mt-10">
        নিচে একটা ক্যারিয়ার বেছে নাও আর দেখো AI কিভাবে ভেতর থেকে এটা বদলে দিচ্ছে। একটাও কাজ পুরোপুরি উধাও হয় না। কিন্তু প্রতিটা চাকরির আকার বদলাচ্ছে।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: JOB TRANSFORMER ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <JobTransformer client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ TASTE: THE IRREPLACEABLE SKILL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        রুচি: অপ্রতিস্থাপনীয় দক্ষতা
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI এক মিনিটে শখানেক লোগো কনসেপ্ট জেনারেট করতে পারে। তোমার কফি শেষ হওয়ার আগেই দশটা essay introduction লিখতে পারে। পাঁচটা অ্যাপ ডিজাইন, চারটা tagline, তিনটা বিজনেস প্ল্যান তৈরি করতে পারে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        কিন্তু কোনটা <em>সঠিক</em> সেটা বলতে পারে না।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        যে পৃথিবীতে অপশন তৈরি করা প্রায় ফ্রি, সেখানে <em>সঠিকটা বেছে নেওয়ার</em> ক্ষমতা তোমার সবচেয়ে মূল্যবান দক্ষতা হয়ে ওঠে। সেই ক্ষমতার একটা নাম আছে: রুচি।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        রুচি রহস্যময় কিছু না। এটা প্রশিক্ষিত হয়। তুমি এটা তৈরি করো অনেক ভালো কাজ আর অনেক খারাপ কাজ দেখে, আর কেন একটা অন্যটার চেয়ে ভালো সেটা articulate করতে শিখে। এটা সেই ফটোগ্রাফার যে জানে কোন শটটা রাখতে হবে। সেই লেখক যে জানে কোন বাক্যটা কাটতে হবে। সেই ডিজাইনার যে জানে কখন কম-ই বেশি।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85]">
        AI জেনারেট করে। তুমি কিউরেট করো। এটাই নতুন শ্রম বিভাজন। দেখো তোমার রুচি কতটা ধারালো।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: TASTE TEST ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <TasteTest client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ YOUR KNOWLEDGE IS YOUR BS DETECTOR ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        তোমার জ্ঞানই তোমার BS ডিটেক্টর
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        নবম অধ্যায়ে আমরা AI হ্যালুসিনেশন নিয়ে কথা বলেছি — কিভাবে AI পারফেক্ট আত্মবিশ্বাসে মিথ্যা বলতে পারে। কিন্তু এখানে অস্বস্তিকর পরবর্তী প্রশ্ন: <strong>তুমি সেটা ধরবে কিভাবে?</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        উত্তর হলো ফার্স্ট প্রিন্সিপলস থিংকিং। AI যখন বলে পাইপের ব্যাসার্ধ দ্বিগুণ করলে পানির প্রবাহ দ্বিগুণ হয়, তুমি সেই ভুল তখনই ধরতে পারবে যদি জানো ক্ষেত্রফল ব্যাসার্ধের <em>বর্গের</em> সাথে বাড়ে। AI যখন বলে একটা syllogism বৈধ, তুমি তখনই লজিক্যাল ফ্যালাসি ধরতে পারবে যদি ডিডাকশনের নিয়ম জানো।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AI যা আছে তা রিমিক্স করে। ফার্স্ট প্রিন্সিপলস থিংকিং মূল সত্য থেকে যুক্তি দেয়। এভাবেই তুমি সত্যিকারের নতুন জায়গায় পৌঁছাও — আর এভাবেই তুমি আত্মবিশ্বাসীভাবে ভুল করা AI-কে ধরো।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        এর মানে এই না তোমাকে সবকিছুতে এক্সপার্ট হতে হবে। কিন্তু যেসব ডোমেইনে তুমি কাজ করো আর তৈরি করো, সেখানে তোমার মৌলিক বোঝাপড়াই তোমাকে আলাদা করে সেই মানুষ থেকে যে চোখ বুজে AI আউটপুট কপি-পেস্ট করে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85]">
        নিজেকে পরীক্ষা করো। নিচের AI বিভিন্ন ডোমেইনের ছয়টা সমস্যায় আত্মবিশ্বাসী উত্তর দেয়। কিছু সঠিক। কিছু সূক্ষ্মভাবে ভুল। কোনটা কোনটা — বুঝতে পারো?
      </p>
    </FadeInBlock>
  </section>

