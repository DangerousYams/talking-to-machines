---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import ProjectPlanner from '../../components/widgets/ch11/ProjectPlanner';
import ShowcaseGallery from '../../components/widgets/ch11/ShowcaseGallery';

const chapter = chapters[10];
---

<ChapterLayout chapter={chapter} locale="bn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>১১</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          অধ্যায় এগারো
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          সত্যিকারের<br />কিছু বানাও
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          সৃষ্টি ছাড়া জ্ঞান হলো ট্রিভিয়া।<br />শিপ করার সময় হয়েছে।
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        তুমি শেষ অধ্যায়ে পৌঁছে গেছ। গত দশটা অধ্যায়ে, তুমি "আমার রচনায় সাহায্য করো" থেকে এজেন্ট বানানো, হ্যালুসিনেশন ডিবাগ করা, আর কাজের ভবিষ্যৎ নিয়ে চিন্তা করা পর্যন্ত পৌঁছেছ। AI সম্পর্কে বেশিরভাগ বড়দের চেয়ে বেশি শিখেছ। কিন্তু একটা অস্বস্তিকর সত্য বলি: <strong>কিছু না বানালে কিছুই মানে রাখে না।</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        AI নিয়ে পড়া সাঁতার নিয়ে পড়ার মতো। তুমি buoyancy-এর পদার্থবিদ্যা পড়তে পারো, অলিম্পিক রেস দেখতে পারো, সব স্ট্রোক টেকনিক মুখস্থ করতে পারো। কিন্তু পানিতে না নামা পর্যন্ত, তুমি কিছুই <em>জানো</em> না। তুমি শুধু <em>জানো সম্পর্কে</em>।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        এই অধ্যায় ঝাঁপ দেওয়ার জন্য। কোনো খেলনা এক্সারসাইজ বা follow-along টিউটোরিয়াল দিয়ে না। একটা আসল প্রজেক্ট। তুমি যেটা বেছে নেবে। তোমার যেটায় আগ্রহ। এমন কিছু যা কাউকে দেখিয়ে বলতে পারবে: <em>"এটা আমি বানিয়েছি।"</em>
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ YOUR TOOLKIT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        তোমার টুলকিট
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        দশ অধ্যায়ের দক্ষতা, ব্যবহারের জন্য তৈরি:
      </p>
    </FadeInBlock>

    <!-- Compact 2-column grid of chapter skills -->
    <FadeInBlock client:visible delay={0.15}>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem 1.5rem; margin-bottom: 2.5rem;">
        {[
          { ch: '১', label: 'প্রম্পট আর্কিটেকচার', color: '#E94560' },
          { ch: '২', label: 'উন্নত টেকনিক', color: '#0F3460' },
          { ch: '৩', label: 'কনটেক্সট ইঞ্জিনিয়ারিং', color: '#7B61FF' },
          { ch: '৪', label: 'AI ল্যান্ডস্কেপ', color: '#0EA5E9' },
          { ch: '৫', label: 'টুল ব্যবহার ও এজেন্ট', color: '#F5A623' },
          { ch: '৬', label: 'এজেন্ট আর্কিটেকচার', color: '#E94560' },
          { ch: '৭', label: 'AI পেয়ার প্রোগ্রামিং', color: '#7B61FF' },
          { ch: '৮', label: 'অর্কেস্ট্রেশন', color: '#0F3460' },
          { ch: '৯', label: 'ক্রিটিক্যাল থিংকিং', color: '#E94560' },
          { ch: '১০', label: 'মানুষের এজ', color: '#16C79A' },
        ].map((item) => (
          <div style="display: flex; align-items: center; gap: 0.6rem; padding: 0.4rem 0;">
            <span style={`font-family: var(--font-mono); font-size: 0.6rem; font-weight: 700; color: ${item.color}; opacity: 0.7; width: 1.25rem; text-align: right; flex-shrink: 0;`}>{item.ch}</span>
            <span style={`font-family: var(--font-body); font-size: 0.9rem; color: var(--color-deep); opacity: 0.8;`}>{item.label}</span>
          </div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        প্রশ্ন এখন: এটা দিয়ে তুমি কি করবে?
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ PLAN BEFORE YOU BUILD ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        বানানোর আগে প্ল্যান করো
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        প্রথমবারের বিল্ডারদের সবচেয়ে বড় ভুল? তারা সরাসরি টুলে ঝাঁপ দেয়। Claude খোলে, বিশাল প্রম্পট টাইপ করে, আর পুরো জিনিসটা এক শটে বানাতে চায়। ব্যর্থ হয়। হতাশ হয়। ছেড়ে দেয়।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        সেরা প্রজেক্ট প্রম্পট দিয়ে শুরু হয় না। কাগজে প্ল্যান দিয়ে শুরু হয়। তুমি কি বানাচ্ছ? কার জন্য? "শেষ" দেখতে কেমন? কিবোর্ডে হাত দেওয়ার আগে এগুলোর উত্তর দাও।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        অধ্যায় ৮ মনে আছে — জটিলতার অর্কেস্ট্রেশন? তোমার ক্যাপস্টোন প্রজেক্ট সেটার ক্ষুদ্র সংস্করণ। কাজটাকে টুকরো করো। কি বানাচ্ছ জানো বানানোর আগে। প্রতিটা টুকরোতে AI-কে সহকর্মী হিসেবে ব্যবহার করো, পুরো জিনিসের জন্য ম্যাজিক ওয়ান্ড হিসেবে না।
      </p>
    </FadeInBlock>

    <!-- Planning Steps -->
    <FadeInBlock client:visible delay={0.25}>
      <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
        <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
        {[
          { word: 'বেছে নাও।', desc: 'এমন কিছু বাছো যা তোমার সত্যিই ভালো লাগে। আগ্রহই কঠিন জায়গাগুলোতে এগিয়ে যাওয়ার শক্তি দেয়।' },
          { word: 'স্কোপ ছোট করো।', desc: 'অর্ধেক করো। তারপর আবার অর্ধেক করো। শেষ করা ছোট প্রজেক্ট ফেলে রাখা বড় প্রজেক্টকে হারায়।' },
          { word: 'ডিকম্পোজ করো।', desc: '৫-৮টা কাজে ভাঙো। প্রতিটা কাজ এক বসায় শেষ করা যায় এমন হওয়া উচিত।' },
          { word: 'বানাও।', desc: 'একটা একটা কাজ করো। প্রতিটা টুকরোতে AI ব্যবহার করো। এগিয়ে যাওয়ার আগে প্রতিটা আউটপুট ভেরিফাই করো।' },
          { word: 'শিপ করো।', desc: 'পারফেক্টের চেয়ে শেষ করা ভালো। শেয়ার করো। ফিডব্যাক নাও। ইটারেট করো।' },
        ].map((step, i) => (
          <div style={`position: relative; padding-bottom: ${i < 4 ? '1.75rem' : '0'};`}>
            <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
            <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
              <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
              <span style="opacity: 0.7;"> {step.desc}</span>
            </p>
          </div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        আরেকটা কথা: যেতে যেতে ডকুমেন্ট করো। প্রজেক্টটা নিজেই গল্পের অর্ধেক। কিভাবে বানালে — সিদ্ধান্তগুলো, ইটারেশনগুলো, মৃত প্রান্তগুলো — সেটা বাকি অর্ধেক। একটা শেষ করা প্রজেক্ট যা তুমি ব্যাখ্যা করতে পারো, যেকোনো টেস্ট স্কোরের চেয়ে বেশি মূল্যবান।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: PROJECT PLANNER ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ProjectPlanner client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE 3-WEEK SPRINT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        ৩-সপ্তাহের স্প্রিন্ট
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        তোমার প্রজেক্ট এক সপ্তাহান্তে হোক বা এক সেমিস্টারে, ছন্দটা একই। সত্যিকারের কিছু শিপ করার জন্য একটা যুদ্ধ-পরীক্ষিত ফ্রেমওয়ার্ক:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div style="display: flex; flex-direction: column; gap: 2rem;">
        {[
          {
            week: 'সপ্তাহ ১',
            title: 'আইডিয়া ও স্কোপ',
            color: '#F5A623',
            tasks: [
              'প্রজেক্ট বাছো। উপরের Project Planner ব্যবহার করো।',
              '"শেষ" দেখতে কেমন তার এক প্যারা বর্ণনা লেখো।',
              'প্রজেক্টটাকে ৫-৮টা কাজে ভাঙো স্পষ্ট deliverable সহ।',
              'প্রতিটা কাজের জন্য কোন AI টুল ব্যবহার করবে ঠিক করো।',
              'সবচেয়ে কঠিন অংশের একটা ক্ষুদ্র prototype আগে বানাও। সেটা কাজ করলে, বাকিটা হবে।',
            ],
          },
          {
            week: 'সপ্তাহ ২',
            title: 'বানাও',
            color: chapter.accent,
            tasks: [
              'একটা একটা কাজ করো। আগে লাফিয়ে যেয়ো না।',
              'প্রতিটা কাজে অধ্যায় ১-এর prompt-evaluate-refine লুপ ব্যবহার করো।',
              '"যেসব প্রম্পট কাজ করেছে" লগ রাখো। পরে নিজেকে ধন্যবাদ দেবে।',
              'আটকে গেলে, প্রাসঙ্গিক অধ্যায় আবার পড়ো। উত্তর সাধারণত এমন একটা টেকনিকে থাকে যেটা চেষ্টা করোনি।',
              'মাঝ-সপ্তাহে কোনো বন্ধু বা পরিবারের সদস্যের কাছ থেকে ফিডব্যাক নাও। নতুন চোখ যা তোমার চোখ মিস করে তা ধরে।',
            ],
          },
          {
            week: 'সপ্তাহ ৩',
            title: 'পলিশ ও প্রেজেন্ট',
            color: '#7B61FF',
            tasks: [
              'সবচেয়ে চোখে পড়া তিনটা rough edge ঠিক করো। বাকি সব ইগনোর করো।',
              'প্রজেক্টের বর্ণনা লেখো: কি করে, কিভাবে বানালে, কি শিখলে।',
              '৩টা মূল প্রম্পট ডকুমেন্ট করো যা তোমার প্রক্রিয়ায় ক্রিটিক্যাল ছিল।',
              '২ মিনিটের একটা walkthrough বানাও (ভিডিও, স্লাইড, বা লাইভ ডেমো)।',
              'শেয়ার করো। একজন শিক্ষকের সাথে, একজন বন্ধুর সাথে, অনলাইনে, স্টুডেন্ট শোকেসে।',
            ],
          },
        ].map((week, i) => (
          <FadeInBlock client:visible delay={0.15 + i * 0.1}>
            <div style={`background: ${week.color}06; border: 1px solid ${week.color}15; border-radius: 12px; padding: 1.5rem 1.75rem;`}>
              <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 1rem;">
                <span style={`font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: ${week.color}; background: ${week.color}15; padding: 3px 10px; border-radius: 100;`}>
                  {week.week}
                </span>
                <span style={`font-family: var(--font-heading); font-size: 1.05rem; font-weight: 700; color: var(--color-deep);`}>
                  {week.title}
                </span>
              </div>
              <ul style="margin: 0; padding-left: 1.25rem;">
                {week.tasks.map((task) => (
                  <li style="font-family: var(--font-body); font-size: 0.9rem; line-height: 1.7; color: var(--color-deep); opacity: 0.8; margin-bottom: 0.35rem;">
                    {task}
                  </li>
                ))}
              </ul>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- BRIDGE TO SHOWCASE GALLERY -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
