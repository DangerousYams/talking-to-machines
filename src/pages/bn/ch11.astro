---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ProjectInstructionsBuilder from '../../components/widgets/ch11/ProjectInstructionsBuilder';

const chapter = chapters[10];
---

<ChapterLayout chapter={chapter} locale="bn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>১১</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          একাদশ অধ্যায়
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          সত্যিকারের<br />কিছু বানাও
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          সৃষ্টি ছাড়া জ্ঞান হলো ট্রিভিয়া।<br />শিপ করার সময় হয়েছে।
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        তুমি শেষ পর্যন্ত পৌঁছে গেছ। দশটা অধ্যায়ে তুমি "আমার রচনায় সাহায্য করো" থেকে কনটেক্সট ইঞ্জিনিয়ারিং, এজেন্ট তৈরি, আর হ্যালুসিনেশন ডিবাগ করা পর্যন্ত এসেছ। বেশিরভাগ বড়দের চেয়ে AI সম্পর্কে বেশি শিখেছ। কিন্তু একটা অস্বস্তিকর সত্য বলি: <strong>কিছু না বানালে কিছুই মানে রাখে না।</strong> AI নিয়ে পড়া সাঁতার নিয়ে পড়ার মতো &mdash; তুমি প্রতিটা স্ট্রোক টেকনিক পড়তে পারো, কিন্তু পানিতে না নামা পর্যন্ত তুমি কিছুই <em>জানো</em> না। তুমি শুধু <em>জানো সম্পর্কে</em>।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ SET UP YOUR AI ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        তোমার AI সেটআপ করো
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        প্রথম প্রম্পট লেখার আগে একটা পাওয়ার মুভ আছে যা বেশিরভাগ নতুনরা বাদ দেয়: <strong>তোমার AI টুলকে একটা স্থায়ী নির্দেশনা ফাইল দাও।</strong> প্রতি সেশনে প্রজেক্ট আবার বোঝানোর বদলে, একবার লিখে রাখো আর AI অটোমেটিক পড়বে। Claude Code পড়ে <code>CLAUDE.md</code>। Cursor পড়ে <code>.cursorrules</code>। GitHub Copilot পড়ে <code>.github/copilot-instructions.md</code>। একই কনসেপ্ট, ভিন্ন ফাইলের নাম। এটা তৃতীয় অধ্যায়ের কনটেক্সট ইঞ্জিনিয়ারিং &mdash; প্রজেক্ট লেভেলে প্রয়োগ করা।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        একটা ভালো নির্দেশনা ফাইল তিনটা প্রশ্নের উত্তর দেয়: তুমি কি বানাচ্ছ, নিয়মগুলো কি, আর "ভালো" দেখতে কেমন? এগুলো ঠিক করলে AI-এর সাথে প্রতিটা কথোপকথন দশ ধাপ এগিয়ে শুরু হয়। প্রজেক্টের স্কোপ এমন ছোট রাখো যাতে শেষ করতে পারো &mdash; শেষ করা উইকেন্ড হ্যাক ফেলে রাখা মাস্টারপিসকে প্রতিবার হারায়।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style="font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;">মূল বিষয়</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          একটা ভালো প্রজেক্ট নির্দেশনা ফাইল হলো সেই পার্থক্য এমন AI-এর মধ্যে যে তোমাকে সাহায্য করে আর এমন AI-এর মধ্যে যে তোমাকে <em>বোঝে</em>। একবার লেখো, প্রতিটা সেশনে সুবিধা পাও।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        এখানেই তোমার প্রজেক্ট নির্দেশনা ফাইল বানাও। সেকশনগুলো পূরণ করো আর তোমার পছন্দের AI টুলের জন্য এক্সপোর্ট করো।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="project-instructions-builder" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ProjectInstructionsBuilder client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        টুল জিনিস বানায় না। টুলসহ মানুষ জিনিস বানায়। আর তোমার কাছে তোমার জেনারেশনের সেরা টুলকিট আছে।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto mb-8" style="max-width: 55ch;">
        এগারোটা অধ্যায় আগে, তুমি "আমার রচনায় সাহায্য করো" টাইপ করেছিলে আর সেরাটা আশা করেছিলে। এখন তুমি কনটেক্সট ইঞ্জিনিয়ার করো, এজেন্ট ডিজাইন করো, আউটপুট ভেরিফাই করো, আর প্রতিটা ধাপে বিচার নিয়ে আসো। কোর্স শেষ। আসল শেখা এখন শুরু &mdash; গিয়ে এমন কিছু বানাও যা শুধু তুমিই ভাবতে পারতে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-center mt-4" style={`font-family: var(--font-heading); font-size: 1.8rem; font-weight: 800; color: ${chapter.accent}; letter-spacing: -0.02em;`}>
        শিপ করো।
      </p>
    </FadeInBlock>
  </section>

</ChapterLayout>
