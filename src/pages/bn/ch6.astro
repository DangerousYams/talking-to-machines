---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import AgentBlueprint from '../../components/widgets/ch6/AgentBlueprint';
import AgentTakeover from '../../components/breaks/AgentTakeover';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[5];
---

<ChapterLayout chapter={chapter} locale="bn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>৬</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          ষষ্ঠ অধ্যায়
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          এজেন্ট<br />তৈরি করা
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          ক্যালকুলেটর আর<br />সহকর্মীর মধ্যে পার্থক্য।
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        চ্যাটবট তোমার কথা বলার জন্য অপেক্ষা করে। এজেন্ট করে না। তাকে একটা লক্ষ্য দাও &mdash; "মঙ্গল গ্রহে উপনিবেশ নিয়ে রিসার্চ করে একটা রিপোর্ট লেখো" &mdash; আর সে কাজটাকে ধাপে ভাগ করে, সঠিক টুলস বেছে নেয়, একে একে এক্সিকিউট করে, নিজের ফলাফল চেক করে, আর কাজ শেষ না হওয়া পর্যন্ত চালিয়ে যায়। এই পার্থক্য &mdash; <em>নির্দেশনার জবাব দেওয়া</em> আর <em>একটা লক্ষ্য অনুসরণ করা</em> &mdash; এটাই ক্যালকুলেটর আর সহকর্মীর মধ্যে পার্থক্য।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        এজেন্ট একটা লুপে চলে: লক্ষ্য নাও, ধাপ প্ল্যান করো, টুলস দিয়ে এক্সিকিউট করো, ফলাফল দেখো, অগ্রগতি মূল্যায়ন করো, সংশোধন করো। তারা একবার প্ল্যান করে অন্ধভাবে এক্সিকিউট করে না &mdash; সেরা এজেন্টরা তিন নম্বর ধাপ গোলমাল হলে সুন্দরভাবে সামলে নেয়। কিন্তু এই ক্ষমতার একটা অন্ধকার দিক আছে: এজেন্ট শুধু খারাপ উত্তর দেয় না, সেগুলোর উপর <em>কাজ করে</em>, তারপর ভাঙা ফলাফল ব্যবহার করে পরবর্তী সিদ্ধান্ত নেয়। ব্যর্থতা জটিল থেকে জটিলতর হয়।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE AGENT LOOP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        এজেন্ট লুপ
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        প্রতিটা এজেন্ট একই পাঁচ-ধাপের চক্রে চলে। এই ধাপগুলো বুঝলেই পার্থক্য হয় কাজের কিছু বানানো আর API ক্রেডিট পুড়িয়ে ইনফিনিট লুপে আটকে যাওয়ার মধ্যে।
      </p>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { letter: 'G', name: 'লক্ষ্য', color: '#E94560', text: 'একটা স্পষ্ট উদ্দেশ্য নাও। "মঙ্গল নিয়ে রিসার্চ" লক্ষ্য না। "মঙ্গল উপনিবেশের চ্যালেঞ্জের ৫০০ শব্দের সামারি সোর্স-সহ লেখো" হলো লক্ষ্য।' },
        { letter: 'P', name: 'পরিকল্পনা', color: '#7B61FF', text: 'লক্ষ্যকে কংক্রিট ধাপে ভাগ করো। ভালো পরিকল্পনাকারী নমনীয় প্ল্যান বানায়। খারাপ পরিকল্পনাকারী শক্ত স্ক্রিপ্ট বানায় যা প্রথম বিপত্তিতেই ভেঙে পড়ে।' },
        { letter: 'T', name: 'এক্সিকিউট', color: '#0EA5E9', text: 'সঠিক টুল দিয়ে প্রতিটা ধাপ চালাও &mdash; সার্চ ইঞ্জিন, কোড ইন্টারপ্রিটার, ফাইল রিডার, API। এজেন্ট শুধু চিন্তা করে না। কাজও করে।' },
        { letter: 'M', name: 'পর্যবেক্ষণ', color: '#16C79A', text: 'কি হলো রেকর্ড করো আর ফলাফল চেক করো। মেমোরি ছাড়া, এজেন্ট একই ব্যর্থ কাজ চিরকাল করতে থাকতে পারে।' },
        { letter: 'E', name: 'মূল্যায়ন', color: '#F5A623', text: 'এটা কি কাজ করেছে? আমি কি লক্ষ্যের কাছাকাছি এসেছি? কিছু ভুল হলে, প্ল্যান সংশোধন করো আর আবার লুপ করো। এটাই এজেন্টকে স্ক্রিপ্ট থেকে আলাদা করে।' },
      ].map((block, i) => (
        <FadeInBlock client:visible delay={i * 0.08}>
          <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${block.color};`}>
              {block.letter}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${block.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {block.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {block.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>মূল বিষয়</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          চ্যাটবট হলো একটা পালা। এজেন্ট হলো পুরো কথোপকথন &mdash; নিজের সাথে, টুলসের সাথে, আর পৃথিবীর সাথে। সেরা এজেন্ট নির্মাতারা স্বায়ত্তশাসন সর্বোচ্চ করে না। তারা চিন্তাশীল চেকপয়েন্ট ডিজাইন করে যেখানে এজেন্ট থেমে যায় আর একজন মানুষকে সিদ্ধান্ত নিতে দেয় চালিয়ে যাবে কি না।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        এবার একটা বানানোর সময়। নিজের এজেন্ট ডিজাইন করো একদম স্ক্র্যাচ থেকে।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <AgentBlueprint client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="এইমাত্র আমার প্রথম AI এজেন্ট স্ক্র্যাচ থেকে ডিজাইন করলাম। এই কোর্সটা ধাপে ধাপে আর্কিটেকচার শেখায় লাইভ ডেমো দিয়ে। হাইপ না, শুধু বিল্ডিং।" client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        লক্ষ্য সব ব্যর্থতা প্রতিরোধ করা না &mdash; ব্যর্থতাকে পুনরুদ্ধারযোগ্য করা।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        এরপর, তুমি একটা সত্যিকারের এজেন্ট ব্যবহার করবে &mdash; যে তোমার কোড পড়ে, পরিবর্তন লেখে, টেস্ট চালায়, আর নিজের ভুল ঠিক করে। Claude Code-এর সাথে পরিচিত হও।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(233,69,96,0.06) 15%, rgba(233,69,96,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#E94560" toolName="Agent Takeover" client:visible>
        <AgentTakeover client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
