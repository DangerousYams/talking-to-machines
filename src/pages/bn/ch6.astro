---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import AgentBlueprint from '../../components/widgets/ch6/AgentBlueprint';
import FailureModesLab from '../../components/widgets/ch6/FailureModesLab';
import HandoffChain from '../../components/widgets/ch6/HandoffChain';

const chapter = chapters[5];
---

<ChapterLayout chapter={chapter} locale="bn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>6</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          ষষ্ঠ অধ্যায়
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          এজেন্ট<br />তৈরি করা
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          ডিজাইন, কানেক্ট এবং ডেপ্লয় করো একটা AI এজেন্ট<br />সম্পূর্ণ নতুন করে।
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        একটা চ্যাটবট তোমার কথা বলার জন্য অপেক্ষা করে। এজেন্ট করে না। তাকে একটা লক্ষ্য দাও — "মঙ্গল গ্রহে উপনিবেশ নিয়ে রিসার্চ করে একটা রিপোর্ট লেখো" — এবং সে কাজটাকে ধাপে ধাপে ভাগ করে, সঠিক টুলস বেছে নেয়, একে একে এক্সিকিউট করে, নিজের ফলাফল চেক করে, আর কাজ শেষ না হওয়া পর্যন্ত চালিয়ে যায়। হাতে ধরে দেখানোর দরকার নেই।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        এই পার্থক্যটা — <em>নির্দেশনার জবাব দেওয়া</em> আর <em>একটা লক্ষ্য অনুসরণ করার</em> — এটাই ক্যালকুলেটর আর সহকর্মীর মধ্যে পার্থক্য। চ্যাটবট প্রশ্নের উত্তর দেয়। এজেন্ট সমস্যার সমাধান করে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        এই অধ্যায়টা হলো এজেন্ট আসলে কীভাবে কাজ করে — যে লুপ তাদের চালায়, যে আর্কিটেকচার তাদের নির্ভরযোগ্য করে, আর যে ব্যর্থতাগুলো তাদের বিপজ্জনক করে তোলে যখন অসাবধানে বানানো হয়।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE AGENT LOOP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        এজেন্ট লুপ
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        পঞ্চম অধ্যায়ে তুমি বেসিক টুল-ইউজ লুপ দেখেছো: পর্যবেক্ষণ, চিন্তা, কাজ। এজেন্ট সেটাকে আরো উচ্চাভিলাষী কিছুতে নিয়ে যায় — একটা পাঁচ-ধাপের চক্র, যার প্রতিটি চালিত হয় আলাদা একটা অভ্যন্তরীণ কম্পোনেন্ট দিয়ে:
      </p>
    </FadeInBlock>

    <!-- Loop Steps with architecture component for each -->
    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { letter: 'G', word: 'লক্ষ্য', color: '#E94560', desc: 'মানুষের কাছ থেকে একটা উচ্চ-স্তরের উদ্দেশ্য নাও। স্পষ্ট লক্ষ্য ছাড়া, এজেন্ট বুঝতে পারে না কখন কাজ শেষ। "মঙ্গল নিয়ে রিসার্চ" লক্ষ্য নয়। "মঙ্গল উপনিবেশের চ্যালেঞ্জের ৫০০ শব্দের সামারি সোর্স-সহ লেখো" হলো লক্ষ্য।' },
        { letter: 'P', word: 'পরিকল্পনা', color: '#7B61FF', desc: 'লক্ষ্যকে কংক্রিট ধাপগুলোতে ভাগ করো। সেরা পরিকল্পনাকারীরা নমনীয় পরিকল্পনা করে যা একটা ধাপ ব্যর্থ হলে মানিয়ে নেয়। খারাপ পরিকল্পনাকারীরা শক্ত স্ক্রিপ্ট করে যা প্রথম বিপত্তিতেই ভেঙে যায়।' },
        { letter: 'T', word: 'এক্সিকিউট', color: '#0EA5E9', desc: 'সঠিক টুল ব্যবহার করে প্রতিটা ধাপ চালাও — সার্চ ইঞ্জিন, কোড ইন্টারপ্রিটার, ফাইল রিডার, API, ক্যালকুলেটর। এজেন্ট শুধু চিন্তা করে না। কাজও করে।' },
        { letter: 'M', word: 'পর্যবেক্ষণ', color: '#16C79A', desc: 'কী হয়েছে রেকর্ড করো এবং ফলাফল চেক করো। কী করেছে এবং কী পেয়েছে তার মেমোরি ছাড়া, এজেন্ট লুপে আটকে একই ব্যর্থ কাজ চিরকাল করতে থাকতে পারে।' },
        { letter: 'E', word: 'মূল্যায়ন', color: '#F5A623', desc: 'এটা কি কাজ করেছে? এই ডেটা কি নির্ভরযোগ্য? আমি কি লক্ষ্যের কাছাকাছি এসেছি? মূল্যায়নকারী একটা এজেন্টকে এমন স্ক্রিপ্ট থেকে আলাদা করে যে শুধু চালায় আর ভালো কিছু আশা করে। কিছু ভুল হলে, পরিকল্পনা সংশোধন করো এবং আবার লুপ করো।' },
      ].map((step, i) => (
        <FadeInBlock client:visible delay={i * 0.08}>
          <div style={`display: flex; gap: 1.25rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1rem; font-weight: 800; color: white; background: ${step.color};`}>
              {step.letter}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.05rem; font-weight: 700; color: ${step.color}; margin: 0 0 0.3rem; line-height: 1.3;`}>
                {step.word}
              </p>
              <p style="font-size: 0.95rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {step.desc}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <p class="text-lg leading-[1.85] mb-10">
        মূল কথা হলো <em>লুপ</em>। এজেন্ট একবার পরিকল্পনা করে অন্ধভাবে এক্সিকিউট করে না। সে পরিকল্পনা করে, কাজ করে, পর্যবেক্ষণ করে, মূল্যায়ন করে, আর সংশোধন করে। সেরা এজেন্টরা হলো যারা তিন নম্বর ধাপ উল্টোপাল্টা হয়ে গেলে সুন্দরভাবে সামলে নেয়।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.55}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        চ্যাটবট হলো একটা টার্ন। এজেন্ট হলো পুরো কথোপকথন — নিজের সাথে, টুলসের সাথে, আর পৃথিবীর সাথে।
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO AGENT BLUEPRINT -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        এবার একটা বানানোর সময়। নিজের এজেন্ট ডিজাইন করো একদম স্ক্র্যাচ থেকে।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: AGENT BLUEPRINT ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <AgentBlueprint client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ WHEN AGENTS FAIL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        যখন এজেন্ট ব্যর্থ হয়
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        এজেন্ট চ্যাটবটের মতো ব্যর্থ হয় না। চ্যাটবট তোমাকে একটা খারাপ উত্তর দিয়ে অপেক্ষা করে। এজেন্ট নিজেকে একটা খারাপ উত্তর দেয়, <em>সেই অনুযায়ী কাজ করে</em>, তারপর ভাঙা ফলাফল ব্যবহার করে পরবর্তী সিদ্ধান্ত নেয়। ব্যর্থতা জটিল থেকে জটিলতর হয়।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        এজেন্ট ভুল হওয়ার তিনটা ক্লাসিক উপায় আছে:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>ব্যর্থতার ধরন ১: অসীম লুপ</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          এজেন্ট একই কাজ বারবার করে আটকে যায়। রিসার্চ এজেন্ট "আরেকটা সোর্স" খুঁজতে থাকে আর কখনো লেখা শুরু করে না। স্টপিং কন্ডিশন ছাড়া, তুমি প্লাগ না তানা পর্যন্ত — বা API ক্রেডিট শেষ না হওয়া পর্যন্ত — সে চলতেই থাকবে।
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="prompt-block mb-10" style={`--accent: #7B61FF;`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:#7B61FF;`}></div>
        <span class="prompt-block-label" style="color: #7B61FF;">ব্যর্থতার ধরন ২: ভুল টুল</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          এজেন্ট এমন টুল বেছে নেয় যা কাজটা করতে পারে না। সে তোমার হার্ডড্রাইভের ফাইলের জন্য ওয়েব-সার্চ করার চেষ্টা করে, বা একটা প্রবন্ধ সামারি করতে ক্যালকুলেটর ডাকে। এজেন্ট বোকা নয় — সে শুধু টুলবক্স থেকে বেছে নিয়েছে টুলটা কাজের উপযুক্ত কি না চেক না করেই।
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="prompt-block mb-10" style={`--accent: #F5A623;`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:#F5A623;`}></div>
        <span class="prompt-block-label" style="color: #F5A623;">ব্যর্থতার ধরন ৩: হ্যালুসিনেটেড এক্শন</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          এজেন্ট এমন টুল বা API উদ্ভাবন করে যেগুলোর অস্তিত্ব নেই, তারপর নকল ফলাফল দিয়ে "ডাকে"। যখন নকল কলটা ব্যর্থ হয়, সে মাঝে মাঝে যে ডেটা পাওয়ার কথা ছিল সেটা বানিয়ে ফেলে। ডবল হ্যালুসিনেশন: নকল টুল, নকল আউটপুট।
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        সমাধানটা সবসময় একই নীতি: <strong>দুর্ভাগ্যজনক পথের জন্য ডিজাইন করো।</strong> সর্বোচ্চ ইটারেশন, টুল ভ্যালিডেশন, আউটপুট যাচাই, আর মানুষের চেকপয়েন্ট। লক্ষ্য সব ব্যর্থতা প্রতিরোধ করা নয় — ব্যর্থতাকে পুনরুদ্ধারযোগ্য করা।
      </p>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO FAILURE MODES LAB -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        তুমি কি একটা ভাঙা এজেন্ট ডায়াগনোজ করতে পারবে? বাগ খুঁজে বের করো এবং গার্ডরেল যোগ করো।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FAILURE MODES LAB ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <FailureModesLab client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE POWER OF MANY: MULTI-AGENT SYSTEMS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        বহুর শক্তি
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
