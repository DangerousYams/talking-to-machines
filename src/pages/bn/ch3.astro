---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ContextWindowViz from '../../components/widgets/ch3/ContextWindowViz';
import ForgettingExperiment from '../../components/widgets/ch3/ForgettingExperiment';
import SystemPromptSandbox from '../../components/widgets/ch3/SystemPromptSandbox';

const chapter = chapters[2];
---

<ChapterLayout chapter={chapter} locale="bn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>৩</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          অধ্যায় তিন
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          কনটেক্সট<br />ইঞ্জিনিয়ারিং
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          AI ভুলে যায় না &mdash; সে আদতে<br />মনেই রাখেনি কখনো।
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        ভাবো তুমি একটা বন্ধুর সাথে কথা বলছ, কিন্তু প্রতি কয়েক মিনিট পর পর কেউ সেই হোয়াইটবোর্ড মুছে দিচ্ছে যেখানে তোমরা দুজন লিখছিলে। তোমাকে আবার শুরু করতে হচ্ছে। তোমার বন্ধু যা অবশিষ্ট আছে তা দেখে ভাবছে কিছুই হয়নি। এরকমই হয় একটা AI-এর "মস্তিষ্কের" ভেতর দীর্ঘ কোনো কথোপকথনের সময়।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        <strong>AI-এর কোনো মেমরি নেই।</strong> তুমি যেভাবে মেমরি বুঝো, সেভাবে না। সে গতকালকের তোমার কথোপকথন মনে রাখে না। এমনকি <em>এই</em> কথোপকথনের শুরুর অংশও মনে রাখে না যদি সেটা অনেক লম্বা হয়ে যায়। প্রতিটা উত্তর সে দেয় একদম ভিত্তি করে যা ঠিক সেই মুহূর্তে তার সামনে দেখতে পাচ্ছে &mdash; এটাকে বলা হয় <strong>কনটেক্সট উইন্ডো</strong>।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        এই উইন্ডোটা বোঝা &mdash; এর ভেতর কি যায়, এটা কত বড়, আর এটা ভর্তি হয়ে গেলে কি হয় &mdash; এসবই AI-এর সাথে কাজ করার সবচেয়ে গুরুত্বপূর্ণ স্কিলগুলোর একটা।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE WHITEBOARD METAPHOR ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        যে হোয়াইটবোর্ড মুছে দেওয়া হয়
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        তুমি যখন একটা AI-কে মেসেজ পাঠাও, সেটা আসলে কি করে: সিস্টেমটা তোমার <em>পুরো কথোপকথনটা</em> নেয় &mdash; তুমি যতগুলো মেসেজ পাঠিয়েছ, AI যতগুলো উত্তর দিয়েছে &mdash; সব কিছু একসাথে এক খণ্ড টেক্সট হিসেবে মডেলের কাছে পাঠায়। AI সেটা সব পড়ে, পরবর্তী উত্তর তৈরি করে, তারপর... সব ভুলে যায়।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        পরের বার তুমি মেসেজ পাঠালে, পুরো প্রক্রিয়াটা আবার শুরু হয়। সিস্টেম আবার পুরো কথোপকথনটা পেস্ট করে, তোমার নতুন মেসেজ যোগ করে, আর AI সব কিছু নতুন করে পড়ে। এটা পৃথিবীর সবচেয়ে পরিশ্রমী কিন্তু স্মৃতিভ্রষ্ট পাঠকের মতো &mdash; প্রতি বার সম্পূর্ণ মনোযোগী, কিন্তু প্রতিটা পালার শুরুতে একদম নতুন।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        একটা AI যে উত্তর দেয়, সেটা সম্পূর্ণ নির্ভর করে ঠিক সেই মুহূর্তে কনটেক্সট উইন্ডোতে যা আছে তার উপর। এর চেয়ে বেশি কিছু না। কনটেক্সট উইন্ডো মেমরি নয়। এটা একটা হোয়াইটবোর্ড &mdash; আর এর সীমানা আছে।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        এর ব্যাপক প্রভাব আছে। মানে AI ততটাই ভালো যতটা তথ্য বর্তমানে তার সামনে আছে। একটা জরুরি বিষয় বাদ দিয়েছ? AI সেটা জাদুমন্ত্রে মনে করতে পারবে না। উইন্ডো ভর্তি করে দিয়েছ অপ্রয়োজনীয় তথ্য দিয়ে? AI কনফিউজড হয়ে যাবে। <strong>কনটেক্সট উইন্ডো তোমার সবচেয়ে গুরুত্বপূর্ণ রিসোর্স।</strong> এটা ম্যানেজ করতে শেখাই আলাদা করে দেয় সাধারণ ইউজারদের থেকে যারা সত্যিই শক্তিশালী ফলাফল পান।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ TOKENS — THE AI'S ALPHABET ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        টোকেন: AI-এর বর্ণমালা
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI তোমার মতো করে শব্দ পড়ে না। সে পড়ে <strong>টোকেন</strong> &mdash; টেক্সটের ছোট অংশ যা সাধারণত একটা শব্দের প্রায় তিন চতুর্থাংশ। "incredible" শব্দটা দুইটা টোকেন। "AI" একটা টোকেন। একটা শব্দের আগের স্পেসও প্রায়ই একই টোকেনের মধ্যে থাকে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: #7B61FF;">
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>সহজ হিসাব</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          ১ টোকেন &asymp; ৪টি অক্ষর &asymp; ০.৭৫ শব্দ<br />
          ১০০ টোকেন &asymp; ৭৫ শব্দ<br />
          সাধারণ এক পাতা টেক্সট &asymp; ৩০০ টোকেন<br />
          একটা পূর্ণ উপন্যাস &asymp; ১,০০,০০০ টোকেন
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        এটা কেন গুরুত্বপূর্ণ? কারণ প্রতিটা AI মডেলের একটা <strong>কনটেক্সট উইন্ডো সাইজ</strong> আছে টোকেন দিয়ে মাপা। Claude-এর কনটেক্সট উইন্ডো ২,০০,০০০ টোকেন ধরতে পারে &mdash; এটা মোটামুটি ৫০০ পাতার একটা বই। GPT-4o ধরে ১,২৮,০০০ টোকেন। এগুলো অনেক বড় মনে হলেও, তোমার ভাবনার চেয়ে অনেক দ্রুত ভর্তি হয়ে যায়।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        তুমি যতগুলো মেসেজ পাঠাও, AI যতগুলো উত্তর লেখে, পর্দার আড়ালে যেসব সিস্টেম ইন্সট্রাকশন কাজ করে &mdash; সব কিছুই একই শেয়ারড বাজেট থেকে টোকেন খরচ করে। আর সেই বাজেট শেষ হয়ে গেলে, জিনিসপত্র পাড় থেকে পড়ে যেতে শুরু করে।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: CONTEXT WINDOW VIZ ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ContextWindowViz client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ WHEN THE WINDOW OVERFLOWS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        উইন্ডো উপচে পড়লে
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        তুমি দশটা মেসেজ কথোপকথন করেছ। তিন নাম্বার মেসেজে তুমি তোমার খাদ্যাভ্যাস সংক্রান্ত নিষেধাজ্ঞার কথা বলেছিলে। পনের নাম্বার মেসেজে এখন রেস্তোরাঁর সুপারিশ নিয়ে গভীর আলোচনায় ডুবে আছ। তুমি জিজ্ঞেস করলে: <em>"আচ্ছা, আমি কি খাদ্যাভ্যাস সংক্রান্ত নিষেধাজ্ঞার কথা বলেছিলাম?"</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        আর AI বলে: <em>"আমার মনে হয় না আপনি কোনো নির্দিষ্ট খাদ্যাভ্যাস সংক্রান্ত নিষেধাজ্ঞার কথা বলেছিলেন।"</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        তুমি হতাশ হয়ে পড়ো। <em>এটা তো এখানেই আছে, আমি বলেছিলাম!</em> কিন্তু ব্যাপারটা হলো: এটা আর <strong>এখানে নেই</strong>। আর নেই। সেই আগের মেসেজটা হয়তো দৃশ্যমান উইন্ডো থেকে পিছলে গেছে, অথবা মডেল সাম্প্রতিক কনটেক্সটের তুলনায় সেটাকে কম প্রাধান্য দিয়েছে। AI অসাবধান হচ্ছে না। এটা আক্ষরিক অর্থেই দেখতে পাচ্ছে না যা আর তার সামনে নেই।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>এটা বাগ নয়। এটাই আর্কিটেকচার।</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI কনটেক্সট উইন্ডো প্রসেস করে ঠিক যেমন একজন মানুষ একটা ডকুমেন্ট এক বসায় পড়ে। ডকুমেন্ট যদি ১০০ পাতার হয়, তাহলে ৯৫ পাতায় পৌঁছানোর সময় ৩ পাতার ডিটেইলস অস্পষ্ট হয়ে যেতে পারে। সমাধান বড় উইন্ডো নয় &mdash; বরং আরো স্মার্টভাবে প্যাক করা যা যায় ভেতরে।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FORGETTING EXPERIMENT ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ForgettingExperiment client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SYSTEM PROMPT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        সিস্টেম প্রম্পট: লুকানো নির্দেশনা
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        প্রতিটা AI কথোপকথনে একটা অংশ আছে যা তুমি কখনো দেখো না। তোমার প্রথম মেসেজের আগে, AI হ্যালো বলার আগে, কনটেক্সট উইন্ডোর একদম উপরে একটা টেক্সট ব্লক বসে থাকে। এটাকে বলা হয় <strong>সিস্টেম প্রম্পট</strong>, আর এটা পরবর্তী সব কিছুকে আকার দেয়।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
