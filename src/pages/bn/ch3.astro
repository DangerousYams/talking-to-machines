---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ContextWindowViz from '../../components/widgets/ch3/ContextWindowViz';
import VibeCheck from '../../components/breaks/VibeCheck';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[2];
---

<ChapterLayout chapter={chapter} locale="bn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>৩</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          তৃতীয় অধ্যায়
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          কনটেক্সট<br />ইঞ্জিনিয়ারিং
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          AI ভুলে যায় না &mdash; সে আদতে<br />মনেই রাখেনি কখনো।
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        প্রতিবার তুমি AI-কে একটা মেসেজ পাঠাও, সে তোমার <em>পুরো কথোপকথনটা</em> নতুন করে পড়ে &mdash; তুমি যতগুলো মেসেজ পাঠিয়েছ, সে যতগুলো উত্তর দিয়েছে &mdash; একটা রিপ্লাই তৈরি করে, তারপর সব ভুলে যায়। পরের পালায়, একই ব্যাপার। পুরো ট্রান্সক্রিপ্ট আবার ফিড হয়। সে পৃথিবীর সবচেয়ে পরিশ্রমী কিন্তু স্মৃতিভ্রষ্ট পাঠকের মতো: প্রতিবার সম্পূর্ণ মনোযোগী, প্রতিটা পালার শুরুতে একদম শূন্য থেকে।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONCEPT SETUP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        উইন্ডোর সীমানা আছে
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10" style="margin-top: 0;">
        সেই ট্রান্সক্রিপ্ট যা AI প্রতি পালায় নতুন করে পড়ে? সেটা থাকে <strong>কনটেক্সট উইন্ডো</strong> নামে কিছুর মধ্যে &mdash; যা মাপা হয় <strong>টোকেনে</strong> (মোটামুটি একটা টোকেন মানে একটা শব্দের তিন-চতুর্থাংশ)। Claude-এর উইন্ডো প্রায় ২,০০,০০০ টোকেন ধরে &mdash; মোটামুটি ৫০০ পাতার একটা বই। শুনতে বিশাল মনে হলেও, তুমি যে প্রতিটা মেসেজ পাঠাও, প্রতিটা উত্তর পাও, আর প্রতিটা লুকানো সিস্টেম নির্দেশনা — সবকিছু একই বাজেট থেকে খরচ হয়। তোমার ভাবনার চেয়ে অনেক দ্রুত ভর্তি হয়ে যায়।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        বাজেট শেষ হয়ে গেলে, সবচেয়ে পুরোনো মেসেজগুলো পাড় থেকে পড়ে যায়। তুমি তোমার খাদ্যাভ্যাসের বিধিনিষেধ তিন নম্বর মেসেজে বলেছিলে? পনের নম্বর মেসেজে AI সেগুলো হয়তো আর দেখতেই পাচ্ছে না। সে অসাবধান হচ্ছে না &mdash; তার সামনে যা নেই সে আক্ষরিক অর্থেই দেখতে পায় না। AI ততটাই ভালো যতটা তথ্য বর্তমানে তার উইন্ডোতে আছে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        এজন্যই সেরা AI ব্যবহারকারীরা শুধু ভালো প্রম্পট লেখে না &mdash; তারা উইন্ডোতে কি <em>ঢোকে</em> সেটা ম্যানেজ করে। চলার পথে সারাংশ করো যাতে গুরুত্বপূর্ণ বিষয়গুলো দৃশ্যমান থাকে। যা গুরুত্বপূর্ণ সেটা আগে রাখো। বিষয় বদলালে নতুন করে শুরু করো। কাঠামোবদ্ধ ফরম্যাট ব্যবহার করো যাতে AI তোমার কনটেক্সট দক্ষভাবে বুঝতে পারে। <strong>কনটেক্সট ইঞ্জিনিয়ারিংই নতুন প্রম্পট ইঞ্জিনিয়ারিং।</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>মূল বিষয়</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          ভালো প্রম্পট লেখা প্রথম ধাপ। AI-এর সামনে কোন তথ্য রাখবে &mdash; আর কিভাবে সেটা কাঠামোবদ্ধ করবে &mdash; এখানেই আসল লেভারেজ। পৃথিবীর সেরা প্রম্পটও ব্যর্থ হয় যদি কনটেক্সট ভুল হয়।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        কনটেক্সট উইন্ডো ভর্তি হতে, উপচে পড়তে, আর ভুলে যেতে দেখো &mdash; রিয়েল টাইমে।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ContextWindowViz client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="অবশেষে বুঝলাম AI কেন কথোপকথনের মাঝে জিনিস 'ভুলে যায়'। এটা মেমরি না — এটা কনটেক্সট উইন্ডো। এই কোর্সটা লাইভ ডেমো দিয়ে এত পরিষ্কারভাবে বোঝায়।" client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        তুমি এখন হোয়াইটবোর্ড দেখতে পাচ্ছো। উইন্ডোর সীমানা অনুভব করতে পারছো। এটা AI-এর সাথে তোমার প্রতিটা কথোপকথন বদলে দেবে।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        এ পর্যন্ত আমরা চ্যাটবট নিয়ে কাজ করেছি। এবার জুম আউট করি &mdash; চ্যাট উইন্ডোর বাইরে শতশত AI টুল আছে, আর এই ল্যান্ডস্কেপ জানা পাল্টে দেয় তুমি কি সম্ভব মনে করো।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Vibe Check" client:visible>
        <VibeCheck client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
