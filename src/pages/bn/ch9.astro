---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import FactOrFabrication from '../../components/widgets/ch9/FactOrFabrication';
import SycophancyTest from '../../components/widgets/ch9/SycophancyTest';

const chapter = chapters[8];
---

<ChapterLayout chapter={chapter} locale="bn">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>৯</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          অধ্যায় নয়
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          AI যখন<br />ভুল করে
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          যে যাচাইয়ের অভ্যাস আলাদা করে<br />অ্যামেচারদের প্রো থেকে।
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        একটা অস্বস্তিকর ব্যাপার বলি: যে AI এইমাত্র তোমাকে একটা নিখুঁত রচনা লিখতে সাহায্য করল, সেই একই AI সমান আত্মবিশ্বাসে বলতে পারে Napoleon Waterloo-র যুদ্ধ জিতেছিলেন। সে দ্বিধা করবে না। আটকাবে না। একটা সম্পূর্ণ বানানো "তথ্য" ঠিক সেই একই কর্তৃত্বপূর্ণ গলায় বলবে যেভাবে বাকি সব কিছু বলে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        AI-এর সাথে কাজ করার মূলে এই প্যারাডক্স: <strong>যে সাবলীলতা একে কাজের করে, সেই সাবলীলতাই একে বিপজ্জনকও করে।</strong> AI জানে না কি সত্য। সে জানে কি সত্য শোনায়। আর এই দুটো খুব, খুব আলাদা জিনিস।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        এই অধ্যায় তোমার BS ডিটেক্টর তৈরি করার জন্য। AI খারাপ বলে না, বরং <em>অন্ধভাবে বিশ্বাস করা</em> খারাপ। যারা AI থেকে সবচেয়ে বেশি পায় তারা ঠিক জানে কখন বিশ্বাস করতে হয় আর কখন যাচাই করতে হয়।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE HALLUCINATION PROBLEM ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        হ্যালুসিনেশন সমস্যা
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI-তে, <strong>হ্যালুসিনেশন</strong> হলো যখন মডেল এমন তথ্য তৈরি করে যা শুনতে বিশ্বাসযোগ্য কিন্তু তথ্যগতভাবে ভুল — বা পুরোটাই বানানো। আর এটা তোমার ধারণার চেয়ে অনেক বেশি ঘটে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: #6B7280;">
        <span class="prompt-block-label" style="color: #6B7280;">উদাহরণ</span>
        <p class="m-0" style="color: var(--color-deep);">
          <strong>তুমি:</strong> "১৯৮৭ সালের উপন্যাস <em>The Sands of Memory</em> কে লিখেছেন?"<br /><br />
          <strong>AI:</strong> "The Sands of Memory (১৯৮৭) লিখেছেন ব্রিটিশ লেখিকা Margaret Thornton। এটি উত্তর-ঔপনিবেশিক পূর্ব আফ্রিকায় ঔপনিবেশবাদ ও পরিচয়ের বিষয়বস্তু অন্বেষণ করে। Thornton এই কাজের জন্য Booker Prize-এ মনোনীত হয়েছিলেন।"
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        বিশ্বাসযোগ্য শোনাচ্ছে, তাই না? একটা নাম আছে, একটা বছর, একটা বিষয়, এমনকি একটা পুরস্কার মনোনয়ন। <strong>কিছুই সত্য না।</strong> বইটার অস্তিত্ব নেই। Margaret Thornton (এই প্রসঙ্গে) অস্তিত্ব নেই। AI সবকিছু বানিয়েছে — আর একটা সত্যিকারের উত্তরের মতো ঠিক একই রকম শোনাচ্ছে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        এটা কেন হয়? কারণ AI মডেল কোনো ডেটাবেস থেকে তথ্য খুঁজে আনে না। তারা <em>পরবর্তী সবচেয়ে সম্ভাব্য টোকেন predict করে</em>। তুমি যখন একটা আসল বইয়ের কথা জিজ্ঞেস করো, ট্রেনিং ডেটার প্যাটার্ন সঠিক তথ্যের দিকে গাইড করে। তুমি যখন এমন কিছু জিজ্ঞেস করো যার অস্তিত্ব নেই, মডেল বলে না "আমি জানি না।" সে তৈরি করে একটা সঠিক উত্তর <em>দেখতে কেমন হতো</em> সেটা।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>মূল বিষয়</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI-এর সত্যের কোনো ধারণা নেই। তার আছে <em>বিশ্বাসযোগ্যতার</em> ধারণা। সে এমন টেক্সট তৈরি করে যা প্যাটার্নে মেলে — সেই টেক্সট বাস্তবের সাথে মেলে কি না সেটা আলাদা ব্যাপার।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONFIDENCE WITHOUT COMPETENCE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        যোগ্যতা ছাড়া আত্মবিশ্বাস
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI হ্যালুসিনেশনের সবচেয়ে কঠিন দিক এটা না যে এগুলো ঘটে। বরং <strong>AI কখনো অনিশ্চয়তার সংকেত দেয় না।</strong> একজন মানুষ যে নিশ্চিত না সে দ্বিধা করবে, সাবধানে বলবে, বলবে "আমার মনে হয়..." বা "আমি নিশ্চিত না, তবে..." AI বানানো তথ্য ঠিক সেই একই পূর্ণ আত্মবিশ্বাসে দেয় যেটা প্রমাণিত তথ্যের জন্য ব্যবহার করে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AI কতটা আত্মবিশ্বাসী শোনাচ্ছে আর কতটা সঠিক — এই দুটোর মধ্যে কোনো সম্পর্ক নেই। একটা ভুল উত্তর আর একটা সঠিক উত্তর বাইরে থেকে দেখতে হুবহু একই।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        এজন্যই "শুনতে ঠিক লাগছে" পরীক্ষাটা মূল্যহীন। তুমি টোন দিয়ে, ডিটেইল দিয়ে, কত নির্দিষ্ট সংখ্যা বা নাম AI অন্তর্ভুক্ত করেছে সেটা দিয়ে সঠিকতা যাচাই করতে পারো না। এসব কিছুই — আর প্রায়ই হয়ও — সম্পূর্ণ বানানো হতে পারে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        এভাবে ভাবো: AI হলো একজন অত্যন্ত বিশ্বাসযোগ্য অভিনেতা যে হাজার হাজার স্ক্রিপ্ট পড়েছে। সে যেকোনো লাইন পারফেক্ট conviction দিয়ে বলতে পারে — কিন্তু conviction মানে জ্ঞান না।
      </p>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO FACT OR FABRICATION -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        তোমার ডিটেক্টর পরীক্ষা করো। AI-এর কোন দাবিগুলো সত্যি আর কোনগুলো বানানো — বুঝতে পারো?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FACT OR FABRICATION ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <FactOrFabrication client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE YES-MAN PROBLEM ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        হ্যাঁ-ম্যান সমস্যা
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        হ্যালুসিনেশনের চেয়ে সূক্ষ্ম আরেকটা সমস্যা আছে: <strong>সাইকোফ্যান্সি।</strong> AI-এর প্রবণতা আছে তোমার সাথে একমত হওয়ার, এমনকি তুমি ভুল হলেও।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        তুমি যদি বলো "Einstein বাতি আবিষ্কার করেছিলেন, তাই না?" — বেশিরভাগ AI মডেল তোমাকে সরাসরি ভুল ধরবে না। বরং, তারা আংশিকভাবে একমত হওয়ার উপায় খুঁজবে — পদার্থবিদ্যার মাধ্যমে Einstein-কে আলোর সাথে সংযুক্ত করবে, তোমার ভুল দাবিটার চারপাশে ঘুরবে, তোমাকে শিক্ষিত না করে আত্মতুষ্ট করবে।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        কেন? কারণ AI মডেলগুলো মানুষের ফিডব্যাকে ট্রেইন করা, আর মানুষ এমন উত্তরে পজিটিভ রেটিং দেয় যা সম্মত আর আত্মতুষ্টিদায়ক। লক্ষ লক্ষ ট্রেনিং উদাহরণে, মডেল শেখে: <em>একমত হলে পুরস্কৃত হয়।</em> তাই সে একমত হয় — যখন করা উচিত না তখনও।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;`}>এটা বিপজ্জনক</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          তুমি যদি AI-কে শুধু তোমার বিদ্যমান বিশ্বাস নিশ্চিত করতে ব্যবহার করো, সে সানন্দে তা করবে। তুমি নিজেকে স্মার্ট মনে করবে কিন্তু আসলে বোকা হচ্ছ। AI-এর সবচেয়ে শক্তিশালী ব্যবহার হলো তোমার অনুমানকে চ্যালেঞ্জ করতে বলা — শক্তিশালী করতে না।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO SYCOPHANCY TEST -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        নিজে দেখো। AI-কে একটা ভুল দাবি খাওয়াও আর দেখো সে পুশব্যাক করে না দমে যায়।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: SYCOPHANCY TEST ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <SycophancyTest client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BUILDING YOUR VERIFICATION HABIT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        যাচাইয়ের অভ্যাস তৈরি করা
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14">
        লক্ষ্য AI-এর সব কথা অবিশ্বাস করা না। লক্ষ্য হলো কিছু স্বয়ংক্রিয় চেক তৈরি করা — একটা যাচাই রিফ্লেক্স — যা AI-জেনারেটেড তথ্যের উপর কাজ করার আগে চালু হয়।
      </p>
    </FadeInBlock>

