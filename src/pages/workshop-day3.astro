      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 1.2rem;
      margin: 0;
      color: var(--color-deep);
      letter-spacing: -0.02em;
    }
    .success-card p {
      font-family: var(--font-body);
      font-size: 0.93rem;
      line-height: 1.5;
      color: var(--color-deep);
