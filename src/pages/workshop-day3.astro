---
export const prerender = true;
import '../styles/global.css';

const slides = [
  'welcome',
  'recap-tools', 'recap-agents', 'recap-extensions',
  'today',
  'break-skills',
  'skills-deep', 'skills-find',
  'skills-anthropic', 'skills-research', 'skills-format',
  'skills-meta', 'skills-creator',
  'break-plan',
  'plan-intro',
  'plan-phase-1', 'plan-phase-2', 'plan-phase-3',
  'plan-success',
  'ramp-case', 'ramp-map',
  'take-home',
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Workshop · Day 3 — Talking to Machines</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Caveat:wght@500;600;700&display=swap" />
  <style>
    /* ══════════════════════════════════════════════════════
       Workshop Day 3 — slide-specific styles
       ══════════════════════════════════════════════════════ */
    body.card-deck-page { background: var(--color-cream); }

    .deck-slide {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 5rem;
      box-sizing: border-box;
    }

    /* Progress rail */
    .progress-rail {
      position: fixed;
      top: 20px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 6px;
      z-index: 50;
      padding: 8px 14px;
      background: rgba(250, 248, 245, 0.75);
      backdrop-filter: blur(10px);
      border-radius: 100px;
      border: 1px solid rgba(26,26,46,0.05);
    }
    .progress-dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: rgba(26,26,46,0.15);
      transition: all 0.3s ease;
    }
    .progress-dot.active {
      background: var(--color-teal);
      width: 16px;
      border-radius: 100px;
    }
    .progress-dot.visited { background: rgba(26,26,46,0.35); }

    /* Slide number */
    .slide-num {
      position: absolute;
      bottom: 28px;
      right: 40px;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      color: var(--color-subtle);
      opacity: 0.5;
    }

    /* Keyboard hint */
    .kbd-hint {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-subtle);
      opacity: 0.55;
      z-index: 50;
      transition: opacity 0.5s ease;
      pointer-events: none;
    }
    .kbd-hint.hidden { opacity: 0; }
    .kbd-hint kbd {
      font-family: var(--font-mono);
      background: rgba(26,26,46,0.06);
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 0.7rem;
      margin: 0 2px;
    }

    /* Staggered entrance */
    .stagger > * {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1);
    }
    .deck-slide.is-active .stagger > * { opacity: 1; transform: translateY(0); }
    .deck-slide.is-active .stagger > *:nth-child(1) { transition-delay: 0.1s; }
    .deck-slide.is-active .stagger > *:nth-child(2) { transition-delay: 0.2s; }
    .deck-slide.is-active .stagger > *:nth-child(3) { transition-delay: 0.3s; }
    .deck-slide.is-active .stagger > *:nth-child(4) { transition-delay: 0.4s; }
    .deck-slide.is-active .stagger > *:nth-child(5) { transition-delay: 0.5s; }
    .deck-slide.is-active .stagger > *:nth-child(6) { transition-delay: 0.6s; }

    /* Print / export */
    @media print {
      @page { size: 1600px 900px; margin: 0; }
      html, body { background: var(--color-cream) !important; width: 1600px !important; height: auto !important; }
      .progress-rail, .kbd-hint { display: none !important; }
      .card-deck-container { height: auto !important; max-height: none !important; overflow: visible !important; scroll-snap-type: none !important; }
      .card-deck-card, .deck-slide { width: 1600px !important; height: 900px !important; scroll-snap-align: none !important; page-break-after: always !important; break-after: page !important; overflow: hidden !important; }
      .card-deck-card:last-child, .deck-slide:last-child { page-break-after: auto !important; break-after: auto !important; }
      .stagger > * { opacity: 1 !important; transform: none !important; transition: none !important; }
      * { animation: none !important; }

      [data-slide="break-skills"],
      [data-slide="break-plan"] { display: none !important; }

      .recap-tools-grid { grid-template-columns: repeat(4, 1fr) !important; }
      .recap-agents-grid { grid-template-columns: repeat(3, 1fr) !important; }
      .recap-ext-grid { grid-template-columns: repeat(2, 1fr) !important; }
      .today-grid { grid-template-columns: repeat(3, 1fr) !important; }
      .sk-find-grid { grid-template-columns: repeat(3, 1fr) !important; }
      .sk-cards { grid-template-columns: repeat(3, 1fr) !important; }
      .meta-grid { grid-template-columns: repeat(3, 1fr) !important; }
      .success-grid { grid-template-columns: repeat(2, 1fr) !important; }
      .week-grid.cols4 { grid-template-columns: repeat(4, 1fr) !important; }
      .week-grid.cols5 { grid-template-columns: repeat(5, 1fr) !important; }
      .ramp-body { grid-template-columns: 1fr 1.1fr !important; }
      .rampmap-row { grid-template-columns: 1fr 60px 1fr !important; }
      .takehome-layout { grid-template-columns: 1.1fr 1fr !important; }
    }

    /* Utilities */
    .caveat { font-family: 'Caveat', cursive; font-weight: 600; }
    .mono-label {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-subtle);
    }

    /* ══════════════════════════════════════════════════════
       WELCOME — Day Three wordmark
       ══════════════════════════════════════════════════════ */
    .slide-welcome {
      align-items: center;
      justify-content: center;
      text-align: center;
    }
    .slide-welcome .eyebrow {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--color-subtle);
      margin-bottom: 1.5rem;
    }
    .slide-welcome .wordmark {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(5rem, 13vw, 11rem);
      line-height: 1.05;
      letter-spacing: -0.04em;
      margin: 0;
    }
    .slide-welcome .wordmark .day {
      display: block;
      color: var(--color-deep);
      font-style: italic;
      font-weight: 500;
    }
    .slide-welcome .wordmark .three {
      display: block;
      color: var(--color-teal);
    }
    .slide-welcome .tagline {
      font-family: var(--font-body);
      font-style: italic;
      font-size: 1.3rem;
      color: var(--color-subtle);
      margin-top: 2rem;
    }
    .slide-welcome .tagline strong { color: var(--color-teal); font-weight: 600; font-style: normal; }

    /* ══════════════════════════════════════════════════════
       RECAP slides (3 x "Day 2 in one frame")
       ══════════════════════════════════════════════════════ */
    .slide-recap { justify-content: center; padding: 3rem 4rem; }
    .recap-content { max-width: 1320px; margin: 0 auto; width: 100%; }
    .recap-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 1.75rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid rgba(26,26,46,0.08);
    }
    .recap-head .kicker {
      font-family: 'Caveat', cursive;
      font-size: 1.5rem;
      color: var(--color-purple);
      transform: rotate(-1deg);
      display: inline-block;
    }
    .recap-head h1 {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.25rem, 4.5vw, 3.25rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0.3rem 0 0;
    }
    .recap-head h1 em { font-style: italic; color: var(--color-purple); }
    .recap-sub {
      font-family: var(--font-body);
      font-style: italic;
      color: var(--color-subtle);
      font-size: 1rem;
      align-self: center;
    }

    /* Recap 1 — tools / models */
    .recap-tools-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }
    .rt-col {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.08);
      border-top: 3px solid currentColor;
      border-radius: 12px;
      padding: 1.2rem 1.15rem;
      display: flex;
      flex-direction: column;
    }
    .rt-col.big3 { color: var(--color-purple); }
    .rt-col.china { color: var(--color-accent-red); }
    .rt-col.local { color: var(--color-teal); }
    .rt-col.map { color: var(--color-amber); }
    .rt-col .rt-label {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: currentColor;
      margin-bottom: 0.4rem;
    }
    .rt-col h3 {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 1.2rem;
      margin: 0 0 0.75rem;
      color: var(--color-deep);
      letter-spacing: -0.02em;
      line-height: 1.2;
    }
    .rt-col h3 em { font-style: italic; color: currentColor; }
    .rt-col ul {
      list-style: none;
      padding: 0;
      margin: 0 0 0.75rem;
    }
    .rt-col li {
      font-family: var(--font-body);
      font-size: 0.88rem;
      line-height: 1.45;
      padding: 0.2rem 0 0.2rem 0.95rem;
      position: relative;
      color: var(--color-deep);
    }
    .rt-col li::before {
      content: '·';
      position: absolute;
      left: 0;
      font-weight: 700;
      color: currentColor;
      font-size: 1.3rem;
      line-height: 1;
      top: 0.1rem;
    }
    .rt-col .rt-takeaway {
      margin-top: auto;
      padding-top: 0.7rem;
      border-top: 1px dashed rgba(26,26,46,0.1);
      font-family: var(--font-body);
      font-style: italic;
      font-size: 0.8rem;
      color: var(--color-subtle);
      line-height: 1.4;
    }

    /* Recap 2 — agents */
    .recap-agents-layout {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: 2.5rem;
      align-items: center;
    }
    .recap-agents-left h2 {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2rem, 3.8vw, 2.75rem);
      letter-spacing: -0.03em;
      line-height: 1.1;
      margin: 0 0 1.25rem;
      color: var(--color-deep);
    }
    .recap-agents-left h2 em { font-style: italic; color: var(--color-accent-red); }
    .recap-agents-formula {
      font-family: var(--font-heading);
      font-weight: 700;
      font-style: italic;
      font-size: 1.15rem;
      color: var(--color-navy);
      margin: 0 0 1.5rem;
      letter-spacing: -0.01em;
    }
    .recap-agents-formula .plus { color: var(--color-subtle); font-style: normal; margin: 0 0.4rem; }
    .recap-agents-left p {
      font-family: var(--font-body);
      font-size: 1.05rem;
      line-height: 1.6;
      color: var(--color-deep);
      margin: 0 0 0.75rem;
      max-width: none;
    }
    .recap-agents-left p em { color: var(--color-navy); font-weight: 600; }
    .recap-agents-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.7rem;
    }
    .recap-agents-pill {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.08);
      border-radius: 10px;
      padding: 0.7rem 0.85rem;
    }
    .recap-agents-pill .k {
      font-family: var(--font-mono);
      font-size: 0.58rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-subtle);
      margin-bottom: 2px;
    }
    .recap-agents-pill .v {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 1rem;
      color: var(--color-deep);
      letter-spacing: -0.01em;
    }
    .recap-agents-pill.cli { border-top: 3px solid var(--color-purple); }
    .recap-agents-pill.mcp { border-top: 3px solid var(--color-teal); }
    .recap-agents-pill.api { border-top: 3px solid var(--color-navy); }
    .recap-agents-bighit {
      margin-top: 1.5rem;
      padding: 1.1rem 1.25rem;
      background: linear-gradient(135deg, rgba(233,69,96,0.06), rgba(123,97,255,0.06));
      border: 1px dashed rgba(233,69,96,0.3);
      border-radius: 12px;
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 1.15rem;
      color: var(--color-deep);
      letter-spacing: -0.01em;
      line-height: 1.3;
    }
    .recap-agents-bighit em { color: var(--color-accent-red); font-style: italic; }

    /* Recap 3 — extensions */
    .recap-ext-layout {
      display: grid;
      grid-template-columns: 1fr 1.1fr;
      gap: 2.5rem;
      align-items: start;
    }
    .recap-ext-left h2 {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(1.6rem, 2.8vw, 2.1rem);
      letter-spacing: -0.02em;
      line-height: 1.2;
      margin: 0 0 1rem;
    }
    .recap-ext-left h2 em { font-style: italic; color: var(--color-teal); }
    .recap-ext-left p.lead {
      font-family: var(--font-body);
      font-size: 1rem;
      line-height: 1.6;
      color: var(--color-deep);
      margin: 0 0 1rem;
    }
    .recap-ext-left p.lead em { color: var(--color-navy); font-weight: 600; }
    .recap-ext-criteria {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .recap-ext-criteria li {
      display: flex;
      gap: 0.85rem;
      padding: 0.65rem 0;
      border-bottom: 1px solid rgba(26,26,46,0.06);
    }
    .recap-ext-criteria li:last-child { border-bottom: none; }
    .recap-ext-criteria .ch {
      flex-shrink: 0;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--color-teal);
      color: var(--color-warm-white);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 0.8rem;
    }
    .recap-ext-criteria .t {
      font-family: var(--font-body);
      font-size: 0.95rem;
      line-height: 1.45;
      color: var(--color-deep);
    }
    .recap-ext-criteria .t strong { font-weight: 700; color: var(--color-navy); }
    .recap-ext-right .rex-head {
      font-family: 'Caveat', cursive;
      font-size: 1.35rem;
      color: var(--color-teal);
      transform: rotate(-1deg);
      display: inline-block;
      margin-bottom: 0.5rem;
    }
    .recap-ext-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.65rem;
    }
    .rex-card {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.08);
      border-left: 3px solid var(--color-teal);
      border-radius: 8px;
      padding: 0.65rem 0.85rem;
    }
    .rex-card .rex-num {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      color: var(--color-subtle);
    }
    .rex-card .rex-name {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 0.95rem;
      color: var(--color-deep);
      letter-spacing: -0.01em;
      margin-top: 2px;
    }
    .rex-card .rex-who {
      font-family: var(--font-body);
      font-style: italic;
      font-size: 0.78rem;
      color: var(--color-subtle);
      margin-top: 2px;
    }

    /* ══════════════════════════════════════════════════════
       TODAY — three-beat agenda
       ══════════════════════════════════════════════════════ */
    .slide-today { justify-content: center; }
    .today-content { max-width: 1100px; margin: 0 auto; width: 100%; }
    .today-head { margin-bottom: 2.5rem; text-align: center; }
    .today-head h1 {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 5vw, 3.75rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0.5rem 0 0.5rem;
    }
    .today-head h1 em { font-style: italic; color: var(--color-teal); }
    .today-head .sub {
      font-family: var(--font-body);
      font-style: italic;
      color: var(--color-subtle);
      font-size: 1.15rem;
    }
    .today-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    .today-card {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.08);
      border-radius: 14px;
      padding: 2rem 1.75rem;
      position: relative;
      overflow: hidden;
    }
    .today-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
    }
    .today-card.a::before { background: var(--color-teal); }
    .today-card.b::before { background: var(--color-amber); }
    .today-card.c::before { background: var(--color-accent-red); }
    .today-num {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-subtle);
      margin-bottom: 0.75rem;
    }
    .today-card h3 {
      font-family: var(--font-heading);
      font-size: 1.6rem;
      font-weight: 800;
      margin: 0 0 0.6rem;
      letter-spacing: -0.02em;
    }
    .today-card.a h3 { color: var(--color-teal); }
    .today-card.b h3 { color: var(--color-amber); }
    .today-card.c h3 { color: var(--color-accent-red); }
    .today-card p {
      font-family: var(--font-body);
      font-size: 1rem;
      line-height: 1.55;
      color: var(--color-deep);
      margin: 0;
    }

    /* ══════════════════════════════════════════════════════
       BREAK slides
       ══════════════════════════════════════════════════════ */
    .slide-break { justify-content: center; align-items: center; text-align: center; }
    .break-label {
      font-family: 'Caveat', cursive;
      font-weight: 600;
      font-size: 1.75rem;
      color: var(--color-teal);
      transform: rotate(-2deg);
      display: inline-block;
      margin-bottom: 0.5rem;
    }
    .break-title {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(4rem, 10vw, 8rem);
      letter-spacing: -0.04em;
      line-height: 0.95;
      margin: 0;
      font-style: italic;
    }
    .break-title .period { color: var(--color-teal); font-style: normal; }
    .break-under {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-subtle);
      margin-top: 2rem;
    }
    .slide-break.break-plan .break-label { color: var(--color-accent-red); }
    .slide-break.break-plan .break-title .period { color: var(--color-accent-red); }

    /* ══════════════════════════════════════════════════════
       SKILLS DEEP — what is a skill, really
       ══════════════════════════════════════════════════════ */
    .slide-skills-deep { justify-content: center; padding: 3rem 4rem; }
    .sd-content { max-width: 1180px; margin: 0 auto; width: 100%; }
    .sd-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-subtle);
      margin-bottom: 0.5rem;
    }
    .sd-title {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2.5rem, 5vw, 3.75rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0 0 1rem;
    }
    .sd-title em { font-style: italic; color: var(--color-teal); }
    .sd-definition {
      display: inline-flex;
      align-items: baseline;
      gap: 0.75rem;
      padding: 0.6rem 1rem;
      background: rgba(22,199,154,0.08);
      border: 1px dashed rgba(22,199,154,0.3);
      border-radius: 10px;
      margin: 0 0 1.5rem;
      font-family: var(--font-body);
      font-size: 1.05rem;
      color: var(--color-deep);
    }
    .sd-definition .eq {
      font-family: 'Caveat', cursive;
      font-size: 1.5rem;
      color: var(--color-teal);
      font-weight: 700;
      line-height: 1;
    }
    .sd-definition strong {
      color: var(--color-teal);
      font-weight: 700;
    }
    .sd-definition em {
      font-style: italic;
      color: var(--color-navy);
    }
    .sd-lead {
      font-family: var(--font-body);
      font-size: 1.25rem;
      line-height: 1.55;
      color: var(--color-deep);
      margin: 0 0 1.5rem;
      max-width: 62ch;
    }
    .sd-lead em { color: var(--color-navy); font-weight: 600; }
