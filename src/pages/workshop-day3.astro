    /* ══════════════════════════════════════════════════════
       SKILL CREATOR — the meta meta
       ══════════════════════════════════════════════════════ */
    .slide-sk-creator { justify-content: center; padding: 3rem 4rem; }
    .skc-content { max-width: 1100px; margin: 0 auto; width: 100%; }
    .skc-solo { max-width: 780px; margin: 0 auto; }
    .skc-layout {
      display: grid;
      grid-template-columns: 1fr 0.9fr;
      gap: 2.5rem;
      align-items: center;
    }
    .skc-eyebrow {
      font-family: 'Caveat', cursive;
      font-size: 1.7rem;
