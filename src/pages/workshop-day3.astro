      height: 3px;
    }
    .plan-arc-stop.a::before { background: var(--color-sky); }
    .plan-arc-stop.b::before { background: var(--color-accent-red); }
    .plan-arc-stop.c::before { background: var(--color-amber); }
    .plan-arc-stop .range {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-subtle);
      margin-bottom: 0.45rem;
    }
    .plan-arc-stop h4 {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 1.35rem;
      margin: 0 0 0.35rem;
      letter-spacing: -0.02em;
    }
    .plan-arc-stop.a h4 { color: var(--color-sky); }
    .plan-arc-stop.b h4 { color: var(--color-accent-red); }
    .plan-arc-stop.c h4 { color: var(--color-amber); }
    .plan-arc-stop p {
      font-family: var(--font-body);
      font-size: 0.9rem;
      line-height: 1.5;
      color: var(--color-deep);
      margin: 0;
    }

    /* ══════════════════════════════════════════════════════
       SUCCESS — how do you know the plan is working
       ══════════════════════════════════════════════════════ */
    .slide-success { justify-content: center; padding: 3rem 4rem; }
