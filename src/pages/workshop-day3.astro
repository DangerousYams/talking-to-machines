      color: var(--color-warm-white);
      white-space: pre-wrap;
      word-wrap: break-word;
    }
    .skc-steps {
      list-style: none;
      padding: 0;
      margin: 1.25rem 0 0;
      counter-reset: skc;
    }
    .skc-steps li {
      counter-increment: skc;
      font-family: var(--font-body);
      font-size: 0.98rem;
      line-height: 1.5;
      color: var(--color-deep);
      padding: 0.4rem 0 0.4rem 2.25rem;
      position: relative;
    }
    .skc-steps li::before {
      content: counter(skc);
      position: absolute;
      left: 0;
      top: 0.4rem;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--color-accent-red);
      color: var(--color-warm-white);
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 0.75rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .skc-steps li strong { color: var(--color-navy); font-weight: 700; }

    /* ══════════════════════════════════════════════════════
       PLAN INTRO
       ══════════════════════════════════════════════════════ */
    .slide-plan-intro { justify-content: center; padding: 3rem 4rem; }
    .plan-intro-content { max-width: 1080px; margin: 0 auto; width: 100%; text-align: center; }
    .plan-intro-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--color-subtle);
    }
    .plan-intro-title {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(3rem, 6.5vw, 5rem);
      letter-spacing: -0.03em;
      line-height: 1;
      margin: 1rem 0 1.25rem;
    }
    .plan-intro-title em { font-style: italic; color: var(--color-accent-red); }
    .plan-intro-lead {
      font-family: var(--font-body);
      font-size: 1.3rem;
      line-height: 1.55;
      color: var(--color-deep);
      max-width: 58ch;
      margin: 0 auto 2rem;
    }
    .plan-intro-lead em { color: var(--color-navy); font-weight: 600; }
    .plan-arc {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-top: 1rem;
    }
    .plan-arc-stop {
      background: var(--color-warm-white);
      border: 1px solid rgba(26,26,46,0.08);
      border-radius: 12px;
      padding: 1.25rem 1rem;
