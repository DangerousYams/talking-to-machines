    .skc-copy-btn {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--color-warm-white);
      background: var(--color-accent-red);
      border: none;
      padding: 5px 14px;
      border-radius: 5px;
      cursor: pointer;
      font-weight: 700;
      transition: background 0.15s ease, transform 0.1s ease;
      position: relative;
    }
    .skc-copy-btn:hover { transform: translateY(-1px); }
    .skc-copy-btn:active { transform: translateY(0); }
    .skc-copy-btn .skc-copy-done { display: none; }
    .skc-copy-btn.copied { background: var(--color-teal); }
    .skc-copy-btn.copied .skc-copy-default { display: none; }
    .skc-copy-btn.copied .skc-copy-done { display: inline; }
    .skc-prompt-box {
      margin: 0;
      padding: 1.1rem 1.25rem;
      font-family: var(--font-mono);
      font-size: 0.85rem;
