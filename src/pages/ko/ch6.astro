---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import AgentBlueprint from '../../components/widgets/ch6/AgentBlueprint';
import FailureModesLab from '../../components/widgets/ch6/FailureModesLab';
import HandoffChain from '../../components/widgets/ch6/HandoffChain';

const chapter = chapters[5];
---

<ChapterLayout chapter={chapter} locale="ko">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>6</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          6장
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          에이전트<br />만들기
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          AI 에이전트를 처음부터<br />설계하고, 연결하고, 배포해.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        챗봇은 네가 말할 때까지 기다려. 에이전트는 안 기다려. 목표를 줘 — "화성 식민지화를 조사하고 보고서를 써줘" — 그러면 일을 단계별로 나누고, 맞는 도구를 고르고, 하나씩 실행하고, 자기 결과를 확인하고, 일이 끝날 때까지 계속 가. 손잡아줄 필요 없어.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        <em>지시에 반응하는 것</em>과 <em>목표를 추구하는 것</em>의 차이 — 그게 계산기와 동료의 차이야. 챗봇은 질문에 답해. 에이전트는 문제를 풀어.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        이 챕터는 에이전트가 내부에서 실제로 어떻게 작동하는지에 대한 거야 — 구동하는 루프, 신뢰성 있게 만드는 아키텍처, 그리고 부주의하게 만들면 위험해지는 실패 모드.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE AGENT LOOP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        에이전트 루프
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        챕터 5에서 기본적인 tool-use 루프를 봤어: 관찰, 생각, 행동. 에이전트는 이걸 더 야심 차게 확장해 — 다섯 단계 사이클, 각각 다른 내부 컴포넌트가 구동하는:
      </p>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { letter: 'G', word: '목표', color: '#E94560', desc: '사람으로부터 높은 수준의 목표를 받아. 명확한 목표 없이는 에이전트가 끝났는지 판단할 방법이 없어. "화성 조사"는 목표가 아냐. "출처 포함 화성 식민지화 과제에 대한 500단어 요약 작성"이 목표야.' },
        { letter: 'P', word: '계획', color: '#7B61FF', desc: '목표를 구체적인 단계로 나눠. 최고의 계획자는 한 단계가 실패해도 적응할 수 있는 유연한 계획을 만들어. 안 좋은 계획자는 첫 번째 예상 밖 상황에서 깨지는 경직된 스크립트를 만들어.' },
        { letter: 'T', word: '실행', color: '#0EA5E9', desc: '각 단계를 맞는 도구로 실행해 — 검색 엔진, 코드 인터프리터, 파일 리더, API, 계산기. 에이전트는 생각만 하는 게 아냐. 행동해.' },
        { letter: 'M', word: '관찰', color: '#16C79A', desc: '뭐가 일어났는지 기록하고 결과를 확인해. 자기가 뭘 했고 뭘 찾았는지에 대한 기억 없이, 루프 안의 에이전트는 같은 실패 행동을 영원히 반복할 수 있어.' },
        { letter: 'E', word: '평가', color: '#F5A623', desc: '이게 됐어? 이 데이터 믿을 만해? 목표에 더 가까워졌어? 평가자가 에이전트를 그냥 돌리고 잘 되길 바라는 스크립트에서 분리시켜줘. 뭔가 이상하면 계획을 조정하고 다시 루프.' },
      ].map((step, i) => (
        <FadeInBlock client:visible delay={i * 0.08}>
          <div style={`display: flex; gap: 1.25rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1rem; font-weight: 800; color: white; background: ${step.color};`}>
              {step.letter}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.05rem; font-weight: 700; color: ${step.color}; margin: 0 0 0.3rem; line-height: 1.3;`}>
                {step.word}
              </p>
              <p style="font-size: 0.95rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {step.desc}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <p class="text-lg leading-[1.85] mb-10">
        핵심 단어는 <em>루프</em>야. 에이전트는 한 번 계획하고 맹목적으로 실행하지 않아. 계획하고, 행동하고, 관찰하고, 평가하고, 조정해. 최고의 에이전트는 3단계에서 꼬였을 때 우아하게 복구하는 녀석들이야.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.55}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        챗봇은 한 번의 턴이야. 에이전트는 하나의 완전한 대화야 — 자기 자신, 도구, 그리고 세계와의.
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO AGENT BLUEPRINT -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        만들 차례야. 처음부터 네 에이전트를 설계해봐.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: AGENT BLUEPRINT ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <AgentBlueprint client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ WHEN AGENTS FAIL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        에이전트가 실패할 때
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        에이전트는 챗봇과 다르게 실패해. 챗봇은 나쁜 답을 주고 기다려. 에이전트는 자기한테 나쁜 답을 주고, <em>그걸 바탕으로 행동하고</em>, 그 깨진 결과로 다음 결정을 내려. 실패가 복합적이야.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        에이전트가 꼬이는 세 가지 전형적인 방식이 있어:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>실패 모드 1: 무한 루프</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          에이전트가 같은 행동을 반복하면서 갇혀. 리서치 에이전트가 "한 가지 소스만 더" 찾으면서 절대 글을 쓰기 시작 안 해. 정지 조건 없이는 네가 중단하거나 API 크레딧이 다 떨어질 때까지 돌아.
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="prompt-block mb-10" style={`--accent: #7B61FF;`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:#7B61FF;`}></div>
        <span class="prompt-block-label" style="color: #7B61FF;">실패 모드 2: 잘못된 도구</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          에이전트가 그 일을 할 수 없는 도구를 선택해. 하드 드라이브에 있는 파일을 웹 검색으로 찾으려고 하거나, 에세이를 요약하려고 계산기를 호출하거나. 에이전트가 멍청한 게 아냐 — 도구가 맞는지 확인하지 않고 도구상자에서 골랐을 뿐이야.
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="prompt-block mb-10" style={`--accent: #F5A623;`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:#F5A623;`}></div>
        <span class="prompt-block-label" style="color: #F5A623;">실패 모드 3: 환각 행동</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          에이전트가 존재하지 않는 도구나 API를 만들어내고, 가짜 결과로 "호출"해. 가짜 호출이 실패하면, 가끔 가져왔어야 할 데이터를 날조하기도 해. 이중 환각: 가짜 도구, 가짜 출력.
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        해결책은 항상 같은 원칙이야: <strong>불행한 경로를 설계해.</strong> 최대 반복 횟수, 도구 유효성 검사, 출력 검증, 사람 체크포인트. 목표는 모든 실패를 막는 게 아냐 — 실패를 복구 가능하게 만드는 거야.
      </p>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO FAILURE MODES LAB -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        고장 난 에이전트를 진단할 수 있어? 버그를 찾고 가드레일을 추가해봐.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FAILURE MODES LAB ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <FailureModesLab client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE POWER OF MANY ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        다수의 힘
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        에이전트 하나도 유용해. 여러 에이전트가 함께 일하면, 어떤 단일 시스템도 감당 못할 문제를 해결할 수 있어. 비결은 전문화야.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        뉴스룸처럼 생각해봐. 같은 사람한테 기사를 취재하고, 글을 쓰고, 편집까지 하라고 하지 않잖아. 각 역할에는 다른 마인드셋, 다른 도구, 다른 기준이 필요해.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        멀티 에이전트 시스템도 같은 방식이야. <strong>리서처</strong> 에이전트가 정보를 수집해. <strong>라이터</strong> 에이전트가 메모를 다듬은 글로 바꿔. <strong>에디터</strong> 에이전트가 검토하고, 팩트체크하고, 개선점을 제안해. 각 에이전트가 자기만의 system prompt, 도구, 성공 기준을 가져.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        멀티 에이전트 설계에서 핵심 질문은 "각 에이전트가 얼마나 똑똑해?"가 아냐. <strong>"인수인계가 얼마나 잘 돼?"</strong>야. 리서처가 라이터한테 메모를 넘길 때, 그 메모가 명확하게 구조화돼 있어? 라이터가 에디터한테 초안을 넘길 때, 에디터가 유용한 피드백을 줄 수 있을 만큼 맥락이 충분해?
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>핵심 인사이트</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          인수인계 문서가 멀티 에이전트 시스템에서 가장 중요한 산출물이야. 뛰어난 라이터도 엉성한 리서치 메모를 구할 수 없어. 에이전트 사이의 인터페이스에서 품질이 결정 돼.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO HANDOFF CHAIN -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        세 에이전트가 협업하는 걸 봐. 인수인계 문서에 주목해 &mdash; 거기서 마법이 일어나거든.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: HANDOFF CHAIN ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <HandoffChain client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ HUMAN IN THE LOOP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        루프 안의 사람
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        챕터 5에서 신뢰 프레임워크를 배웠어: 위험도, 되돌림 가능성, 신뢰가 얼마나 많은 자율성을 줄지 결정한다고. 에이전트에서는 이게 더 중요해져 — 에이전트는 질문에 답하기만 하는 게 아니거든. <em>행동을 취하고</em>, 연결하고, 방치하면 실수를 복합적으로 만들어.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85]">
        최고의 에이전트 빌더는 자율성을 최대화하는 사람이 아냐. <strong>사려 깊은 체크포인트</strong>를 설계하는 사람이야 — 에이전트가 멈추고, 작업을 보여주고, 사람이 계속할지 결정하게 하는 순간. 좋은 에이전트는 언제 물어야 하는지 알아.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CLOSING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
