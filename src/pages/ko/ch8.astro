---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import ProjectOrchestrator from '../../components/widgets/ch8/ProjectOrchestrator';
import ContextPacking from '../../components/widgets/ch8/ContextPacking';

const chapter = chapters[7];
---

<ChapterLayout chapter={chapter} locale="ko">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>8</div>
    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">8장</p>
      </FadeInBlock>
      <FadeInBlock client:visible delay={0.15}>
        <h1 class="mb-8 leading-[1.08]" style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}>
          복잡성<br />오케스트레이션
        </h1>
      </FadeInBlock>
      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          어떤 context window보다 큰<br />프로젝트에서 AI 관리하기.
        </p>
      </FadeInBlock>
    </div>
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse"><div class="w-px h-10 bg-deep/40"></div></div>
  </section>

  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        모든 야심 찬 초보가 부딪히는 순간이 있어: AI한테 진짜 뭔가를 만들어달라고 해 — 완전한 게임, 백엔드 있는 웹사이트, 인용 포함 연구 논문 — 그리고 전부 무너져. AI가 충분히 똑똑하지 않아서가 아냐. 프로젝트가 하나의 대화에 비해 너무 큰 거야.
      </p>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        요구사항 벽을 붙여넣으면, AI가 자신 있는 답을 주고, 20분 뒤에 요청한 것의 반을 까먹고, 아키텍처에서 자기 모순을 일으키고, 존재하지 않는 라이브러리를 환각했다는 걸 깨달아. 다시 시도해. 같은 결과, 다른 환각.
      </p>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        이건 AI 문제가 아냐. <strong>오케스트레이션 문제</strong>야. 이걸 푸는 법을 배우는 게 AI를 일회성 작업에 쓰는 사람과 진짜 뭔가를 만드는 사람의 차이야.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">한 방 Prompt의 함정</h2>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">AI를 처음 배우면, 자연스럽게 모든 걸 한 번에 하려고 해. 거대한 prompt 하나. 대화 하나. 시도 하나. 간단한 작업 — 이메일 쓰기, 아이디어 브레인스토밍, 개념 설명 — 에는 잘 돼.</p>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">근데 복잡성이 한 방 접근법을 세 가지로 깨뜨려:</p>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.2}>
      <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 2.5rem;">
        {[
          { num: '1', title: 'Context 오버플로우', text: 'AI가 한 번에 담을 수 있는 정보에 한계가 있어. 전체 프로젝트는 그 한계를 넘어서, AI가 이전 요구사항을 "까먹기" 시작해.' },
          { num: '2', title: '주의력 분산', text: 'Context window 안에서도 열두 가지를 동시에 저글링하라고 하면 각각에 쏠리는 집중이 줄어. 전반적으로 품질이 떨어져.' },
          { num: '3', title: '에러 복합', text: '복잡한 결과물에서 작은 실수 하나가 눈덩이가 돼. AI가 DB 스키마를 잘못 잡으면, 그 위에 지은 모든 게 잘못돼 — 그리고 생성된 코드 벽 깊숙이서 발견하기 어려워.' },
        ].map((item, i) => (
          <FadeInBlock client:visible delay={0.2 + i * 0.08}>
            <div style="display: flex; gap: 1.25rem; align-items: flex-start;">
              <div style={`flex-shrink: 0; width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 0.8rem; font-weight: 700; color: white; background: ${chapter.accent};`}>{item.num}</div>
              <div style="flex: 1;">
                <p style={`font-family: var(--font-heading); font-size: 1rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.3rem; line-height: 1.3;`}>{item.title}</p>
                <p style="font-size: 0.95rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">{item.text}</p>
              </div>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.5}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>해결책은 더 나은 prompt가 아냐. 더 나은 프로세스야.</div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">분해: 마스터 스킬</h2>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">프로 소프트웨어 엔지니어는 전체 앱을 한 번에 만들지 않아. 조각으로 나눠 — 모듈, 컴포넌트, 함수 — 각각 명확한 목적, 입력, 출력이 있게. 그다음 조립해.</p>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">복잡한 프로젝트에서 AI와 일할 때도 같은 규율이 필요해. 프로젝트를 하나의 집중된 AI 대화가 잘 처리할 수 있을 만큼 작은 작업으로 <strong>분해</strong>해야 해.</p>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">좋은 분해는 세 가지 규칙을 따라:</p>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.25}>
      <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
        <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
        {[
          { word: '단일 책임.', desc: '각 작업은 하나만 해. "DB를 설계하고 API를 만들고 프론트엔드를 짜라"는 하나가 아니라 세 개의 작업이야.' },
          { word: '명확한 인터페이스.', desc: '모든 작업에 정의된 입력(시작에 필요한 것)과 출력(만들어내는 것)이 있어. 한 작업의 출력이 다음의 입력이 되는 거야.' },
          { word: '최소 의존성.', desc: '병렬로 할 수 있는 작업은 해. 한 작업이 진짜로 다른 작업의 출력이 필요할 때만 의존성을 만들어.' },
        ].map((step, i) => (
          <div style={`position: relative; padding-bottom: ${i < 2 ? '1.75rem' : '0'};`}>
            <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
            <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
              <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
              <span style="opacity: 0.7;"> {step.desc}</span>
            </p>
          </div>
        ))}
      </div>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>분해는 사람의 스킬이야, AI 스킬이 아냐.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">AI가 작업 분해를 브레인스토밍하는 건 도와줄 수 있어. 근데 일을 어떻게 나눌지, 뭐가 뭐에 의존하는지, 뭘 우선시할지 결정하는 건 네 일이야. 프로젝트 관리고, 네가 키울 수 있는 가장 가치 있는 스킬 중 하나야.</p>
      </div>
    </FadeInBlock>
  </section>

  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">실제 프로젝트를 분해해봐. 작업을 드래그하고, 의존성을 추적하고, 계획이 만들어지는 걸 봐.</p>
    </FadeInBlock>
  </section>

  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible><ProjectOrchestrator client:visible /></FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">인수인계 패턴</h2>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">프로젝트를 작업으로 나눴으면, 연결할 방법이 필요해. AI 워크플로우에서 이 연결이 <strong>인수인계</strong>야 — 한 대화의 출력이 다음의 입력이 되는 순간.</p>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: var(--color-navy);">
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>인수인계 패턴</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          대화 1이 <strong>산출물</strong>을 만들어 — 문서, 스키마, 계획.<br />
          그 산출물이 대화 2에 <strong>context</strong>로 붙여넣어져.<br />
          대화 2가 그 위에 쌓아서 다음 산출물을 만들어.<br />
          프로젝트가 완성될 때까지 반복.
        </p>
      </div>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">릴레이 경주라고 생각해. 각 주자(대화)가 자기 구간을 뛰고 바통(산출물)을 다음한테 넘겨. 바통이 핵심이야 — 떨어뜨리거나 엉키면, 다음 주자가 비틀거려.</p>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">인수인계 산출물이 <em>선명해야</em> 한다는 뜻이야. DB 스키마가 데이터 모델의 모호한 설명보다 더 나은 인수인계야. 번호가 매겨진 API 엔드포인트 목록이 "유저 관련 처리하는 백엔드 필요해"보다 나아. 산출물이 날카로울수록 다음 대화가 더 잘 돼.</p>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.3}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>인수인계 산출물의 품질이 하류에서 만들어지는 모든 것의 품질을 결정해. 쓰레기가 들어가면, 쓰레기가 나와 — 대화를 넘어서.</div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">Context Packing의 기술</h2>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">새 AI 대화를 시작할 때마다, 대부분 알아채지 못하는 결정을 하고 있어: <strong>어떤 context를 포함할지?</strong></p>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">예산이 제한돼 있어 — context window. 그리고 잠재적으로 관련 있는 정보 더미가 있어: 코드 파일, 문서, 이전 대화, 에러 로그, 디자인 스펙. 전부 안 들어가. 들어간다 해도, 전부 넣으면 AI의 주의력이 분산돼.</p>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">Context packing은 여행 가방 싸기와 같아. 옷장 전체를 가져갈 수 없어. 어디 가는지(작업), 뭐가 필요한지(관련 정보), 뭘 놓고 갈 수 있는지(나머지)를 생각해야 해.</p>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.25}>
      <div style="display: flex; flex-direction: column; gap: 1.25rem; margin-bottom: 2.5rem;">
        {[
          { label: 'Context가 너무 적으면', color: '#E94560', text: 'AI가 필요한 걸 못 갖고 환각으로 빈틈을 채워. 자신 있게 들리지만 디테일을 만들어내.' },
          { label: 'Context가 너무 많으면', color: '#F5A623', text: 'AI가 압도당해. 중요한 디테일이 잡음 속에서 사라져. 결과물이 일반적이고 초점이 없어져.' },
          { label: '딱 맞는 Context', color: '#16C79A', text: 'AI가 이 특정 작업에 필요한 것만 정확히 가져. 결과물이 정밀하고, 관련 있고, 실행 가능해.' },
        ].map((item, i) => (
          <FadeInBlock client:visible delay={0.25 + i * 0.08}>
            <div style={`padding: 1rem 1.25rem; border-radius: 10px; border-left: 3px solid ${item.color}; background: ${item.color}08;`}>
              <p style={`font-family: var(--font-heading); font-size: 0.9rem; font-weight: 700; color: ${item.color}; margin: 0 0 0.25rem;`}>{item.label}</p>
              <p style="font-size: 0.9rem; line-height: 1.7; color: var(--color-deep); opacity: 0.75; margin: 0;">{item.text}</p>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>저장광이 아니라 편집자처럼 생각해.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">모든 AI 상호작용 전에 스스로 물어봐: AI가 이 특정 작업을 하려면 <em>뭘 알아야 해?</em> 그걸 포함해. 나머지는 빼. 프로젝트 관리에 적용한 context engineering이야.</p>
      </div>
    </FadeInBlock>
  </section>

  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">Context 여행 가방을 싸봐. 넘치지 않게 중요한 걸 넣을 수 있어?</p>
    </FadeInBlock>
  </section>

  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible><ContextPacking client:visible /></FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">효과적이었던 걸 추적하기</h2>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">누구나 겪는 시나리오: 정확히 필요한 결과를 내는 대단한 AI 대화를 해. 일주일 뒤, 비슷한 게 필요해. 뭐라고 했는지 기억이 안 나. 다시 만들려고 해. 결과가 더 안 좋아.</p>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">복잡한 AI 프로젝트는 많은 산출물을 만들어 — 통했던 prompts, 좋았던 결과물, 내린 결정, 실패한 접근법. 추적 시스템 없이는 이미 알아낸 걸 다시 발견하느라 시간을 낭비하게 돼.</p>
    </FadeInBlock>
    <FadeInBlock client:visible delay={0.2}>
