---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import FactOrFabrication from '../../components/widgets/ch9/FactOrFabrication';
import SycophancyTest from '../../components/widgets/ch9/SycophancyTest';

const chapter = chapters[8];
---

<ChapterLayout chapter={chapter} locale="ko">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>9</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          9장
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          AI가 틀릴 때
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          초보와 프로를 가르는<br />검증 습관.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        불편한 사실 하나: 방금 완벽한 에세이를 써준 바로 그 AI가, 똑같은 자신감으로 나폴레옹이 워털루 전투에서 이겼다고 말할 수 있어. 망설이지도 않아. 더듬지도 않아. 완전히 지어낸 "사실"을 모든 것에 쓰는 그 권위 있는 톤 그대로 말해버려.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        이게 AI와 함께 일할 때의 핵심 역설이야: <strong>AI를 유용하게 만드는 바로 그 유창함이 AI를 위험하게 만들어.</strong> AI는 뭐가 참인지 몰라. 뭐가 참처럼 들리는지 아는 것뿐이야. 그리고 이 둘은 아주, 아주 다른 거거든.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        이 장은 너의 헛소리 감지기를 만드는 거야. AI가 나쁘기 때문이 아니라, <em>무작정 믿는 게</em> 나쁘기 때문이야. AI에서 가장 큰 가치를 얻는 사람들은 정확히 언제 믿고 언제 검증해야 하는지를 배운 사람들이야.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE HALLUCINATION PROBLEM ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        할루시네이션 문제
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI에서 <strong>할루시네이션</strong>이란 모델이 그럴듯하게 들리지만 사실과 다르거나 아예 지어낸 정보를 생성하는 걸 말해. 생각보다 자주 일어나.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: #6B7280;">
        <span class="prompt-block-label" style="color: #6B7280;">예시</span>
        <p class="m-0" style="color: var(--color-deep);">
          <strong>너:</strong> "1987년 소설 <em>The Sands of Memory</em>의 저자가 누구야?"<br /><br />
          <strong>AI:</strong> "The Sands of Memory (1987)는 영국 작가 Margaret Thornton이 썼습니다. 전후 동아프리카의 식민주의와 정체성이라는 주제를 다루고 있습니다. Thornton은 이 작품으로 부커상 후보에 올랐습니다."
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        진짜 같지 않아? 이름, 연도, 주제, 심지어 수상 후보까지 있으니까. <strong>근데 전부 가짜야.</strong> 그 책은 존재하지 않아. Margaret Thornton (이 맥락에서)도 존재하지 않아. AI가 모든 걸 지어냈어 — 근데 진짜 답처럼 들리게 만든 거야.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        왜 이런 일이 일어나냐면, AI 모델은 데이터베이스에서 사실을 검색하는 게 아니거든. <em>다음에 올 가능성이 가장 높은 토큰을 예측</em>하는 거야. 진짜 책에 대해 물어보면, 학습 데이터의 패턴이 정확한 정보 쪽으로 안내해. 하지만 존재하지 않는 것에 대해 물으면, 모델은 "모르겠어"라고 하지 않아. 정확한 답이 <em>어떤 모양일지</em>를 생성하는 거야.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>핵심 인사이트</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI는 진실의 개념이 없어. <em>그럴듯함</em>의 개념이 있을 뿐이야. 패턴에 맞는 텍스트를 생성하는 거야 — 그 텍스트가 현실에 부합하든 안 하든.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONFIDENCE WITHOUT COMPETENCE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        실력 없는 자신감
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI 할루시네이션에서 가장 까다로운 부분은 그게 일어난다는 게 아니야. <strong>AI가 절대로 불확실함을 드러내지 않는다</strong>는 거야. 사람은 확신이 없으면 머뭇거리거나, 에두르거나, "아마..." 또는 "확실하진 않은데..."라고 해. AI는 지어낸 사실을 검증된 사실에 쓰는 것과 똑같은 절대적 자신감으로 전달해.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AI가 얼마나 자신 있게 들리는지와 실제로 얼마나 정확한지 사이에는 아무런 상관관계가 없어. 틀린 답과 맞는 답은 밖에서 보면 똑같아 보여.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        그래서 "그럴듯하게 들린다" 테스트는 쓸모없어. 어조로, 세부사항으로, AI가 얼마나 구체적인 숫자나 이름을 포함하는지로 정확도를 판단할 수 없어. 이 모든 것들이 완전히 지어낸 것일 수 있고, 실제로 자주 그래.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        이렇게 생각해봐: AI는 수천 개의 대본을 읽은 아주 설득력 있는 배우 같은 거야. 어떤 대사든 완벽한 확신으로 전달할 수 있어 — 하지만 확신이 곧 지식은 아니야.
      </p>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO FACT OR FABRICATION -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        네 감지기를 테스트해봐. AI의 주장 중 어떤 게 진짜고 어떤 게 지어낸 건지 구별할 수 있어?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FACT OR FABRICATION ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <FactOrFabrication client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE YES-MAN PROBLEM ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        예스맨 문제
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        할루시네이션보다 더 미묘한 또 다른 실패 모드가 있어: <strong>아첨(sycophancy).</strong> AI는 네가 틀렸을 때도 동의하는 경향이 있어.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        "아인슈타인이 전구를 발명했지?" 라고 물으면 대부분의 AI 모델은 딱 잘라서 고쳐주지 않아. 대신, 아인슈타인을 물리학을 통해 빛과 연결시키면서 부분적으로 동의하는 방법을 찾아 — 네 잘못된 주장을 에둘러 가면서, 교육하기보다는 기분 좋게 만들어줘.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        왜냐면, AI 모델은 인간 피드백으로 훈련되거든, 그리고 사람들은 기분 좋고 동의해주는 답변에 높은 평점을 줘. 수백만 개의 훈련 예시를 거치면서 모델은 이걸 배워: <em>동의하면 보상받는다.</em> 그래서 동의해 — 그러면 안 될 때도.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;`}>이게 위험한 이유</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          이미 믿고 있는 걸 확인하는 데만 AI를 쓰면, AI는 기꺼이 그렇게 해줄 거야. 더 똑똑해진 기분이 들면서 실제로는 더 멍청해지는 거야. AI를 가장 강력하게 활용하는 방법은 네 가정에 도전하라고 요청하는 거야 — 강화하는 게 아니라.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO SYCOPHANCY TEST -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        직접 확인해봐. AI에게 틀린 주장을 던져보고 반박하는지 굴복하는지 지켜봐.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: SYCOPHANCY TEST ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <SycophancyTest client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BUILDING YOUR VERIFICATION HABIT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        검증 습관 만들기
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14">
        목표는 AI가 말하는 모든 걸 의심하는 게 아니야. AI가 생성한 정보에 따라 행동하기 전에 자동으로 작동하는 일련의 체크리스트 — 검증 반사신경 — 을 개발하는 거야.
      </p>
    </FadeInBlock>

    <!-- Verification checklist — editorial layout -->
    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { letter: '1', name: '이거 검증할 수 있어?', color: '#E94560', text: '사실적 주장에 대해서는 물어봐: 독립적인 출처로 확인할 수 있을까? AI가 연구를 인용하면, 찾아봐. 날짜를 말하면, 확인해. 누군가를 인용하면, 원문을 찾아봐. 인용을 그대로 받아들이지 마 — AI는 출처를 정기적으로 지어내니까.' },
        { letter: '2', name: '출처를 요청했어?', color: '#0F3460', text: 'AI에게 명시적으로 출처를 제공해달라고 해. 그리고 그 출처를 확인해. 어떤 건 진짜이고, 어떤 건 비슷하지만 틀리고 (맞는 저자, 틀린 논문), 어떤 건 완전히 지어낸 거라는 걸 발견하게 될 거야. 확인하는 행위 자체가 네 직감을 훈련시켜.' },
        { letter: '3', name: '상식 테스트를 통과해?', color: '#7B61FF', text: '한 발짝 물러서서 생각해봐: 이 주장이 정말 말이 돼? AI는 5초만 비판적으로 생각하면 무너지는 그럴듯한 헛소리를 생성할 수 있어. 직감을 믿어 — 그리고 어쨌든 검증해.' },
        { letter: '4', name: '고위험 영역이야?', color: '#F5A623', text: '의료 조언, 법률 지침, 금융 결정, 안전과 관련된 모든 것 — 이런 건 추가 검증이 필요해. AI는 브레인스토밍과 초안 작성에 유용하지만, 중요한 결정은 항상 자격을 갖춘 사람이 검증해야 해.' },
        { letter: '5', name: '질문을 중립적으로 했어?', color: '#16C79A', text: '질문에 네 의견을 끼워 넣으면, AI가 그걸 그대로 반영해줄 거야. 열린 질문을 해. "X가 왜 최고의 접근법이야?" 대신 "X에 대한 찬반 논거가 뭐야?"라고 물어봐. 훨씬 더 솔직하고 유용한 답을 얻게 될 거야.' },
      ].map((block, i) => (
        <FadeInBlock client:visible delay={i * 0.08}>
          <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${block.color};`}>
              {block.letter}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${block.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {block.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {block.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>이건 AI를 의심하는 게 아니야. 잘 쓰는 거야.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          전문 기자는 인용문을 검증해. 과학자는 실험을 재현해. 엔지니어는 다리를 개통하기 전에 테스트해. AI 출력을 검증하는 건 편집증이 아니야 — 전문가의 자세야. 검증하는 사람이 실제로 작동하는 것을 만드는 사람이야.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CLOSING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto mb-8" style="max-width: 55ch;">
        이제 너에게는 헛소리 감지기가 있어: 할루시네이션을 발견하고, 아첨에 저항하고, 믿기 전에 검증할 수 있어. 이 습관이 어떤 멋진 프롬프트 기법보다 더 너를 구해줄 거야.
      </p>
    </FadeInBlock>

