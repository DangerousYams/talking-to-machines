    <!-- ═══ Dot constellation canvas ═══ -->
    <script>
    (function() {
      const canvas = document.getElementById('dot-canvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const CONNECTION_DIST = 140;
      const LINE_MAX_OPACITY = 0.25;
      const dpr = window.devicePixelRatio || 1;

      // Particle seed data: [xPct, yPct, size, color, opacity]
      const COLORS = ['#E94560','#7B61FF','#16C79A','#F5A623','#0EA5E9','#0F3460'];
      const seeds = [
        // Upper-right cluster (dense burst)
        [0.94, 0.10, 9,  '#E94560', 0.85], [0.87, 0.06, 4,  '#7B61FF', 0.80],
        [0.83, 0.15, 6,  '#16C79A', 0.80], [0.78, 0.08, 2,  '#F5A623', 0.90],
        [0.91, 0.19, 3.5,'#0EA5E9', 0.75], [0.72, 0.04, 1.5,'#0F3460', 0.70],
        [0.96, 0.22, 7,  '#F5A623', 0.70], [0.70, 0.13, 10, '#E94560', 0.50],
        [0.82, 0.03, 3,  '#16C79A', 0.70], [0.76, 0.17, 1.5,'#7B61FF', 0.80],
        [0.89, 0.13, 5,  '#0F3460', 0.60], [0.75, 0.07, 2.5,'#0EA5E9', 0.75],
        [0.93, 0.05, 4,  '#16C79A', 0.65], [0.80, 0.21, 8,  '#7B61FF', 0.45],
        // Upper-left scatter
        [0.05, 0.08, 7,  '#7B61FF', 0.70], [0.10, 0.16, 2.5,'#E94560', 0.85],
        [0.16, 0.04, 10, '#0EA5E9', 0.45], [0.07, 0.22, 1.5,'#16C79A', 0.85],
        [0.22, 0.12, 5,  '#F5A623', 0.70], [0.15, 0.20, 2,  '#0F3460', 0.65],
        [0.03, 0.14, 3.5,'#E94560', 0.60], [0.19, 0.08, 6,  '#7B61FF', 0.50],
        [0.12, 0.02, 2,  '#F5A623', 0.75], [0.08, 0.18, 4,  '#0EA5E9', 0.55],
        // Mid-left
        [0.03, 0.35, 5,  '#E94560', 0.55], [0.05, 0.48, 8,  '#0F3460', 0.40],
        [0.09, 0.43, 2,  '#7B61FF', 0.70], [0.02, 0.55, 3,  '#16C79A', 0.50],
        [0.07, 0.40, 1.5,'#F5A623', 0.65],
        // Mid-right
        [0.96, 0.38, 4,  '#16C79A', 0.65], [0.92, 0.52, 7,  '#F5A623', 0.45],
        [0.86, 0.46, 2,  '#E94560', 0.65], [0.98, 0.45, 3,  '#0EA5E9', 0.55],
        [0.90, 0.35, 1.5,'#0F3460', 0.60],
        // Bottom scatter
        [0.08, 0.78, 6,  '#0EA5E9', 0.55], [0.16, 0.84, 2.5,'#7B61FF', 0.75],
        [0.88, 0.75, 5,  '#E94560', 0.55], [0.80, 0.86, 2,  '#16C79A', 0.80],
        [0.72, 0.81, 3.5,'#0F3460', 0.45], [0.28, 0.90, 9,  '#F5A623', 0.35],
        [0.35, 0.82, 1.5,'#E94560', 0.70], [0.92, 0.82, 4,  '#7B61FF', 0.50],
        [0.20, 0.76, 3,  '#16C79A', 0.60], [0.60, 0.88, 2,  '#0EA5E9', 0.55],
        // Center sparse (far from text — edges of the middle band)
        [0.30, 0.30, 2,  '#F5A623', 0.40], [0.68, 0.32, 1.5,'#16C79A', 0.45],
        [0.32, 0.60, 3,  '#7B61FF', 0.35], [0.65, 0.62, 2,  '#E94560', 0.40],
      ];

      let particles = [];
      let w, h;

      function resize() {
        const rect = canvas.parentElement.getBoundingClientRect();
        w = rect.width;
        h = rect.height;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        canvas.style.width = w + 'px';
        canvas.style.height = h + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

        // Re-init particles with current dimensions
        particles = seeds.map(function(s, i) {
          var style = Math.random(); // 0-0.33 = lazy, 0.33-0.66 = drifter, 0.66-1 = restless
          var spdMul = style < 0.33 ? 0.6 : style < 0.66 ? 1.0 : 1.5;
          var ampMul = style < 0.33 ? 0.7 : style < 0.66 ? 1.0 : 1.4;
          return {
            baseX: s[0] * w,
            baseY: s[1] * h,
            x: s[0] * w,
            y: s[1] * h,
            r: s[2],
            color: s[3],
            opacity: s[4],
            phase: i * 0.7 + Math.random() * 3,
            speedX: (0.12 + Math.random() * 0.35) * spdMul,
            speedY: (0.10 + Math.random() * 0.30) * spdMul,
            speedZ: (0.05 + Math.random() * 0.15) * spdMul, // 3rd layer
            ampX: (18 + Math.random() * 35) * ampMul,
            ampY: (14 + Math.random() * 28) * ampMul,
            ampZ: (6 + Math.random() * 14) * ampMul, // 3rd layer
            phaseZ: Math.random() * Math.PI * 2,
          };
        });
      }

      function hexToRgb(hex) {
        var r = parseInt(hex.slice(1,3), 16);
        var g = parseInt(hex.slice(3,5), 16);
        var b = parseInt(hex.slice(5,7), 16);
        return [r, g, b];
      }

      var t = 0;
      function draw() {
        if (reducedMotion) {
          // Static: draw once, no animation
          ctx.clearRect(0, 0, w, h);
          drawFrame(0);
          return;
        }
        t += 0.0096;
        ctx.clearRect(0, 0, w, h);
        drawFrame(t);
        requestAnimationFrame(draw);
      }

      function drawFrame(time) {
        // Update positions
        for (var i = 0; i < particles.length; i++) {
          var p = particles[i];
          p.x = p.baseX + Math.sin(time * p.speedX + p.phase) * p.ampX
                        + Math.sin(time * p.speedX * 0.6 + p.phase * 1.3) * p.ampX * 0.3
                        + Math.cos(time * p.speedZ + p.phaseZ) * p.ampZ;
          p.y = p.baseY + Math.cos(time * p.speedY + p.phase * 0.8) * p.ampY
                        + Math.cos(time * p.speedY * 0.5 + p.phase * 1.7) * p.ampY * 0.3
                        + Math.sin(time * p.speedZ * 0.8 + p.phaseZ * 1.4) * p.ampZ;
        }

        // Draw connections
        for (var i = 0; i < particles.length; i++) {
          for (var j = i + 1; j < particles.length; j++) {
            var a = particles[i];
            var b = particles[j];
            var dx = a.x - b.x;
            var dy = a.y - b.y;
            var dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < CONNECTION_DIST) {
              var alpha = (1 - dist / CONNECTION_DIST) * LINE_MAX_OPACITY;
              var grad = ctx.createLinearGradient(a.x, a.y, b.x, b.y);
              var rgbA = hexToRgb(a.color);
              var rgbB = hexToRgb(b.color);
              grad.addColorStop(0, 'rgba(' + rgbA[0] + ',' + rgbA[1] + ',' + rgbA[2] + ',' + alpha + ')');
              grad.addColorStop(1, 'rgba(' + rgbB[0] + ',' + rgbB[1] + ',' + rgbB[2] + ',' + alpha + ')');
              ctx.beginPath();
              ctx.moveTo(a.x, a.y);
              ctx.lineTo(b.x, b.y);
              ctx.strokeStyle = grad;
              ctx.lineWidth = 1;
              ctx.stroke();
            }
          }
        }

        // Draw dots
        for (var i = 0; i < particles.length; i++) {
          var p = particles[i];
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          var rgb = hexToRgb(p.color);
          ctx.fillStyle = 'rgba(' + rgb[0] + ',' + rgb[1] + ',' + rgb[2] + ',' + p.opacity + ')';
          ctx.fill();
        }
      }

      resize();
      draw();
      window.addEventListener('resize', function() { resize(); if (reducedMotion) draw(); });
    })();
    </script>

    <!-- ═══ Scroll reveal observer ═══ -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>

    <script>
      const courseVerbs = [
        { verb: 'Write' },
        { verb: 'Code' },
        { verb: 'Research' },
        { verb: 'Create' },
        { verb: 'Solve problems' },
        { verb: 'Think' },
      ];
      const coursePart = document.getElementById('course-cycling-part');
      if (coursePart) {
        let ci = 0;
        setInterval(() => {
          coursePart.style.opacity = '0';
          coursePart.style.transform = 'translateY(6px)';
          setTimeout(() => {
            ci = (ci + 1) % courseVerbs.length;
            coursePart.textContent = courseVerbs[ci].verb;
            coursePart.style.transform = 'translateY(-6px)';
            void coursePart.offsetHeight;
            coursePart.style.opacity = '1';
            coursePart.style.transform = 'translateY(0)';
          }, 400);
        }, 2800);
      }
    </script>

  </body>
