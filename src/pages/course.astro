---
export const prerender = true;
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import GtagHead from '../components/analytics/GtagHead.astro';

// ── Replace these with real URLs ──
const FORM_URL_WEEKEND = '#register-weekend';
const FORM_URL_WEEKDAY = 'https://rzp.io/rzp/bghr9A8s';
const FORM_URL_CONSULT = '#register-consult';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Live AI workshops for ages 11+. Learn prompting, creative tools, and agent design — hands-on, from a Pixar veteran. Small cohorts on Zoom." />
    <meta property="og:title" content="Talking to Machines — Live Course" />
    <meta property="og:description" content="Live AI workshops for ages 11+. Prompting, tools, agents — hands-on, on Zoom." />
    <title>Live Course — Talking to Machines</title>
    <GtagHead />
    <style>
      /* ── Hero cards ── */
      .hero-card {
        position: absolute;
        top: 0;
        left: 50%;
        z-index: 1;
        transform: translate(-50%, 10px) scale(0.92);
        transform-origin: center bottom;
        opacity: 0;
        background: white;
        padding: 1.75rem 2.75rem;
        box-shadow: 0 8px 30px rgba(26, 26, 46, 0.07);
        pointer-events: none;
        text-align: center;
        min-width: 360px;
      }
      /* Hand-drawn-ish border radii — each corner different */
      .card-for {
        border-radius: 24px 18px 22px 16px;
        border: 2px solid rgba(22, 199, 154, 0.35);
        box-shadow: 0 8px 30px rgba(22, 199, 154, 0.08);
        animation: card-pop-1 12s cubic-bezier(0.34, 1.56, 0.64, 1) 1s infinite;
        overflow: visible;
      }
      .card-for-icon {
        animation: icon-parallax-1 12s cubic-bezier(0.34, 1.56, 0.64, 1) 1s infinite;
      }
      @keyframes icon-parallax-1 {
        0%   { transform: translateY(8px) scale(0.9) rotate(0deg); }
        3%   { transform: translateY(-14px) scale(1.06) rotate(-6deg); }
        5%   { transform: translateY(-5px) scale(1.02) rotate(-3deg); }
        15%  { transform: translateY(-3px) scale(1) rotate(-2deg); }
        33%  { transform: translateY(-3px) scale(1) rotate(-2deg); }
        36%  { transform: translateY(10px) scale(0.9) rotate(2deg); }
        100% { transform: translateY(8px) scale(0.9) rotate(0deg); }
      }
      .card-by {
        border-radius: 18px 24px 16px 22px;
        border: 2px solid rgba(123, 97, 255, 0.35);
        box-shadow: 0 8px 30px rgba(123, 97, 255, 0.08);
        animation: card-pop-2 12s cubic-bezier(0.34, 1.56, 0.64, 1) 5s infinite;
        overflow: visible;
      }
      .card-by-photo {
        animation: photo-parallax 12s cubic-bezier(0.34, 1.56, 0.64, 1) 5s infinite;
      }
      @keyframes photo-parallax {
        0%   { transform: translateY(6px) scale(0.95); }
        3%   { transform: translateY(-12px) scale(1.04); }
        5%   { transform: translateY(-4px) scale(1.02); }
        15%  { transform: translateY(-2px) scale(1); }
        33%  { transform: translateY(-2px) scale(1); }
        36%  { transform: translateY(8px) scale(0.95); }
        100% { transform: translateY(6px) scale(0.95); }
      }
      .card-why {
        border-radius: 20px 16px 24px 18px;
        border: 2px solid rgba(245, 166, 35, 0.4);
        box-shadow: 0 8px 30px rgba(245, 166, 35, 0.1);
        animation: card-pop-3 12s cubic-bezier(0.34, 1.56, 0.64, 1) 9s infinite;
        overflow: visible;
      }
      .card-why-icon {
        animation: icon-parallax-3 12s cubic-bezier(0.34, 1.56, 0.64, 1) 9s infinite;
      }
      .card-why-rocket {
        animation: rocket-rise 12s cubic-bezier(0.34, 1.56, 0.64, 1) 9s infinite;
      }
      @keyframes rocket-rise {
        0%   { transform: translateY(8px) scale(0.9); }
        3%   { transform: translateY(-10px) scale(1.06); }
        5%   { transform: translateY(-6px) scale(1.02); }
        15%  { transform: translateY(-14px) scale(1); }
        25%  { transform: translateY(-24px) scale(1); }
        33%  { transform: translateY(-30px) scale(1); }
        36%  { transform: translateY(10px) scale(0.9); }
        100% { transform: translateY(8px) scale(0.9); }
      }
      @keyframes icon-parallax-3 {
        0%   { transform: translateY(8px) scale(0.9) rotate(0deg); }
        3%   { transform: translateY(-14px) scale(1.06) rotate(5deg); }
        5%   { transform: translateY(-5px) scale(1.02) rotate(2deg); }
        15%  { transform: translateY(-3px) scale(1) rotate(1deg); }
        33%  { transform: translateY(-3px) scale(1) rotate(1deg); }
        36%  { transform: translateY(10px) scale(0.9) rotate(-2deg); }
        100% { transform: translateY(8px) scale(0.9) rotate(0deg); }
      }

      .hero-card-label {
        display: block;
        font-family: var(--font-mono);
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
      }
      .card-for .hero-card-label { color: var(--color-teal); }
      .card-by .hero-card-label { color: var(--color-purple); }
      .card-why .hero-card-label { color: var(--color-amber); }
      .hero-card-text {
        display: block;
        font-family: var(--font-body);
        font-size: 1.3rem;
        line-height: 1.5;
        color: var(--color-deep);
      }

      /* Each card gets a slightly different path — feels alive, not mechanical */
      @keyframes card-pop-1 {
        0%   { opacity: 0; transform: translate(-50%, 10px) scale(0.92) rotate(0deg); }
        3%   { opacity: 1; transform: translate(-50%, -108%) scale(1) rotate(-1.5deg); }
        5%   { transform: translate(-50%, -103%) scale(1) rotate(-1deg); }
        33%  { opacity: 1; transform: translate(-50%, -105%) scale(1) rotate(-0.5deg); }
        36%  { opacity: 0; transform: translate(-50%, -80%) scale(0.96) rotate(0.5deg); }
        100% { opacity: 0; transform: translate(-50%, 10px) scale(0.92) rotate(0deg); }
      }
      @keyframes card-pop-2 {
        0%   { opacity: 0; transform: translate(-50%, 10px) scale(0.92) rotate(0deg); }
        3%   { opacity: 1; transform: translate(-50%, -110%) scale(1) rotate(1.5deg); }
        5%   { transform: translate(-50%, -104%) scale(1) rotate(1deg); }
        33%  { opacity: 1; transform: translate(-50%, -106%) scale(1) rotate(0.5deg); }
        36%  { opacity: 0; transform: translate(-50%, -82%) scale(0.96) rotate(-0.5deg); }
        100% { opacity: 0; transform: translate(-50%, 10px) scale(0.92) rotate(0deg); }
      }
      @keyframes card-pop-3 {
        0%   { opacity: 0; transform: translate(-50%, 10px) scale(0.92) rotate(0deg); }
        3%   { opacity: 1; transform: translate(-50%, -106%) scale(1) rotate(-1deg); }
        5%   { transform: translate(-50%, -102%) scale(1) rotate(-0.5deg); }
        33%  { opacity: 1; transform: translate(-50%, -104%) scale(1) rotate(0deg); }
        36%  { opacity: 0; transform: translate(-50%, -78%) scale(0.96) rotate(1deg); }
        100% { opacity: 0; transform: translate(-50%, 10px) scale(0.92) rotate(0deg); }
      }

      @media (max-width: 640px) {
        .hero-card { padding: 1.25rem 1.5rem; min-width: 220px; }
        .hero-card-text { font-size: 1rem; }
      }

      /* ── Animations ── */
      @keyframes float-slow {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-18px) rotate(3deg); }
      }
      @keyframes float-med {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-12px) rotate(-2deg); }
      }
      @keyframes float-fast {
        0%, 100% { transform: translateY(0) scale(1); }
        50% { transform: translateY(-8px) scale(1.05); }
      }
      @keyframes pulse-ring {
        0%, 100% { transform: scale(1); opacity: 0.4; }
        50% { transform: scale(1.3); opacity: 0; }
      }
      @keyframes fade-in-up {
        from { opacity: 0; transform: translateY(24px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes shimmer {
        0% { background-position: -200% 0; }
        100% { background-position: 200% 0; }
      }

      .reveal {
        opacity: 0;
        transform: translateY(24px);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }
      .reveal-delay-1 { transition-delay: 0.1s; }
      .reveal-delay-2 { transition-delay: 0.2s; }
      .reveal-delay-3 { transition-delay: 0.3s; }

      /* ── Hero ── */
      .course-hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 6rem 1.5rem 4rem;
        text-align: center;
        overflow: hidden;
      }
      .course-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
          radial-gradient(ellipse 60% 45% at 25% 35%, rgba(233, 69, 96, 0.07) 0%, transparent 70%),
          radial-gradient(ellipse 50% 55% at 80% 55%, rgba(123, 97, 255, 0.06) 0%, transparent 70%),
          radial-gradient(ellipse 45% 40% at 55% 85%, rgba(22, 199, 154, 0.05) 0%, transparent 70%),
          radial-gradient(ellipse 30% 30% at 10% 80%, rgba(245, 166, 35, 0.04) 0%, transparent 70%);
        pointer-events: none;
      }

      .hero-dot {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
        z-index: 0;
      }
      @keyframes drift-1 {
        0%, 100% { transform: translate(0, 0); }
        33% { transform: translate(3px, -6px); }
        66% { transform: translate(-2px, 4px); }
      }
      @keyframes drift-2 {
        0%, 100% { transform: translate(0, 0); }
        33% { transform: translate(-4px, 3px); }
        66% { transform: translate(5px, -2px); }
      }
      @keyframes drift-3 {
        0%, 100% { transform: translate(0, 0); }
        50% { transform: translate(2px, -4px); }
      }

      /* ── Cards ── */
      .pricing-card {
        position: relative;
        background: white;
        border: 1px solid rgba(26, 26, 46, 0.08);
        border-radius: 20px;
        padding: 2.5rem 2rem;
        transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease;
      }
      .pricing-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 50px rgba(26, 26, 46, 0.1);
      }
      .pricing-card.featured {
        border-color: transparent;
        background: linear-gradient(white, white) padding-box,
                    linear-gradient(135deg, var(--color-accent-red), var(--color-purple)) border-box;
        border: 2px solid transparent;
        box-shadow: 0 8px 32px rgba(233, 69, 96, 0.1);
      }
      .pricing-card.featured:hover {
        box-shadow: 0 24px 56px rgba(233, 69, 96, 0.15);
      }

      .cta-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.9rem 2rem;
        border-radius: 100px;
        font-family: var(--font-body);
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
        cursor: pointer;
        position: relative;
        overflow: hidden;
      }
      .cta-btn.primary {
        background: var(--color-deep);
        color: var(--color-cream);
      }
      .cta-btn.primary:hover {
        background: var(--color-accent-red);
        box-shadow: 0 8px 24px rgba(233, 69, 96, 0.25);
        transform: translateY(-2px);
      }
      .cta-btn.primary:hover svg {
        transform: translateX(3px);
      }
      .cta-btn.primary svg {
        transition: transform 0.3s ease;
      }
      .cta-btn.outline {
        background: transparent;
        color: var(--color-deep);
        border: 1.5px solid rgba(26, 26, 46, 0.2);
      }
      .cta-btn.outline:hover {
        background: var(--color-deep);
        color: var(--color-cream);
        border-color: var(--color-deep);
      }

      .pillar-card {
        background: white;
        border: 1px solid rgba(26, 26, 46, 0.06);
        border-radius: 20px;
        padding: 2rem 1.75rem 2rem;
        position: relative;
        overflow: hidden;
        transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease;
      }
      .pillar-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 36px rgba(26, 26, 46, 0.07);
      }

      .pillar-icon {
        width: 56px;
        height: 56px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.25rem;
        position: relative;
      }
      .pillar-icon::after {
        content: '';
        position: absolute;
        inset: -4px;
        border-radius: 20px;
        opacity: 0;
        transition: opacity 0.3s ease;
      }
      .pillar-card:hover .pillar-icon::after {
        opacity: 1;
        animation: pulse-ring 1.5s ease infinite;
      }

      .prereq-card {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        background: white;
        border: 1px solid rgba(26, 26, 46, 0.06);
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }
      .prereq-card:hover {
        transform: translateX(4px);
        box-shadow: -4px 4px 16px rgba(26, 26, 46, 0.04);
      }

      .prereq-icon {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      /* ── Session timeline ── */
      .session-timeline {
        position: relative;
        padding-left: 2.5rem;
      }
      .session-timeline::before {
        content: '';
        position: absolute;
        left: 8px;
        top: 12px;
        bottom: 12px;
        width: 2px;
        background: linear-gradient(to bottom, var(--color-accent-red), var(--color-purple), var(--color-teal));
        border-radius: 1px;
      }
      .session-entry {
        position: relative;
        padding: 1.5rem 0 1.5rem 0;
      }
      .session-dot-outer {
        position: absolute;
        left: -2.5rem;
        top: 1.75rem;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .session-dot-inner {
        width: 8px;
        height: 8px;
        border-radius: 50%;
      }

      /* ── FAQ ── */
      .faq-item summary {
        font-family: var(--font-heading);
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        padding: 1.1rem 0;
        color: var(--color-deep);
        list-style: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(26, 26, 46, 0.06);
        transition: color 0.2s ease;
      }
      .faq-item summary:hover {
        color: var(--color-accent-red);
      }
      .faq-item summary::after {
        content: '+';
        font-family: var(--font-mono);
        font-size: 1.2rem;
        font-weight: 300;
        color: var(--color-subtle);
        transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), color 0.2s ease;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
      }
      .faq-item summary:hover::after { color: var(--color-accent-red); }
      .faq-item[open] summary::after { transform: rotate(45deg); }
      .faq-item .faq-body {
        padding: 0.75rem 0 1.25rem;
        font-size: 0.95rem;
        line-height: 1.75;
        color: var(--color-deep);
        opacity: 0.7;
      }

      /* ── Decorative dividers ── */
      .section-divider {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem 0;
      }
      .section-divider svg { opacity: 0.85; }

      /* ── Responsive ── */
      @media (max-width: 768px) {
        .pricing-card { padding: 2rem 1.5rem; border-radius: 16px; }
        .pillar-card { padding: 1.5rem 1.25rem; }
      }

      @media (prefers-reduced-motion: reduce) {
        .hero-dot { animation: none !important; }
        .reveal { opacity: 1; transform: none; transition: none; }
      }
    </style>
  </head>

  <body class="bg-cream text-deep min-h-screen">

    <!-- ═══ HEADER ═══ -->
    <header style="position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(250, 248, 245, 0.9); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(26,26,46,0.04);">
      <div style="max-width: 1100px; margin: 0 auto; padding: 0.75rem 1.5rem; display: flex; justify-content: space-between; align-items: center;">
        <a href="/" style="font-family: var(--font-heading); font-size: 1rem; font-weight: 800; color: var(--color-deep); text-decoration: none; letter-spacing: -0.02em;">
          Talking to Machines
        </a>
        <a href="https://rzp.io/rzp/bghr9A8s" class="cta-btn primary" style="padding: 0.5rem 1.25rem; font-size: 0.8rem;">
          Register Now
        </a>
      </div>
    </header>

    <!-- ═══ HERO ═══ -->
    <section class="course-hero">
      <!-- Animated dot constellation -->
      <canvas id="dot-canvas" style="position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0;"></canvas>

      <div style="max-width: 700px; position: relative; z-index: 1; text-align: center; margin: 0 auto;">

        <!-- Title + animated cards container -->
        <div style="position: relative; display: inline-block; margin-top: 6rem; margin-bottom: 2.5rem;">
          <!-- Cards (behind the title, pop out on animation) -->
          <div class="hero-card card-for" style="display: flex; align-items: center; gap: 1.25rem; text-align: left; padding-left: 4.5rem; overflow: visible;">
            <svg width="108" height="108" viewBox="0 0 60 60" fill="none" class="card-for-icon" style="flex-shrink: 0; position: absolute; left: -45px;">
              <!-- Floppy ears -->
              <ellipse cx="14" cy="22" rx="8" ry="12" fill="#16C79A" opacity="0.45" transform="rotate(-15 14 22)"/>
              <ellipse cx="46" cy="22" rx="8" ry="12" fill="#16C79A" opacity="0.45" transform="rotate(15 46 22)"/>
              <!-- Head -->
              <circle cx="30" cy="30" r="16" fill="#16C79A" opacity="0.35"/>
              <!-- Big eyes -->
              <circle cx="24" cy="28" r="4.5" fill="white"/>
              <circle cx="36" cy="28" r="4.5" fill="white"/>
              <circle cx="25" cy="27.5" r="2.5" fill="#0f9b7a"/>
              <circle cx="37" cy="27.5" r="2.5" fill="#0f9b7a"/>
              <circle cx="25.8" cy="26.6" r="0.9" fill="white"/>
              <circle cx="37.8" cy="26.6" r="0.9" fill="white"/>
              <!-- Blink lids -->
              <ellipse cx="24" cy="28" rx="5" ry="0" fill="#16C79A" opacity="0.5">
                <animate attributeName="ry" values="0;5;0" dur="0.2s" repeatCount="1" begin="3s;6.5s;11s" fill="freeze"/>
              </ellipse>
              <ellipse cx="36" cy="28" rx="5" ry="0" fill="#16C79A" opacity="0.5">
                <animate attributeName="ry" values="0;5;0" dur="0.2s" repeatCount="1" begin="3s;6.5s;11s" fill="freeze"/>
              </ellipse>
              <!-- Button nose -->
              <circle cx="30" cy="34" r="2.5" fill="#0f9b7a" opacity="0.6"/>
            </svg>
            <div>
              <span style="display: block; font-family: var(--font-heading); font-size: 1.3rem; font-weight: 800; color: var(--color-deep); line-height: 1.2;">Go from curious to capable</span>
              <span style="display: block; font-family: var(--font-body); font-size: 1rem; color: var(--color-subtle); line-height: 1.4; margin-top: 0.3rem;">For anyone aged 11+. No experience needed.</span>
            </div>
          </div>
          <div class="hero-card card-by" style="display: flex; align-items: center; gap: 1.25rem; text-align: left; padding-left: 4.5rem; overflow: visible;">
            <img src="/images/shalin.png" alt="Shalin Shodhan" width="100" height="100" class="card-by-photo" style="border-radius: 50%; object-fit: cover; flex-shrink: 0; position: absolute; left: -40px; box-shadow: 0 4px 20px rgba(0,0,0,0.1);" />
            <div>
              <span style="display: block; font-family: var(--font-heading); font-size: 1.3rem; font-weight: 800; color: var(--color-deep); line-height: 1.2;">Shalin Shodhan</span>
              <span style="display: block; font-family: var(--font-body); font-size: 1rem; color: var(--color-subtle); line-height: 1.4; margin-top: 0.3rem;">Author of the first interactive AI curriculum</span>
            </div>
          </div>
          <div class="hero-card card-why" style="display: flex; align-items: center; gap: 1.25rem; text-align: left; padding-left: 4.5rem; overflow: visible;">
            <svg width="126" height="126" viewBox="0 0 60 60" fill="none" class="card-why-icon card-why-rocket" style="flex-shrink: 0; position: absolute; left: -35px;">
              <!-- Rocket body -->
              <rect x="24" y="12" width="12" height="24" rx="6" fill="#F5A623" opacity="0.8"/>
              <!-- Nose cone -->
              <polygon points="30,4 24,16 36,16" fill="#E8912D" opacity="0.9"/>
              <!-- Window -->
              <circle cx="30" cy="22" r="3.5" fill="white" opacity="0.9"/>
              <circle cx="30" cy="22" r="2" fill="#F5A623" opacity="0.4"/>
              <!-- Boosters -->
              <rect x="19" y="30" width="5" height="8" rx="2" fill="#D4801A" opacity="0.6"/>
              <rect x="36" y="30" width="5" height="8" rx="2" fill="#D4801A" opacity="0.6"/>
              <!-- Fins -->
              <polygon points="24,34 19,40 24,38" fill="#E8912D" opacity="0.5"/>
              <polygon points="36,34 41,40 36,38" fill="#E8912D" opacity="0.5"/>
              <!-- Core flame -->
              <ellipse cx="30" cy="42" rx="4" ry="6" fill="#F5A623" opacity="0.5">
                <animate attributeName="ry" values="6;8;5;7;6" dur="0.4s" repeatCount="indefinite"/>
