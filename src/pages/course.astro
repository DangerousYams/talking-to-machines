---
export const prerender = true;
import '../styles/global.css';

// ── Replace these with real URLs ──
const FORM_URL_WEEKEND = '#register-weekend';
const FORM_URL_WEEKDAY = 'https://rzp.io/rzp/x7radzW';
const FORM_URL_CONSULT = '#register-consult';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Live AI workshops for ages 11+. Learn prompting, creative tools, and agent design — hands-on, from a Pixar veteran. Small cohorts on Zoom." />
    <meta property="og:title" content="Talking to Machines — Live Course" />
    <meta property="og:description" content="Live AI workshops for ages 11+. Prompting, tools, agents — hands-on, on Zoom." />
    <title>Live Course — Talking to Machines</title>
    <style>
      /* ── Animations ── */
      @keyframes float-slow {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-18px) rotate(3deg); }
      }
      @keyframes float-med {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-12px) rotate(-2deg); }
      }
      @keyframes float-fast {
        0%, 100% { transform: translateY(0) scale(1); }
        50% { transform: translateY(-8px) scale(1.05); }
      }
      @keyframes pulse-ring {
        0%, 100% { transform: scale(1); opacity: 0.4; }
        50% { transform: scale(1.3); opacity: 0; }
      }
      @keyframes fade-in-up {
        from { opacity: 0; transform: translateY(24px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes shimmer {
        0% { background-position: -200% 0; }
        100% { background-position: 200% 0; }
      }

      .reveal {
        opacity: 0;
        transform: translateY(24px);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }
      .reveal-delay-1 { transition-delay: 0.1s; }
      .reveal-delay-2 { transition-delay: 0.2s; }
      .reveal-delay-3 { transition-delay: 0.3s; }

      /* ── Hero ── */
      .course-hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 6rem 1.5rem 4rem;
        text-align: center;
        overflow: hidden;
      }
      .course-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
          radial-gradient(ellipse 60% 45% at 25% 35%, rgba(233, 69, 96, 0.07) 0%, transparent 70%),
          radial-gradient(ellipse 50% 55% at 80% 55%, rgba(123, 97, 255, 0.06) 0%, transparent 70%),
          radial-gradient(ellipse 45% 40% at 55% 85%, rgba(22, 199, 154, 0.05) 0%, transparent 70%),
          radial-gradient(ellipse 30% 30% at 10% 80%, rgba(245, 166, 35, 0.04) 0%, transparent 70%);
        pointer-events: none;
      }

      .hero-dot {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
        z-index: 0;
      }
      @keyframes drift-1 {
        0%, 100% { transform: translate(0, 0); }
        33% { transform: translate(3px, -6px); }
        66% { transform: translate(-2px, 4px); }
      }
      @keyframes drift-2 {
        0%, 100% { transform: translate(0, 0); }
        33% { transform: translate(-4px, 3px); }
        66% { transform: translate(5px, -2px); }
      }
      @keyframes drift-3 {
        0%, 100% { transform: translate(0, 0); }
        50% { transform: translate(2px, -4px); }
      }

      /* ── Cards ── */
      .pricing-card {
        position: relative;
        background: white;
        border: 1px solid rgba(26, 26, 46, 0.08);
        border-radius: 20px;
        padding: 2.5rem 2rem;
        transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease;
      }
      .pricing-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 50px rgba(26, 26, 46, 0.1);
      }
      .pricing-card.featured {
        border-color: transparent;
        background: linear-gradient(white, white) padding-box,
                    linear-gradient(135deg, var(--color-accent-red), var(--color-purple)) border-box;
        border: 2px solid transparent;
        box-shadow: 0 8px 32px rgba(233, 69, 96, 0.1);
      }
      .pricing-card.featured:hover {
        box-shadow: 0 24px 56px rgba(233, 69, 96, 0.15);
      }

      .cta-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.9rem 2rem;
        border-radius: 100px;
        font-family: var(--font-body);
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
        cursor: pointer;
        position: relative;
        overflow: hidden;
      }
      .cta-btn.primary {
        background: var(--color-deep);
        color: var(--color-cream);
      }
      .cta-btn.primary:hover {
        background: var(--color-accent-red);
        box-shadow: 0 8px 24px rgba(233, 69, 96, 0.25);
        transform: translateY(-2px);
      }
      .cta-btn.primary:hover svg {
        transform: translateX(3px);
      }
      .cta-btn.primary svg {
        transition: transform 0.3s ease;
      }
      .cta-btn.outline {
        background: transparent;
        color: var(--color-deep);
        border: 1.5px solid rgba(26, 26, 46, 0.2);
      }
      .cta-btn.outline:hover {
        background: var(--color-deep);
        color: var(--color-cream);
        border-color: var(--color-deep);
      }

      .pillar-card {
        background: white;
        border: 1px solid rgba(26, 26, 46, 0.06);
        border-radius: 20px;
        padding: 2rem 1.75rem 2rem;
        position: relative;
        overflow: hidden;
        transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease;
      }
      .pillar-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 36px rgba(26, 26, 46, 0.07);
      }

      .pillar-icon {
        width: 56px;
        height: 56px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.25rem;
        position: relative;
      }
      .pillar-icon::after {
        content: '';
        position: absolute;
        inset: -4px;
        border-radius: 20px;
        opacity: 0;
        transition: opacity 0.3s ease;
      }
      .pillar-card:hover .pillar-icon::after {
        opacity: 1;
        animation: pulse-ring 1.5s ease infinite;
      }

      .prereq-card {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        background: white;
        border: 1px solid rgba(26, 26, 46, 0.06);
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }
      .prereq-card:hover {
        transform: translateX(4px);
        box-shadow: -4px 4px 16px rgba(26, 26, 46, 0.04);
      }

      .prereq-icon {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      /* ── Session timeline ── */
      .session-timeline {
        position: relative;
        padding-left: 2.5rem;
      }
      .session-timeline::before {
        content: '';
        position: absolute;
        left: 8px;
        top: 12px;
        bottom: 12px;
        width: 2px;
        background: linear-gradient(to bottom, var(--color-accent-red), var(--color-purple), var(--color-teal));
        border-radius: 1px;
      }
      .session-entry {
        position: relative;
        padding: 1.5rem 0 1.5rem 0;
      }
      .session-dot-outer {
        position: absolute;
        left: -2.5rem;
        top: 1.75rem;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .session-dot-inner {
        width: 8px;
        height: 8px;
        border-radius: 50%;
      }

      /* ── FAQ ── */
      .faq-item summary {
        font-family: var(--font-heading);
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        padding: 1.1rem 0;
        color: var(--color-deep);
        list-style: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(26, 26, 46, 0.06);
        transition: color 0.2s ease;
      }
      .faq-item summary:hover {
        color: var(--color-accent-red);
      }
      .faq-item summary::after {
        content: '+';
        font-family: var(--font-mono);
        font-size: 1.2rem;
        font-weight: 300;
        color: var(--color-subtle);
        transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), color 0.2s ease;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
      }
      .faq-item summary:hover::after { color: var(--color-accent-red); }
      .faq-item[open] summary::after { transform: rotate(45deg); }
      .faq-item .faq-body {
        padding: 0.75rem 0 1.25rem;
        font-size: 0.95rem;
        line-height: 1.75;
        color: var(--color-deep);
        opacity: 0.7;
      }

      /* ── Decorative dividers ── */
      .section-divider {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem 0;
      }
      .section-divider svg { opacity: 0.85; }

      /* ── Responsive ── */
      @media (max-width: 768px) {
        .pricing-card { padding: 2rem 1.5rem; border-radius: 16px; }
        .pillar-card { padding: 1.5rem 1.25rem; }
      }

      @media (prefers-reduced-motion: reduce) {
        .hero-dot { animation: none !important; }
        .reveal { opacity: 1; transform: none; transition: none; }
      }
    </style>
  </head>

  <body class="bg-cream text-deep min-h-screen">

    <!-- ═══ HEADER ═══ -->
    <header style="position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(250, 248, 245, 0.9); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(26,26,46,0.04);">
      <div style="max-width: 1100px; margin: 0 auto; padding: 0.75rem 1.5rem; display: flex; justify-content: space-between; align-items: center;">
        <a href="/" style="font-family: var(--font-heading); font-size: 1rem; font-weight: 800; color: var(--color-deep); text-decoration: none; letter-spacing: -0.02em;">
          Talking to Machines
        </a>
        <a href="https://rzp.io/rzp/x7radzW" class="cta-btn primary" style="padding: 0.5rem 1.25rem; font-size: 0.8rem;">
          Register Now
        </a>
      </div>
    </header>

    <!-- ═══ HERO ═══ -->
    <section class="course-hero">
      <!-- Animated dot constellation -->
      <canvas id="dot-canvas" style="position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0;"></canvas>

      <div style="max-width: 700px; position: relative; z-index: 1; text-align: center; margin: 0 auto;">
        <!-- Eyebrow -->
        <p style="font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600; letter-spacing: 0.25em; text-transform: uppercase; color: var(--color-subtle); opacity: 0.7; margin-bottom: 2.5rem; animation: fade-in-up 0.6s ease both;">
          Live Zoom classes
        </p>

        <!-- Headline -->
        <h1 style="font-family: var(--font-heading); font-size: clamp(3rem, 8vw, 5.5rem); font-weight: 800; line-height: 1.05; color: var(--color-deep); margin-bottom: 2rem; animation: fade-in-up 0.6s ease 0.1s both;">
          Talking to<br />
          <span style="color: var(--color-accent-red);">Machines</span>
        </h1>

        <!-- Animated subtitle -->
        <div style="height: 2.25rem; position: relative; overflow: hidden; margin-bottom: 2.5rem; animation: fade-in-up 0.6s ease 0.2s both;" aria-label="Write better with AI">
          <p style="font-family: var(--font-body); font-size: clamp(1.15rem, 2.5vw, 1.5rem); line-height: 1.5; color: var(--color-deep); opacity: 0.7;">
            <span
              id="course-cycling-part"
              class="inline-block"
              style="transition: all 0.5s ease-in-out;"
            >Write</span><span
              id="course-cycling-suffix"
              class="inline-block"
              style="transition: opacity 0.5s ease-in-out; opacity: 1;"
            >&nbsp;better with AI</span>
          </p>
        </div>

        <!-- CTA -->
        <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem; animation: fade-in-up 0.6s ease 0.4s both;">
          <a href="#sessions" class="cta-btn outline">
            What You'll Learn
          </a>
          <a href="https://rzp.io/rzp/x7radzW" class="cta-btn primary">
            Register
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>

      <!-- Scroll cue -->
      <div style="position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%); opacity: 0.25; animation: float-fast 2s ease-in-out infinite;">
        <svg width="20" height="28" viewBox="0 0 20 28" fill="none">
          <rect x="1" y="1" width="18" height="26" rx="9" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="10" cy="8" r="2" fill="currentColor" opacity="0.4"/>
        </svg>
      </div>
    </section>


    <!-- ═══ Divider ═══ -->
    <div class="section-divider">
      <svg width="100" height="20" viewBox="0 0 100 20" fill="none">
        <circle cx="12" cy="12" r="3" fill="#E94560" opacity="0.5"/>
        <circle cx="28" cy="6" r="2.5" fill="#7B61FF" opacity="0.45"/>
        <circle cx="40" cy="14" r="4" fill="#16C79A" opacity="0.5"/>
        <circle cx="55" cy="8" r="2" fill="#F5A623" opacity="0.55"/>
        <circle cx="66" cy="15" r="3.5" fill="#0EA5E9" opacity="0.4"/>
        <circle cx="80" cy="5" r="2.5" fill="#0F3460" opacity="0.35"/>
        <circle cx="92" cy="11" r="3" fill="#E94560" opacity="0.4"/>
      </svg>
    </div>

    <!-- ═══ THREE PILLARS ═══ -->
    <section id="sessions" style="max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem 4rem;">
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 3rem;">
        <div style="flex: 1; height: 1px; background: rgba(26,26,46,0.08);"></div>
        <span style="font-family: var(--font-mono); font-size: 0.6rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-subtle);">What you'll learn</span>
        <div style="flex: 1; height: 1px; background: rgba(26,26,46,0.08);"></div>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem;">
        <!-- Pillar 1: Prompting -->
        <div class="pillar-card reveal">
          <div style="position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--color-accent-red), rgba(233,69,96,0.3)); border-radius: 20px 20px 0 0;"></div>
          <div class="pillar-icon" style="background: rgba(233, 69, 96, 0.08);">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
              <path d="M4 20V8a2 2 0 012-2h16a2 2 0 012 2v8a2 2 0 01-2 2H8l-4 4v-2z" stroke="#E94560" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M9 11h10M9 15h6" stroke="#E94560" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <span style="font-family: var(--font-mono); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-accent-red);">Session 1</span>
          <h3 style="font-family: var(--font-heading); font-size: 1.35rem; font-weight: 800; margin: 0.5rem 0 0.75rem; color: var(--color-deep);">Prompting</h3>
          <p style="font-size: 0.9rem; line-height: 1.7; color: var(--color-deep); opacity: 0.65; margin: 0;">
            The five building blocks. The Socratic method. Few-shot prompting. Chain-of-thought. Context windows and system prompts.
          </p>
        </div>

        <!-- Pillar 2: Tools -->
        <div class="pillar-card reveal reveal-delay-1">
          <div style="position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--color-purple), rgba(123,97,255,0.3)); border-radius: 20px 20px 0 0;"></div>
          <div class="pillar-icon" style="background: rgba(123, 97, 255, 0.08);">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
              <rect x="4" y="4" width="9" height="9" rx="2" stroke="#7B61FF" stroke-width="1.5"/>
              <rect x="15" y="4" width="9" height="9" rx="2" stroke="#7B61FF" stroke-width="1.5"/>
              <rect x="4" y="15" width="9" height="9" rx="2" stroke="#7B61FF" stroke-width="1.5"/>
              <circle cx="19.5" cy="19.5" r="4.5" stroke="#7B61FF" stroke-width="1.5"/>
            </svg>
          </div>
          <span style="font-family: var(--font-mono); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-purple);">Session 2</span>
          <h3 style="font-family: var(--font-heading); font-size: 1.35rem; font-weight: 800; margin: 0.5rem 0 0.75rem; color: var(--color-deep);">Tools</h3>
          <p style="font-size: 0.9rem; line-height: 1.7; color: var(--color-deep); opacity: 0.65; margin: 0;">
            <strong>Code with Claude.</strong> Research with NotebookLM. Generate images, music, websites, presentations, reports and much more.
          </p>
        </div>

        <!-- Pillar 3: Agents -->
        <div class="pillar-card reveal reveal-delay-2">
          <div style="position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--color-teal), rgba(22,199,154,0.3)); border-radius: 20px 20px 0 0;"></div>
          <div class="pillar-icon" style="background: rgba(22, 199, 154, 0.08);">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
              <circle cx="14" cy="10" r="4" stroke="#16C79A" stroke-width="1.5"/>
              <path d="M14 14v4M10 22h8M14 18v4" stroke="#16C79A" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M8 10h-2M22 10h-2" stroke="#16C79A" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="14" cy="10" r="1.5" fill="#16C79A" opacity="0.3"/>
            </svg>
          </div>
          <span style="font-family: var(--font-mono); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-teal);">Session 3</span>
          <h3 style="font-family: var(--font-heading); font-size: 1.35rem; font-weight: 800; margin: 0.5rem 0 0.75rem; color: var(--color-deep);">Agents</h3>
          <p style="font-size: 0.9rem; line-height: 1.7; color: var(--color-deep); opacity: 0.65; margin: 0;">
            How AI goes from answering questions to taking actions. Agent design, failure modes, and the critical thinking that matters most.
          </p>
        </div>
      </div>
    </section>

    <!-- ═══ Divider ═══ -->
    <div class="section-divider">
      <svg width="100" height="20" viewBox="0 0 100 20" fill="none">
        <circle cx="12" cy="12" r="3" fill="#E94560" opacity="0.5"/>
        <circle cx="28" cy="6" r="2.5" fill="#7B61FF" opacity="0.45"/>
        <circle cx="40" cy="14" r="4" fill="#16C79A" opacity="0.5"/>
        <circle cx="55" cy="8" r="2" fill="#F5A623" opacity="0.55"/>
        <circle cx="66" cy="15" r="3.5" fill="#0EA5E9" opacity="0.4"/>
        <circle cx="80" cy="5" r="2.5" fill="#0F3460" opacity="0.35"/>
        <circle cx="92" cy="11" r="3" fill="#E94560" opacity="0.4"/>
      </svg>
    </div>

    <!-- ═══ PRICING ═══ -->
    <section id="pricing" style="max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem 4rem;">
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 3rem;">
        <div style="flex: 1; height: 1px; background: rgba(26,26,46,0.08);"></div>
        <span style="font-family: var(--font-mono); font-size: 0.6rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-subtle);">Pricing</span>
        <div style="flex: 1; height: 1px; background: rgba(26,26,46,0.08);"></div>
      </div>

      <div style="max-width: 480px; margin: 0 auto;">
        <div class="pricing-card featured reveal">
          <h3 style="font-family: var(--font-heading); font-size: 1.6rem; font-weight: 800; color: var(--color-deep); margin: 0 0 0.25rem;">Talking to Machines</h3>
          <p style="font-size: 0.85rem; color: var(--color-subtle); margin: 0 0 1.5rem;">Three sessions. Six hours. Build real things.</p>

          <div style="display: flex; align-items: baseline; gap: 0.25rem; margin-bottom: 0.25rem;">
            <span style="font-family: var(--font-heading); font-size: 2.5rem; font-weight: 800; color: var(--color-deep); line-height: 1;">₹25,000</span>
          </div>
          <p style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--color-subtle); margin: 0 0 1.5rem;">6 hours &middot; April 20, 22, 24 &middot; Mon / Wed / Fri</p>

          <ul style="list-style: none; padding: 0; margin: 0 0 2rem;">
            {['3 hours of live instruction', '3 hours of hands-on lab', 'Full session recordings', '10–20 students per cohort'].map((item) => (
              <li style="display: flex; align-items: flex-start; gap: 0.6rem; margin-bottom: 0.5rem; font-size: 0.9rem; line-height: 1.6; color: var(--color-deep); opacity: 0.7;">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink: 0; margin-top: 2px;">
                  <circle cx="9" cy="9" r="8" fill="rgba(233, 69, 96, 0.1)"/>
                  <path d="M5.5 9.5l2 2 5-5" stroke="#E94560" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {item}
              </li>
