---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ContextWindowViz from '../../components/widgets/ch3/ContextWindowViz';
import ForgettingExperiment from '../../components/widgets/ch3/ForgettingExperiment';
import SystemPromptSandbox from '../../components/widgets/ch3/SystemPromptSandbox';

const chapter = chapters[2];
---

<ChapterLayout chapter={chapter} locale="mr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>3</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          धडा तीन
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Context<br />Engineering
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          AI विसरत नाही &mdash; त्याने कधी<br />लक्षात ठेवलंच नव्हतं.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        कल्पना कर तू एका मित्राशी बोलतोयस, पण दर काही मिनिटांनी कुणीतरी तुम्ही दोघांनी लिहिलेला whiteboard पुसून टाकतो. तू पुन्हा सुरू करतोस. तुझा मित्र उरलेलं वाचतो आणि काहीच झालं नाही असं दाखवत पुढे बोलतो. लांब conversation दरम्यान AI च्या "brain" मध्ये असंच होतं.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        <strong>AI ला memory नाही.</strong> तू memory म्हणतोस तसली नाही. त्याला कालची conversation आठवत नाही. <em>ही</em> conversation पुरेशी लांब गेली असेल तर सुरुवात सुद्धा आठवत नाही. त्याचा प्रत्येक response पूर्णपणे त्याला सध्या दिसतं त्यावर आधारित आहे &mdash; text ची एक window ज्याला <strong>context window</strong> म्हणतात.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        ही window समजून घेणं &mdash; त्यात काय जातं, किती मोठी आहे, आणि भरल्यावर काय होतं &mdash; AI सोबत काम करण्यातल्या सर्वात महत्त्वाच्या skills पैकी एक आहे.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE WHITEBOARD METAPHOR ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        पुसला जाणारा Whiteboard
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        जेव्हा तू AI ला message पाठवतोस, तेव्हा खरोखर काय होतं ते हे आहे: system तुझं <em>संपूर्ण conversation</em> &mdash; तू पाठवलेला प्रत्येक message, AI ने दिलेला प्रत्येक response &mdash; सगळं एक block म्हणून model ला परत feed करतो. AI ते सगळं वाचतो, पुढचा response generate करतो, आणि मग... सगळं विसरतो.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        पुढचा message पाठवल्यावर, सगळं पुन्हा होतं. System पूर्ण conversation पुन्हा paste करतो, तुझा नवीन message जोडतो, आणि AI सगळं fresh वाचतो. जगातला सर्वात मेहनती पण विस्मरणाचा वाचक &mdash; प्रत्येक वेळी पूर्णपणे thorough, पण प्रत्येक turn ला शून्यापासून सुरू.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AI चा प्रत्येक response पूर्णपणे त्या क्षणी context window मध्ये काय आहे त्यावर आधारित आहे. त्यापलीकडे काहीच नाही. Context window memory नाही. तो whiteboard आहे &mdash; आणि त्याला कडा आहेत.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        याचे प्रचंड परिणाम आहेत. म्हणजे AI फक्त त्याच्या समोर सध्या असलेल्या माहितीइतकाच चांगला आहे. एखादी महत्त्वाची detail सोडलीस? AI जादूने आठवणार नाही. Window noise ने भरलीस? AI गोंधळेल. <strong>Context window हा तुझा सर्वात महत्त्वाचा resource आहे.</strong> तो manage करायला शिकणं हेच casual users आणि खरोखर powerful results मिळवणारे लोक यांना वेगळं करतं.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ TOKENS — THE AI'S ALPHABET ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Tokens: AI ची वर्णमाला
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI तू वाचतोस तसे शब्द वाचत नाही. तो <strong>tokens</strong> वाचतो &mdash; text चे तुकडे जे साधारण एका शब्दाच्या तीन-चतुर्थांश असतात. "Incredible" हा शब्द दोन tokens आहे. "AI" एक token आहे. शब्दाआधीचा space अनेकदा त्याच token मध्ये bundled असतो.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: #7B61FF;">
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Quick math</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          1 token &asymp; 4 characters &asymp; 0.75 शब्द<br />
          100 tokens &asymp; 75 शब्द<br />
          एक typical page &asymp; 300 tokens<br />
          एक संपूर्ण novel &asymp; 100,000 tokens
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        हे का महत्त्वाचं आहे? कारण प्रत्येक AI model चा <strong>context window size</strong> tokens मध्ये मोजला जातो. Claude चा context window 200,000 tokens ठेवू शकतो &mdash; म्हणजे साधारण 500-पानांचं पुस्तक. GPT-4o 128,000 ठेवतो. हे प्रचंड वाटतं, पण तुला वाटतं त्यापेक्षा लवकर भरतं.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        तू पाठवलेला प्रत्येक message, AI ने लिहिलेला प्रत्येक response, मागे काम करणारा प्रत्येक system instruction &mdash; हे सगळे एकाच shared budget मधून tokens consume करतात. आणि जेव्हा budget संपतो, तेव्हा गोष्टी कडेवरून पडायला लागतात.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: CONTEXT WINDOW VIZ ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ContextWindowViz client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ WHEN THE WINDOW OVERFLOWS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Window ओव्हरफ्लो झाल्यावर
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        तू दहा messages conversation मध्ये आहेस. तिसऱ्या message मध्ये तू dietary restrictions सांगितल्यास. पंधराव्या message पर्यंत, restaurant recommendations बद्दल खोल चर्चा चालू आहे. तू विचारतोस: <em>"मी कुठले dietary restrictions सांगितले होते?"</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        आणि AI म्हणतो: <em>"तुम्ही कुठल्या specific dietary restrictions चा उल्लेख केला नाहीत असं वाटतं."</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        तुला frustration वाटतं. <em>ते तिथेच आहे, मी सांगितलं होतं!</em> पण गोष्ट अशी आहे: ते <strong>तिथे नाही.</strong> आता नाही. तो सुरुवातीचा message visible window मधून बाहेर गेला असेल, किंवा model ने recent context ला priority दिली असेल. AI निष्काळजी नाही. त्याला त्याच्या समोर जे नाही ते literally दिसत नाही.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>हा bug नाही. ही architecture आहे.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI context window process करतो एखादा माणूस एका बैठकीत document वाचतो तसं. Document 100 पानांचं असेल तर, पान 3 वरच्या details पान 95 पर्यंत fuzzy होऊ शकतात. Solution मोठी window नाही &mdash; आत काय जातं ते smartly pack करणं आहे.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FORGETTING EXPERIMENT ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ForgettingExperiment client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SYSTEM PROMPT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        System Prompt: लपलेल्या सूचना
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        प्रत्येक AI conversation चा एक भाग आहे जो तुला कधीच दिसत नाही. तुझ्या पहिल्या message आधी, AI hello म्हणण्याआधी, context window च्या अगदी वर एक text block बसलेला असतो. त्याला <strong>system prompt</strong> म्हणतात, आणि तो पुढे होणाऱ्या सगळ्या गोष्टींना shape देतो.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        System prompt मध्ये AI ला personality, rules, boundaries मिळतात. जेव्हा ChatGPT weapon बनवायला मदत करायला नकार देतो, तो system prompt आहे. जेव्हा Claude म्हणतो "I'd be happy to help," ती trained behavior आहे जी system prompt ने reinforce केली आहे. जेव्हा customer service chatbot topic वर राहतो, तो &mdash; बरोबर ओळखलंस &mdash; system prompt आहे.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style="--accent: #7B61FF;">
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Example system prompt</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          "तू एक helpful cooking assistant आहेस. फक्त cooking आणि food preparation बद्दलच्या प्रश्नांची उत्तरं दे. दुसरं काही विचारलं तर नम्रपणे conversation cooking कडे redirect कर. Responses 150 शब्दांच्या आत ठेव. Warm, encouraging tone वापर."
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        System prompt special आहे कारण तो <strong>context window च्या वर pinned राहतो</strong>. Conversation किती लांब गेली तरी, system prompt scroll होत नाही. तो नेहमी तिथे असतो, नेहमी AI च्या behavior वर influence करत. त्यामुळे तो संपूर्ण context window मधला सर्वात valuable real estate आहे.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        System prompt म्हणजे AI ची job description. तो AI ला काय बोलायचं ते सांगत नाही &mdash; तो AI ला कोण <em>असायचं</em> ते सांगतो.
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: SYSTEM PROMPT SANDBOX ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <SystemPromptSandbox client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONTEXT ENGINEERING STRATEGIES ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Context Manage करण्याच्या Strategies
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14">
        आता window समजली, तर ती pro सारखी manage कशी करायची ते शिक. या techniques आहेत ज्या "AI वापरणारे" आणि AI कडून extraordinary results मिळवणारे यांना वेगळं करतात.
      </p>
    </FadeInBlock>

    <!-- Strategies — editorial layout matching ch1's building blocks -->
    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { num: '1', name: 'जसजसं पुढे जा तसं summarize कर', color: '#7B61FF', text: 'दर 5-10 messages नंतर, AI ला key decisions आणि details चा छोटा recap लिहायला सांग. मग तो summary तुझ्या पुढच्या message मध्ये paste कर. यामुळे context "reset" होतो सर्वात महत्त्वाची माहिती सर्वात पुढे ठेवून.' },
        { num: '2', name: 'महत्त्वाचं पुढे ठेव', color: '#16C79A', text: 'सर्वात critical माहिती message च्या सुरुवातीला ठेव, शेवटी गाडू नकोस. AI सुरुवातीला आणि शेवटी जे येतं त्याकडे जास्त लक्ष देतो — मधला भाग हरवू शकतो, विशेषतः लांब prompts मध्ये.' },
        { num: '3', name: 'नवीन conversation strategically सुरू कर', color: '#0EA5E9', text: 'विषय खूप बदलल्यावर नवीन conversation सुरू करायला घाबरू नकोस. पूर्ण history नव्हे तर निर्णयांचा summary carry over कर. Clean context अनेकदा cluttered context पेक्षा चांगला असतो.' },
        { num: '4', name: 'काय लक्षात ठेवायचं ते explicitly सांग', color: '#F5A623', text: '"महत्त्वाचं: user vegetarian आहे. हे विसरू नकोस." मूर्ख वाटतं, पण काम करतं. Explicit reminders anchors सारखे काम करतात ज्यांना AI जास्त weight देतो.' },
        { num: '5', name: 'Structured formats वापर', color: '#E94560', text: 'Bulleted lists, headers, आणि clear labels AI ला तुझा context जास्त efficiently parse करायला मदत करतात. व्यवस्थित organized prompt prose च्या भिंतीपेक्षा दुप्पट token count इतका valuable आहे.' },
      ].map((strategy, i) => (
        <FadeInBlock client:visible delay={i * 0.08}>
          <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${strategy.color};`}>
              {strategy.num}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${strategy.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {strategy.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {strategy.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
