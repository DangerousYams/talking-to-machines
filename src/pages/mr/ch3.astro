---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ContextWindowViz from '../../components/widgets/ch3/ContextWindowViz';
import VibeCheck from '../../components/breaks/VibeCheck';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[2];
---

<ChapterLayout chapter={chapter} locale="mr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>3</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          अध्याय तीन
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Context<br />Engineering
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          AI विसरत नाही &mdash; तो मुळात<br />लक्षात ठेवतच नव्हता.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        प्रत्येक वेळी तू AI ला message पाठवतोस, तो तुझं <em>संपूर्ण conversation</em> सुरुवातीपासून वाचतो &mdash; तू पाठवलेला प्रत्येक message, त्याने दिलेला प्रत्येक response &mdash; reply generate करतो, आणि मग सगळं विसरतो. पुढच्या turn ला, तेच. संपूर्ण transcript परत feed होतो. तो जगातला सर्वात मेहनती पण amnesiac वाचक आहे: प्रत्येक वेळी पूर्णपणे thorough, प्रत्येक turn ला zero पासून सुरू.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONCEPT SETUP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Window ला कडा आहेत
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10" style="margin-top: 0;">
        तो transcript जो AI प्रत्येक turn ला परत वाचतो? तो <strong>context window</strong> नावाच्या गोष्टीत राहतो &mdash; <strong>tokens</strong> मध्ये मोजला जातो (साधारण एक token म्हणजे एका शब्दाचा तीन-चतुर्थांश भाग). Claude चं window साधारण 200,000 tokens धरतं &mdash; 500 पानांचं पुस्तक. खूप मोठं वाटतं, पण तू पाठवलेला प्रत्येक message, मिळालेला प्रत्येक response, आणि प्रत्येक hidden system instruction — सगळे एकाच budget मधून खातात. ते तुला वाटतं त्यापेक्षा लवकर भरतं.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Budget संपलं की सर्वात जुने messages कडेवरून पडतात. तू message तीन मध्ये तुझ्या dietary restrictions सांगितल्या? Message पंधरा पर्यंत AI ला ते कदाचित दिसणार नाहीत. तो बेजबाबदार नाहीये &mdash; जे त्याच्या समोर नाही ते त्याला अक्षरशः दिसत नाही. AI फक्त तेवढाच चांगला आहे जेवढी information सध्या त्याच्या window मध्ये आहे.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        म्हणूनच सर्वात चांगले AI users फक्त चांगले prompts लिहित नाहीत &mdash; ते window मध्ये काय <em>जातं</em> ते manage करतात. वेळोवेळी summarize कर म्हणजे महत्त्वाचे details दिसत राहतील. महत्त्वाचं आधी ठेव. Topic बदलला की fresh सुरू कर. Structured formats वापर म्हणजे AI तुझा context efficiently parse करू शकेल. <strong>Context engineering हे नवीन prompt engineering आहे.</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Key insight</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          चांगला prompt लिहिणं हे step one आहे. AI समोर कोणती information ठेवायची &mdash; आणि ती कशी structure करायची &mdash; इथे खरा leverage आहे. जगातला सर्वात चांगला prompt context चुकीचा असेल तर fail होतो.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Context window भरताना, overflow होताना, आणि विसरताना बघ &mdash; real time मध्ये.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ContextWindowViz client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="शेवटी कळलं AI conversation मध्ये गोष्टी का 'विसरतो'. ती memory नाही — ते context window आहे. हा course live demos सोबत इतकं स्पष्ट समजावतो." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        आता तुला whiteboard दिसतोय. Window च्या कडा जाणवतायत. ते AI सोबतचं प्रत्येक conversation बदलतं.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        आतापर्यंत आपण chatbots सोबत काम करत होतो. पुढे, आपण zoom out करतो &mdash; chat window पलीकडे शेकडो AI tools अस्तित्वात आहेत, आणि landscape माहीत असणं तुला काय possible वाटतं ते बदलतं.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Vibe Check" client:visible>
        <VibeCheck client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
