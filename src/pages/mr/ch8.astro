---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import ProjectOrchestrator from '../../components/widgets/ch8/ProjectOrchestrator';
import ContextPacking from '../../components/widgets/ch8/ContextPacking';

const chapter = chapters[7];
---

<ChapterLayout chapter={chapter} locale="mr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>8</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          धडा आठ
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          गुंतागुंतीच्या<br />ऑर्केस्ट्रेशन
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          कोणत्याही context window पेक्षा मोठे<br />प्रोजेक्ट्स व्यवस्थापित करणे.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        प्रत्येक महत्वाकांक्षी नवशिक्या यांना असा एक क्षण येतो: तुम्ही AI ला खरोखर काहीतरी तयार करायला सांगता — एक पूर्ण गेम, backend असलेली वेबसाइट, citations असलेला संशोधन पेपर — आणि सर्व काही कोसळते. AI पुरेसे स्मार्ट नसल्यामुळे नाही. तर प्रोजेक्ट एकाच conversation साठी खूप मोठे असल्यामुळे.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        तुम्ही आवश्यकतांची भिंत paste करता, AI तुम्हाला आत्मविश्वासपूर्ण वाटणारे उत्तर देते, आणि वीस मिनिटांनंतर तुम्हाला लक्षात येते की त्याने तुम्ही विचारलेल्या अर्ध्या गोष्टी विसरल्या आहेत, architecture बद्दल विरोधाभासी गोष्टी सांगितल्या आहेत, आणि अस्तित्वातच नसलेल्या library चे hallucination केले आहे. तुम्ही पुन्हा प्रयत्न करता. समान परिणाम, वेगळे hallucinations.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        ही AI समस्या नाही. ही <strong>ऑर्केस्ट्रेशनची समस्या</strong> आहे. आणि ती सोडवायला शिकणे म्हणजे AI चा one-off कामांसाठी वापर करणाऱ्या व्यक्तीमध्ये आणि खरी गोष्टी तयार करण्यासाठी वापर करणाऱ्या व्यक्तीमधला फरक.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE ONE-PROMPT TRAP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        One-Prompt ची जाळी
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        जेव्हा तुम्ही AI वापरायला शिकता, तेव्हा तुम्ही नैसर्गिकपणे सर्व काही एकाच shot मध्ये करण्याचा प्रयत्न करता. एक मोठे प्रॉम्प्ट. एक conversation. एक प्रयत्न. आणि साध्या कामांसाठी — ईमेल लिहिणे, कल्पना करणे, concept समजावणे — ते ठीक काम करते.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        पण गुंतागुंत one-prompt approach तीन रीतीने तोडते:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 2.5rem;">
        {[
          { num: '1', title: 'Context overflow', text: 'AI एकाच वेळी इतकीच माहिती ठेवू शकते. पूर्ण प्रोजेक्ट त्या मर्यादेलाच ओलांडतो, त्यामुळे AI तुमच्या आधीच्या आवश्यकता "विसरू" लागते.' },
          { num: '2', title: 'Attention dilution', text: 'Context window मधेही, AI ला बारा वेगवेगळ्या गोष्टी एकाच वेळी सांभाळायला सांगितले तर प्रत्येकावर कमी फोकस मिळतो. सर्वत्र quality घसरते.' },
          { num: '3', title: 'Error compounding', text: 'गुंतागुंतीच्या output मध्ये एक छोटीशी चूक वाढत जाते. AI ने database schema चुकीचे केले तर त्या schema वर बनवलेले सर्व काही चुकीचे होते — आणि generated code च्या भिंतीत ते शोधणे कठीण.' },
        ].map((item, i) => (
          <FadeInBlock client:visible delay={0.2 + i * 0.08}>
            <div style="display: flex; gap: 1.25rem; align-items: flex-start;">
              <div style={`flex-shrink: 0; width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 0.8rem; font-weight: 700; color: white; background: ${chapter.accent};`}>
                {item.num}
              </div>
              <div style="flex: 1;">
                <p style={`font-family: var(--font-heading); font-size: 1rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.3rem; line-height: 1.3;`}>
                  {item.title}
                </p>
                <p style="font-size: 0.95rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                  {item.text}
                </p>
              </div>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.5}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        उपाय चांगले प्रॉम्प्ट नाही. चांगली प्रक्रिया आहे.
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ DECOMPOSITION: THE MASTER SKILL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        डीकम्पोझिशन: मास्टर स्किल
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        व्यावसायिक software engineers संपूर्ण applications एकाच बसण्यात तयार करत नाहीत. ते त्यांचे तुकडे करतात — modules, components, functions — प्रत्येकाचा स्पष्ट उद्देश, स्पष्ट inputs आणि स्पष्ट outputs. मग ते त्यांना जोडतात.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        गुंतागुंतीच्या प्रोजेक्ट्सवर AI सोबत काम करताना तीच शिस्त लागते. तुम्हाला तुमचे प्रोजेक्ट अशा कामांमध्ये <strong>decompose</strong> करावे लागेल जे एकाच, focused AI conversation मध्ये चांगल्या पद्धतीने handle होऊ शकतील.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        चांगले decomposition तीन नियम पाळते:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
        <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
        {[
          { word: 'Single responsibility.', desc: 'प्रत्येक काम एकच गोष्ट करते. "Database design करा आणि API बनवा आणि frontend लिहा" ही तीन कामे आहेत, एक नाही.' },
          { word: 'Clear interfaces.', desc: 'प्रत्येक कामाचे defined input (सुरुवातीसाठी काय लागते) आणि defined output (काय तयार करते) असते. एका कामाचे output दुसऱ्या कामाचे input होते.' },
          { word: 'Minimal dependencies.', desc: 'जी कामे parallel मध्ये होऊ शकतात ती पाहिजेत. फक्त तेव्हाच dependency तयार करा जेव्हा एका कामाला खरोखरच दुसऱ्याच्या output ची गरज असे.' },
        ].map((step, i) => (
          <div style={`position: relative; padding-bottom: ${i < 2 ? '1.75rem' : '0'};`}>
            <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
            <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
              <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
              <span style="opacity: 0.7;"> {step.desc}</span>
            </p>
          </div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Decomposition हे मानवी skill आहे, AI चे नाही.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI तुम्हाला task breakdown brainstorm करण्यात मदत करू शकते, पण काम कसे विभागायचे, काय कशावर अवलंबून आहे, आणि कशाला प्राधान्य द्यायचे — हे तुमचे काम आहे. हे project management आहे, आणि तुम्ही develop करू शकणाऱ्या सर्वात मौल्यवान skills पैकी एक.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO PROJECT ORCHESTRATOR -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        खऱ्या प्रोजेक्ट चा decomposition करण्याचा प्रयत्न करा. Tasks drag करा, dependencies track करा, plan आकार घेताना बघा.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: PROJECT ORCHESTRATOR ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ProjectOrchestrator client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE HANDOFF PATTERN ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Handoff Pattern
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        एकदा तुम्ही प्रोजेक्ट tasks मध्ये मोडला की, तुम्हाला त्यांना जोडण्याचा मार्ग हवा. AI workflows मध्ये, हे connection म्हणजे <strong>handoff</strong> — तो क्षण जेव्हा एका conversation चे output दुसऱ्याचे input होते.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: var(--color-navy);">
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Handoff Pattern</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          Conversation 1 एक <strong>artifact</strong> तयार करते — document, schema, plan.<br />
          ते artifact Conversation 2 मध्ये <strong>context</strong> म्हणून paste केले जाते.<br />
          Conversation 2 त्यावर आधारित काम करून पुढचे artifact तयार करते.<br />
          प्रोजेक्ट पूर्ण होईपर्यंत repeat करा.
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        हे relay race सारखे आहे. प्रत्येक runner (conversation) आपला भाग पूर्ण करतो आणि baton (artifact) पुढच्या runner ला देतो. Baton हा महत्वाचा भाग आहे — जर तो गळला किंवा बिघडला, तर पुढचा runner अडकतो.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        याचा अर्थ तुमच्या handoff artifacts <em>crisp</em> असाव्या लागतात. Database schema हे data model च्या अस्पष्ट वर्णनापेक्षा चांगले handoff आहे. API endpoints ची numbered list "user stuff handle करणारा backend हवा" पेक्षा चांगली. Artifact जितके sharp असेल, तितके पुढचे conversation चांगले perform करेल.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        तुमच्या handoff artifact ची quality downstream मध्ये बनवल्या जाणाऱ्या सर्व गोष्टींची quality ठरवते. Garbage in, garbage out — conversations मध्ये.
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONTEXT PACKING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Context Packing ची कला
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        जेव्हा तुम्ही नवीन AI conversation सुरू करता, तेव्हा तुम्ही असा निर्णय घेत आहात जे बहुतेकांच्या लक्षातही येत नाही: <strong>कोणता context include करायचा?</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        तुमचे मर्यादित budget आहे — context window. आणि तुमच्याकडे संभाव्य relevant माहितीचा ढीग आहे: code files, documentation, मागच्या conversations, error logs, design specs. सर्व काही fit होणार नाही. आणि झाले तरी, सर्व काही dump केल्याने AI चे attention dilute होईल.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        Context packing हे trip साठी सामान pack करण्यासारखे आहे. तुम्ही तुमचा संपूर्ण wardrobe आणू शकत नाही. तुम्हाला विचार करावा लागेल कुठे जात आहात (task), कशाची गरज पडेल (relevant information), आणि काय मागे ठेवू शकता (बाकी सर्व काही).
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div style="display: flex; flex-direction: column; gap: 1.25rem; margin-bottom: 2.5rem;">
        {[
          { label: 'खूप कमी context', color: '#E94560', text: 'AI ला जे हवे आहे ते मिळत नाही आणि तो gaps hallucinations ने भरतो. आत्मविश्वासाने वाटतो पण तपशील बनवतो.' },
          { label: 'खूप जास्त context', color: '#F5A623', text: 'AI overwhelm होतो. महत्वाचे तपशील noise मध्ये हरवतात. Output generic आणि unfocused होते.' },
          { label: 'योग्य context', color: '#16C79A', text: 'AI ला या specific task साठी नक्की जे हवे आहे ते मिळते. Output precise, relevant आणि actionable होते.' },
        ].map((item, i) => (
          <FadeInBlock client:visible delay={0.25 + i * 0.08}>
            <div style={`padding: 1rem 1.25rem; border-radius: 10px; border-left: 3px solid ${item.color}; background: ${item.color}08;`}>
              <p style={`font-family: var(--font-heading); font-size: 0.9rem; font-weight: 700; color: ${item.color}; margin: 0 0 0.25rem;`}>
                {item.label}
              </p>
              <p style="font-size: 0.9rem; line-height: 1.7; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {item.text}
              </p>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Editor सारखे विचारा, जमावदाराने नाही.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          प्रत्येक AI interaction आधी स्वतःला विचारा: या specific task साठी AI ला काय <em>माहिती हवी</em>? ते include करा. बाकी सर्व काही सोडा. हेच आहे context engineering applied to project management.
        </p>
