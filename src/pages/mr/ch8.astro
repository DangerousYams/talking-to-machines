---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import StackDecoder from '../../components/widgets/ch8/StackDecoder';
import ComplexityScore from '../../components/breaks/ComplexityScore';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[7];
---

<ChapterLayout chapter={chapter} locale="mr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>8</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          अध्याय आठ
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Complexity चं<br />Orchestration
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          कोणत्याही context window पेक्षा मोठ्या<br />projects मध्ये AI manage करणं.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        प्रत्येक ambitious beginner ला हा moment येतो: तू AI ला काहीतरी खरं build करायला सांगतोस — एक पूर्ण game, backend सोबत website, citations सोबत research paper — आणि सगळं कोलमडतं. AI पुरेसा smart नाही म्हणून नाही. कारण project एका single conversation साठी खूप मोठा आहे. तू requirements ची भिंत paste करतोस आणि वीस मिनिटांनी कळतं की त्याने तू सांगितलेलं अर्धं विसरलं.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        ही AI ची समस्या नाही. ही <strong>orchestration</strong> ची समस्या आहे. आणि ती सोडवायला शिकणं हाच one-off tasks साठी AI वापरणारा आणि खऱ्या गोष्टी build करणारा यातला फरक आहे.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONTEXT PACKING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Context Packing ची कला
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Complex projects one-prompt approach तोडतात. Context overflow होतो, attention dilute होतं, errors compound होतात. Fix चांगला prompt नाही — <strong>decomposition</strong> आहे. Project focused tasks मध्ये तोड, मग प्रत्येक task साठी काळजीपूर्वक निवड AI ला खरोखर कोणता context लागतो. खूप कमी म्हणजे hallucinations. खूप जास्त म्हणजे focus गमावतो. Sweet spot म्हणजे surgical precision.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Suitcase pack करण्यासारखं विचार कर. तू तुझं संपूर्ण कपाट घेऊन जाऊ शकत नाहीस. तुला विचार करावा लागतो कुठे जातोयस (task), काय लागेल (relevant information), आणि काय सोडता येईल (बाकी सगळं). प्रत्येक conversation ला नेमका तेवढाच context मिळतो जेवढा लागतो — जास्त नाही, कमी नाही.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style="font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;">Key insight</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          तुझ्या handoff artifact ची quality downstream बनणाऱ्या सगळ्यांची quality ठरवते. एक crisp schema अस्पष्ट description पेक्षा नेहमी जिंकतो. Garbage in, garbage out — conversations मध्ये पण.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Context suitcase pack कर. Overflow न होता महत्त्वाचं fit करू शकतोस का?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <StackDecoder client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="AI चा सर्वात कठीण भाग prompting नाही — multiple conversations मध्ये complex projects orchestrate करणं आहे. हा course शेवटी ते कसं करायचं समजावतो." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style="border-color: var(--color-navy); max-width: 50ch; margin: 0 auto 2rem;">
        Complex projects भयंकर नसतात. ते फक्त crisp artifacts ने जोडलेल्या focused conversations ची मालिका असतात.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        पुढे: AI कधी <em>चुकतो</em> ते ओळखणं. Hallucinations, sycophancy, आणि तुला honest ठेवणाऱ्या verification सवयी.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(15,52,96,0.06) 15%, rgba(15,52,96,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#0F3460" toolName="Complexity Score" client:visible>
        <ComplexityScore client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
