---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import WhatWouldYouBuild from '../../components/widgets/ch7/WhatWouldYouBuild';
import ShipIt from '../../components/breaks/ShipIt';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';
import ForYouCard from '../../components/ui/ForYouCard';

const chapter = chapters[6];
const conceptsSummary = chapter.concepts.map(c => c.name).join(', ');
---

<ChapterLayout chapter={chapter} locale="mr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>7</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          अध्याय सात
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          हे कोणीही<br />बनवू शकतं
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          तुला programmer असायला नको.<br />तुला एक idea हवी.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Ohio मधल्या एका teacher ने weekend मध्ये grading app बनवली. एका musician ने setlist optimizer बनवला जो energy आणि key नुसार गाणी arrange करतो. एका high school junior ने debate prep tool बनवलं जे कोणत्याही resolution साठी counterarguments generate करतं. यांपैकी कोणीही programmer नाही. कोणीही coding class गेलं नाही. त्यांनी काय हवं ते describe केलं, आणि coding agent ने बनवलं.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        हा unlock कोणाला expected नव्हता. Coders fast झाले हे नाही &mdash; पण <strong>non-coders software बनवू शकतात हेच खरं.</strong> जसं spreadsheets ने data analysis democratize केलं आणि Canva ने graphic design, तसंच AI coding agents software development स्वतःच democratize करतायत.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ PERSONAL SOFTWARE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Personal Software Revolution
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        ही idea सगळं बदलते: <strong>personal software.</strong> एकाच audience साठी बनवलेली tools &mdash; तू. Market research नाही, business plan नाही, venture funding नाही. फक्त तुझी एक problem आणि ती solve करणारं tool. AI आधी personal software बनवायचं म्हणजे coding शिकणं, जे महिने किंवा वर्षं लागतात. आता एक दुपार लागते. बनवण्याची cost जवळजवळ शून्यावर आली आहे &mdash; म्हणजे आता फक्त बनवण्यासारखी idea असणं महत्त्वाचं आहे.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        हे शक्य करणाऱ्या tools ना <strong>coding agents</strong> म्हणतात. Claude Code, Cursor, Antigravity, Replit &mdash; हे AI tools आहेत जे तुझा पूर्ण project वाचू शकतात, multiple files मध्ये code लिहू शकतात, run करू शकतात, error आला तर fix करू शकतात, आणि परत run करू शकतात. तू एकही line of code ला हात न लावता. ते autocomplete नाहीत. ते AI collaborators आहेत जे तुझ्या descriptions ला working software मध्ये बदलतात.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Director ची भूमिका</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          तू code लिहित नाहीस. तू <strong>direct</strong> करतोस. तुझं काम आहे काय बनवायचं ते specify करणं, output evaluate करणं, आणि बरोबर होईपर्यंत iterate करणं. Agent technical execution handle करतो. स्वतःला film director समज &mdash; तू camera operate करत नाहीस, पण तुझ्या vision शिवाय काहीच बनत नाही.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE AGENT AS GUIDE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        तुझा Agent तुला जे माहीत नाही ते सगळं जाणतो
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        "पण मला database म्हणजे काय ते माहीत नाही." Good news: तुला माहीत असायला नको. तुझा coding agent तुझा tutor पण आहे. काहीही विचार. "React component म्हणजे काय?" तो explain करेल. "हे internet वर कसं deploy करायचं?" तो step by step guide करेल. "या error चा काय अर्थ आहे?" तो jargon plain English मध्ये translate करेल.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        हेच safety net आहे जे बाकी सगळं possible बनवतं. तुला technical vocabulary पाठ करायची गरज नाही &mdash; तुला फक्त ती <em>आहे</em> हे माहीत असायला हवं जेणेकरून तू विचारू शकशील. Agent प्रत्येक gap भरतो. हे एखाद्या धीर, अथक expert सारखं आहे जो तुझ्या शेजारी बसलाय आणि basic प्रश्न विचारल्याबद्दल कधीच judge करत नाही.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Skill Paradox</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          तुला output <em>evaluate</em> करण्याइतकं knowledge लागतं, प्रत्येक line लिहिण्याइतकं नाही. Film director ला camera कसा बनवायचा माहीत नसतं &mdash; पण shot बरोबर दिसतंय का ते माहीत असतं. इथे तसंच आहे: app काम करतंय का हे माहीत असायला हवं, code कसा काम करतो हे नाही.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Non-coders ने काय बनवलंय ते browse कर &mdash; मग स्वतःचं imagine कर.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="what-would-you-build" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <WhatWouldYouBuild client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <div class="py-8">
    <ForYouCard
      chapterSlug={chapter.slug}
      chapterTitle={chapter.title}
      chapterConcepts={conceptsSummary}
      accentColor={chapter.accent}
      client:load
    />
  </div>
  <SharePrompt text="या chapter ने मला convince केलं की AI सोबत कोणीही software बनवू शकतं. Hand-wavy नाही — non-coders कसं real tools बनवतायत ते exactly दाखवतं." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Software बनवण्याची cost शून्यावर आली. आता फक्त बनवण्यासारखी idea असणं उरलंय.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        तुझ्याकडे idea आहे. पण coding agent उघडण्याआधी, तुला त्याची भाषा बोलता यायला हवी. Code नाही &mdash; फक्त building ची vocabulary. ती पुढे येतेय.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Ship It" client:visible>
        <ShipIt client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
