---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import TerminalPlayground from '../../components/widgets/ch7/TerminalPlayground';
import SkillBuilder from '../../components/widgets/ch7/SkillBuilder';
import RefactorRace from '../../components/widgets/ch7/RefactorRace';

const chapter = chapters[6];
---

<ChapterLayout chapter={chapter} locale="mr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>7</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          सातवा अध्याय
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Claude Code<br />मास्टर करणे
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          तुमचा AI जोडीदार प्रोग्रामर, पहिल्या कमांड<br />पासून ते कस्टम Skills पर्यंत.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        एक क्षण असतो जो प्रत्येक कोडरला आठवतो. तुम्ही टर्मिनल उघडता, साध्या भाषेत एक request टाइप करता, आणि AI तुमची files वाचताना, तुमचे architecture समजून घेताना, अनेक files मध्ये code लिहिताना, चालवताना, error आल्यावर दुरुस्त करताना, आणि पुन्हा चालवताना पाहात राहाता — तुम्ही एकही line स्पर्श न करता. तेच म्हणजे Claude Code.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        हे autocomplete नाही. हे snippets लिहिणारा chatbot नाही. Claude Code हे एक <em>agentic</em> coding tool आहे — एक command-line जोडीदार जो तुमचा संपूर्ण project बघू शकतो, files मध्ये बदल करू शकतो, shell commands execute करू शकतो, आणि स्वतःच्या चुकांमधून शिकू शकतो. हे फक्त code suggest करत नाही. हे code <strong>ship</strong> करतो.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        पण हे tool फक्त तितकेच चांगले आहे जितका चांगला मानूष त्याला चालवतो. Claude Code हजारो lines चा परफेक्ट code सेकंदांत लिहू शकतो — किंवा हजारो lines चा दिसण्यात reasonable असलेला कचरा. फरक तुम्हीच आहात.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ HOW CLAUDE CODE THINKS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Claude Code कसा विचार करतो
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        जेव्हा तुम्ही Claude Code ला काही task देता, तो लगेच typing सुरू करत नाही. तो Chapter 6 मधील agent loop चालवतो, code साठी विशेष बनवलेला:
      </p>
    </FadeInBlock>

    <!-- Agent loop visualization -->
    <FadeInBlock client:visible delay={0.15}>
      <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
        <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
        {[
          { word: 'वाच.', desc: 'Codebase स्कॅन करा — files, imports, tests, configs. काय अस्तित्वात आहे ते समजून घ्या.' },
          { word: 'योजना.', desc: 'कोणत्या files मध्ये, कशाचे, कोणत्या क्रमाने बदल करायचे ते ठरवा.' },
          { word: 'लिहा.', desc: 'Edits करा. Files तयार करा. Code modify करा.' },
          { word: 'चालवा.', desc: 'Commands execute करा — build, test, lint. काय होते ते पहा.' },
          { word: 'दुरुस्त.', desc: 'जर काही बिघडले असेल तर error वाचा, adjust करा, आणि पुन्हा प्रयत्न करा.' },
        ].map((step, i) => (
          <div style={`position: relative; padding-bottom: ${i < 4 ? '1.75rem' : '0'};`}>
            <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
            <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
              <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
              <span style="opacity: 0.7;"> {step.desc}</span>
            </p>
          </div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        हा वाच-योजना-लिहा-चालवा-दुरुस्त loop हेच Claude Code ला साध्या code generator पासून वेगळे करते. हे तुम्हाला snippet देऊन निघून जात नाही. ते <em>loop मध्येच रहाते</em> — code खरोखरच work करेपर्यंत iterate करत राहते.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85]">
        याचा विचार pair programming सारखा करा. तुम्ही वर्णन करता काय हवे आहे. Claude Code ते लिहितो. Tests fail होतात. Claude Code error वाचतो, adjust करतो, re-run करतो. हे cycle तीन, पाच, दहा वेळा होऊ शकते — सर्व काही सेकंदांत.
      </p>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO TERMINAL PLAYGROUND -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        हा loop कसा काम करतो ते पहा. एक request टाइप करा आणि Claude Code काम करताना बघा.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: TERMINAL PLAYGROUND ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <TerminalPlayground client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE CLAUDE.MD FILE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        CLAUDE.md File
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        बहुतेक beginners हे चुकवतात: <strong>तुम्ही Claude Code ला कायमस्वरूपी instructions देऊ शकता.</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        तुमच्या project च्या root मध्ये <code>CLAUDE.md</code> नावाची file टाका, आणि Claude Code प्रत्येक session च्या सुरुवातीला ती वाचतो. हे system prompt सारखे आहे, पण तुमच्या संपूर्ण codebase साठी.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>CLAUDE.md</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep); font-family: var(--font-mono); font-size: 0.85rem;">
          # माझा Project<br /><br />
          Tech stack: Astro + React + Tailwind<br />
          नेहमी TypeScript वापरा strict mode सह.<br />
          Components src/components/ मध्ये ठेवा.<br />
          प्रत्येक नवीन function साठी tests लिहा.<br />
          Prettier formatting वापरा — config कधीही बदलू नका.<br /><br />
          ## Style Rules<br />
          - Default exports पेक्षा named exports ला प्राधान्य द्या<br />
          - Inline styles नाही, CSS modules वापरा<br />
          - Components 150 lines पेक्षा कमी ठेवा
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        CLAUDE.md शिवाय, तुम्ही प्रत्येक session च्या पहिल्या काही मिनिटे तुमची preferences पुन्हा समजावून सांगण्यात घालवता. त्यासह, Claude Code ला तुमचा stack, तुमची conventions, आणि तुमच्या boundaries आधीच माहीत असतात. हे context engineering (Chapter 3) आहे coding साठी applied.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>CLAUDE.md चा विचार तुमच्या project च्या constitution सारखा करा.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          हे तुम्ही आधीच घेतलेले निर्णय encode करते — त्यामुळे AI नवीन निर्णयांवर focus करू शकते. तुमची CLAUDE.md जितकी specific, तितके कमी तुम्हाला स्वतःला repeat करावे लागते.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BUILDING SKILLS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Skills बनवणे
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        CLAUDE.md Claude Code ला तुमच्या project बद्दल सामान्य knowledge देते. पण specific, repeatable tasks चे काय? तिथे <strong>Skills</strong> काम येतात.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Skill म्हणजे तुमच्या CLAUDE.md मधील instructions चा एक set जो Claude Code ला specific प्रकारचे task कसे handle करायचे ते शिकवतो. हे recipe सारखे आहे: "जेव्हा कोणी तुम्हाला नवीन React component बनवायला सांगते, तेव्हा अगदी असे करा."
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        Skills शिवाय, तुम्ही प्रत्येक वेळी तीच steps समजावून सांगाल. Skills सह, तुम्ही एकदाच समजावा आणि AI कायमचे लक्षात ठेवते.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        चांगल्या skill चे तीन भाग असतात:
      </p>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { letter: 'T', name: 'Trigger', color: '#7B61FF', text: 'हे skill कधी activate होते? "Component बनवायला सांगितल्यावर..." किंवा "Test failure fix करताना..." स्पष्ट triggers AI ला चुकीची recipe वापरण्यापासून रोकतात.' },
        { letter: 'S', name: 'Steps', color: '#16C79A', text: 'नक्की काय करायचे, कोणत्या क्रमाने? Numbered steps सर्वात चांगले काम करतात. File locations, naming conventions, आणि required patterns बद्दल specific व्हा.' },
        { letter: 'E', name: 'Examples', color: '#F5A623', text: 'यशस्वी result कसा दिसतो ते दाखवा. Before-and-after, उदाहरण file structure, किंवा sample output. Examples च्या उपस्थितीत ambiguity मरते.' },
      ].map((block, i) => (
        <FadeInBlock client:visible delay={0.3 + i * 0.08}>
          <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${block.color};`}>
              {block.letter}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${block.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {block.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {block.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>
  </section>

  <!-- BRIDGE TO SKILL BUILDER -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        एक लिहून पहा. Trigger पासून ते steps पर्यंत ते examples पर्यंत skill बनवा.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: SKILL BUILDER ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <SkillBuilder client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ SPECIFY, GENERATE, VERIFY ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Specify, Generate, Verify
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        जेव्हा तुम्ही Claude Code सह काम करता, तेव्हा तुमचे काम बदलते. आता तुम्ही प्रत्येक line लिहिणारे नाहीत. तुम्ही असे आहात जे काय बनवायचे ते <strong>specify</strong> करतात, AI ला ते <strong>generate</strong> करू देतात, आणि मग <strong>verify</strong> करतात की ते खरोखरच बरोबर आहे का.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        हा loop — specify, generate, verify — हे मूलभूत workflow आहे:
      </p>
    </FadeInBlock>

    <!-- SGV Loop -->
    <FadeInBlock client:visible delay={0.2}>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12">
        {[
          { step: '01', title: 'Specify', desc: 'तुम्हाला काय हवे आहे याबद्दल precise व्हा. तुमची request जितकी clear, तितका कमी वेळ output दुरुस्त करण्यात जाईल. Edge cases, file locations, आणि expected behavior समाविष्ट करा.', color: '#7B61FF' },
          { step: '02', title: 'Generate', desc: 'Claude Code ला त्याचे काम करू द्या. Agent loop बघा — वाचणे, planning, लिहिणे, चालवणे, दुरुस्त करणे. Mid-cycle मध्ये interrupt करण्याचा मोह टाळा.', color: '#0EA5E9' },
          { step: '03', title: 'Verify', desc: 'हे तुमचे सर्वात महत्त्वाचे काम आहे. Code वाचा. Tests चालवा. Edge cases तपासा. तुम्ही मागितले तेच करतो का? हा code तुम्ही तुमचे नाव sign करू शकाल असा आहे का?', color: '#16C79A' },
        ].map((item) => (
          <div style={`background: ${item.color}06; border: 1px solid ${item.color}18; border-radius: 12px; padding: 1.25rem;`}>
            <div style={`font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700; color: ${item.color}; letter-spacing: 0.1em; margin-bottom: 0.5rem;`}>{item.step}</div>
            <div style={`font-family: var(--font-heading); font-size: 1rem; font-weight: 700; color: ${item.color}; margin-bottom: 0.5rem;`}>{item.title}</div>
            <p style="font-size: 0.85rem; line-height: 1.65; color: var(--color-deep); opacity: 0.7; margin: 0;">
              {item.desc}
            </p>
          </div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85] mb-10">
        बहुतेक beginners तिसरी step skip करतात. त्यांना code दिसते, reasonable वाटते, आणि पुढे जातात. असे व्हू नका. <strong>Generated code हा first draft आहे.</strong> तुमचे verification हे edit आहे जे त्याला publishable बनवते.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        विडंबना? AI जितक्या वेगाने code generate करते, तुमचे verification तितकेच <em>अधिक महत्त्वाचे</em> होते. Judgment शिवाय speed म्हणजे फक्त वेगवान चुका.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SKILL PARADOX ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
