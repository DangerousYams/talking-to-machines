---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import TerminalPlayground from '../../components/widgets/ch7/TerminalPlayground';
import ShipIt from '../../components/breaks/ShipIt';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[6];
---

<ChapterLayout chapter={chapter} locale="mr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>7</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          अध्याय सात
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Claude Code<br />मध्ये Master
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          तुझा AI pair programmer, पहिल्या<br />command पासून custom Skills पर्यंत.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        प्रत्येक coder ला एक moment लक्षात राहतो. तू terminal उघडतोस, natural-language request टाइप करतोस, आणि बघतोस एक AI तुझ्या files वाचतो, architecture समजतो, multiple files मध्ये code लिहितो, तो run करतो, error येतो, error fix करतो, आणि परत run करतो — तू एकही line ला हात न लावता. Claude Code autocomplete नाही. तो एक <em>agentic</em> coding tool आहे जो तुझा संपूर्ण project बघतो, files मध्ये changes करतो, shell commands execute करतो, आणि स्वतःच्या चुकांवर iterate करतो.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        पण tool तेवढंच चांगलं आहे जेवढा त्याला steer करणारा माणूस. Claude Code seconds मध्ये हजार lines चा perfect code लिहू शकतो — किंवा हजार lines चा बरोबर दिसणारा garbage. फरक तू आहेस.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE LOOP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Specify, Generate, Verify
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        जेव्हा तू Claude Code ला task देतोस, तो agent loop चालवतो: codebase वाचा, काय बदलायचं plan करा, edits लिहा, code run करा, जे तुटलं ते fix करा. तो हा loop तीन, पाच, दहा वेळा cycle करू शकतो — सगळं seconds मध्ये. तुझं काम आता प्रत्येक line लिहिणं नाही. ते <strong>specify</strong> करणं आहे काय build करायचं, AI ला <strong>generate</strong> करू देणं, आणि मग <strong>verify</strong> करणं की ते खरोखर बरोबर आहे. बहुतेक beginners शेवटचं step skip करतात. Code दिसतो, reasonable वाटतो, आणि ते पुढे जातात. तसा माणूस होऊ नकोस. Generated code हा first draft आहे. तुझं verification हे ते edit आहे जे तो publishable बनवतं.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Secret weapon म्हणजे <code>CLAUDE.md</code> file — तुझ्या project root मध्ये टाक आणि Claude Code प्रत्येक session च्या सुरुवातीला ते वाचतो. तुझा tech stack, naming conventions, style rules, testing expectations — सगळं एकदा encode केलं म्हणजे तुला कधीच repeat करावं लागत नाही. हे context engineering आहे coding ला applied.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>ध्येय प्रत्येक line लिहिणं नाही — प्रत्येक line समजणं आहे.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          जर तुला Claude ने generate केलेला code वाचता येत नाही, तर तू verify करू शकत नाहीस. सर्वात चांगले Claude Code users ते नाहीत जे सर्वात जास्त code generate करतात — ते ते आहेत जे सर्वात चांगले प्रश्न विचारतात आणि सर्वात सूक्ष्म bugs पकडतात.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Loop action मध्ये बघ. Request टाइप कर आणि Claude Code काम करताना बघ.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="terminal-playground" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <TerminalPlayground client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="हा Claude Code वरचा chapter भयंकर आहे — एक AI pair programmer problem वर विचार करताना, code लिहिताना, आणि स्वतःला debug करताना बघितला. Coding चं future इथे आहे." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Claude Code तुझ्यासाठी code लिहित नाही — तुझ्यासोबत code लिहितो.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        एक conversation एक task handle करू शकतं. पण खऱ्या projects मध्ये डझनभर असतात. पुढे: मोठ्या ambitions चे तुकडे AI execute करू शकेल अशा pieces मध्ये कसे करायचे.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Ship It" client:visible>
        <ShipIt client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
