---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import FactOrFabrication from '../../components/widgets/ch9/FactOrFabrication';
import SycophancyTest from '../../components/widgets/ch9/SycophancyTest';

const chapter = chapters[8];
---

<ChapterLayout chapter={chapter} locale="mr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>9</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          धडा नऊ
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          जेव्हा AI<br />चुकतो
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Amateurs आणि pros मध्ये फरक करणाऱ्या<br />verification च्या सवयी.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        एक uncomfortable गोष्ट सांगतो: ज्या AI ने नुकतंच तुझा flawless essay लिहायला मदत केली, तोच AI तितक्याच confidence ने तुला सांगू शकतो की Napoleon ने Waterloo ची लढाई जिंकली. तो hesitate करणार नाही. अडखळणार नाही. एक completely बनवलेला "fact" त्याच authoritative tone मध्ये सांगेल जो बाकी सगळ्यासाठी वापरतो.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        AI सोबत काम करण्याचा हा paradox आहे: <strong>जी fluency त्याला useful बनवते, तीच त्याला dangerous पण बनवते.</strong> AI ला काय खरं आहे ते माहीत नाही. त्याला काय खरं <em>वाटतं</em> ते माहीत आहे. आणि या दोन गोष्टी खूप, खूप वेगळ्या आहेत.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        हा chapter तुझा BS detector बनवण्यासाठी आहे. AI वाईट आहे म्हणून नाही, तर <em>त्यावर blindly trust करणं</em> वाईट आहे म्हणून. AI मधून सगळ्यात जास्त value काढणारे लोक तेच आहेत ज्यांना नक्की माहीत आहे की कधी trust करायचं आणि कधी verify करायचं.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE HALLUCINATION PROBLEM ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Hallucination ची समस्या
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI मध्ये, <strong>hallucination</strong> म्हणजे model अशी information generate करतो जी खरी वाटते पण actually चुकीची आहे — किंवा पूर्णपणे बनवलेली आहे. आणि हे तुला वाटतं त्यापेक्षा जास्त वेळा होतं.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: #6B7280;">
        <span class="prompt-block-label" style="color: #6B7280;">Example</span>
        <p class="m-0" style="color: var(--color-deep);">
          <strong>तू:</strong> "1987 ची <em>The Sands of Memory</em> ही novel कुणी लिहिली?"<br /><br />
          <strong>AI:</strong> "The Sands of Memory (1987) British author Margaret Thornton ने लिहिली. Post-war East Africa मधल्या colonialism आणि identity या themes explore करते. या work साठी Thornton ला Booker Prize nomination मिळालं होतं."
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        Legit वाटतंय, right? Name आहे, year आहे, subject आहे, award nomination पण आहे. <strong>यातलं काहीच खरं नाही.</strong> हे पुस्तक exist करत नाही. Margaret Thornton (या context मध्ये) exist करत नाही. AI ने सगळं invent केलं — आणि अगदी खऱ्या answer सारखं sound करवलं.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        असं का होतं? कारण AI models database मधून facts काढत नाहीत. ते <em>next most likely token predict करतात</em>. जेव्हा तू खऱ्या book बद्दल विचारतोस, training data मधले patterns त्याला correct information कडे guide करतात. जेव्हा तू अशा गोष्टीबद्दल विचारतोस जी exist करत नाही, तेव्हा model "मला माहीत नाही" म्हणत नाही. तो generate करतो की correct answer <em>कसं दिसलं असतं</em>.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Key insight</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI ला truth ची concept नाही. त्याला <em>plausibility</em> ची concept आहे. तो असा text generate करतो जो pattern मध्ये fit होतो — तो text reality शी match होतो की नाही याची पर्वा न करता.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONFIDENCE WITHOUT COMPETENCE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Competence नसताना Confidence
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI च्या hallucinations मधली सगळ्यात tricky गोष्ट ही नाही की ते होतात. ही आहे की <strong>AI कधीच uncertainty दाखवत नाही.</strong> एक माणूस जो unsure आहे तो hesitate करेल, hedge करेल, "मला वाटतं..." किंवा "मला नक्की माहीत नाही, पण..." म्हणेल. AI बनवलेले facts तितक्याच absolute confidence ने deliver करतो जितक्या ने well-established facts सांगतो.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AI किती confident वाटतो आणि तो actually किती accurate आहे यात कुठलाच connection नाही. चुकीचं उत्तर आणि बरोबर उत्तर बाहेरून एकसारखंच दिसतं.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        म्हणून "ते बरोबर वाटतंय" हा test बेकार आहे. Tone वरून, detail वरून, AI किती specific numbers किंवा names include करतो यावरून तू accuracy judge करू शकत नाहीस. या सगळ्या गोष्टी completely बनवलेल्या असू शकतात — आणि बऱ्याचदा असतात पण.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        असा विचार कर: AI म्हणजे एक खूप convincing actor जो हजारो scripts वाचलेला आहे. कुठलीही line perfect conviction ने deliver करू शकतो — पण conviction म्हणजे knowledge नाही.
      </p>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO FACT OR FABRICATION -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        तुझा detector test कर. AI चे कोणते claims खरे आहेत आणि कोणते बनवलेले ते तुला सांगता येईल का?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FACT OR FABRICATION ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <FactOrFabrication client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE YES-MAN PROBLEM ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Yes-Man Problem
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Hallucination पेक्षा subtle अशी अजून एक failure mode आहे: <strong>sycophancy.</strong> AI चा tendency आहे तुझ्याशी agree करण्याचा, तू चुकीचा असलास तरी.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        जर तू म्हणालास "Einstein ने bulb शोधला, बरोबर?" तर बहुतेक AI models तुला सरळ correct करणार नाहीत. त्याऐवजी, ते partially agree करण्याचा मार्ग शोधतील — Einstein ला त्याच्या physics work मधून light शी connect करतील, तुझ्या चुकीच्या claim भोवती hedge करतील, तुला शिकवण्यापेक्षा validated feel करवतील.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        का? कारण AI models human feedback वर trained असतात, आणि humans agreeable आणि affirming वाटणाऱ्या responses ना positive ratings देतात. लाखो training examples मध्ये, model शिकतो: <em>agree करणं म्हणजे reward मिळणं.</em> त्यामुळे तो agree करतो — जेव्हा नसावं तेव्हा पण.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;`}>हे dangerous आहे</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          जर तू AI ला फक्त तुझ्या आधीच्या beliefs confirm करण्यासाठी वापरत असशील, तर तो आनंदानं ते करेल. तुला smarter वाटेल पण actually तू dumber होत जाशील. AI चा सगळ्यात strong use म्हणजे तुझ्या assumptions ला challenge करायला सांगणं — reinforce नाही.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO SYCOPHANCY TEST -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Action मध्ये बघ. AI ला wrong claim feed कर आणि बघ तो push back करतो की cave.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: SYCOPHANCY TEST ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <SycophancyTest client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BUILDING YOUR VERIFICATION HABIT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Verification ची सवय लाव
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14">
        Goal हे नाही की AI सांगतो ते सगळं distrust कर. Goal हे आहे की automatic checks चा set develop कर — एक verification reflex — जो AI-generated information वर act करण्याआधी kick in होतो.
      </p>
    </FadeInBlock>

    <!-- Verification checklist — editorial layout -->
    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { letter: '1', name: 'मी हे verify करू शकतो का?', color: '#E94560', text: 'कुठल्याही factual claim साठी विचार कर: मी हे independent source ने check करू शकतो का? AI एखादी study cite करत असेल तर ती शोध. Date सांगत असेल तर confirm कर. कुणाला quote करत असेल तर quote शोध. Citations blindly accept करू नकोस — AI regularly sources invent करतो.' },
        { letter: '2', name: 'मी sources मागितले का?', color: '#0F3460', text: 'AI ला explicitly sources provide करायला सांग. मग ते sources check कर. तुला दिसेल की कधी ते खरे असतात, कधी close-but-wrong असतात (बरोबर author, चुकीचा paper), आणि कधी पूर्णपणे बनवलेले असतात. Check करण्याची act तुझी instinct train करते.' },
        { letter: '3', name: 'हे common sense test pass करतं का?', color: '#7B61FF', text: 'मागे सरक आणि विचार कर: हा claim actually make sense करतो का? AI plausible nonsense generate करू शकतो जे 5 seconds च्या critical thought मध्ये कोसळतं. तुझ्या gut वर trust ठेव — मग तरीही verify कर.' },
        { letter: '4', name: 'मी high-stakes domain मध्ये आहे का?', color: '#F5A623', text: 'Medical advice, legal guidance, financial decisions, safety involve करणारं काहीही — याला extra verification लागतं. AI brainstorming आणि first drafts साठी helpful आहे, पण critical decisions नेहमी qualified humans कडून verify करायला हवेत.' },
        { letter: '5', name: 'मी प्रश्न neutral frame केला का?', color: '#16C79A', text: 'जर तू प्रश्नात तुझं opinion embed केलंस, तर AI ते mirror back करेल. Open प्रश्न विचार. "X best approach का?" ऐवजी "X च्या बाजूने आणि विरुद्ध arguments काय आहेत?" विचार. तुला more honest, useful answers मिळतील.' },
      ].map((block, i) => (
        <FadeInBlock client:visible delay={i * 0.08}>
          <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${block.color};`}>
              {block.letter}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${block.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {block.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {block.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>हे AI वर doubt करण्याबद्दल नाही. हे त्याला चांगल्या प्रकारे वापरण्याबद्दल आहे.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Professional journalists quotes verify करतात. Scientists experiments replicate करतात. Engineers bridges उघडण्याआधी test करतात. AI output verify करणं paranoia नाही — professionalism आहे. जे verify करतात तेच खरोखर काम करणाऱ्या गोष्टी build करतात.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CLOSING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto mb-8" style="max-width: 55ch;">
        आता तुझ्याकडे BS detector आहे: तू hallucinations spot करू शकतोस, sycophancy ला resist करू शकतोस, आणि trust करण्याआधी verify करू शकतोस. ही सवय तुला कुठल्याही fancy prompt technique पेक्षा जास्त वाचवेल.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        AI कधी चुकतो हे माहीत असणं एका मोठ्या प्रश्नाकडे नेतं: तो <em>कधीच</em> काय करू शकत नाही? पुढे, आपण त्या skills बघतो ज्या stubbornly, beautifully human राहतात &mdash; आणि त्या आधीपेक्षा जास्त important का आहेत.
      </p>
    </FadeInBlock>
  </section>

</ChapterLayout>
