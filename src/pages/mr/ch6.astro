---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import AgentBlueprint from '../../components/widgets/ch6/AgentBlueprint';
import FailureModesLab from '../../components/widgets/ch6/FailureModesLab';
import HandoffChain from '../../components/widgets/ch6/HandoffChain';

const chapter = chapters[5];
---

<ChapterLayout chapter={chapter} locale="mr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>6</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          धडा सहा
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          एजंट्स<br />बांधणे
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          AI एजंटला डिझाइन कर, वायर कर आणि<br />सुरूवातीपासून तैनात कर.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        चॅटबॉट तुमच्या बोलण्याची वाट पाहतो. एजंट तसं करत नाही. त्याला एक लक्ष्य द्या — "मार्स कॉलोनायझेशनवर संशोधन कर आणि रिपोर्ट लिहा" — आणि ते काम छोट्या स्टेप्समध्ये मोडेल, योग्य टूल्स निवडेल, त्यांना एक एक करून execute करेल, स्वतःचे रिझल्ट तपासेल, आणि काम पूर्ण होईपर्यंत चालू ठेवेल. कुणाला हात धरून घेऊन यावं लागत नाही.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        हा फरक — <em>इन्स्ट्रक्शन्सना प्रतिसाद देणे</em> आणि <em>लक्ष्य पाठपुरावा</em> — हा कॅल्क्युलेटर आणि सहकाऱ्यामधला फरक आहे. चॅटबॉट्स प्रश्नांची उत्तरं देतात. एजंट्स समस्या सोडवतात.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        हा धडा एजंट्स खरंच कसे काम करतात याबद्दल आहे — त्यांना चालवणारा लूप, त्यांना विश्वासार्ह बनवणारी आर्किटेक्चर, आणि फेल्युअर मोड्स ज्यांमुळे ते निष्काळजीपणे बनवले तर धोकादायक बनतात.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE AGENT LOOP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        एजंट लूप
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        पाचव्या धड्यात तुम्ही बेसिक टूल-युज लूप पाहिला: निरीक्षण कर, विचार कर, कृती कर. एजंट्स त्यावर काहीसं महत्त्वाकांक्षी विस्तार करतात — पाच स्टेप्सचे सायकल, प्रत्येक वेगळ्या अंतर्गत कॉम्पोनेंटद्वारे चालवलेलं:
      </p>
    </FadeInBlock>

    <!-- Loop Steps with architecture component for each -->
    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { letter: 'G', word: 'लक्ष्य (Goal)', color: '#E94560', desc: 'माणसाकडून उच्च-स्तरीय उद्दिष्ट घे. स्पष्ट लक्ष्याशिवाय एजंटकडे निर्णय घेण्याचा कोणताच आधार नसतो की ते पूर्ण झाले की नाही. "मार्सवर संशोधन कर" हे लक्ष्य नाही. "मार्स कॉलोनायझेशनच्या आव्हानांवर स्रोतांसह 500 शब्दांचं सारांश लिहा" हे आहे.' },
        { letter: 'P', word: 'योजना (Plan)', color: '#7B61FF', desc: 'लक्ष्याला ठोस स्टेप्समध्ये मोड. सर्वोत्तम प्लॅनर्स अशा लवचिक योजना तयार करतात ज्या स्टेप फेल झाल्यावर अडाप्ट होतात. वाईट प्लॅनर्स कठोर स्क्रिप्ट्स बनवतात ज्या पहिल्या आश्चर्यातच तुटतात.' },
        { letter: 'T', word: 'अंमलबजावणी (Execute)', color: '#0EA5E9', desc: 'प्रत्येक स्टेप योग्य टूल वापरून चालवा — सर्च इंजिन्स, कोड इंटरप्रिटर्स, फाइल रीडर्स, APIs, कॅल्क्युलेटर्स. एजंट्स फक्त विचार करत नाहीत. ते कृती करतात.' },
        { letter: 'M', word: 'निरीक्षण (Observe)', color: '#16C79A', desc: 'काय झालं ते रेकॉर्ड कर आणि रिझल्ट तपास. काय केलं आणि काय आढळलं याची मेमरी नसल्यास लूपमध्ये अडकलेला एजंट कदाचित तोच फेल झालेली कृती सतत रिपीट करेल.' },
        { letter: 'E', word: 'मूल्यांकन (Evaluate)', color: '#F5A623', desc: 'हे काम करतं का? हा डेटा विश्वासार्ह आहे का? मी लक्ष्याच्या जवळ आहे का? मूल्यांकक एजंटला फक्त चालून आशा धरणाऱ्या स्क्रिप्टपासून वेगळं करतो. काहीतरी गडबड असेल तर योजना अडजस्ट कर आणि पुन्हा लूप कर.' },
      ].map((step, i) => (
        <FadeInBlock client:visible delay={i * 0.08}>
          <div style={`display: flex; gap: 1.25rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1rem; font-weight: 800; color: white; background: ${step.color};`}>
              {step.letter}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.05rem; font-weight: 700; color: ${step.color}; margin: 0 0 0.3rem; line-height: 1.3;`}>
                {step.word}
              </p>
              <p style="font-size: 0.95rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {step.desc}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <p class="text-lg leading-[1.85] mb-10">
        मुख्य शब्द <em>लूप</em> आहे. एजंट एकदा प्लॅन करून आंधळेपणाने execute करत नाही. ते प्लॅन करतं, कृती करतं, निरीक्षण करतं, मूल्यांकन करतं आणि अडजस्ट करतं. सर्वोत्तम एजंट्स ते असतात जे तिसरा स्टेप गडबडीत गेल्यावर सुंदर रीतीने रिकव्हर होतात.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.55}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        चॅटबॉट एकच टर्न असतो. एजंट संपूर्ण संभाषण असतं — स्वतःशी, त्याच्या टूल्सशी आणि जगाशी.
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO AGENT BLUEPRINT -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        आता एक बनवण्याची वेळ आली. सुरूवातीपासून तुमचं स्वतःचं एजंट डिझाइन करा.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: AGENT BLUEPRINT ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <AgentBlueprint client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ WHEN AGENTS FAIL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        एजंट्स कधी फेल होतात
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        एजंट्स चॅटबॉट्ससारखे फेल होत नाहीत. चॅटबॉट तुम्हाला वाईट उत्तर देऊन वाट पाहतो. एजंट स्वतःला वाईट उत्तर देतं, <em>त्यावर कृती करतं</em>, मग तुटलेल्या परिणामाचा वापर करून पुढचा निर्णय घेतं. फेल्युअर्स कंपाउंड होतात.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        एजंट्स गडबडण्याचे तीन क्लासिक मार्ग आहेत:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>फेल्युअर मोड 1: अनंत लूप</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          एजंट एकच कृती रिपीट करण्यात अडकतं. संशोधन एजंट "आणखी एक स्रोत" शोधत राहतं आणि लिहिणं कधीच सुरू करत नाही. स्टॉपिंग कंडिशनशिवाय तुम्ही प्लग काढेपर्यंत ते चालत राहतं — किंवा API क्रेडिट्स संपेपर्यंत.
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="prompt-block mb-10" style={`--accent: #7B61FF;`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:#7B61FF;`}></div>
        <span class="prompt-block-label" style="color: #7B61FF;">फेल्युअर मोड 2: चुकीचं टूल</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          एजंट अशं टूल सेलेक्ट करतं जे काम करू शकत नाही. ते तुमच्या हार्ड ड्राइव्हवरची फाइल वेब-सर्चमध्ये शोधण्याचा प्रयत्न करतं, किंवा निबंध सारांशित करण्यासाठी कॅल्क्युलेटर कॉल करतं. एजंट मूर्ख आहे असं नाही — त्याने फक्त टूलबॉक्समधून निवडलं टूल कामासाठी योग्य आहे की नाही हे न तपासता.
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="prompt-block mb-10" style={`--accent: #F5A623;`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:#F5A623;`}></div>
        <span class="prompt-block-label" style="color: #F5A623;">फेल्युअर मोड 3: हॅल्युसिनेटेड अॅक्शन्स</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          एजंट अस्तित्वात नसलेली टूल्स किंवा APIs शोधून काढतं, मग त्यांना बनावट रिझल्ट्ससह "कॉल" करतं. जेव्हा बनावट कॉल फेल होतं तेव्हा कधी कधी तो मिळायला हवा असलेला डेटाही फॅब्रिकेट करतं. डबल हॅल्युसिनेशन: बनावट टूल, बनावट आउटपुट.
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        फिक्स नेहमी एकच सिद्धांत असतो: <strong>unhappy path साठी डिझाइन करा.</strong> मॅक्स iterations, टूल व्हॅलिडेशन, आउटपुट व्हेरिफिकेशन आणि ह्युमन चेकपॉइंट्स. लक्ष्य सर्व फेल्युअर रोखणं नाही — फेल्युअर रिकव्हरेबल बनवणं आहे.
      </p>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO FAILURE MODES LAB -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        तुम्ही तुटलेल्या एजंटचं डायग्नोसिस करू शकता का? बग शोधा आणि गार्डरेल घाला.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FAILURE MODES LAB ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <FailureModesLab client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE POWER OF MANY: MULTI-AGENT SYSTEMS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        अनेकांची शक्ती
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        एक एजंट उपयुक्त आहे. अनेक एजंट्स एकत्र काम करताना अशा समस्या हाताळू शकतात ज्या कोणत्याही एकल सिस्टमला overwhelm करतील. युक्ती स्पेशालायझेशनमध्ये आहे.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        न्यूजरूमसारखं विचार करा. तुम्ही एकाच व्यक्तीला स्टोरी investigate करायला, आर्टिकल लिहायला आणि प्रकाशनासाठी एडिट करायला सांगत नाही. प्रत्येक भूमिकेला वेगळी मानसिकता, वेगळी टूल्स आणि वेगळे मानदंड लागतात.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        मल्टी-एजंट सिस्टम्स तशीच काम करतात. <strong>संशोधक</strong> एजंट माहिती गोळा करतं. <strong>लेखक</strong> एजंट कच्च्या नोट्स पॉलिश्ड गद्यात रूपांतरित करतं. <strong>संपादक</strong> एजंट रिव्ह्यू करतं, फॅक्ट-चेक करतं आणि सुधारणा सुचवतं. प्रत्येक एजंटकडे स्वतःचं सिस्टम प्रॉम्प्ट, स्वतःची टूल्स आणि स्वतःचे यशाचे मापदंड असतात.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
