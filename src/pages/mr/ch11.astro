---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ProjectInstructionsBuilder from '../../components/widgets/ch11/ProjectInstructionsBuilder';

const chapter = chapters[10];
const conceptsSummary = chapter.concepts.map(c => c.name).join(', ');
---

<ChapterLayout chapter={chapter} locale="mr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>11</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          अध्याय अकरा
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          काहीतरी खरं<br />बनव
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          निर्मिती नसलेलं ज्ञान म्हणजे trivia.<br />Ship करायची वेळ आली.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        तू पोहोचलास. दहा अध्यायांमध्ये "माझ्या essay मध्ये help कर" पासून context engineering, agents बनवणं, software ची vocabulary शिकणं, build loop master करणं, आणि taste develop करण्यापर्यंत आलास. पण इथे एक uncomfortable truth आहे: <strong>तू काहीतरी build करेपर्यंत यातलं काहीच matter करत नाही.</strong> AI बद्दल वाचणं म्हणजे swimming बद्दल वाचण्यासारखं &mdash; तू प्रत्येक stroke technique study करू शकतोस, पण पाण्यात उतरेपर्यंत तुला काहीच <em>कळत</em> नाही. तुला फक्त त्या<em>बद्दल</em> कळतं.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ SET UP YOUR AI ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        तुझा AI Set Up कर
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        पहिला prompt लिहिण्यापूर्वी, एक power move आहे जी बहुतेक beginners skip करतात: <strong>तुझ्या AI tool ला permanent instruction file दे.</strong> प्रत्येक session मध्ये तुझा project परत समजावण्याऐवजी, एकदा लिही आणि तुझा AI automatically वाचतो. Claude Code <code>CLAUDE.md</code> वाचतो. Cursor <code>.cursorrules</code> वाचतो. GitHub Copilot <code>.github/copilot-instructions.md</code> वाचतो. तीच concept, वेगवेगळे filenames. हे Chapter 3 मधलं context engineering आहे — project level वर applied.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        एक चांगला instruction file तीन प्रश्नांची उत्तरं देतो: तू काय build करतोयस, rules काय आहेत, आणि "चांगलं" कसं दिसतं? हे बरोबर मिळव आणि तुझ्या AI सोबतचं प्रत्येक conversation दहा steps पुढे सुरू होतं. तुझ्या project चा scope पूर्ण करता येईल इतका छोटा ठेव — पूर्ण झालेला weekend hack सोडून दिलेल्या masterpiece पेक्षा नेहमी चांगला.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style="font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;">मुख्य अंतर्दृष्टी</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          चांगला project instruction file हा तुला help करणाऱ्या AI आणि तुला <em>समजणाऱ्या</em> AI मधला फरक आहे. एकदा लिही, प्रत्येक session मध्ये फायदा मिळव.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        तुझा project instruction file इथेच build कर. Sections भर आणि तुझ्या आवडीच्या AI tool साठी export कर.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="project-instructions-builder" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ProjectInstructionsBuilder client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Tools गोष्टी build करत नाहीत. Tools असलेले लोक गोष्टी build करतात. आणि तुझ्याकडे तुझ्या generation ला कधीही मिळालेलं सर्वात चांगलं toolkit आहे.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto mb-8" style="max-width: 55ch;">
        अकरा अध्याय आधी, तू "माझ्या essay मध्ये help कर" टाइप केलंस आणि best ची आशा ठेवलीस. आता तू context engineer करतोस, agents build करतोस, software ची भाषा बोलतोस, confidence ने iterate करतोस, आणि तू बनवतोस त्या प्रत्येक गोष्टीत taste आणतोस. Course संपला. खरं शिकणं आता सुरू होतं &mdash; जा आणि असं काहीतरी बनव जे फक्त तुलाच सुचेल.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-center mt-4" style={`font-family: var(--font-heading); font-size: 1.8rem; font-weight: 800; color: ${chapter.accent}; letter-spacing: -0.02em;`}>
        Ship कर.
      </p>
    </FadeInBlock>
  </section>

</ChapterLayout>
