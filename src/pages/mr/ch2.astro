---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import PromptLaboratory from '../../components/widgets/ch2/PromptLaboratory';
import FlipTheScript from '../../components/widgets/ch2/FlipTheScript';
import DebugThePrompt from '../../components/widgets/ch2/DebugThePrompt';

const chapter = chapters[1];
---

<ChapterLayout chapter={chapter} locale="mr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>2</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          धडा दोन
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          विचारण्याची<br />कला
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          सर्वोत्तम prompt तो आहे जो<br />AI ला तुला प्रश्न विचारायला लावतो.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        मागच्या धड्यात तू चांगल्या prompt चे पाच बिल्डिंग ब्लॉक्स शिकलास — Role, Task, Format, Constraints, Examples. हा पाया आहे. पण ingredients माहीत असणं तुला chef बनवत नाही.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        हा धडा <em>technique</em> बद्दल आहे. Prompt टाइप करणारा आणि prompt <em>craft</em> करणारा यातला फरक. प्रश्न विचारणं आणि <strong>योग्य</strong> प्रश्न विचारणं — जो खरोखर उपयुक्त काहीतरी unlock करतो — यातला फरक आहे.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        सर्वोत्तम AI users हे विषयातले experts नसतात — <strong>ते विचारण्यातले experts असतात.</strong> आणि विचारणं ही शिकता येणारी skill आहे.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SOCRATIC FLIP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Socratic Flip
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        बहुतेक लोक AI ला vending machine सारखं वापरतात. Prompt टाक, उत्तर घे. पण सर्वोत्तम results commands मधून नाही, <em>conversations</em> मधून मिळतात. आणि सर्वात powerful conversation technique २,४०० वर्षं जुनी आहे.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Socrates ने कधीच प्रश्नाचं थेट उत्तर दिलं नाही. त्याने <em>आणखी</em> प्रश्न विचारले — probing, clarifying, challenging — जोपर्यंत त्याचे विद्यार्थी स्वतःच deeper understanding पर्यंत पोहोचले. तू AI सोबत तीच approach वापरू शकतोस, पण flipped.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AI ला उत्तर मागण्याऐवजी, AI ला तुला interview करायला सांग. तुला विचारायला विसरलेले clarifying questions AI ला विचारू दे.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        विचार कर: जेव्हा तू "birthday party plan कर" टाइप करतोस, तेव्हा डझनभर details सोडतोस ज्या उत्तर पूर्णपणे बदलतात. किती लोक? Budget किती? Indoor की outdoor? AI ला माहीत नाही — पण तो विचारू शकतो.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Socratic Prompt</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          "मला birthday party plan करायची आहे. Planning सुरू करण्याआधी, मला 5 specific प्रश्न विचार जे तुला माझ्या exact situation साठी tailored plan बनवायला मदत करतील. एका वेळी एक विचार आणि माझ्या उत्तराची वाट बघ."
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        ही एक technique — कोण प्रश्न विचारतो हे flip करणे — ही तुझ्या सर्वात powerful upgrades पैकी एक आहे. यामुळे AI answer machine मधून <strong>thinking partner</strong> बनतो.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FLIP THE SCRIPT ═══ -->
  <section id="flip-the-script" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <FlipTheScript client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ FEW-SHOT PROMPTING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        सांगण्यापेक्षा दाखव
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        कल्पना कर तू एका मित्राला एक style समजावून सांगतोयस. तू पाच मिनिटं शब्दांत describe करू शकतोस — "मला playful पण childish नाही, casual पण sloppy नाही, छोट्या sentences आणि unexpected comparisons हवेत." किंवा तू फक्त एक example दाखवू शकतोस: <em>"असं लिहा."</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        हेच <strong>few-shot prompting</strong> आहे. तुला abstract मध्ये काय हवं ते describe करण्याऐवजी, तू AI ला concrete examples देतोस. एक example म्हणजे "one-shot" prompt. दोन-तीन examples म्हणजे "few-shot." शून्य examples — जिथे तू फक्त describe करतोस — म्हणजे "zero-shot."
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style="--accent: #6B7280;">
        <span class="prompt-block-label" style="color: #6B7280;">Zero-shot (describe करणे)</span>
        <p class="m-0" style="color: var(--color-deep);">"Running shoes साठी product description लिहा. Punchy आणि conversational ठेव, छोट्या sentences मध्ये. Marketing clichés टाळ."</p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Few-shot (दाखवणे)</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          "CloudRunner X1 running shoe साठी product description लिहा. मला ही style हवी आहे:<br /><br />
          <em>Example: 'The Weekender Tote — Fits your laptop, your lunch, and your questionable life choices. Water-resistant canvas because we know you'll spill something. Five pockets, none of which you'll remember later.'</em><br /><br />
          हा tone match कर: छोटे sentences, self-aware humor, buzzwords पेक्षा specificity."
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85] mb-10">
        Few-shot version dramatically चांगले results देईल. AI "smarter" असल्यामुळे नाही — तर तू त्याला vague direction ऐवजी <strong>concrete target</strong> दिल्यामुळे. एक चांगलं example शंभर शब्दांच्या description पेक्षा जास्त powerful आहे.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>मुख्य अंतर्दृष्टी</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          जेव्हा AI तुला हवी ती style match करत नाही, तेव्हा adjectives वाढवू नकोस. Example दे. "असं" हे "जास्त punchy पण warm पण casual पण formal नको" पेक्षा नेहमी जिंकतं.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ MINI-CHALLENGE: Zero to Few-Shot ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-12">
    <FadeInBlock client:visible>
      <div style={`background: linear-gradient(135deg, ${chapter.accent}08, ${chapter.accent}04); border: 1px solid ${chapter.accent}20; border-radius: 12px; padding: 2rem 2rem 1.75rem;`}>
        <p style={`font-family: var(--font-mono); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: ${chapter.accent}; margin: 0 0 0.75rem;`}>
          छोटा experiment
        </p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0 0 1rem; color: var(--color-deep);">
          तू नुकतंच AI ला काहीतरी लिहायला सांगितलं होतंस — एक email, एक story, एक social media post. आता कल्पना कर तू तुला हव्या असलेल्या tone चं एक concrete example दिलं असतंस. Output कसं बदललं असतं?
        </p>
        <p style="font-size: 0.9rem; line-height: 1.7; margin: 0; color: var(--color-deep); opacity: 0.6;">
          ते लक्षात ठेव. खाली Prompt Laboratory मध्ये तू ते खरोखर test करू शकतोस.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CHAIN OF THOUGHT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Step by Step विचार कर
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        एक भन्नाट गोष्ट आहे: जर तू AI ला math problem सोडवायला सांगितलंस, तर तो चुकू शकतो. पण जर तू त्याला <em>step by step problem सोडव</em> असं सांगितलंस, तर तो बरोबर उत्तर देतो बऱ्याच जास्त वेळा. उत्तर तेच आहे. प्रश्न वेगळा आहे.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        या technique ला <strong>chain-of-thought prompting</strong> म्हणतात. थेट उत्तर मागण्याऐवजी, तू AI ला त्याचं reasoning दाखवायला सांगतोस. "Step by step विचार कर." "उत्तर देण्याआधी हे मोडून सांग." "जसजसं पुढे जा तसं reasoning explain कर."
      </p>
    </FadeInBlock>

    <!-- Before/After comparison -->
    <FadeInBlock client:visible delay={0.2}>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
        <div>
          <div class="prompt-block" style="--accent: #E94560; min-height: 100%;">
            <span class="prompt-block-label" style="color: #E94560;">Chain-of-thought शिवाय</span>
            <p class="m-0" style="color: var(--color-deep); font-size: 0.85rem;">
              "एक bat आणि ball मिळून $1.10 ला आहेत. Bat ball पेक्षा $1.00 जास्त आहे. Ball किती?"
            </p>
            <p style="color: #E94560; font-size: 0.8rem; margin: 1rem 0 0; font-weight: 600;">
              AI चं उत्तर: $0.10 (चुकीचं)
            </p>
          </div>
        </div>
        <div>
          <div class="prompt-block" style={`--accent: ${chapter.accent}; min-height: 100%;`}>
            <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
            <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Chain-of-thought सह</span>
            <p class="m-0" style="color: var(--color-deep); font-size: 0.85rem;">
              "एक bat आणि ball मिळून $1.10 ला आहेत. Bat ball पेक्षा $1.00 जास्त आहे. Ball किती? Step by step विचार कर."
            </p>
            <p style={`color: ${chapter.accent}; font-size: 0.8rem; margin: 1rem 0 0; font-weight: 600;`}>
              AI चं उत्तर: $0.05 (बरोबर)
            </p>
          </div>
        </div>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        हे का काम करतं? जेव्हा तू AI ला step by step reasoning दाखवायला सांगतोस, तेव्हा प्रत्येक step पुढच्या step ला feed करतो. AI ला scratch paper दिल्यासारखं आहे — जितकं जास्त तो विचार लिहितो, तितकं चांगलं final answer मिळतं.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        Chain-of-thought AI ला smarter बनवत नाही. तो slow बनवतो — आणि slow विचार अनेकदा चांगला विचार असतो.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        हे फक्त math साठी नाही. जेव्हा उत्तरासाठी reasoning लागतं तेव्हा हे वापर: argument analyze करणं, options compare करणं, project plan करणं, code debug करणं. जेव्हाही तुला एखाद्या माणसाला "काम दाखव" असं सांगायचं असतं, तेव्हा AI लाही तेच सांग.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE PROMPT ASSEMBLY ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Techniques जोडणे
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        खरी power techniques combine करण्यात आहे. Few-shot examples <em>अधिक</em> chain-of-thought. System role <em>अधिक</em> constraints <em>अधिक</em> format specification. प्रत्येक technique एक lever आहे, आणि एकाच वेळी अनेक levers खेचणं असं काहीतरी produce करतं जे कुणीही एकट्यानं achieve करू शकत नव्हतं.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        पण एक nuance आहे जो beginners आणि experts ना वेगळं करतो: <strong>जास्त नेहमीच चांगलं नसतं.</strong> Casual brainstorm ला एक-दोन techniques लागतात. High-stakes essay ला पाच. Informal प्रश्नाला शून्य. कळ ही आहे की किती levers खेचायचे — आणि कुठले.
      </p>
    </FadeInBlock>

    <!-- Technique stack visual -->
    <FadeInBlock client:visible delay={0.2}>
      <div style="margin-bottom: 2.5rem;">
        {[
          { label: 'Casual brainstorm', techniques: ['Task'], color: '#6B7280', width: '25%' },
          { label: 'School assignment', techniques: ['Role', 'Task', 'Format'], color: '#F5A623', width: '50%' },
          { label: 'Important project', techniques: ['Role', 'Context', 'Task', 'Format', 'Examples'], color: '#0EA5E9', width: '75%' },
          { label: 'High-stakes output', techniques: ['Role', 'Context', 'Examples', 'Task', 'Format', 'Constraints', 'Chain-of-thought'], color: '#0F3460', width: '100%' },
        ].map((level, i) => (
          <FadeInBlock client:visible delay={i * 0.06} key={i}>
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem;">
              <span style={`font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600; color: ${level.color}; width: 120px; flex-shrink: 0; text-align: right;`}>
                {level.label}
              </span>
              <div style="flex: 1; height: 24px; background: rgba(26,26,46,0.03); border-radius: 6px; overflow: hidden;">
                <div style={`height: 100%; width: ${level.width}; background: linear-gradient(90deg, ${level.color}20, ${level.color}40); border-radius: 6px; display: flex; align-items: center; padding: 0 8px; gap: 4px;`}>
                  {level.techniques.map((t, j) => (
                    <span key={j} style={`font-family: var(--font-mono); font-size: 0.55rem; font-weight: 600; color: ${level.color}; opacity: 0.8;`}>
                      {t}{j < level.techniques.length - 1 ? ' +' : ''}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.4}>
      <div class="insight-box">
