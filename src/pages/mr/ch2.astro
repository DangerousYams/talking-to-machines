    <!-- Bug types -->
    <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 2.5rem;">
      {[
        { name: 'संदिग्ध (Ambiguous)', desc: 'Prompt चे अनेक अर्थ निघू शकतात. "कुत्र्यांबद्दल काहीतरी लिहा" — कुठल्या प्रकारचं लिखाण? कुणासाठी? किती लांबीचं?', color: '#E94560' },
        { name: 'विरोधाभासी (Contradictory)', desc: 'Prompt उलट गोष्टी मागतो. "छोटं ठेव पण comprehensive कर." "Fun tone वापर पण formal ठेव." एक निवड.', color: '#F5A623' },
        { name: 'Context missing', desc: 'Prompt मध्ये महत्त्वाची माहिती नाही. कोड न share करता "माझा code fix कर." Essay न देता "माझा essay improve कर."', color: '#0EA5E9' },
        { name: 'एकाच वेळी खूप कामं', desc: 'Prompt एकदम पाच गोष्टी मागतो. AI सगळ्यांमध्ये पसरतो आणि कुठलंच बरोबर करत नाही.', color: '#7B61FF' },
