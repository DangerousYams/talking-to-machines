---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import SkillsSpectrum from '../../components/widgets/ch10/SkillsSpectrum';
import JobTransformer from '../../components/widgets/ch10/JobTransformer';
import TasteTest from '../../components/widgets/ch10/TasteTest';
import FirstPrinciplesLab from '../../components/widgets/ch10/FirstPrinciplesLab';

const chapter = chapters[9];
---

<ChapterLayout chapter={chapter} locale="mr">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>10</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          धडा दहा
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          माणसाचं<br />Edge
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          AI काय replace करू शकत नाही &mdash;<br />आणि काय 10x सोपं करतो.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        प्रत्येक वेळी नवीन AI capability येते, तीच headline दिसते: <em>"AI [insert job] replace करेल का?"</em> हा चुकीचा प्रश्न आहे. नेहमीच चुकीचा होता. बरोबर प्रश्न हा आहे: <em>"यामुळे आधी शक्य नव्हतं असं काय शक्य होतं?"</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        AI माणसांना replace करत नाही. तो <strong>tasks</strong> replace करतो. आणि जेव्हा तू कुठल्याही job वर — कुठलीही career, कुठलीही creative pursuit, कुठलाही profession — zoom in करतोस, तेव्हा एक mix दिसतो: काही tasks AI brilliantly handle करतो, काही मध्ये assist करतो, आणि काही stubbornly, beautifully human राहतात.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        हा धडा ती line शोधण्याबद्दल आहे. तुला त्याची भीती वाटावी म्हणून नाही, तर तू <strong>त्या line च्या योग्य बाजूला उभा राहू शकतोस</strong> — जिथे तुझ्या uniquely human skills जास्त valuable होतात, कमी नाही.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SPECTRUM, NOT THE CLIFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Spectrum, कडा नाही
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI आणि jobs बद्दलचे बहुतेक conversations ते binary सारखं treat करतात: एकतर AI तुझं काम करू शकतो, किंवा नाही. Robot apocalypse किंवा business as usual. पण reality spectrum आहे.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        काही tasks जवळजवळ पूर्णपणे automate करता येतात. काही AI ने enhance होतात. काही untouched राहतात. आणि सर्वात interesting — ज्यांकडे लक्ष द्यायला हवं — ते मध्ये आहेत, जिथे माणसं आणि AI एकत्र काम करतात.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        Data entry? AI हाताळतो. Meetings schedule करणं? जवळजवळ solved. First draft लिहिणं? AI shockingly चांगला आहे. पण <em>काय build करायचं ते ठरवणं</em>, <em>crisis मध्ये room read करणं</em>, <em>data चा अर्थ काय ते ठरवणं</em> — यासाठी AI कडे नसलेलं काहीतरी लागतं.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        प्रत्येक skill खरोखर कुठे पडते? तुझी intuition test कर.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: SKILLS SPECTRUM ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <SkillsSpectrum client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ JOBS DON'T DISAPPEAR — THEY SHAPE-SHIFT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Jobs नाहीशा होत नाहीत &mdash; त्या बदलतात
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        जेव्हा 1970 मध्ये ATMs आले, सगळ्यांनी predict केलं bank tellers गायब होतील. त्याऐवजी, bank tellers ची संख्या <em>वाढली</em>. का? कारण ATMs मुळे नवीन branches उघडणं स्वस्त झालं, आणि teller चं काम cash मोजण्यापासून financial products विकणं आणि customer relationships बांधणं कडे shift झालं.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        AI तेच करतोय, पण जलद आणि सगळ्या industries मध्ये एकदम. Job title तोच राहतो. Job <em>description</em> dramatically बदलतो. 2025 मधला journalist 2015 मधल्या journalist सारखं काम करत नाही, byline तोच दिसत असला तरी.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>नवीन career math</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          हे "humans vs. AI" नाही. हे <strong>humans with AI vs. humans without AI</strong> आहे. AI tools सोबत काम करायला शिकणारे लोक jobs गमावत नाहीत — ते काम जलद, चांगलं, आणि आधी नसलेल्या capabilities सह करतात.
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mt-10">
        खालची career निवड आणि AI ती आतून कशी transform करतो ते बघ. एकही task पूर्णपणे गायब होत नाही. पण प्रत्येक job चा shape बदलतोय.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: JOB TRANSFORMER ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <JobTransformer client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ TASTE: THE IRREPLACEABLE SKILL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Taste: Replace न होणारी Skill
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI एका मिनिटात शंभर logo concepts generate करू शकतो. तुझी coffee संपण्याआधी दहा essay introductions लिहू शकतो. पाच app designs, चार taglines, तीन business plans produce करू शकतो.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        पण कुठला <em>बरोबर</em> आहे ते सांगू शकत नाही.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        अशा जगात जिथे options generate करणं जवळजवळ free आहे, <em>बरोबर option निवडण्याची</em> ability ही तुझ्याकडे असू शकणारी सर्वात valuable skill बनते. त्या ability ला एक नाव आहे: taste.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        Taste काही magical नाही. ती trained असते. भरपूर चांगलं काम आणि भरपूर वाईट काम बघून, आणि एक दुसऱ्यापेक्षा <em>का</em> चांगलं आहे हे articulate करायला शिकून ती develop होते. कुठला shot ठेवायचा हे माहीत असणारा photographer. कुठलं sentence cut करायचं हे माहीत असणारा writer. Less is more कधी आहे हे माहीत असणारा designer.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85]">
        AI generate करतो. तू curate करतोस. हे नवीन division of labor आहे. बघूया तुझी taste किती sharp आहे.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: TASTE TEST ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <TasteTest client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ YOUR KNOWLEDGE IS YOUR BS DETECTOR ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        तुझं ज्ञान हा तुझा BS Detector आहे
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        धडा 9 मध्ये आपण AI hallucinations बद्दल बोललो — AI कसा perfect confidence ने खोटं सांगू शकतो. पण एक uncomfortable follow-up प्रश्न आहे: <strong>तू ते कसं पकडशील?</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        उत्तर first principles thinking आहे. जेव्हा AI सांगतो की pipe चा radius दुप्पट केल्यावर पाण्याचा flow दुप्पट होतो, तू ती चूक फक्त तेव्हाच पकडू शकतोस जेव्हा तुला माहीत असतं की area radius च्या <em>square</em> प्रमाणे वाढतो. जेव्हा AI म्हणतो syllogism valid आहे, तू logical fallacy तेव्हाच ओळखू शकतोस जेव्हा तुला deduction चे rules माहीत असतात.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AI जे आहे ते remix करतो. First principles thinking ground truth मधून reason करतं. अशा प्रकारे तू खरोखर नवीन territory मध्ये push करतोस — आणि अशा प्रकारे confidently चुकीच्या AI ला पकडतोस.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        याचा अर्थ तुला सगळ्यात expert असायला लागत नाही. पण ज्या domains मध्ये तू काम करतोस आणि create करतोस, तुझी foundational understanding हीच तुला AI output आंधळेपणाने copy-paste करणाऱ्यापासून वेगळं करते.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85]">
        स्वतःला test कर. खालचा AI सहा problems ला confident answers देतो वेगवेगळ्या domains मध्ये. काही बरोबर आहेत. काही subtly चुकीचे. तू ओळखू शकतोस कुठला कुठला?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FIRST PRINCIPLES LAB ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <FirstPrinciplesLab client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ WHAT STAYS HUMAN ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        माणसाकडे काय राहतं
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14">
        आपण सगळं explore केल्यावर, एक pattern दिसतो. सर्वात human राहणाऱ्या skills random नाहीत — त्या काही deep capabilities भोवती cluster करतात ज्या AI कडे fundamentally नाहीत.
      </p>
    </FadeInBlock>

    <!-- Human edge capabilities -->
    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { icon: '🎯', name: 'निर्णय (Judgment)', color: '#16C79A', text: 'काय important आहे ते निवडणं. काय build करायचं, काय cut करायचं, काय ship करायचं, काय kill करायचं. AI decisions inform करू शकतो पण घेऊ शकत नाही — कारण decisions ला values लागतात, आणि values human आहेत.' },
        { icon: '🤝', name: 'सहानुभूती (Empathy)', color: '#0EA5E9', text: 'दुसऱ्याला काय वाटतंय ते समजणं आणि खऱ्या care ने respond करणं. AI text मध्ये empathy simulate करतो. माणसं relationships मध्ये, crisis मध्ये, सर्वात महत्त्वाच्या क्षणांमध्ये ती practice करतात.' },
        { icon: '🧭', name: 'Vision', color: '#7B61FF', text: 'अजून अस्तित्वात नसलेलं बघणं आणि ते असायला हवं असं ठरवणं. प्रत्येक product, प्रत्येक company, प्रत्येक creative काम कुणाच्या तरी conviction ने सुरू झालं की जगाला काहीतरी नवीन लागतं. AI ला गोष्टी हव्या असू शकत नाहीत.' },
        { icon: '⚡', name: 'नेतृत्व (Leadership)', color: '#F5A623', text: 'लोकांना inspire करणं, conflict navigate करणं, trust build करणं. या fundamentally social skills आहेत ज्यांना presence, emotional intelligence, आणि accountable असण्याची ability लागते.' },
        { icon: '🔍', name: 'Original प्रश्न विचारणं', color: '#E94560', text: 'AI प्रश्नांची उत्तरं देण्यात great आहे. माणसं कुणाला विचारायला सुचलं नव्हतं असे प्रश्न विचारण्यात great आहेत. Science, business, आणि art मधले सर्वात महत्त्वाचे breakthroughs एका प्रश्नाने सुरू झाले, उत्तराने नाही.' },
      ].map((item, i) => (
        <FadeInBlock client:visible delay={i * 0.08}>
          <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; background: ${item.color}10; border: 1px solid ${item.color}20;`}>
              {item.icon}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${item.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {item.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {item.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>मुख्य अंतर्दृष्टी</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          या फक्त "nice to have" soft skills नाहीत. AI-augmented जगात, या <strong>hard skills</strong> आहेत. Judge करण्याची, empathize करण्याची, lead करण्याची, envision करण्याची ability — या तुझ्या सर्वात competitive advantages बनतात <em>कारण</em> AI बाकी सगळं handle करतो.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CLOSING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto mb-8" style="max-width: 55ch;">
        Taste. Judgment. Empathy. Vision. First principles reasoning. AI ने ताब्यात घेतल्यानंतर उरलेलं नाहीत &mdash; तू table वर काय आणतोस ते <em>define</em> करणाऱ्या skills आहेत.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
