---
// Takeaways v2b — "Master AI." with Shalin photo + credential bottom-right
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Workshop Takeaways v2b</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;0,900;1,400;1,500;1,600&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    astro-dev-toolbar { display: none !important; }
    body { width: 1080px; height: 1350px; overflow: hidden; background: #0B0E16; }
    .canvas { position: relative; width: 1080px; height: 1350px; overflow: hidden; }
    .el { position: absolute; }
  </style>
</head>
<body>
<div class="canvas">

  <div class="el" style="top: -250px; left: 50%; transform: translateX(-50%); width: 1200px; height: 1000px; border-radius: 50%; background: radial-gradient(circle, rgba(233, 69, 96, 0.09) 0%, rgba(233, 69, 96, 0) 55%); pointer-events: none;"></div>
  <div class="el" style="bottom: -350px; left: 50%; transform: translateX(-50%); width: 1200px; height: 900px; border-radius: 50%; background: radial-gradient(circle, rgba(22, 199, 154, 0.06) 0%, rgba(22, 199, 154, 0) 55%); pointer-events: none;"></div>

  <svg class="el" style="top: 0; left: 0;" width="1080" height="1350" viewBox="0 0 1080 1350" fill="none">
    <line x1="55" y1="25" x2="200" y2="60" stroke="#E94560" stroke-width="1" opacity="0.18"/>
    <line x1="200" y1="60" x2="130" y2="155" stroke="#F5A623" stroke-width="1" opacity="0.16"/>
    <line x1="850" y1="35" x2="1010" y2="80" stroke="#16C79A" stroke-width="1" opacity="0.18"/>
    <line x1="1010" y1="80" x2="960" y2="170" stroke="#E94560" stroke-width="1" opacity="0.16"/>
    <line x1="130" y1="155" x2="60" y2="310" stroke="#F5A623" stroke-width="1" opacity="0.18"/>
    <line x1="960" y1="170" x2="1040" y2="300" stroke="#16C79A" stroke-width="1" opacity="0.18"/>
    <circle cx="55" cy="25" r="3" fill="#E94560" opacity="0.42"/>
    <circle cx="200" cy="60" r="5" fill="#F5A623" opacity="0.36"/>
    <circle cx="850" cy="35" r="5" fill="#16C79A" opacity="0.36"/>
    <circle cx="1010" cy="80" r="3" fill="#E94560" opacity="0.42"/>
    <circle cx="130" cy="155" r="4" fill="#F5A623" opacity="0.38"/>
    <circle cx="960" cy="170" r="4" fill="#16C79A" opacity="0.38"/>
    <circle cx="60" cy="310" r="3" fill="#E94560" opacity="0.42"/>
    <circle cx="1040" cy="300" r="6" fill="#F5A623" opacity="0.30"/>
  </svg>

  <!-- Top question -->
  <div class="el" style="top: 105px; left: 0; width: 1080px; text-align: center;">
    <span style="font-family: 'Playfair Display', Georgia, serif; font-style: italic; font-weight: 400; font-size: 46px; color: #F5EEDF; opacity: 0.70; letter-spacing: -0.5px;">
      Want to do more with AI?
    </span>
  </div>

  <!-- Hero: Master AI. -->
  <div class="el" style="top: 180px; left: 0; width: 1080px; text-align: center;">
    <span style="font-family: 'Playfair Display', Georgia, serif; font-weight: 800; font-size: 188px; line-height: 1.0; color: #F5EEDF; letter-spacing: -6px;">
      Master <em style="font-style: italic; color: #FF6B85; font-weight: 600;">AI.</em>
    </span>
  </div>

  <!-- Tagline -->
  <div class="el" style="top: 380px; left: 0; width: 1080px; text-align: center;">
    <span style="font-family: 'JetBrains Mono', monospace; font-size: 22px; font-weight: 600; letter-spacing: 6px; color: #D4A574; text-transform: uppercase; opacity: 0.90;">
      An online AI workshop
    </span>
  </div>

  <div class="el" style="top: 435px; left: 50%; transform: translateX(-50%); display: flex; align-items: center; gap: 14px;">
    <div style="width: 50px; height: 1px; background: rgba(245, 238, 223, 0.35);"></div>
    <div style="width: 6px; height: 6px; border-radius: 50%; background: #D4A574; opacity: 0.80;"></div>
    <div style="width: 6px; height: 6px; border-radius: 50%; background: #D4A574; opacity: 0.80;"></div>
    <div style="width: 6px; height: 6px; border-radius: 50%; background: #D4A574; opacity: 0.80;"></div>
    <div style="width: 50px; height: 1px; background: rgba(245, 238, 223, 0.35);"></div>
  </div>

  <!-- Sessions — compressed -->
  <div class="el" style="top: 510px; left: 60px; width: 960px;">
    <div style="display: flex; align-items: center; gap: 22px; margin-bottom: 22px;">
      <span style="font-family: 'JetBrains Mono', monospace; font-size: 24px; font-weight: 600; color: #D4A574; letter-spacing: 4px;">APRIL 20</span>
      <div style="flex: 1; height: 1px; background: linear-gradient(to right, rgba(212, 165, 116, 0.40) 0%, rgba(212, 165, 116, 0) 100%);"></div>
    </div>
    <div style="font-family: 'Playfair Display', Georgia, serif; font-size: 58px; font-weight: 600; line-height: 1.12; color: #F5EEDF; letter-spacing: -1.2px; white-space: nowrap;">
      <em style="font-style: italic; color: #F5EEDF; font-weight: 500;">Great answers</em> from AI.
    </div>
  </div>

  <div class="el" style="top: 705px; left: 60px; width: 960px;">
    <div style="display: flex; align-items: center; gap: 22px; margin-bottom: 22px;">
      <span style="font-family: 'JetBrains Mono', monospace; font-size: 24px; font-weight: 600; color: #D4A574; letter-spacing: 4px;">APRIL 22</span>
      <div style="flex: 1; height: 1px; background: linear-gradient(to right, rgba(212, 165, 116, 0.40) 0%, rgba(212, 165, 116, 0) 100%);"></div>
    </div>
    <div style="font-family: 'Playfair Display', Georgia, serif; font-size: 58px; font-weight: 600; line-height: 1.12; color: #F5EEDF; letter-spacing: -1.2px; white-space: nowrap;">
      <em style="font-style: italic; color: #F5EEDF; font-weight: 500;">AI helper</em> for your business.
    </div>
  </div>

  <div class="el" style="top: 900px; left: 60px; width: 960px;">
    <div style="display: flex; align-items: center; gap: 22px; margin-bottom: 22px;">
      <span style="font-family: 'JetBrains Mono', monospace; font-size: 24px; font-weight: 600; color: #D4A574; letter-spacing: 4px;">APRIL 24</span>
      <div style="flex: 1; height: 1px; background: linear-gradient(to right, rgba(212, 165, 116, 0.40) 0%, rgba(212, 165, 116, 0) 100%);"></div>
    </div>
    <div style="font-family: 'Playfair Display', Georgia, serif; font-size: 58px; font-weight: 600; line-height: 1.12; color: #F5EEDF; letter-spacing: -1.2px; white-space: nowrap;">
      Put AI <em style="font-style: italic; color: #F5EEDF; font-weight: 500;">to work.</em>
    </div>
  </div>

  <!-- Divider above byline -->
  <div class="el" style="top: 1080px; left: 60px; width: 960px; height: 1px; background: linear-gradient(to right, rgba(245, 238, 223, 0) 0%, rgba(245, 238, 223, 0.25) 50%, rgba(245, 238, 223, 0) 100%);"></div>

  <!-- Byline text (left) -->
  <div class="el" style="top: 1110px; left: 60px; width: 720px;">
    <div style="font-family: 'Playfair Display', Georgia, serif; font-style: italic; font-size: 28px; font-weight: 400; color: #F5EEDF; opacity: 0.70; margin-bottom: 8px;">
      Build with
    </div>
    <div style="font-family: 'Playfair Display', Georgia, serif; font-weight: 700; font-size: 48px; color: #F5EEDF; letter-spacing: -0.8px; line-height: 1.0; margin-bottom: 16px;">
      Shalin Shodhan
    </div>
    <div style="font-family: 'Source Serif 4', Georgia, serif; font-style: italic; font-size: 25px; font-weight: 400; line-height: 1.45; color: #F5EEDF; opacity: 0.85;">
      Award-winning game designer &amp; author of<br/>
      the AI curriculum, <em style="font-style: italic; color: #FF6B85; opacity: 0.95;">Talking to Machines.</em>
    </div>
  </div>

  <!-- Photo (right) -->
  <div class="el" style="top: 1100px; left: 820px;">
    <img src="/images/shalin.png" alt="Shalin Shodhan" width="180" height="180" style="border-radius: 50%; object-fit: cover; border: 2px solid rgba(255, 107, 133, 0.35); box-shadow: 0 0 40px rgba(233, 69, 96, 0.15);" />
  </div>

</div>
</body>
</html>
