---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ContextWindowViz from '../../components/widgets/ch3/ContextWindowViz';
import VibeCheck from '../../components/breaks/VibeCheck';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[2];
---

<ChapterLayout chapter={chapter} locale="te">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>3</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          మూడో అధ్యాయం
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Context<br />Engineering
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          AI మర్చిపోదు &mdash; అసలు<br />గుర్తుంచుకోవడమే లేదు.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        ప్రతిసారి నువ్వు AI కి message పంపినప్పుడు, అది నీ <em>మొత్తం conversation</em> ను మొదటి నుండి చదువుతుంది &mdash; నువ్వు పంపిన ప్రతి message, అది ఇచ్చిన ప్రతి response &mdash; reply generate చేసి, అంతా మర్చిపోతుంది. తర్వాతి turn, అదే. మొత్తం transcript మళ్ళీ feed అవుతుంది. ఇది ప్రపంచంలోనే అత్యంత శ్రద్ధగల కానీ జ్ఞాపకశక్తి లేని reader: ప్రతిసారీ పూర్తిగా చదువుతుంది, ప్రతి turn zero నుండి start చేస్తుంది.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONCEPT SETUP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Window కి అంచులు ఉంటాయి
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10" style="margin-top: 0;">
        AI ప్రతి turn లో re-read చేసే transcript? అది <strong>context window</strong> అనే దాంట్లో ఉంటుంది &mdash; <strong>tokens</strong> లో measure అవుతుంది (సుమారుగా ఒక word కి ఒకటిన్నర tokens). Claude window సుమారు 2,00,000 tokens hold చేస్తుంది &mdash; ఒక 500-page book. చాలా ఉన్నట్టు అనిపిస్తుంది, కానీ నువ్వు పంపే ప్రతి message, నీకు వచ్చే ప్రతి response, ప్రతి hidden system instruction — అన్నీ అదే budget నుండి తింటాయి. నువ్వు అనుకున్నదాని కంటే fast గా నిండిపోతుంది.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Budget అయిపోయినప్పుడు, పాత messages అంచు నుండి జారిపోతాయి. మూడో message లో నీ dietary restrictions చెప్పావా? పదిహేనో message కల్లా AI వాటిని చూడలేకపోవచ్చు. అది careless గా ఉండట్లేదు &mdash; దాని ముందు లేనిది literally చూడలేదు. AI దాని window లో ఇప్పుడు ఉన్న information అంత మాత్రమే మంచిది.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        అందుకే best AI users కేవలం మంచి prompts రాయరు &mdash; window <em>లోకి</em> ఏం వెళ్తుందో manage చేస్తారు. Key details కనిపించేలా periodically summarize చేయి. ముఖ్యమైనది ముందు పెట్టు. Topic మారినప్పుడు fresh start చెయ్. AI నీ context efficiently parse చేయడానికి structured formats వాడు. <strong>Context engineering అనేది కొత్త prompt engineering.</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>కీలక అంశం</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          గొప్ప prompt రాయడం step one. AI ముందు ఏ information పెట్టాలో &mdash; దాన్ని ఎలా structure చేయాలో &mdash; decide చేయడంలో అసలు leverage ఉంది. ప్రపంచంలో best prompt కూడా context తప్పుగా ఉంటే fail అవుతుంది.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Context window నిండిపోవడం, overflow అవ్వడం, మర్చిపోవడం &mdash; real time లో చూడు.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ContextWindowViz client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="AI conversation మధ్యలో ఎందుకు 'మర్చిపోతుందో' చివరకు అర్థమైంది. ఇది memory కాదు — ఇది context window. ఈ course live demos తో చాలా clearly explain చేస్తుంది." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        ఇప్పుడు whiteboard కనిపిస్తోంది. Window అంచులు feel అవుతున్నాయి. ఇది AI తో నీ ప్రతి conversation ని మారుస్తుంది.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        ఇప్పటి వరకు chatbots తో work చేస్తున్నాం. తర్వాత, zoom out చేద్దాం &mdash; chat window బయట వందల AI tools ఉన్నాయి, landscape తెలిసుకుంటే ఏం possible అనుకుంటావో అదే మారుతుంది.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Vibe Check" client:visible>
        <VibeCheck client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
