---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ContextWindowViz from '../../components/widgets/ch3/ContextWindowViz';
import ForgettingExperiment from '../../components/widgets/ch3/ForgettingExperiment';
import SystemPromptSandbox from '../../components/widgets/ch3/SystemPromptSandbox';

const chapter = chapters[2];
---

<ChapterLayout chapter={chapter} locale="te">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>3</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          అధ్యాయం మూడు
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Context<br />Engineering
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          AI మర్చిపోదు &mdash; అది మొట్టమొదట<br />గుర్తు పెట్టుకోలేదు.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        మీరు స్నేహితుడితో మాట్లాడుతున్నారని అనుకోండి, కానీ ప్రతి కొన్ని నిమిషాలకు ఎవరో మీరిద్దరూ వ్రాసిన whiteboard ని తుడిచేస్తూ ఉంటారు. మీరు మళ్లీ మొదలుపెట్టాలి. మీ స్నేహితుడు మిగిలిపోయిన దాన్ని చూసి, ఏమీ జరగనట్లుగా కొనసాగించే ప్రయత్నం చేస్తాడు. AI యొక్క "మెదడు" లో దీర్ఘ సంభాషణ సమయంలో అలాంటిదే జరుగుతుంది.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        <strong>AI కి మెమరీ లేదు.</strong> మీరు మెమరీ అనుకున్న రీతిలో కాదు. అది నిన్నటి మీ సంభాషణ గుర్తుచేసుకోదు. <em>ఈ</em> సంభాషణ చాలా పొడవుగా సాగితే దాని మొదటి భాగాన్ని కూడా గుర్తుపట్టదు. అది చెప్పే ప్రతి సమాధానం దాని ప్రస్తుతం కనిపిస్తున్న దాని మీద మాత్రమే ఆధారపడి ఉంటుంది &mdash; <strong>context window</strong> అని పిలిచే text కిటికీ.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        ఈ కిటికీని అర్థం చేసుకోవడం &mdash; దానిలో ఏమి వెళ్తుంది, ఎంత పెద్దది, నిండిపోయాకు ఏమవుతుంది &mdash; AI తో పని చేయడంలో అత్యంత ముఖ్యమైన నైపుణ్యాలలో ఒకటి.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE WHITEBOARD METAPHOR ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        తుడిచేయబడే Whiteboard
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        మీరు AI కి సందేశం పంపినప్పుడు, అసలు ఏమవుతుందంటే: సిస్టం మీ <em>మొత్తం సంభాషణను</em> &mdash; మీరు పంపిన ప్రతి సందేశం, AI ఇచ్చిన ప్రతి జవాబు &mdash; తీసుకొని, అన్నింటినీ ఒకే text block గా model కి అందిస్తుంది. AI అంతా చదివి, తదుపరి జవాబు generate చేసి, ఆ తర్వాత... అన్నీ మర్చిపోతుంది.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        తదుపరిసారి మీరు సందేశం పంపినప్పుడు, మొత్తం process మళ్లీ repeat అవుతుంది. సిస్టం మొత్తం సంభాషణను మళ్లీ paste చేసి, మీ కొత్త సందేశాన్ని చేర్చి, AI అంతా fresh గా చదువుతుంది. ఇది ప్రపంచంలోనే అత్యంత pillar కానీ amnesia గల reader లాంటిది &mdash; ప్రతిసారీ పూర్తిగా thorough గా ఉంటుంది, కానీ ప్రతి turn లో మొదటినుంచీ start చేస్తుంది.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AI generate చేసే ప్రతి response, ఆ క్షణంలో context window లో ఉన్న దాని మీద మాత్రమే ఆధారపడుతుంది. దానికంటే ఏమీ లేదు. Context window అంటే మెమరీ కాదు. అది whiteboard &mdash; దానికి అంచులు ఉంటాయి.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        దీనివల్ల పెద్ద ప్రభావాలు ఉంటాయి. AI అనేది దాని ముందు ప్రస్తుతం ఉన్న సమాచారం అంత మంచిదే. ముఖ్యమైన detail ని మిస్ చేస్తే? AI దాన్ని magically గుర్తుచేసుకోదు. కిటికీని noise తో నింపేస్తే? AI confused అవుతుంది. <strong>Context window మీ అత్యంత ముఖ్యమైన resource.</strong> దాన్ని manage చేయడం నేర్చుకోవడమే casual users కు మరియు నిజంగా powerful results పొందే వారికి మధ్య తేడా.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ TOKENS — THE AI'S ALPHABET ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Tokens: AI యొక్క వర్ణమాల
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI మీలాగా words చదవదు. అది <strong>tokens</strong> చదువుతుంది &mdash; సాధారణంగా మూడు వంతుల మేర word ఉండే text chunks. "incredible" అనే మాట రెండు tokens. "AI" ఒక token. ఒక word ముందు space చాలా సార్లు అదే token లోనే ఉంటుంది.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: #7B61FF;">
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>త్వరిత లెక్క</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          1 token &asymp; 4 characters &asymp; 0.75 words<br />
          100 tokens &asymp; 75 words<br />
          ఒక సాధారణ పేజీ text &asymp; 300 tokens<br />
          పూర్తి నవల &asymp; 100,000 tokens
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        దీనికేందుకు matter అవుతుంది? ఎందుకంటే ప్రతి AI model కి tokens లో measure చేసిన <strong>context window size</strong> ఉంటుంది. Claude యొక్క context window 200,000 tokens పట్టుకోగలదు &mdash; దాదాపు 500-page పుస్తకం. GPT-4o 128,000 పట్టుకుంటుంది. ఇవి చాలా పెద్దవిగా అనిపిస్తాయి, కానీ మీరు అనుకున్నంత కంటే వేగంగా నిండిపోతాయి.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        మీరు పంపిన ప్రతి సందేశం, AI వ్రాసిన ప్రతి జవాబు, వెనుకで పని చేస్తున్న ప్రతి system instruction &mdash; అన్నీ అదే shared budget నుంచి tokens వినియోగిస్తాయి. మరియు ఆ budget అయిపోయినప్పుడు, విషయాలు edge నుంచి జారిపోవడం మొదలవుతాయి.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: CONTEXT WINDOW VIZ ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ContextWindowViz client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ WHEN THE WINDOW OVERFLOWS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        కిటికీ నిండిపోయినప్పుడు
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        మీరు సంభాషణలో పది సందేశాలు పంపారు. మూడవ సందేశంలో మీ dietary restrictions గురించి చెప్పారు. పదిహేనవ సందేశంలో restaurant recommendations లో లోతుగా ఉన్నారు. మీరు అడుగుతారు: <em>"ఆగండి, నేను ఏ dietary restrictions చెప్పాను?"</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        మరియు AI చెబుతుంది: <em>"మీరు ఏ specific dietary restrictions చెప్పలేదని అనుకుంటున్నాను."</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        మీకు కోపం వస్తుంది. <em>అక్కడే ఉంది, నేను చెప్పాను!</em> కానీ విషయం ఏమిటంటే: అది <strong>అక్కడ లేదు</strong>. ఇప్పుడు లేదు. ఆ తొలి సందేశం visible window నుంచి జారిపోయి ఉండవచ్చు, లేదా model దాన్ని recent context కోసం తక్కువ priority ఇచ్చి ఉండవచ్చు. AI careless గా ఉండటం లేదు. దాని ముందు లేని దాన్ని అది అక్షరాలా చూడలేదు.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>ఇది bug కాదు. Architecture అది.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI context window ను ఒక human ఒక document ని single sitting లో చదువుతున్నట్లు process చేస్తుంది. Document 100 pages పొడవు ఉంటే, page 3 లో details page 95 దగ్గర వచ్చేసరికి fuzzy అయ్యి ఉండవచ్చు. Solution పెద్ద window కాదు &mdash; ఏమి వెళ్తుందనే దాని smarter packing.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FORGETTING EXPERIMENT ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ForgettingExperiment client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SYSTEM PROMPT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        System Prompt: దాచిన సూచనలు
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ప్రతి AI సంభాషణలో మీరు ఎప్పుడూ చూడని భాగం ఉంటుంది. మీ మొదటి సందేశం ముందు, AI hello చెప్పే ముందు, context window అట్టుపైన ఒక text block కూర్చుని ఉంటుంది. దాన్ని <strong>system prompt</strong> అంటారు, మరియు అది తదుపరిది అంతా shape చేస్తుంది.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        System prompt అంటే AI కి దాని personality, దాని rules, దాని boundaries వచ్చే చోటు. ChatGPT weapon తయారు చేయడంలో మీకు సహాయం చేయడానికి నిరాకరించినప్పుడు, అది system prompt. Claude "I'd be happy to help" అన్నప్పుడు, అది system prompt తో reinforce చేసిన trained behavior. Customer service chatbot topic లోనే ఉన్నప్పుడు, అది &mdash; మీరు అనుకున్నట్లే &mdash; system prompt.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style="--accent: #7B61FF;">
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>System prompt ఉదాహరణ</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          "మీరు సహాయకరమైన cooking assistant. Cooking మరియు food preparation గురించి మాత్రమే ప్రశ్నలకు జవాబు ఇవ్వండి. వేరేవి అడిగితే, మర్యాదగా సంభాషణను cooking topics వైపు మరల్చండి. జవాబులను 150 words లోపు ఉంచండి. Warm, encouraging tone వాడండి."
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
