---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import ProjectOrchestrator from '../../components/widgets/ch8/ProjectOrchestrator';
import ContextPacking from '../../components/widgets/ch8/ContextPacking';

const chapter = chapters[7];
---

<ChapterLayout chapter={chapter} locale="te">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>8</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          అధ్యాయం ఎనిమిది
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Complexity ని<br />Orchestrate చేయడం
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          ఏ context window కంటే పెద్ద<br />projects లో AI ని manage చేయడం.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        ప్రతి ambitious beginner ఇక్కడ hit అవుతాడు: AI ని ఏదైనా real build చేయమంటావ్ — full game, backend తో website, citations తో research paper — మరియు అంతా కూలిపోతుంది. AI తగినంత smart కాదని కాదు. Project single conversation కి చాలా big కాబట్టి.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        Requirements wall paste చేస్తావ్, AI confident-sounding response ఇస్తుంది, ఇరవై నిమిషాల తర్వాత realize అవుతావ్ — నువ్వు ask చేసినదాంట్లో సగం మర్చిపోయింది, architecture మీద తనకు తానే contradict చేసుకుంది, మరియు exist అవ్వని library hallucinate చేసింది. మళ్ళీ try చేస్తావ్. Same result, different hallucinations.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        ఇది AI problem కాదు. ఇది <strong>orchestration problem</strong>. దీన్ని solve చేయడం నేర్చుకోవడం one-off tasks కోసం AI use చేసే వ్యక్తి మరియు real things build చేయడానికి use చేసే వ్యక్తి మధ్య తేడా.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE ONE-PROMPT TRAP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        One-Prompt Trap
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI use చేయడం మొదట నేర్చుకున్నప్పుడు, naturally అంతా one shot లో చేయడానికి try చేస్తావ్. ఒక massive prompt. ఒక conversation. ఒక attempt. Simple tasks కి — email రాయడం, ideas brainstorm చేయడం, concept explain చేయడం — అది fine గా work అవుతుంది.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        కానీ complexity one-prompt approach ని మూడు విధాలుగా break చేస్తుంది:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 2.5rem;">
        {[
          { num: '1', title: 'Context overflow', text: 'AI ఒకేసారి limited information మాత్రమే hold చేయగలదు. Full project ఆ limit exceed చేస్తుంది, కాబట్టి AI నీ earlier requirements "మర్చిపోవడం" start చేస్తుంది.' },
          { num: '2', title: 'Attention dilution', text: 'Context window లోపల కూడా, AI ని ఒకేసారి పన్నెండు different concerns juggle చేయమంటే ప్రతి ఒక్కదానికి తక్కువ focus వస్తుంది. Quality across the board drop అవుతుంది.' },
          { num: '3', title: 'Error compounding', text: 'Complex output లో ఒక చిన్న mistake cascade అవుతుంది. AI database schema wrong గా చేస్తే, ఆ schema మీద build అయిన అంతా wrong — మరియు generated code wall లో deep గా spot చేయడం కష్టం.' },
        ].map((item, i) => (
          <FadeInBlock client:visible delay={0.2 + i * 0.08}>
            <div style="display: flex; gap: 1.25rem; align-items: flex-start;">
              <div style={`flex-shrink: 0; width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 0.8rem; font-weight: 700; color: white; background: ${chapter.accent};`}>
                {item.num}
              </div>
              <div style="flex: 1;">
                <p style={`font-family: var(--font-heading); font-size: 1rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.3rem; line-height: 1.3;`}>
                  {item.title}
                </p>
                <p style="font-size: 0.95rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                  {item.text}
                </p>
              </div>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.5}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        Solution better prompt కాదు. Better process.
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ DECOMPOSITION: THE MASTER SKILL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Decomposition: Master Skill
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Professional software engineers entire applications ఒక sitting లో build చేయరు. వాటిని pieces గా విడగొడతారు — modules, components, functions — ఒక్కొక్కటి clear purpose, clear inputs, మరియు clear outputs తో. ఆపై assemble చేస్తారు.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Complex projects మీద AI తో work చేయడానికి same discipline అవసరం. నీ project ని single, focused AI conversation బాగా handle చేయగల tasks గా <strong>decompose</strong> చేయాలి.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        Good decomposition మూడు rules follow చేస్తుంది:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
        <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
        {[
          { word: 'Single responsibility.', desc: 'ప్రతి task ఒకే పని చేస్తుంది. "Database design చేయి AND API build చేయి AND frontend write చేయి" మూడు tasks, ఒకటి కాదు.' },
          { word: 'Clear interfaces.', desc: 'ప్రతి task కి defined input (start చేయడానికి ఏమి కావాలి) మరియు defined output (ఏమి produce చేస్తుంది) ఉంటాయి. ఒక task output next task input అవుతుంది.' },
          { word: 'Minimal dependencies.', desc: 'Parallel గా చేయగల tasks parallel గా చేయాలి. ఒక task genuinely మరొక task output need అయినప్పుడే dependencies create చేయి.' },
        ].map((step, i) => (
          <div style={`position: relative; padding-bottom: ${i < 2 ? '1.75rem' : '0'};`}>
            <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
            <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
              <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
              <span style="opacity: 0.7;"> {step.desc}</span>
            </p>
          </div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Decomposition human skill, AI skill కాదు.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI task breakdown brainstorm చేయడంలో help చేయగలదు, కానీ work ఎలా split చేయాలో, ఏది ఏది మీద depend అవుతుందో, ఏది prioritize చేయాలో decide చేయడం — అది నీ job. ఇది project management, మరియు నువ్వు develop చేయగల most valuable skills లో ఒకటి.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO PROJECT ORCHESTRATOR -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Real project decompose చేయడానికి try చేయి. Tasks drag చేయి, dependencies track చేయి, plan shape అవ్వడం చూడు.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: PROJECT ORCHESTRATOR ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ProjectOrchestrator client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE HANDOFF PATTERN ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Handoff Pattern
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Project ని tasks గా break చేసిన తర్వాత, వాటిని connect చేయడానికి way కావాలి. AI workflows లో, ఈ connection <strong>handoff</strong> — ఒక conversation output next conversation input అయ్యే moment.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: var(--color-navy);">
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Handoff Pattern</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          Conversation 1 ఒక <strong>artifact</strong> produce చేస్తుంది — document, schema, plan.<br />
          ఆ artifact ని Conversation 2 లోకి <strong>context</strong> గా paste చేస్తారు.<br />
          Conversation 2 దాని మీద build చేసి next artifact produce చేస్తుంది.<br />
          Project complete అయ్యే వరకు repeat చేయి.
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        Relay race లాగా ఆలోచించు. ప్రతి runner (conversation) తన leg cover చేసి baton (artifact) ని next runner కి pass చేస్తుంది. Baton critical piece — drop అయినా garble అయినా, next runner stumble అవుతాడు.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        అంటే నీ handoff artifacts <em>crisp</em> గా ఉండాలి. Database schema, data model యొక్క vague description కంటే better handoff. Numbered list of API endpoints, "user stuff handle చేసే backend కావాలి" కంటే better. Artifact ఎంత sharp గా ఉంటే, next conversation అంత better perform చేస్తుంది.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        నీ handoff artifact quality downstream build అయ్యే అంతటి quality ని determine చేస్తుంది. Garbage in, garbage out — conversations అంతటా.
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONTEXT PACKING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Context Packing Art
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ప్రతిసారి new AI conversation start చేసినప్పుడు, చాలా మంది గమనించని decision తీసుకుంటున్నావ్: <strong>ఏ context include చేయాలి?</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Limited budget ఉంది — context window. మరియు potentially relevant information pile ఉంది: code files, documentation, previous conversations, error logs, design specs. అంతా fit అవ్వదు. అంతా fit అయినా, everything dump చేస్తే AI attention dilute అవుతుంది.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        Context packing trip కోసం suitcase pack చేయడం లాంటిది. Entire closet తీసుకెళ్ళలేవు. ఎక్కడికి వెళ్తున్నావో (task), ఏమి కావాలో (relevant information), మరియు ఏమి వదిలేయవచ్చో (everything else) ఆలోచించాలి.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div style="display: flex; flex-direction: column; gap: 1.25rem; margin-bottom: 2.5rem;">
        {[
          { label: 'చాలా తక్కువ context', color: '#E94560', text: 'AI కి కావాల్సింది లేదు, gaps ని hallucinations తో fill చేస్తుంది. Confident గా sound అవుతుంది కానీ details invent చేస్తుంది.' },
          { label: 'చాలా ఎక్కువ context', color: '#F5A623', text: 'AI overwhelm అవుతుంది. Important details noise లో lost అవుతాయి. Output generic మరియు unfocused అవుతుంది.' },
          { label: 'సరైన context', color: '#16C79A', text: 'AI కి ఈ specific task కోసం exactly ఏమి కావాలో అది ఉంటుంది. Output precise, relevant, మరియు actionable అవుతుంది.' },
        ].map((item, i) => (
          <FadeInBlock client:visible delay={0.25 + i * 0.08}>
            <div style={`padding: 1rem 1.25rem; border-radius: 10px; border-left: 3px solid ${item.color}; background: ${item.color}08;`}>
              <p style={`font-family: var(--font-heading); font-size: 0.9rem; font-weight: 700; color: ${item.color}; margin: 0 0 0.25rem;`}>
                {item.label}
              </p>
              <p style="font-size: 0.9rem; line-height: 1.7; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {item.text}
              </p>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Editor లాగా ఆలోచించు, hoarder లాగా కాదు.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          ప్రతి AI interaction ముందు, ఆలోచించు: ఈ specific task చేయడానికి AI కి ఏమి <em>తెలియాలి</em>? అది include చేయి. మిగతాదంతా వదిలేయి. ఇది context engineering ని project management కి apply చేయడం.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO CONTEXT PACKING -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Context suitcase pack చేయి. Overflow అవ్వకుండా important stuff fit చేయగలవా?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: CONTEXT PACKING ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ContextPacking client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ VERSION CONTROL FOR AI WORK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
