---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import ToolCatalog from '../../components/widgets/ch5/ToolCatalog';
import TrustThermometer from '../../components/widgets/ch5/TrustThermometer';

const chapter = chapters[4];
---

<ChapterLayout chapter={chapter} locale="te">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>5</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          అధ్యాయం ఐదు
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          టూల్స్<br />ఇవ్వు
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          "ప్రశ్నలకు సమాధానాలు" నుండి<br />"చర్యలు తీసుకోవడం" వరకు.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8" style="--drop-cap-color: #F5A623;">
        ఇప్పటి వరకు నీ ప్రతి AI సంభాషణ అదే పద్ధతిని అనుసరించింది. నువ్వు ఏదైనా టైప్ చేస్తావ్. AI తిరిగి ఏదైనా టైప్ చేస్తుంది. టెక్స్ట్ లోపలకు, టెక్స్ట్ బయటకు. చాలా అధునాతనమైన ఆటోకంప్లీట్. కానీ అది పైభాగం కాదు. అది కేవలం నేల మాత్రమే.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        AI ఏదైనా అసలు <em>చేయగలిగితే</em> ఎలా ఉంటుంది? వాతావరణం గురించి చెప్పడం మాత్రమే కాకుండా, నిజమైన వాతావరణ సమాచారాన్ని తనిఖీ చేసినట్లైతే? కోడ్ రాయడం మాత్రమే కాకుండా, దాన్ని నడిపి ఏమి జరిగిందో చెప్పినట్లైతే? Google లో ఏం వెతకాలో చెప్పడం మాత్రమే కాకుండా, వెబ్ లో కూడా వెతికి దొరికినది తీసుకొచ్చినట్లైతే?
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        అదే టూల్ ఉపయోగం. ఇది AI ఎలా పని చేస్తుందనే విషయాన్ని పూర్తిగా మార్చేస్తుంది.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BEYOND TEXT-IN TEXT-OUT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        టెక్స్ట్-ఇన్, టెక్స్ట్-అవుట్ దాటి
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        చాట్‌బాట్‌ని నువ్వు అడిగినప్పుడు ఏమి జరుగుతుందో ఆలోచించు: <em>"టోక్యోలో ఇప్పుడు ఎంత టైమ్?"</em> AI కి అసలు సమయం తెలియదు. ఇది నెలలు లేదా సంవత్సరాల పాత డేటాపై శిక్షణ పొందింది. దానికి గడియారం లేదు. కాబట్టి అది చేయగలిగిన ఒకే పని చేస్తుంది — తన శిక్షణ డేటాలోని నమూనాల ఆధారంగా అంచనా వేస్తుంది. కొన్నిసార్లు దగ్గరగా ఉంటుంది. కొన్నిసార్లు హాస్యాస్పదంగా తప్పుగా ఉంటుంది.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="prompt-block mb-10" style="--accent: #6B7280;">
        <span class="prompt-block-label" style="color: #6B7280;">టూల్స్ లేకుండా</span>
        <p class="m-0" style="color: var(--color-deep);">
          <span style="font-style: italic; opacity: 0.6;">యూజర్:</span> టోక్యోలో ఎంత టైమ్?<br />
          <span style="font-style: italic; opacity: 0.6;">AI:</span> దాదాపు 2:30 PM JST ఉంటుంది. <span style="color: var(--color-accent-red); font-size: 0.85em;">(ఊహిస్తూ)</span>
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        ఇప్పుడు అదే AI కి <strong>టూల్</strong> ఇవ్వు — ఏ టైమ్‌జోన్‌లోనైనా ప్రస్తుత సమయాన్ని తిరిగి ఇచ్చే సాధారణ ఫంక్షన్. అకస్మాత్తుగా:
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="prompt-block mb-10" style="--accent: var(--color-amber);">
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>టూల్స్ తో</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          <span style="font-style: italic; opacity: 0.6;">యూజర్:</span> టోక్యోలో ఎంత టైమ్?<br />
          <span style="font-style: italic; opacity: 0.6;">AI ఆలోచన:</span> <span style="color: var(--color-purple); font-size: 0.9em;">నా దగ్గర టైమ్‌జోన్ టూల్ ఉంది. దాన్ని ఉపయోగిస్తాను.</span><br />
          <span style="font-style: italic; opacity: 0.6;">AI కాల్ చేస్తుంది:</span> <code style="font-size: 0.85em;">get_time("Asia/Tokyo")</code><br />
          <span style="font-style: italic; opacity: 0.6;">టూల్ రిటర్న్ చేస్తుంది:</span> <code style="font-size: 0.85em;">14:47 JST</code><br />
          <span style="font-style: italic; opacity: 0.6;">AI:</span> టోక్యోలో ప్రస్తుతం 2:47 PM (JST) ఉంది. <span style="color: var(--color-teal); font-size: 0.85em;">(ధృవీకరించబడింది)</span>
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85]">
        అదే ప్రశ్న. పూర్తిగా వేరే విశ్వసనీయత. AI తెలివైనది కాలేదు — అది <strong>అనుసంధానం</strong> అయ్యింది. ఇప్పుడు అది తన సొంత మెదడు బయటకు చేరుకుని నిజ ప్రపంచంతో సంభాషించగలుగుతుంది.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ HOW TOOL USE ACTUALLY WORKS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        టూల్ ఉపయోగం అసలు ఎలా పని చేస్తుంది
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ఇది మానసిక నమూనా. నువ్వు AI కి టూల్స్ యాక్సెస్ ఇచ్చినప్పుడు, నువ్వు దానికి <strong>టూల్‌బాక్స్</strong> ఇచ్చి చెబుతున్నావ్: <em>"ఇవి నువ్వు చేయగలిగిన పనులు. ప్రతి టూల్ కోసం, దాన్ని ఎలా పిలవాలో, ఏమి తీసుకుంటుందో మరియు ఏమి తిరిగి ఇస్తుందో ఇక్కడ ఉంది. వాటిని ఎప్పుడు వాడాలో నువ్వే నిర్ణయించుకో."</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-14">
        AI ప్రతి అభ్యర్థనకు ప్రతి టూల్‌ని గుడ్డిగా వాడదు. ఏ టూల్స్ సంబంధితంగా ఉన్నాయో దాని గురించి ఆలోచిస్తుంది, వాడాలా వద్దా అని నిర్ణయిస్తుంది, సరైన ఇన్‌పుట్‌ను రూపొందిస్తుంది, టూల్‌ని పిలుస్తుంది, ఫలితాన్ని చదువుతుంది, తరువాత ఆ ఫలితాన్ని తన జవాబులోకి చేర్చుతుంది. ఈ ప్రక్రియను <strong>ఫంక్షన్ కాలింగ్</strong> అంటారు — ఇది ఆశ్చర్యకరంగా స్థిరమైన లూప్‌ను అనుసరిస్తుంది.
      </p>
    </FadeInBlock>

    <!-- The Agent Loop — editorial layout -->
    <FadeInBlock client:visible delay={0.2}>
      <div style={`position: relative; padding-left: 2.5rem; margin-bottom: 3rem;`}>
        <div style={`position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: linear-gradient(to bottom, ${chapter.accent}, ${chapter.accent}20);`}></div>
        {[
          { word: 'గమనించు.', desc: 'యూజర్ రిక్వెస్ట్ మరియు లభించిన సందర్భాన్ని చదవు.' },
          { word: 'ఆలోచించు.', desc: 'నిర్ణయించు: "దీని కోసం నాకు టూల్ కావాలా, లేదా నేను డైరెక్ట్‌గా సమాధానం ఇవ్వగలనా?"' },
          { word: 'చర్య తీసుకో.', desc: 'సరైన ఆర్గుమెంట్స్‌తో తగిన టూల్‌ని కాల్ చేయి.' },
          { word: 'గమనించు.', desc: 'టూల్ రిజల్ట్‌ని చదవు.' },
          { word: 'స్పందించు.', desc: 'అన్నింటినీ ఉపయోగకరమైన సమాధానంలోకి సంయోజించు.' },
        ].map((step, i) => (
          <div style={`position: relative; padding-bottom: ${i < 4 ? '1.75rem' : '0'};`}>
            <div style={`position: absolute; left: -2.5rem; top: 6px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid ${chapter.accent}; background: var(--color-cream);`}></div>
            <p style="margin: 0; font-size: 1rem; line-height: 1.5;">
              <strong style={`color: ${chapter.accent}; font-family: var(--font-heading); font-weight: 700;`}>{step.word}</strong>
              <span style="opacity: 0.7;"> {step.desc}</span>
            </p>
          </div>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AI స్క్రిప్ట్ అమలు చేయడం లేదు. అది ప్రతిసారీ నిర్ణయం తీసుకుంటుంది: "ఇది టూల్ వాడాల్సిన సందర్భమా లేక నేను స్వయంగా సమాధానం ఇవ్వగలనా?"
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        ఇది <strong>ఏజెంట్ లూప్</strong> — గమనించు, ఆలోచించు, చర్య తీసుకో, గమనించు, స్పందించు. AI దగ్గర ఒక టూల్ ఉన్నా లేదా వంద టూల్స్ ఉన్నా అదే లూప్. నువ్వు దానికి ఎక్కువ టూల్స్ ఇస్తే, అది మరింత సామర్థ్యవంతంగా మారుతుంది. కానీ అంతే కాకుండా, <em>ఏ</em> టూల్‌ని <em>ఎప్పుడు</em> వాడాలనే దాని నిర్ణయంపై నువ్వు మరింత నమ్మకం ఉంచాల్సి ఉంటుంది.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SEVEN TOOLS ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        అన్నిటినీ మార్చే ఏడు టూల్స్
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI వాడగల వందలాది నిర్దిష్ట టూల్స్ ఉన్నాయి, కానీ అవి ఎక్కువగా ఏడు వర్గాలలోకి వస్తాయి. ప్రతిదీ AI ఏమి చేయగలదనేదాన్ని పూర్తిగా వేరే విధంగా విస్తరిస్తుంది. కొన్ని దానికి <em>జ్ఞానం</em> ఇస్తాయి (వెబ్ వెతుకుడు, డేటాబేసులు). కొన్ని దానికి <em>సామర్థ్యాలు</em> ఇస్తాయి (కోడ్ అమలు, చిత్ర నిర్మాణం). కొన్ని దానికి <em>చేతులు</em> ఇస్తాయి (ఫైల్ సవరణ, API కాల్స్).
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        AI కి టూల్ కావాలని గుర్తించడం నుండి దాన్ని పిలవడం వరకు, ఫలితాన్ని వాడడం వరకు పూర్తి ఆలోచన ప్రక్రియను చూడటానికి కింది ఏదైనా టూల్‌పై క్లిక్ చేయి.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: TOOL CATALOG ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ToolCatalog client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE TRUST QUESTION ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
