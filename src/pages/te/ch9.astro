---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import FactOrFabrication from '../../components/widgets/ch9/FactOrFabrication';
import SweetTalker from '../../components/breaks/SweetTalker';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[8];
---

<ChapterLayout chapter={chapter} locale="te">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>9</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          తొమ్మిదో అధ్యాయం
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          AI తప్పు<br />చేసినప్పుడు
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Amateurs నుండి pros ని separate చేసే<br />verification habits.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        ఇప్పుడే flawless essay రాయడంలో help చేసిన AI, అదే confidence తో Napoleon Waterloo యుద్ధం గెలిచాడని కూడా చెప్పగలదు. Hesitate చేయదు. Stammer చేయదు. పూర్తిగా fabricate చేసిన "fact" ని అన్నిటికీ వాడే అదే authoritative tone లో చెబుతుంది. ఇదే AI తో work చేయడంలో ఉన్న paradox: <strong>దాన్ని useful చేసే fluency, dangerous కూడా చేస్తుంది.</strong>
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONCEPT: HALLUCINATION ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Plausibility అంటే Truth కాదు
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10" style="margin-top: 0;">
        AI models database నుండి facts retrieve చేయవు. తర్వాతి most likely word predict చేస్తాయి. నిజమైన విషయం గురించి అడిగినప్పుడు, training data correct information వైపు guide చేస్తుంది. లేనిది గురించి అడిగినప్పుడు, model "నాకు తెలియదు" అనదు. Correct answer <em>ఎలా ఉంటుందో</em> generate చేస్తుంది — names, dates, citations అన్నీతో. అంతా fabricated.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        AI ఎంత confidently sound అవుతుందో, actually ఎంత accurate ఉందో — రెండింటికి correlation లేదు. Wrong answer మరియు right answer బయటి నుండి identical గా కనిపిస్తాయి. Tone బట్టి, detail బట్టి, AI include చేసిన specific numbers బట్టి accuracy judge చేయలేవు. "ఇది right గా sound అవుతోంది" test పనికిరానిది. నీ ఏకైక defense verification.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>కీలక అంశం</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI కి truth concept లేదు. <em>Plausibility</em> concept ఉంది. Pattern కి fit అయ్యే text generate చేస్తుంది — ఆ text reality కి correspond అవుతుందో లేదో count చేయదు.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        నీ detector test చెయ్. AI claims లో ఏవి real, ఏవి fabricated అని చెప్పగలవా?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FactOrFabrication client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="ప్రతి AI user కి ఈ chapter అవసరం. AI ఎలా hallucinate చేస్తుందో, తప్పు answers తో ఎందుకు agree అవుతుందో, ఎలా catch చేయాలో teach చేస్తుంది. చాలా practical." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        AI నుండి ఎక్కువ value పొందేవాళ్ళు ఎప్పుడు trust చేయాలో, ఎప్పుడు verify చేయాలో exactly నేర్చుకున్నవాళ్ళు.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        AI ఎప్పుడు wrong అవుతుందో తెలుసుకోవడం ఒక పెద్ద ప్రశ్నకు దారి తీస్తుంది: అది <em>ఎప్పటికీ</em> చేయలేనిది ఏంటి? తర్వాత, మొండిగా, అందంగా human గా ఉండే skills ని explore చేద్దాం — మరియు అవి ఎందుకు ఇప్పటికంటే ఎక్కువ matter అవుతున్నాయో.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(233,69,96,0.06) 15%, rgba(233,69,96,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#E94560" toolName="Sweet Talker" client:visible>
        <SweetTalker client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
