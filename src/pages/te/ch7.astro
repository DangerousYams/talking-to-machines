---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import WhatWouldYouBuild from '../../components/widgets/ch7/WhatWouldYouBuild';
import ShipIt from '../../components/breaks/ShipIt';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[6];
---

<ChapterLayout chapter={chapter} locale="te">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>7</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          ఏడో అధ్యాయం
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Claude Code<br />Master చేయడం
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          నీ AI pair programmer, మొదటి<br />command నుండి custom Skills వరకు.
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        ప్రతి coder కి గుర్తుండే ఒక moment ఉంటుంది. Terminal open చేసి, natural-language request టైప్ చేసి, AI నీ files చదవడం, architecture అర్థం చేసుకోవడం, multiple files లో code రాయడం, run చేయడం, error వచ్చినప్పుడు fix చేయడం, మళ్ళీ run చేయడం చూస్తావ్ — నువ్వు ఒక్క line కూడా touch చేయకుండా. Claude Code autocomplete కాదు. ఇది <em>agentic</em> coding tool — నీ entire project చూస్తుంది, files అంతటా changes చేస్తుంది, shell commands execute చేస్తుంది, తన mistakes మీద iterate చేస్తుంది.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        Tool అయితే దాన్ని steer చేసే human అంత మాత్రమే మంచిది. Claude Code seconds లో వెయ్యి lines perfect code రాయగలదు — లేదా వెయ్యి lines plausible-looking garbage. తేడా నువ్వే.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE LOOP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Specify, Generate, Verify
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        Claude Code కి task ఇచ్చినప్పుడు, అది agent loop run చేస్తుంది: codebase చదువు, ఏం change చేయాలో plan చెయ్, edits రాయి, code run చెయ్, break అయినది fix చెయ్. ఆ loop లో మూడు, ఐదు, పది సార్లు cycle అవ్వవచ్చు — అంతా seconds లో. నీ job ఇక ప్రతి line రాయడం కాదు. ఏం build చేయాలో <strong>specify</strong> చెయ్, AI ని <strong>generate</strong> చేయనివ్వు, తర్వాత actually right గా ఉందో <strong>verify</strong> చెయ్. Beginners చాలా మంది ఆ last step skip చేస్తారు. Code appear అవ్వడం చూస్తారు, reasonable గా కనిపిస్తుంది, ముందుకు వెళ్తారు. ఆ వ్యక్తి కావద్దు. Generated code first draft. నీ verification దాన్ని publishable చేసే edit.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Secret weapon <code>CLAUDE.md</code> file — దాన్ని project root లో drop చేస్తే Claude Code ప్రతి session start లో చదువుతుంది. నీ tech stack, naming conventions, style rules, testing expectations — అన్నీ ఒకసారి encode చేస్తే repeat చేయాల్సిన అవసరం లేదు. ఇది coding కి apply చేసిన context engineering.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Goal ప్రతి line రాయడం కాదు — ప్రతి line అర్థం చేసుకోవడం.</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Claude generate చేసిన code చదవలేకపోతే, verify చేయలేవు. Best Claude Code users ఎక్కువ code generate చేసేవాళ్ళు కాదు — best questions అడిగి subtlest bugs catch చేసేవాళ్ళు.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        Loop action లో చూడు. Request టైప్ చేసి Claude Code work చేయడం watch చెయ్.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="terminal-playground" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <WhatWouldYouBuild client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="Claude Code మీద ఈ chapter wild — AI pair programmer problem think through చేయడం, code రాయడం, తనను తాను debug చేయడం చూశాను. Coding భవిష్యత్తు ఇక్కడే ఉంది." client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Claude Code నీ కోసం code రాయడం లేదు — నీతో కలిసి code రాస్తోంది.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        ఒక conversation ఒక task handle చేయగలదు. కానీ real projects లో dozens ఉంటాయి. తర్వాత: పెద్ద ambitions ని AI actually execute చేయగలిగే pieces గా ఎలా break చేయాలో.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Ship It" client:visible>
        <ShipIt client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
