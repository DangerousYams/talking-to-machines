---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ToolWall from '../../components/widgets/ch4/ToolWall';
import WorkflowBuilder from '../../components/widgets/ch4/WorkflowBuilder';
import HeadToHead from '../../components/widgets/ch4/HeadToHead';

const chapter = chapters[3];
---

<ChapterLayout chapter={chapter} locale="te">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>4</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          అధ్యాయం నాలుగు
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          AI<br />పరిస్థితి
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          మీరు ఇప్పుడే వాడగల<br />ప్రతి AI టూల్ గైడ్.
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        చాలా మంది "AI" అంటే ChatGPT అని అనుకుంటారు. లేకపోతే Google Gemini లేదా Claude గురించి విన్నారేమో. అది "ఇంటర్నెట్" అంటే Google అనుకోవడం లాంటిది. తప్పు కాదు. కానీ అది చాలా పెద్దది మధ్య చిన్న ముక్కేనా.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        ప్రస్తుతం మీరు ఈ రోజే వాడగలిగిన వందలాది AI టూల్స్ ఉన్నాయి -- కొంత భవిష్యత్ లో కాదు, మీ బ్రౌజర్ నుండి ఇప్పుడే. ఒక వాక్యం నుండి ఫోటోలాంటి చిత్రాలు తయారు చేసే టూల్స్. పూర్తి పాటలు కంపోజ్ చేసే టూల్స్. మీ రీసెర్చ్ టాపిక్ గురించి ఇప్పటివరకు వ్రాసిన అన్ని పేపర్లను చదివి, మూడు పేరాలలో సారాంశం చెప్పే టూల్స్.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        ఈ అధ్యాయం మీ గైడ్. అన్ని టూల్స్ కాటలాగ్ కాదు -- అది వచ్చే మంగళవారికే పాతబడిపోతుంది -- కానీ <strong>భూభాగపు మ్యాప్</strong>. ముఖ్యమైన కేటగిరీలు, తెలుసుకోవలసిన టూల్స్, మరియు సరైన టూల్ ఎంచుకోవడానికి సహాయపడే ఆలోచన ఫ్రేమ్‌వర్క్.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ BEYOND THE CHATBOT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        చాట్‌బాట్ కంటే ఎక్కువ
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        చాట్‌బాట్ అనేది హిమగర్భం మధ్య కనిపించే భాగమే. దాని కింద, AI అనేకం ప్రత్యేక సామర్థ్యాలుగా విభజించబడింది, వాటిలో ప్రతిది వేరే రకమైన పనికి వేరే రకమైన టూల్.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        సంగీత వాయిద్యాల గురించి ఆలోచించండి. పియానో మరియు డ్రమ్‌సెట్ రెండూ "సంగీత వాయిద్యాలు," కానీ మీరు పియానిస్ట్‌ని బీట్ వేయమని అడగరు, డ్రమ్మర్‌ని కాంసెర్ట్ వాయించమని అడగరు. AI టూల్స్ కూడా అలాగే. ఇమేజ్ జనరేషన్ కోసం చేసిన టూల్ కోడ్ కోసం చేసిన దానికంటే పూర్తిగా వేరు -- వేరు ఆర్కిటెక్చర్, వేరు ట్రైనింగ్ డేటా, వేరు బలాలు.
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        10 AI టూల్స్‌ని బేసిక్ లెవెల్‌లో తెలిసిన వ్యక్తి, ఒక టూల్ లోతుగా తెలిసిన వారిని ఎల్లప్పుడూ మించిపోతారు. ఎక్కువ టూల్స్ అవగాహన అంటే తొలుత గెలుపు.
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        ఈ రోజు నిలుచుండే పరిస్థితి ఇక్కడ ఉంది, ఈ టూల్స్ అసలు <em>ఏం చేస్తాయి</em> దాని ఆధారంగా వ్యవస్థీకరించబడింది.
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE EIGHT FAMILIES ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        ఎనిమిది కుటుంబాలు
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14">
        మీరు ఎదుర్కొనే ప్రతి AI టూల్ ఈ కేటగిరీలలో ఒకటిలో సరిపోతుంది. కొన్ని టూల్స్ సరిహద్దులు దాటుతాయి, కానీ ఈ కుటుంబాలు అర్థం చేసుకోవడం గందరగోళాన్ని అర్థం చేసుకోవడానికి మానసిక మ్యాప్ ఇస్తుంది.
      </p>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { icon: '1', name: 'చిత్ర జనరేటర్లు', color: '#E94560', text: 'టెక్స్ట్ లోపలికి, చిత్రాలు బయటకు. ఫోటోలాంటి దృశ్యాల నుండి యానిమే నుండి చమురు చిత్రాల వరకు. Midjourney, DALL-E 3, Stable Diffusion, Flux, Ideogram. అత్యంత ప్రజాస్వామిక కేటగిరీ -- ఎవరైనా మాటల నుండి దృశ్య కళ తయారు చేయగలరు.' },
        { icon: '2', name: 'చిత్ర ఎడిటర్లు', color: '#F5A623', text: 'నిజమైన చిత్రంతో ప్రారంభించి దాన్ని మార్చండి. బ్యాక్‌గ్రౌండ్లు తొలగించండి, రెజోల్యూషన్ పెంచండి, వస్తువులు మార్చండి, దృశ్యాలను రీలైట్ చేయండి. Photoshop AI, Magnific, Clipdrop. ఇవి మానవ ఫోటోగ్రాఫర్లను మరియు డిజైనర్లను మార్చకుండా వారికి సహాయం చేస్తాయి.' },
        { icon: '3', name: 'వీడియో క్రియేటర్లు', color: '#7B61FF', text: 'కొత్త సరిహద్దు. టెక్స్ట్ లేదా స్థిర చిత్రాల నుండి వీడియో క్లిప్‌లు జనరేట్ చేయండి. Sora, Runway, Kling, Pika. ఇంకా ప్రారంభమే -- చాలా క్లిప్‌లు 30 సెకన్లకు మించవు -- కానీ అద్భుతమైన వేగంతో మెరుగుపడుతున్నాయి. చిత్రనిర్మాణం ఎప్పటికీ అలాగే ఉండదు.' },
        { icon: '4', name: 'సంగీతం & ఆడియో', color: '#16C79A', text: 'టెక్స్ట్ వివరణ నుండి పూర్తి పాటలు, 30-సెకన్ల నమూనా నుండి వాయిస్ క్లోనింగ్, డిమాండ్‌పై సౌండ్ ఎఫెక్ట్‌లు. Suno, Udio, ElevenLabs. ఈ టూల్స్ స్టూడియో మరియు టీమ్ అవసరమైన దాన్ని ఒకే ప్రాంప్ట్‌లోకి కుదించాయి.' },
        { icon: '5', name: 'రీసెర్చ్ ఏజెంట్లు', color: '#0EA5E9', text: 'మీ కోసం ఇంటర్నెట్ (లేదా అకాడెమిక్ డేటాబేసులు) చదివే AI. Perplexity వెతుకుతుంది మరియు ఉదహరిస్తుంది. Elicit పేపర్లు చదువుతుంది. Consensus శాస్త్రీయ ఒప్పందాన్ని కనుగొంటుంది. NotebookLM మీ డాక్యుమెంట్లను నిపుణులుగా మారుస్తుంది.' },
        { icon: '6', name: 'AI బ్రౌజర్లు', color: '#6B7280', text: 'మానవుడిలా వెబ్‌ను నావిగేట్ చేయగల ఏజెంట్లు. బటన్లు క్లిక్ చేయండి, ఫార్మలు నింపండి, పేజీల మధ్య నావిగేట్ చేయండి. Arc, Operator, Claude Computer Use. "ప్రశ్నలకు సమాధానం" మరియు "పనులు చేయడం" మధ్య వంతెన.' },
        { icon: '7', name: 'కోడింగ్ టూల్స్', color: '#E94560', text: 'కోడ్ రాసే, సవరించే, రన్ చేసే, మరియు డీబగ్ చేసే AI. Claude Code మీ టెర్మినల్ నుండి పనిచేస్తుంది. Cursor మరియు Windsurf పూర్తి ఎడిటర్లు. Copilot ఇన్‌లైన్ సూచనలు ఇస్తుంది. Replit Agent మొత్తం యాప్‌లను మొదటి నుండి నిర్మిస్తుంది.' },
        { icon: '8', name: 'చాట్‌బాట్లు & అసిస్టెంట్లు', color: '#0F3460', text: 'మీరు ఇప్పటికే తెలిసిన సాధారణ-ప్రయోజన సంభాషణ AI: ChatGPT, Claude, Gemini. ఇవి స్విస్ ఆర్మీ నైవ్స్ -- అనేక విషయాలలో మంచివి, మీరు వాటిని ఎలా ప్రాంప్ట్ చేయాలో తెలిసినప్పుడు ఉత్తమమైనవి (అధ్యాయాలు 1-3 వల్ల మీకు తెలుసు).' },
      ].map((family, i) => (
        <FadeInBlock client:visible delay={i * 0.06}>
          <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${family.color};`}>
              {family.icon}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${family.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {family.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {family.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>కీలక అంతర్దృష్టి</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          ఈ కేటగిరీలు కలుస్తున్నాయి. చిత్ర జనరేటర్లు వీడియో జోడిస్తున్నాయి. చాట్‌బాట్లు టూల్ వినియోగాన్ని పొందుతున్నాయి. కోడింగ్ టూల్స్ ఏజెంట్లుగా మారుతున్నాయి. రెండు సంవత్సరాలలో, సరిహద్దులు అస్పష్టంగా ఉంటాయి. కానీ ప్రస్తుతం, నిపుణులు తమ ప్రత్యేకతలో సాధారణ టూల్స్‌ని మించిపోతున్నారు.
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- BRIDGE TO TOOL WALL -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        పూర్తి కేటలాగ్ అన్వేషించండి. ఏ టూల్ అయినా క్లిక్ చేసి అది ఏం చేస్తుందో తెలుసుకోండి.
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: TOOL WALL ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <ToolWall client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CHOOSING THE RIGHT TOOL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        సరైన టూల్ ఎంచుకోవడం
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
