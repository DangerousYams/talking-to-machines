---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import PromptLaboratory from '../../components/widgets/ch2/PromptLaboratory';
import FlipTheScript from '../../components/widgets/ch2/FlipTheScript';
import DebugThePrompt from '../../components/widgets/ch2/DebugThePrompt';

const chapter = chapters[1];
---

<ChapterLayout chapter={chapter} locale="ja">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>2</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          第二章
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          質問の<br />アート
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          最高のプロンプトとは、<br />AIに質問させる質問だ。
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        前の章で、良いプロンプトの5つのビルディングブロック——Role、Task、Format、Constraints、Examples——を学んだ。それが基礎だ。でも材料を知っているだけではシェフにはなれない。
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        この章は<em>テクニック</em>についてだ。プロンプトを打ち込む人と、プロンプトを<em>作り込む</em>人の違い。質問するのと<strong>正しい</strong>質問をするのの違い——本当に使えるものを引き出す質問をすることだ。
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        AIをうまく使う人は、そのトピックの専門家じゃない——<strong>質問の専門家だ。</strong>そして質問は学べるスキルだ。
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SOCRATIC FLIP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        ソクラテス式フリップ
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ほとんどの人がAIを自動販売機のように使っている。プロンプトを入れて、答えを受け取る。でも最高の結果が生まれるのは、命令じゃなく<em>会話</em>からだ。そして最もパワフルな会話テクニックは2,400年前のものだ。
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        ソクラテスは質問に直接答えなかった。<em>もっと</em>質問した——掘り下げて、明確にして、挑んで——生徒が自分で深い理解にたどり着くまで。AIにも同じアプローチが使えるけど、逆転させるんだ。
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AIに答えを求めるんじゃなくて、AIに君をインタビューしてもらう。君が考え忘れていた質問をAIにさせるんだ。
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        考えてみよう。「誕生日パーティーを企画して」と打つとき、答えを大きく変える何十もの情報が抜けている。何人来る？予算は？屋内？屋外？AIは知らない——でも聞ける。
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>ソクラテス式プロンプト</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          「誕生日パーティーを企画したい。企画を始める前に、僕の状況にぴったりのプランを作るための具体的な質問を5つしてほしい。1つずつ聞いて、僕の返答を待ってから次に進んで。」
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        このテクニック1つ——質問する側を逆転させる——は、最もパワフルなアップグレードの1つだ。AIを回答マシンから<strong>思考パートナー</strong>に変える。
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FLIP THE SCRIPT ═══ -->
  <section id="flip-the-script" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <FlipTheScript client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ FEW-SHOT PROMPTING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        説明するより見せる
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        友達にあるスタイルを説明しようとしている場面を想像しよう。5分かけて言葉で説明できる——「遊び心があるけど子供っぽくなくて、カジュアルだけどだらしなくなくて、短い文で意外な比喩がある」。あるいは、例をひとつ見せるだけでいい：<em>「こんな感じで書いて。」</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        これが<strong>Few-shotプロンプティング</strong>だ。抽象的に欲しいものを説明する代わりに、AIに具体的な例を見せる。例が1つなら「ワンショット」プロンプト。2〜3個なら「Few-shot」。例なし——欲しいものを説明するだけ——が「ゼロショット」。
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style="--accent: #6B7280;">
        <span class="prompt-block-label" style="color: #6B7280;">ゼロショット（説明）</span>
        <p class="m-0" style="color: var(--color-deep);">「ランニングシューズの商品説明を書いて。パンチの効いた会話調で、短い文で。マーケティングの決まり文句は避けて。」</p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Few-shot（見せる）</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          「CloudRunner X1ランニングシューズの商品説明を書いて。こういうスタイルがいい：<br /><br />
          <em>例：『ウィークエンドトート——ノートPC、ランチ、それと微妙な人生の選択を全部入れられる。防水キャンバス生地、だってどうせ何かこぼすでしょ。5つのポケット、後で全部忘れるやつ。』</em><br /><br />
          このトーンに合わせて：短い文、自覚的なユーモア、バズワードより具体性。」
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85] mb-10">
        Few-shot版の方が圧倒的に良い結果を出す。AIが「賢くなった」からじゃない——曖昧な方向の代わりに<strong>具体的なターゲット</strong>を与えたからだ。良い例1つは、100語の説明に匹敵する。
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>核心的な気づき</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AIが欲しいスタイルに合わないとき、形容詞を増やすな。例を追加しよう。「こんな感じで」は「もっとパンチ効いた感じだけど温かみもあって、でもカジュアルすぎないように」に毎回勝つ。
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ MINI-CHALLENGE: Zero to Few-Shot ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-12">
    <FadeInBlock client:visible>
      <div style={`background: linear-gradient(135deg, ${chapter.accent}08, ${chapter.accent}04); border: 1px solid ${chapter.accent}20; border-radius: 12px; padding: 2rem 2rem 1.75rem;`}>
        <p style={`font-family: var(--font-mono); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: ${chapter.accent}; margin: 0 0 0.75rem;`}>
          ちょっとした実験
        </p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0 0 1rem; color: var(--color-deep);">
          最近AIに書いてもらったもの——メール、ストーリー、SNSの投稿——を思い出してみよう。もし欲しいトーンの具体例を1つ含めていたら、アウトプットはどう変わっていただろう？
        </p>
        <p style="font-size: 0.9rem; line-height: 1.7; margin: 0; color: var(--color-deep); opacity: 0.6;">
          覚えておこう。下のプロンプトラボラトリーで実際に試せる。
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CHAIN OF THOUGHT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        ステップ・バイ・ステップで考える
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        こんなすごい話がある：AIに数学の問題を解かせると間違えることがある。でも<em>ステップバイステップで解いて</em>と頼むと、正解率が格段に上がる。答えは同じ。質問の仕方が違うだけだ。
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        このテクニックは<strong>Chain-of-thought（思考の連鎖）プロンプティング</strong>と呼ばれる。答えを直接求めるんじゃなくて、AIに推論過程を見せてもらう。「ステップバイステップで考えて」「答える前に分解して」「推論を説明しながら進めて」。
      </p>
    </FadeInBlock>

    <!-- Before/After comparison -->
    <FadeInBlock client:visible delay={0.2}>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
        <div>
          <div class="prompt-block" style="--accent: #E94560; min-height: 100%;">
            <span class="prompt-block-label" style="color: #E94560;">Chain-of-thoughtなし</span>
            <p class="m-0" style="color: var(--color-deep); font-size: 0.85rem;">
              「バットとボールを合わせて$1.10。バットはボールより$1.00高い。ボールはいくら？」
            </p>
            <p style="color: #E94560; font-size: 0.8rem; margin: 1rem 0 0; font-weight: 600;">
              AIの答え：$0.10（不正解）
            </p>
          </div>
        </div>
        <div>
          <div class="prompt-block" style={`--accent: ${chapter.accent}; min-height: 100%;`}>
            <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
            <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Chain-of-thoughtあり</span>
            <p class="m-0" style="color: var(--color-deep); font-size: 0.85rem;">
              「バットとボールを合わせて$1.10。バットはボールより$1.00高い。ボールはいくら？ステップバイステップで考えて。」
            </p>
            <p style={`color: ${chapter.accent}; font-size: 0.8rem; margin: 1rem 0 0; font-weight: 600;`}>
              AIの答え：$0.05（正解）
            </p>
          </div>
        </div>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        なぜ効くのか？AIにステップバイステップで推論させると、各ステップが次に繋がる。AIにメモ用紙を渡すようなもの——思考を書き出せば書き出すほど、最終的な答えが良くなる。
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        Chain-of-thoughtはAIを賢くするんじゃない。遅くする——そして遅い思考はたいてい良い思考だ。
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        数学だけの話じゃない。推論が必要な場面ならいつでも使える：議論の分析、選択肢の比較、プロジェクトの計画、コードのデバッグ。人間に「過程を見せて」と言いたい場面では、AIにも同じことを求めよう。
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE PROMPT ASSEMBLY ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        テクニックを組み合わせる
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        本当のパワーはテクニックの組み合わせから生まれる。Few-shot<em>と</em>Chain-of-thought。システムロール<em>と</em>制約<em>と</em>フォーマット指定。各テクニックはレバーで、複数のレバーを同時に引くと、どれか一つだけでは達成できないものが生まれる。
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        でもここに初心者と上級者を分けるニュアンスがある：<strong>多ければいいってものじゃない。</strong>カジュアルなブレストなら1〜2個のテクニックで十分。重要なエッセイなら5個必要。雑な質問ならゼロ。スキルは何本のレバーを引くか——そしてどのレバーを引くか——を知ることだ。
      </p>
    </FadeInBlock>

    <!-- Technique stack visual -->
    <FadeInBlock client:visible delay={0.2}>
      <div style="margin-bottom: 2.5rem;">
        {[
          { label: 'カジュアルなブレスト', techniques: ['Task'], color: '#6B7280', width: '25%' },
          { label: '学校の課題', techniques: ['Role', 'Task', 'Format'], color: '#F5A623', width: '50%' },
          { label: '重要なプロジェクト', techniques: ['Role', 'Context', 'Task', 'Format', 'Examples'], color: '#0EA5E9', width: '75%' },
          { label: '超重要なアウトプット', techniques: ['Role', 'Context', 'Examples', 'Task', 'Format', 'Constraints', 'Chain-of-thought'], color: '#0F3460', width: '100%' },
        ].map((level, i) => (
          <FadeInBlock client:visible delay={i * 0.06} key={i}>
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem;">
              <span style={`font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600; color: ${level.color}; width: 120px; flex-shrink: 0; text-align: right;`}>
                {level.label}
              </span>
              <div style="flex: 1; height: 24px; background: rgba(26,26,46,0.03); border-radius: 6px; overflow: hidden;">
                <div style={`height: 100%; width: ${level.width}; background: linear-gradient(90deg, ${level.color}20, ${level.color}40); border-radius: 6px; display: flex; align-items: center; padding: 0 8px; gap: 4px;`}>
                  {level.techniques.map((t, j) => (
                    <span key={j} style={`font-family: var(--font-mono); font-size: 0.55rem; font-weight: 600; color: ${level.color}; opacity: 0.8;`}>
                      {t}{j < level.techniques.length - 1 ? ' +' : ''}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.4}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>核心的な気づき</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          プロンプトの書きすぎも問題だ。シンプルな質問に500語のプロンプトを書いても答えは良くならない——むしろAIを混乱させることがある。プロンプトの複雑さをタスクの複雑さに合わせよう。
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: PROMPT LABORATORY ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <PromptLaboratory client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ WHEN PROMPTS GO WRONG ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        プロンプトがうまくいかないとき
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ダメなAIのアウトプットは、<strong>ほぼ絶対にAIのせいじゃない。</strong>アウトプットが汎用的で、曖昧で、あるいは全く的外れなとき、バグは大抵プロンプトにある。そしてコードのデバッグと同じように、プロンプトのデバッグも学べるスキルだ。
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        最もよくあるプロンプトのバグは5つのカテゴリに分かれる。見分け方を覚えたら、至るところで目につくようになる——自分のプロンプトにも、「AIは使えない」と文句を言う他人の話の中にも。
      </p>
    </FadeInBlock>

    <!-- Bug types -->
    <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 2.5rem;">
      {[
        { name: '曖昧', desc: 'プロンプトが複数の意味に取れる。「犬について何か書いて」——どんな文章？誰向け？どのくらいの長さ？', color: '#E94560' },
        { name: '矛盾', desc: 'プロンプトが相反することを求めている。「短くてかつ包括的に」「楽しい雰囲気だけどフォーマルに」。どっちか選ぼう。', color: '#F5A623' },
        { name: 'コンテキスト不足', desc: 'プロンプトに重要な情報が欠けている。コードを見せずに「コードを直して」。エッセイなしに「エッセイを改善して」。', color: '#0EA5E9' },
        { name: 'タスクが多すぎ', desc: 'プロンプトが一度に5つのことを求めている。AIが力を分散して、どれもうまくいかない。', color: '#7B61FF' },
        { name: '誘導質問', desc: 'プロンプトがAIに何を考えるか指示している。「Xが最高だと思わない？」AIは同意する。それは役に立たない。', color: '#16C79A' },
      ].map((bug, i) => (
        <FadeInBlock client:visible delay={i * 0.07}>
          <div style={`display: flex; gap: 1rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 6px; height: 6px; border-radius: 50%; margin-top: 10px; background: ${bug.color};`}></div>
            <div>
              <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${bug.color}; margin: 0 0 0.2rem;`}>
                {bug.name}
              </p>
              <p style="font-size: 0.95rem; line-height: 1.7; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {bug.desc}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.45}>
      <p class="text-lg leading-[1.85]">
        最も厄介なバグは<em>誘導質問</em>だ。素晴らしいアウトプットが出ている<em>ように感じる</em>から発見しにくい——AIが同意してくれてるじゃないか！でも同意は正確さじゃない。自分の既存の信念を確認するように質問を組み立てたら、AIを思考パートナーではなく、イエスマンにしてしまっている。
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: DEBUG THE PROMPT ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <DebugThePrompt client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CLOSING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto mb-8" style="max-width: 55ch;">
        この章の始めは単発のコマンドを打っていた。今は質問を逆転させ、説明より例を見せ、おかしくなったプロンプトをデバッグできるようになった。
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        でも学んだすべてのテクニックは、同じ見えない壁にぶつかる——<em>コンテキストウィンドウ</em>だ。次はそれをこじ開けて、AIが実際に何を見ているのかを理解しよう。
      </p>
    </FadeInBlock>
  </section>

</ChapterLayout>
