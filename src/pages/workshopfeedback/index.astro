---
export const prerender = true;
import '../../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import GtagHead from '../../components/analytics/GtagHead.astro';
import HeadSEO from '../../components/seo/HeadSEO.astro';
import WorkshopFeedbackSurvey from '../../components/workshopfeedback/WorkshopFeedbackSurvey';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Workshop feedback — Talking to Machines</title>
    <HeadSEO
      title="Workshop feedback — Talking to Machines"
      description="A quick post-workshop check-in."
      path="/workshopfeedback"
    />
    <GtagHead />
    <style>
      .intro-page {
        min-height: 100vh;
        position: relative;
        overflow: hidden;
      }
      .intro-page::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
          radial-gradient(ellipse 60% 50% at 20% 30%, rgba(123, 97, 255, 0.06) 0%, transparent 70%),
          radial-gradient(ellipse 50% 50% at 80% 60%, rgba(22, 199, 154, 0.05) 0%, transparent 70%),
          radial-gradient(ellipse 40% 40% at 60% 90%, rgba(245, 166, 35, 0.04) 0%, transparent 70%);
        pointer-events: none;
      }

      .intro-header {
        text-align: center;
        padding: 3rem 1.5rem 0;
        position: relative;
        z-index: 1;
      }
      .intro-header a { text-decoration: none; }
      .intro-logo {
        font-family: var(--font-heading);
        font-size: clamp(1rem, 2.5vw, 1.2rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--color-deep);
        opacity: 0.7;
      }
      .intro-subtitle {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--color-purple);
        margin-top: 0.35rem;
      }

      .deco-dot {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
        z-index: 0;
      }
      .deco-dot-1 {
        width: 8px; height: 8px;
        background: rgba(22, 199, 154, 0.22);
        top: 15%; left: 12%;
        animation: float-slow 10s ease-in-out infinite;
      }
      .deco-dot-2 {
        width: 6px; height: 6px;
        background: rgba(123, 97, 255, 0.22);
        top: 25%; right: 15%;
        animation: float-med 8s ease-in-out infinite;
      }
      .deco-dot-3 {
        width: 10px; height: 10px;
        background: rgba(245, 166, 35, 0.18);
        bottom: 20%; left: 8%;
        animation: float-slow 12s ease-in-out infinite;
      }
      .deco-dot-4 {
        width: 5px; height: 5px;
        background: rgba(233, 69, 96, 0.22);
        bottom: 30%; right: 10%;
        animation: float-med 9s ease-in-out infinite;
      }

      @keyframes float-slow {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-18px) rotate(3deg); }
      }
      @keyframes float-med {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-12px) rotate(-2deg); }
      }

      @media (max-width: 640px) {
        .intro-header { padding-top: 2rem; }
        .deco-dot { display: none; }
      }
    </style>
  </head>
  <body>
    <div class="intro-page">
      <div class="deco-dot deco-dot-1"></div>
      <div class="deco-dot deco-dot-2"></div>
      <div class="deco-dot deco-dot-3"></div>
      <div class="deco-dot deco-dot-4"></div>

      <header class="intro-header">
        <a href="/course">
          <div class="intro-logo">Talking to Machines</div>
        </a>
        <div class="intro-subtitle">Post-workshop feedback</div>
      </header>

      <WorkshopFeedbackSurvey client:load />
    </div>
    <Analytics />
  </body>
</html>
