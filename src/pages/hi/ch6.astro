---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import AgentBlueprint from '../../components/widgets/ch6/AgentBlueprint';
import AgentTakeover from '../../components/breaks/AgentTakeover';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[5];
---

<ChapterLayout chapter={chapter} locale="hi">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>6</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          अध्याय छह
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Agents<br />बनाना
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Calculator और<br />coworker में फर्क।
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Chatbot तुम्हारे बोलने का इंतज़ार करता है। Agent नहीं। इसे goal दो — "Mars colonization पर research करो और report लिखो" — और ये work को steps में break करता है, सही tools pick करता है, एक-एक करके execute करता है, अपने results check करता है, और तब तक चलता रहता है जब तक job done न हो जाए। यह distinction — <em>instructions को respond करना</em> vs. <em>goal pursue करना</em> — calculator और coworker में फर्क है।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        Agents एक loop पर चलते हैं: goal receive करो, steps plan करो, tools से execute करो, results observe करो, progress evaluate करो, adjust करो। वो एक बार plan करके blindly execute नहीं करते — best agents gracefully recover करते हैं जब step three sideways जाता है। लेकिन इस power की dark side भी है: agents सिर्फ bad answers नहीं देते, वो उन पर <em>act</em> करते हैं, फिर broken result use करके next decision बनाते हैं। Failures compound होती हैं।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE ANATOMY OF AN AGENT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Agent Loop
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        हर agent same five-step cycle पर चलता है। ये steps समझना useful चीज़ बनाने और API credits को infinite loop में जलाने के बीच का फर्क है।
      </p>
    </FadeInBlock>

    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { letter: 'G', name: 'Goal', color: '#E94560', text: 'Clear objective receive करो। "Mars research करो" goal नहीं है। "Mars colonization challenges का 500-word summary लिखो, sources के साथ" goal है।' },
        { letter: 'P', name: 'Plan', color: '#7B61FF', text: 'Goal को concrete steps में break करो। Good planners flexible plans बनाते हैं। Bad planners rigid scripts बनाते हैं जो first surprise पर टूट जाते हैं।' },
        { letter: 'T', name: 'Execute', color: '#0EA5E9', text: 'Right tool use करके हर step run करो — search engines, code interpreters, file readers, APIs। Agents सिर्फ think नहीं करते। वो act करते हैं।' },
        { letter: 'M', name: 'Observe', color: '#16C79A', text: 'Record करो कि क्या हुआ और results check करो। Memory के बिना agent same failing action forever repeat कर सकता है।' },
        { letter: 'E', name: 'Evaluate', color: '#F5A623', text: 'क्या यह work किया? क्या मैं goal के closer हूँ? अगर कुछ off है, plan adjust करो और फिर loop करो। यही agent को script से separate करता है।' },
      ].map((block, i) => (
        <FadeInBlock client:visible delay={i * 0.08}>
          <div style={`display: flex; gap: 1.5rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: white; background: ${block.color};`}>
              {block.letter}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${block.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {block.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {block.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Key insight</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Chatbot एक single turn है। Agent एक whole conversation है — खुद से, अपने tools से, और world से। Best agent builders autonomy maximize नहीं करते। वो thoughtful checkpoints design करते हैं जहाँ agent pause करता है और human को decide करने देता है कि continue करना है या नहीं।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        अब build करने का time है। अपना agent from scratch design करो।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <AgentBlueprint client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="अभी-अभी अपना पहला AI agent from scratch design किया। यह course architecture step by step live demos के साथ walk through कराता है। कोई hype नहीं, बस building।" client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Goal सारी failure prevent करना नहीं है — failure को recoverable बनाना है।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        आगे: तुम एक real agent use करोगे — एक जो तुम्हारा code पढ़ता है, changes लिखता है, tests run करता है, और अपनी mistakes fix करता है। Meet Claude Code।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(233,69,96,0.06) 15%, rgba(233,69,96,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#E94560" toolName="Agent Takeover" client:visible>
        <AgentTakeover client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
