---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import DebugDetective from '../../components/widgets/ch9/DebugDetective';
import EvalFramework from '../../components/breaks/EvalFramework';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[8];
---

<ChapterLayout chapter={chapter} locale="hi">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>9</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          अध्याय नौ
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          जब AI गलत<br />हो जाए
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Verification की वो habits<br />जो amateurs को pros से अलग करती हैं।
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        जिस AI ने अभी तुम्हारा flawless essay लिखने में help की, वही equal confidence के साथ तुम्हें बता सकता है कि Napoleon ने Waterloo की battle जीती थी। Hesitate नहीं करेगा। Stammer नहीं करेगा। Completely fabricated "fact" को same authoritative tone में state करेगा जो बाकी सब चीज़ों के लिए use करता है। यही AI के साथ काम करने का paradox है: <strong>वही fluency जो इसे useful बनाती है, वही इसे dangerous बनाती है।</strong>
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CONCEPT: HALLUCINATION ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Plausibility Truth नहीं है
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10" style="margin-top: 0;">
        AI models database से facts retrieve नहीं करते। वो next most likely word predict करते हैं। जब तुम कुछ real के बारे में पूछते हो, training data इन्हें correct information की तरफ guide करता है। जब ऐसी चीज़ के बारे में पूछते हो जो exist नहीं करती, model "I don't know" नहीं कहता। वो generate करता है कि correct answer <em>कैसा दिखता</em> — names, dates, और citations के साथ। सब fabricated।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        AI कितना confident sound करता है और कितना accurate actually है — इसमें कोई correlation नहीं है। Wrong answer और right answer बाहर से identical दिखते हैं। Tone से, detail से, या AI कितने specific numbers include करता है उससे accuracy judge नहीं कर सकते। "Sahi lag raha hai" test worthless है। तुम्हारा एकमात्र defense verification है।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Key insight</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          AI का truth का concept नहीं है। इसका <em>plausibility</em> का concept है। ये वो text generate करता है जो pattern में fit करे — चाहे वो text reality से match करे या न करे।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        अपना detector test करो। क्या तुम बता सकते हो कि कौन से AI claims real हैं और कौन से fabricated?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <DebugDetective client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="हर AI user को यह chapter चाहिए। सिखाता है exactly कैसे AI hallucinate करता है, wrong answers से क्यों agree करता है, और कैसे catch करें। बहुत practical।" client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        जो लोग AI से सबसे ज्यादा value पाते हैं, वो वही हैं जिन्होंने सीखा है exactly कब trust करना है और कब verify।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        जानना कि AI कब wrong है एक bigger question की तरफ ले जाता है: ये कभी क्या <em>नहीं</em> कर सकता? आगे, हम उन skills explore करते हैं जो stubbornly, beautifully human रहती हैं — और क्यों वो पहले से कहीं ज़्यादा matter करती हैं।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(233,69,96,0.06) 15%, rgba(233,69,96,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#E94560" toolName="Eval Framework" client:visible>
        <EvalFramework client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
