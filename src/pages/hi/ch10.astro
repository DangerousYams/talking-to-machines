---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import TasteTest from '../../components/widgets/ch10/TasteTest';
import IrreplaceableYou from '../../components/breaks/IrreplaceableYou';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';
import ForYouCard from '../../components/ui/ForYouCard';

const chapter = chapters[9];
const conceptsSummary = chapter.concepts.map(c => c.name).join(', ');
---

<ChapterLayout chapter={chapter} locale="hi">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>10</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          अध्याय दस
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Taste ही<br />Product है
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          AI options generate करता है। तुम<br />सही वाला चुनते हो। यही skill है।
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        AI तीस seconds में website generate कर सकता है। ज़्यादातर एक जैसी दिखती हैं: rounded corners, gradient backgrounds, generic hero sections, placeholder stock phrases। ये <strong>AI slop</strong> है &mdash; default output जब कोई taste exercise नहीं करता। Technically functional है। Aesthetically भूलने लायक़ है। और यही मिलता है जब तुम AI जो भी दे वो बिना कुछ बेहतर माँगे accept कर लो।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        इसका इलाज और prompting नहीं है। इसका इलाज standards होना है। जानना कि "अच्छा" कैसा दिखता है। और AI को दिखाना कि तुम्हें क्या चाहिए, बजाय इसके कि वो ख़ुद guess करे।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ REFERENCES ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Descriptions नहीं, References दो
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        "Modern और clean बनाओ" AI को लगभग कुछ नहीं बताता। "stripe.com जैसा बनाओ &mdash; minimal, बहुत whitespace, एक accent color, बड़ी bold headings" सब कुछ बता देता है। <strong>References हमेशा descriptions से जीतती हैं।</strong> एक screenshot हज़ार शब्दों की prompting से ज़्यादा काम का है। जो चीज़ें तुम्हें पसंद हैं उनके examples collect करो &mdash; websites, apps, designs &mdash; और agent को दो। "ये layout चाहिए लेकिन इन colors के साथ।" "ये typography लेकिन dashboard पर apply करो।"
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Taste पैदाइशी नहीं होता। ये exposure plus judgment है। तुम इसे develop करते हो अच्छी चीज़ें देखकर और समझकर कि वो <em>क्यों</em> अच्छी हैं। जितने ज़्यादा references collect करो, उतनी तेज़ तुम्हारी नज़र होती जाएगी। और नज़र जितनी तेज़, उतनी बेहतर तुम्हारी instructions agent को।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>तीन evaluation lenses</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Agent ने जो बनाया उसे तीन lenses से judge करो। <strong>Visual:</strong> मेरी references जैसा दिखता है? <strong>Functional:</strong> वो करता है जो मैंने specify किया? <strong>User:</strong> मैं actually ये use करना चाहूँगा? इनमें से किसी का जवाब अगर नहीं है, तो iterate करो। इन lenses के लिए code पढ़ने की ज़रूरत नहीं।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ HUMAN EDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Human Edge
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        AI options generate करता है। तुम सही वाला चुनते हो। वो judgment &mdash; taste, empathy, vision &mdash; तुम्हारा edge है। AI एक minute में दस logo variants बना सकता है। लेकिन सिर्फ़ तुम जानते हो कौन सा तुम्हारे brand के लिए <em>सही लगता</em> है। AI landing page के दस versions draft कर सकता है। लेकिन सिर्फ़ तुम जानते हो कौन सा तुम्हारे audience को touch करेगा। Scarce skill generation नहीं है। <strong>Curation</strong> है।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        AI fundamentally क्या नहीं कर सकता: <em>क्या</em> build करना है ये choose करना। <em>किसके</em> लिए है ये decide करना। <em>क्यों</em> matter करता है ये तय करना। Creative vision set करना। Room read करना। जानना कि कुछ "off" है भले ही बता न पाओ क्यों। ये AI में bugs नहीं हैं &mdash; ये इंसान होने के features हैं। और जब generation free है, ये पहले से ज़्यादा valuable हैं।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        इन options को best से worst rank करो। फिर देखो experts ने कैसे score किया &mdash; और क्यों।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <TasteTest client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <div class="py-8">
    <ForYouCard
      chapterSlug={chapter.slug}
      chapterTitle={chapter.title}
      chapterConcepts={conceptsSummary}
      accentColor={chapter.accent}
      client:load
    />
  </div>
  <SharePrompt text="'AI options generate करता है। तुम सही वाला चुनते हो।' Taste, references, और human edge पर ये chapter AI के साथ build करने का सबसे important सबक़ है।" client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        जब generation free है, तो बस taste ही matter करता है।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        एक chapter बचा है। और theory नहीं। अब time है सब कुछ जो सीखा है उसे combine करके कुछ real बनाने का &mdash; कुछ ऐसा जो सिर्फ़ तुम सोच सकते हो।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(22,199,154,0.06) 15%, rgba(22,199,154,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#16C79A" toolName="Irreplaceable You" client:visible>
        <IrreplaceableYou client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
