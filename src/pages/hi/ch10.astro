---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';

import Divider from '../../components/ui/Divider';
import SkillsSpectrum from '../../components/widgets/ch10/SkillsSpectrum';
import JobTransformer from '../../components/widgets/ch10/JobTransformer';
import TasteTest from '../../components/widgets/ch10/TasteTest';
import FirstPrinciplesLab from '../../components/widgets/ch10/FirstPrinciplesLab';

const chapter = chapters[9];
---

<ChapterLayout chapter={chapter} locale="hi">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>10</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          अध्याय दस
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          इंसानी<br />Edge
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          जो AI replace नहीं कर सकता &mdash;<br />और क्या 10x आसान बना देता है।
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        जब भी कोई नई AI capability आती है, वही headline नज़र आती है: <em>"क्या AI [कोई job डालो] को replace कर देगा?"</em> यह गलत सवाल है। हमेशा से गलत सवाल रहा है। सही सवाल यह है: <em>"इससे क्या possible हो जाता है जो पहले possible नहीं था?"</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        AI इंसानों को replace नहीं करता। यह <strong>tasks</strong> को replace करता है। और जब तुम किसी भी job को — किसी भी career, creative pursuit या profession को — closely देखते हो, तो एक mix मिलता है: कुछ tasks जो AI brilliantly handle करता है, कुछ में assist करता है, और कुछ जो बिल्कुल, beautifully human रह जाते हैं।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        यह chapter उस line को find करने के बारे में है। इसलिए नहीं कि तुम उससे डरो, बल्कि इसलिए कि तुम उसकी <strong>सही side पर खड़े हो सको</strong> — उस side पर जहाँ तुम्हारी uniquely human skills ज्यादा valuable हो जाती हैं, कम नहीं।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SPECTRUM, NOT THE CLIFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Spectrum है, Cliff नहीं
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI और jobs के बारे में ज्यादातर conversations इसे binary treat करती हैं: या तो AI तुम्हारी job कर सकता है या नहीं। Robot apocalypse या business as usual। लेकिन reality एक spectrum है।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        कुछ tasks लगभग पूरी तरह automatable हैं। कुछ AI से enhance होते हैं। कुछ untouched रहते हैं। और सबसे interesting वाले — जिन पर ध्यान देना worth है — बीच में कहीं fall करते हैं, जहाँ humans और AI together काम करते हैं।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-10">
        Data entry? AI handle कर लेता है। Meetings schedule करना? Basically solved। First draft लिखना? AI shockingly good है। लेकिन <em>क्या build करना है choose करना</em>, <em>crisis में room read करना</em>, <em>decide करना कि data का क्या मतलब है</em> — इनके लिए कुछ चाहिए जो AI के पास नहीं है।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85]">
        हर skill actually कहाँ fall करती है? अपना intuition test करो।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: SKILLS SPECTRUM ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <SkillsSpectrum client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ JOBS DON'T DISAPPEAR — THEY SHAPE-SHIFT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Jobs Disappear नहीं होतीं — Shape-Shift होती हैं
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        जब ATMs 1970s में आए, सबने predict किया कि bank tellers vanish हो जाएंगे। Instead, bank tellers की संख्या <em>बढ़ गई</em>। क्यों? क्योंकि ATMs ने नई branches खोलना cheaper बना दिया, और teller की job cash count करने से shift होकर financial products sell करने और customer relationships build करने में हो गई।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        AI वही कर रहा है, लेकिन faster और हर industry में एक साथ। Job title same रहता है। Job <em>description</em> dramatically change हो जाता है। 2025 में एक journalist वही काम नहीं कर रहा जो 2015 में journalist करता था, भले ही byline identical लगे।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>नया career math</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          यह "humans vs. AI" नहीं है। यह <strong>humans with AI vs. humans without AI</strong> है। जो लोग AI tools के साथ काम करना सीखते हैं, वे अपनी jobs नहीं खोते — वे अपने jobs faster, better, और उन capabilities के साथ करते हैं जो उनके पास पहले नहीं थीं।
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mt-10">
        नीचे कोई career pick करो और देखो कि AI इसे अंदर से कैसे transform करता है। एक भी task completely disappear नहीं होता। लेकिन हर job का shape change हो रहा है।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: JOB TRANSFORMER ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <JobTransformer client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ TASTE: THE IRREPLACEABLE SKILL ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Taste: Irreplaceable Skill
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        AI एक minute में सौ logo concepts generate कर सकता है। तुम्हारी coffee finish होने से पहले दस essay introductions लिख सकता है। पाँच app designs, चार taglines, तीन business plans produce कर सकता है।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        लेकिन यह नहीं बता सकता कि कौन सा <em>सही</em> है।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        एक world में जहाँ options generate करना लगभग free है, <em>सही वाला choose करने</em> की ability सबसे valuable skill हो जाती है। उस ability का एक नाम है: taste।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        Taste mystical नहीं है। यह trained है। तुम इसे बहुत सारे अच्छे काम और बुरे काम देखकर develop करते हो, और यह सीखकर कि एक दूसरे से बेहतर <em>क्यों</em> है। यह photographer है जो जानता है कि कौन सा shot keep करना है। Writer जो जानता है कि कौन सा sentence cut करना है। Designer जो जानता है कि कब less is more।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85]">
        AI generate करता है। तुम curate करते हो। यह नया division of labor है। देखते हैं तुम्हारा taste कितना sharp है।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: TASTE TEST ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <TasteTest client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ YOUR KNOWLEDGE IS YOUR BS DETECTOR ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        तुम्हारा Knowledge तुम्हारा BS Detector है
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Chapter 9 में हमने AI hallucinations के बारे में बात की — कैसे AI perfect confidence के साथ falsehoods state कर सकता है। लेकिन यहाँ uncomfortable follow-up question है: <strong>तुम इसे कैसे catch करते हो?</strong>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Answer है first principles thinking। जब AI तुम्हें बताता है कि pipe का radius double करने से water flow double हो जाता है, तुम उस mistake को तभी catch कर सकते हो अगर तुम जानते हो कि area radius के <em>square</em> के साथ scale करता है। जब AI कहता है कि कोई syllogism valid है, तुम logical fallacy को तभी spot कर सकते हो अगर तुम deduction के rules समझते हो।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AI existing चीजों को remix करता है। First principles thinking ground truth से reason करती है। यही तरीका है genuinely नए territory में push करने का — और यही तरीका है AI को catch करने का जो confidently गलत है।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        इसका मतलब यह नहीं कि तुम्हें हर चीज़ में expert होना चाहिए। लेकिन जिन domains में तुम काम करते और create करते हो, तुम्हारी foundational understanding ही तुम्हें उससे अलग करती है जो blindly AI output को copy-paste करता है।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85]">
        अपने आप को test करो। नीचे AI अलग-अलग domains के छह problems के confident answers देता है। कुछ सही हैं। कुछ subtly गलत हैं। क्या तुम बता सकते हो कौन से कौन से हैं?
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FIRST PRINCIPLES LAB ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <FirstPrinciplesLab client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ WHAT STAYS HUMAN ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        क्या Human रहता है
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14">
        जो कुछ हमने explore किया है, उसके बाद एक pattern emerge होता है। जो skills सबसे ज्यादा human रहती हैं, वे random नहीं हैं — वे कुछ deep capabilities के around cluster करती हैं जो AI के पास fundamentally नहीं हैं।
      </p>
    </FadeInBlock>

    <!-- Human edge capabilities -->
    <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
      {[
        { icon: '🎯', name: 'Judgment', color: '#16C79A', text: 'Choose करना कि क्या matters है। क्या build करना है, क्या cut करना है, क्या ship करना है, क्या kill करना है। AI decisions को inform कर सकता है लेकिन make नहीं कर सकता — क्योंकि decisions require values, और values human हैं।' },
        { icon: '🤝', name: 'Empathy', color: '#0EA5E9', text: 'समझना कि दूसरा person कैसा feel करता है और genuine care के साथ respond करना। AI text में empathy simulate करता है। Humans इसे relationships में, crisis में, उन moments में practice करते हैं जो सबसे ज्यादा matter करते हैं।' },
        { icon: '🧭', name: 'Vision', color: '#7B61FF', text: 'देखना कि क्या अभी exist नहीं करता और decide करना कि इसे होना चाहिए। हर product, हर company, हर creative work किसी के conviction से start हुआ कि world को कुछ नया चाहिए। AI चीज़ें want नहीं कर सकता।' },
        { icon: '⚡', name: 'Leadership', color: '#F5A623', text: 'लोगों को inspire करना, conflict navigate करना, trust build करना। ये fundamentally social skills हैं जिनके लिए presence, emotional intelligence, और accountable होने की ability चाहिए।' },
        { icon: '🔍', name: 'Original questions पूछना', color: '#E94560', text: 'AI questions answer करने में great है। Humans उन questions पूछने में great हैं जो किसी ने पूछने के बारे में सोचा ही नहीं था। Science, business, और art में सबसे important breakthroughs एक question से start हुए, answer से नहीं।' },
      ].map((item, i) => (
        <FadeInBlock client:visible delay={i * 0.08}>
          <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
            <div style={`flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; background: ${item.color}10; border: 1px solid ${item.color}20;`}>
              {item.icon}
            </div>
            <div style="flex: 1;">
              <p style={`font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: ${item.color}; margin: 0 0 0.35rem; line-height: 1.3;`}>
                {item.name}
              </p>
              <p style="font-size: 1rem; line-height: 1.75; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {item.text}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.5}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Key insight</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          ये सिर्फ "nice to have" soft skills नहीं हैं। AI-augmented world में, ये <strong>hard skills</strong> हैं। Judge करने, empathize करने, lead करने, envision करने की ability तुम्हारे सबसे competitive advantages बन जाते हैं precisely <em>क्योंकि</em> AI बाकी सब कुछ handle करता है।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CLOSING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto mb-8" style="max-width: 55ch;">
        Taste। Judgment। Empathy। Vision। First principles reasoning। ये AI के take over करने के बाद के leftovers नहीं हैं &mdash; ये वे skills हैं जो <em>define</em> करती हैं कि तुम table पर क्या लाते हो।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        एक chapter बाकी है। अब कोई theory नहीं। Time है जो कुछ भी तुमने सीखा है उसे combine करने और कुछ real build करने का &mdash; कुछ ऐसा जिसे सिर्फ तुम बनाने के बारे में सोचोगे।
      </p>
    </FadeInBlock>
  </section>

</ChapterLayout>