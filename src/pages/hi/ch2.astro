---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import PromptLaboratory from '../../components/widgets/ch2/PromptLaboratory';
import FlipTheScript from '../../components/widgets/ch2/FlipTheScript';
import DebugThePrompt from '../../components/widgets/ch2/DebugThePrompt';

const chapter = chapters[1];
---

<ChapterLayout chapter={chapter} locale="hi">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <!-- Giant background number -->
    <div class="chapter-number" style={`color: ${chapter.accent};`}>2</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          अध्याय दो
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          सवाल पूछने<br />का फन
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          सबसे अच्छा prompt वो होता है<br />जो AI को तुमसे सवाल पूछने पर मजबूर कर दे।
        </p>
      </FadeInBlock>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ STORY OPENER — with drop cap ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="drop-cap text-lg leading-[1.85] mb-8">
        पिछले chapter में तुमने अच्छे prompt के पांच building blocks सीखे — Role, Task, Format, Constraints, Examples। वो foundation था। लेकिन ingredients जानने से तुम chef नहीं बन जाते।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-8">
        यह chapter <em>technique</em> के बारे में है। वो difference जो prompt type करने वाले और prompt <em>craft</em> करने वाले के बीच होता है। यह question पूछने और <strong>सही</strong> question पूछने के बीच का फर्क है — वो सवाल जो कुछ genuinely useful unlock कर दे।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85]">
        सबसे अच्छे AI users topic के experts नहीं होते — <strong>वे पूछने के experts होते हैं।</strong> और पूछना एक skill है जो तुम सीख सकते हो।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE SOCRATIC FLIP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Socratic Flip
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        ज्यादातर लोग AI को vending machine की तरह use करते हैं। Prompt डालो, answer निकालो। लेकिन सबसे अच्छे results <em>conversations</em> से आते हैं, commands से नहीं। और सबसे powerful conversation technique 2,400 साल पुराना है।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        Socrates कभी भी question का direct answer नहीं देते थे। वे <em>और</em> questions पूछते थे — probing, clarifying, challenging — जब तक उनके students खुद deeper understanding पर नहीं पहुंचते। तुम AI के साथ same approach use कर सकते हो, बस flipped।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        AI से answer मांगने के बजाय, AI से कहो कि वो तुम्हारा interview करे। इसे वे clarifying questions पूछने दो जो तुम think करना भूल गए।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        सोचो इस बारे में: जब तुम "birthday party plan करो" type करते हो, तो तुम dozens के details छोड़ रहे हो जो answer को massively change करते हैं। कितने लोग? Budget क्या है? Indoor या outdoor? AI नहीं जानता — लेकिन पूछ सकता है।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Socratic Prompt</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          "मैं birthday party plan करना चाहता हूं। Planning start करने से पहले, मुझसे 5 specific questions पूछो जो तुम्हें मेरी exact situation के according plan बनाने में help करेंगे। एक-एक करके पूछो और मेरे response का wait करो।"
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        यह single technique — flip करना कि कौन questions पूछता है — सबसे powerful upgrades में से एक है जो तुम कर सकते हो। यह AI को answer machine से <strong>thinking partner</strong> में बदल देता है।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: FLIP THE SCRIPT ═══ -->
  <section id="flip-the-script" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <FlipTheScript client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ FEW-SHOT PROMPTING ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Show, Don't Tell
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Imagine करो कि तुम किसी friend को style explain करने की कोशिश कर रहे हो। तुम पांच minute words में describe कर सकते हो — "मुझे कुछ playful चाहिए लेकिन childish नहीं, casual लेकिन sloppy नहीं, short sentences और unexpected comparisons के साथ।" या फिर तुम simply example दिखा सकते हो: <em>"इस तरह लिखो।"</em>
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        यही है <strong>few-shot prompting</strong>। Abstract में describe करने की कोशिश करने के बजाय, तुम AI को concrete examples देते हो। एक example "one-shot" prompt होता है। दो या तीन examples "few-shot" होता है। Zero examples — जहां तुम सिर्फ describe करते हो कि तुम्हें क्या चाहिए — "zero-shot" होता है।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <div class="prompt-block mb-10" style="--accent: #6B7280;">
        <span class="prompt-block-label" style="color: #6B7280;">Zero-shot (describing)</span>
        <p class="m-0" style="color: var(--color-deep);">"मुझे running shoes के लिए product description लिख दो। Punchy और conversational बनाओ, short sentences के साथ। Marketing clichés avoid करो।"</p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <div class="prompt-block mb-10" style={`--accent: ${chapter.accent};`}>
        <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
        <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Few-shot (showing)</span>
        <p class="m-0 leading-relaxed" style="color: var(--color-deep);">
          "CloudRunner X1 running shoe के लिए product description लिखो। मुझे यह style चाहिए:<br /><br />
          <em>Example: 'The Weekender Tote — Fits your laptop, your lunch, and your questionable life choices. Water-resistant canvas because we know you'll spill something. Five pockets, none of which you'll remember later.'</em><br /><br />
          इसी tone को match करो: short sentences, self-aware humor, buzzwords के बजाय specificity।"
        </p>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <p class="text-lg leading-[1.85] mb-10">
        Few-shot version dramatically better results produce करेगा। इसलिए नहीं कि AI "smarter" है — बल्कि क्योंकि तुमने इसे vague direction के बजाय <strong>concrete target</strong> दिया। एक अच्छा example सौ words के description के बराबर होता है।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Key insight</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          जब AI तुम्हारी चाहते style को match नहीं कर रहा, तो ज्यादा adjectives add मत करो। Example add करो। "इस तरह" हमेशा "make it more punchy but also warm but not too casual" से better होता है।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ MINI-CHALLENGE: Zero to Few-Shot ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-12">
    <FadeInBlock client:visible>
      <div style={`background: linear-gradient(135deg, ${chapter.accent}08, ${chapter.accent}04); border: 1px solid ${chapter.accent}20; border-radius: 12px; padding: 2rem 2rem 1.75rem;`}>
        <p style={`font-family: var(--font-mono); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: ${chapter.accent}; margin: 0 0 0.75rem;`}>
          Quick experiment
        </p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0 0 1rem; color: var(--color-deep);">
          कुछ ऐसा सोचो जिसे तुमने recently AI से लिखने को कहा था — email, story, या social media post। अब imagine करो अगर तुमने tone का concrete example include किया होता। Output कैसे change हुआ होता?
        </p>
        <p style="font-size: 0.9rem; line-height: 1.7; margin: 0; color: var(--color-deep); opacity: 0.6;">
          इसे अपने back pocket में रखो। नीचे का Prompt Laboratory तुम्हें real में test करने देगा।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ CHAIN OF THOUGHT ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Step by Step सोचो
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        यहां कुछ wild बात है: अगर तुम AI से math problem solve करने को कहो, तो वो गलत कर सकता है। लेकिन अगर तुम इसे <em>problem को step by step solve</em> करने को कहो, तो वो काफी ज्यादा बार सही करता है। Answer same होता है। Question different होता है।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        इस technique को <strong>chain-of-thought prompting</strong> कहते हैं। Answer directly मांगने के बजाय, तुम AI से इसकी reasoning show करने को कहते हो। "Think through this step by step।" "Break this down before answering।" "Explain your reasoning as you go।"
      </p>
    </FadeInBlock>

    <!-- Before/After comparison -->
    <FadeInBlock client:visible delay={0.2}>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
        <div>
          <div class="prompt-block" style="--accent: #E94560; min-height: 100%;">
            <span class="prompt-block-label" style="color: #E94560;">Chain-of-thought के बिना</span>
            <p class="m-0" style="color: var(--color-deep); font-size: 0.85rem;">
              "एक bat और ball together $1.10 cost करते हैं। Bat ball से $1.00 ज्यादा cost करता है। Ball कितने का है?"
            </p>
            <p style="color: #E94560; font-size: 0.8rem; margin: 1rem 0 0; font-weight: 600;">
              AI का answer: $0.10 (गलत)
            </p>
          </div>
        </div>
        <div>
          <div class="prompt-block" style={`--accent: ${chapter.accent}; min-height: 100%;`}>
            <div style={`position:absolute;top:-1px;left:2rem;right:2rem;height:2px;border-radius:1px;background:${chapter.accent};`}></div>
            <span class="prompt-block-label" style={`color: ${chapter.accent};`}>Chain-of-thought के साथ</span>
            <p class="m-0" style="color: var(--color-deep); font-size: 0.85rem;">
              "एक bat और ball together $1.10 cost करते हैं। Bat ball से $1.00 ज्यादा cost करता है। Ball कितने का है? Step by step सोचो।"
            </p>
            <p style={`color: ${chapter.accent}; font-size: 0.8rem; margin: 1rem 0 0; font-weight: 600;`}>
              AI का answer: $0.05 (सही)
            </p>
          </div>
        </div>
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.25}>
      <p class="text-lg leading-[1.85] mb-10">
        यह क्यों काम करता है? जब तुम AI से step by step reasoning show करने को कहते हो, तो हर step next step में feed होता है। यह AI को scratch paper देने जैसा है — जितना ज्यादा वो अपनी thinking write करता है, उतना better final answer मिलता है।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="pull-quote" style={`border-color: ${chapter.accent};`}>
        Chain-of-thought AI को smarter नहीं बनाता। यह इसे slower बनाता है — और slower thinking अक्सर better thinking होती है।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.35}>
      <p class="text-lg leading-[1.85]">
        यह सिर्फ math के लिए नहीं है। इसे use करो जब भी answer में reasoning की जरूरत हो: argument analyze करना, options compare करना, project plan करना, code debug करना। जब भी तुम चाहोगे कि human अपना "work show करे," AI से same चीज़ मांगो।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE PROMPT ASSEMBLY ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Techniques को Assemble करना
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Real power techniques को combine करने से आती है। Few-shot examples <em>plus</em> chain-of-thought। System role <em>plus</em> constraints <em>plus</em> format specification। हर technique एक lever है, और multiple levers को together pull करना कुछ ऐसा produce करता है जो इनमें से कोई भी अकेले achieve नहीं कर सकता।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        लेकिन यहां nuance है जो beginners को experts से separate करती है: <strong>more हमेशा better नहीं होता।</strong> Casual brainstorm को एक-दो techniques की जरूरत होती है। High-stakes essay को पांच की। Informal question को zero की। Skill यह जानना है कि कितने levers pull करने हैं — और कौन से।
      </p>
    </FadeInBlock>

    <!-- Technique stack visual -->
    <FadeInBlock client:visible delay={0.2}>
      <div style="margin-bottom: 2.5rem;">
        {[
          { label: 'Casual brainstorm', techniques: ['Task'], color: '#6B7280', width: '25%' },
          { label: 'School assignment', techniques: ['Role', 'Task', 'Format'], color: '#F5A623', width: '50%' },
          { label: 'Important project', techniques: ['Role', 'Context', 'Task', 'Format', 'Examples'], color: '#0EA5E9', width: '75%' },
          { label: 'High-stakes output', techniques: ['Role', 'Context', 'Examples', 'Task', 'Format', 'Constraints', 'Chain-of-thought'], color: '#0F3460', width: '100%' },
        ].map((level, i) => (
          <FadeInBlock client:visible delay={i * 0.06} key={i}>
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem;">
              <span style={`font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600; color: ${level.color}; width: 120px; flex-shrink: 0; text-align: right;`}>
                {level.label}
              </span>
              <div style="flex: 1; height: 24px; background: rgba(26,26,46,0.03); border-radius: 6px; overflow: hidden;">
                <div style={`height: 100%; width: ${level.width}; background: linear-gradient(90deg, ${level.color}20, ${level.color}40); border-radius: 6px; display: flex; align-items: center; padding: 0 8px; gap: 4px;`}>
                  {level.techniques.map((t, j) => (
                    <span key={j} style={`font-family: var(--font-mono); font-size: 0.55rem; font-weight: 600; color: ${level.color}; opacity: 0.8;`}>
                      {t}{j < level.techniques.length - 1 ? ' +' : ''}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </FadeInBlock>
        ))}
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.4}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Key insight</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          Over-prompting एक real चीज़ है। Simple question के लिए 500-word prompt answer को better नहीं बनाता — वो actually AI को confuse कर सकता है। अपनी prompt complexity को task complexity से match करो।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET: PROMPT LABORATORY ═══ -->
  <section class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <FadeInBlock client:visible>
      <PromptLaboratory client:visible />
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ WHEN PROMPTS GO WRONG ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        जब Prompts गलत हो जाते हैं
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-10">
        Bad AI output <strong>almost never AI की fault होती है।</strong> जब output generic, vague, या plain wrong होता है, तो bug usually prompt में होता है। और code debug करने की तरह, prompts debug करना भी learnable skill है।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.15}>
      <p class="text-lg leading-[1.85] mb-10">
        सबसे common prompt bugs पांच categories में fall करते हैं। एक बार तुम इन्हें spot करना सीख जाओ, तो तुम्हें ये हर जगह दिखेंगे — तुम्हारे अपने prompts में और दूसरे लोगों की complaints में कि AI "useless" है।
      </p>
    </FadeInBlock>

    <!-- Bug types -->
    <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 2.5rem;">
      {[
        { name: 'Ambiguous', desc: 'Prompt का multiple मतलब हो सकता है। "Dogs के बारे में कुछ लिखो" — कैसी writing? किसके लिए? कितनी लंबी?', color: '#E94560' },
        { name: 'Contradictory', desc: 'Prompt opposing चीज़ें मांगता है। "Short लेकिन comprehensive बनाओ।" "Fun tone use करो लेकिन formal रखो।" एक pick करो।', color: '#F5A623' },
        { name: 'Missing context', desc: 'Prompt में crucial information गायब है। "My code fix करो" code share किए बिना। "My essay improve करो" essay के बिना।', color: '#0EA5E9' },
        { name: 'Too many tasks', desc: 'Prompt एक साथ पांच चीज़ें मांगता है। AI spread हो जाता है और कोई भी चीज़ अच्छी नहीं करता।', color: '#7B61FF' },
        { name: 'Leading question', desc: 'Prompt AI को बताता है कि क्या सोचना है। "Don\'t you agree that X is the best?" AI agree करेगा। यह useful नहीं है।', color: '#16C79A' },
      ].map((bug, i) => (
        <FadeInBlock client:visible delay={i * 0.07}>
          <div style={`display: flex; gap: 1rem; align-items: flex-start;`}>
            <div style={`flex-shrink: 0; width: 6px; height: 6px; border-radius: 50%; margin-top: 10px; background: ${bug.color};`}></div>
            <div>
              <p style={`font-family: var(--font-heading); font-size: 0.95rem; font-weight: 700; color: ${bug.color}; margin: 0 0 0.2rem;`}>
                {bug.name}
              </p>
              <p style="font-size: 0.95rem; line-height: 1.7; color: var(--color-deep); opacity: 0.75; margin: 0;">
                {bug.desc}
              </p>
            </div>
          </div>
        </FadeInBlock>
      ))}
    </div>

    <FadeInBlock client:visible delay={0.45}>
      <p class="text-lg leading-[1.85]">
        सबसे insidious bug <em>leading question</em> है। यह spot करना सबसे hard है क्योंकि <em>लगता</em> है कि तुम्हें great output मिल रहा है — AI तुमसे agree कर रहा है! लेकिन agreement accuracy नहीं है। जब तुम question को अपनी existing belief confirm करने के लिए frame करते हो, तो तुमने AI को yes-man बना दिया है, thinking partner नहीं।
      </p>
    </FadeInBlock>
  </section>

