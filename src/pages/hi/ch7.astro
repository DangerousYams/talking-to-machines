---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import WhatWouldYouBuild from '../../components/widgets/ch7/WhatWouldYouBuild';
import ShipIt from '../../components/breaks/ShipIt';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';
import ForYouCard from '../../components/ui/ForYouCard';

const chapter = chapters[6];
const conceptsSummary = chapter.concepts.map(c => c.name).join(', ');
---

<ChapterLayout chapter={chapter} locale="hi">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>7</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          अध्याय सात
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          कोई भी<br />बना सकता है
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          तुम्हें programmer होने की ज़रूरत नहीं।<br />तुम्हें एक idea की ज़रूरत है।
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        Ohio की एक teacher ने weekend में एक grading app बना दी। एक musician ने setlist optimizer बनाया जो गानों को energy और key के हिसाब से arrange करता है। एक high school junior ने debate prep tool बनाया जो किसी भी resolution के counterarguments generate करता है। इनमें से कोई programmer नहीं है। किसी ने coding class नहीं ली। इन्होंने बताया क्या चाहिए, और एक coding agent ने बना दिया।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        ये वो unlock है जो किसी ने आते नहीं देखा। बात ये नहीं कि coders faster हो गए &mdash; बात ये है कि <strong>non-coders software बना ही सकते हैं।</strong> जैसे spreadsheets ने data analysis को democratize किया और Canva ने graphic design को, AI coding agents software development ख़ुद को democratize कर रहे हैं।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ PERSONAL SOFTWARE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Personal Software Revolution
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        यहाँ वो idea है जो सब बदल देता है: <strong>personal software।</strong> ऐसे tools जो सिर्फ़ एक person के लिए बने हों &mdash; तुम। कोई market research नहीं, कोई business plan नहीं, कोई venture funding नहीं। बस एक problem जो तुम्हारे सामने है और एक tool जो उसे solve करे। AI से पहले, personal software बनाने का मतलब था coding सीखना, जिसमें महीने या साल लगते हैं। अब एक दोपहर लगती है। Building की cost लगभग zero हो गई &mdash; जिसका मतलब है कि बस एक चीज़ matter करती है: एक ऐसा idea जो बनाने लायक़ हो।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        जो tools ये possible बनाते हैं उन्हें <strong>coding agents</strong> कहते हैं। Claude Code, Cursor, Antigravity, Replit &mdash; ये AI tools हैं जो तुम्हारा पूरा project पढ़ सकते हैं, multiple files में code लिख सकते हैं, run कर सकते हैं, error आए तो fix कर सकते हैं, और दोबारा run कर सकते हैं। बिना तुम्हारे एक line code छुए। ये autocomplete नहीं हैं। ये AI collaborators हैं जो तुम्हारी descriptions को working software में बदलते हैं।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Director की भूमिका</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          तुम code नहीं लिखते। तुम <strong>direct</strong> करते हो। तुम्हारा काम है बताना क्या build करना है, output evaluate करना, और iterate करना जब तक सही न हो। Agent technical execution handle करता है। ख़ुद को film director समझो &mdash; तुम camera operate नहीं करते, लेकिन तुम्हारे vision के बिना कुछ नहीं बनता।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE AGENT AS GUIDE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        तुम्हारा Agent सब जानता है जो तुम नहीं जानते
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        "लेकिन मुझे database क्या होता है वो भी नहीं पता।" Good news: तुम्हें जानने की ज़रूरत भी नहीं। तुम्हारा coding agent तुम्हारा tutor भी है। कुछ भी पूछो। "React component क्या होता है?" वो समझा देगा। "इसे internet पर कैसे deploy करें?" Step by step बता देगा। "ये error का मतलब क्या है?" Jargon को simple Hindi में translate कर देगा।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        ये वो safety net है जो बाक़ी सब possible बनाता है। तुम्हें technical vocabulary रटने की ज़रूरत नहीं — तुम्हें बस इतना जानना है कि ये <em>exist करती है</em> ताकि तुम पूछ सको। Agent हर gap भर देता है। ये ऐसा है जैसे तुम्हारे बग़ल में एक patient, थकान-मुक्त expert बैठा हो जो basic सवाल पूछने पर कभी judge नहीं करता।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Skill paradox</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          तुम्हें इतना knowledge चाहिए कि output <em>evaluate</em> कर सको, हर line लिखने लायक़ नहीं। Film director को camera बनाना नहीं आना चाहिए &mdash; लेकिन shot सही दिख रहा है या नहीं, ये पता होना चाहिए। यहाँ भी वही: तुम्हें पता होना चाहिए कि app काम कर रही है या नहीं, code कैसे काम करता है ये नहीं।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="font-family: var(--font-body); text-wrap: balance;">
        देखो non-coders ने क्या-क्या बनाया है &mdash; फिर अपना imagine करो।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="what-would-you-build" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <WhatWouldYouBuild client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <div class="py-8">
    <ForYouCard
      chapterSlug={chapter.slug}
      chapterTitle={chapter.title}
      chapterConcepts={conceptsSummary}
      accentColor={chapter.accent}
      client:load
    />
  </div>
  <SharePrompt text="इस chapter ने मुझे convince कर दिया कि कोई भी AI के साथ software बना सकता है। हवा-हवाई बात नहीं — exactly दिखाता है कैसे non-coders real tools बना रहे हैं।" client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Software बनाने की cost अब लगभग zero है। बस एक चीज़ बची है — एक ऐसा idea जो बनाने लायक़ हो।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        तुम्हारे पास idea है। लेकिन coding agent खोलने से पहले, तुम्हें उसकी भाषा बोलनी आनी चाहिए। Code नहीं &mdash; बस building की vocabulary। वो अगला है।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Ship It" client:visible>
        <ShipIt client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
