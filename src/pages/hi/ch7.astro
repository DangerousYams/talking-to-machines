---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import TerminalPlayground from '../../components/widgets/ch7/TerminalPlayground';
import ShipIt from '../../components/breaks/ShipIt';
import BreakReveal from '../../components/breaks/BreakReveal';
import SharePrompt from '../../components/ui/SharePrompt';

const chapter = chapters[6];
---

<ChapterLayout chapter={chapter} locale="hi">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>7</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          अध्याय सात
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          Claude Code<br />में Mastery
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          तुम्हारा AI pair programmer, पहले<br />command से custom Skills तक।
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        हर coder को एक moment याद रहता है। तुम terminal खोलते हो, natural-language request type करते हो, और AI को देखते हो जो तुम्हारी files पढ़ता है, architecture समझता है, multiple files में code लिखता है, run करता है, error आती है, error fix करता है, और फिर run करता है — तुमने एक line भी touch नहीं की। Claude Code autocomplete नहीं है। यह एक <em>agentic</em> coding tool है जो तुम्हारा पूरा project देखता है, files में changes करता है, shell commands execute करता है, और अपनी mistakes पर iterate करता है।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mt-8">
        लेकिन tool उतना ही good है जितना human उसे steer कर रहा है। Claude Code seconds में हज़ार lines perfect code लिख सकता है — या हज़ार lines plausible-looking garbage। फर्क तुम हो।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ THE LOOP ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        Specify, Generate, Verify
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        जब तुम Claude Code को task देते हो, वो agent loop run करता है: codebase read करो, plan करो क्या change करना है, edits लिखो, code run करो, जो भी broke उसे fix करो। वो इस loop में तीन, पांच, दस बार cycle कर सकता है — सब seconds में। तुम्हारा job अब हर line लिखना नहीं है। तुम्हारा job है <strong>specify</strong> करो क्या build करना है, AI को <strong>generate</strong> करने दो, और फिर <strong>verify</strong> करो कि वो actually सही है। Most beginners वो last step skip कर देते हैं। वो code appear होता देखते हैं, reasonable लगता है, और आगे बढ़ जाते हैं। वो person मत बनो। Generated code first draft है। तुम्हारी verification वो edit है जो इसे publishable बनाती है।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        Secret weapon है <code>CLAUDE.md</code> file — इसे project root में drop करो और Claude Code हर session की शुरुआत में पढ़ता है। तुम्हारा tech stack, naming conventions, style rules, testing expectations — सब एक बार encode करो ताकि कभी repeat न करना पड़े। यह Chapter 3 की context engineering है coding पर applied।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style={`font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: ${chapter.accent}; margin: 0 0 0.5rem;`}>Goal हर line लिखना नहीं — हर line समझना है।</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          अगर तुम Claude के generate किए code को read नहीं कर सकते, तो verify नहीं कर सकते। Best Claude Code users वो नहीं जो most code generate करते हैं — वो हैं जो best questions पूछते हैं और subtlest bugs catch करते हैं।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        Loop को action में देखो। Request type करो और Claude Code को काम करते देखो।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="terminal-playground" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <TerminalPlayground client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <SharePrompt text="Claude Code वाला chapter wild है — एक AI pair programmer को problem through think करते, code लिखते, और खुद debug करते देखा। Coding का future यही है।" client:visible />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Claude Code तुम्हारे लिए code नहीं लिख रहा — तुम्हारे साथ code लिख रहा है।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto" style="max-width: 55ch;">
        एक conversation एक task handle कर सकता है। लेकिन real projects में dozens tasks होते हैं। आगे: कैसे big ambitions को उन pieces में break करें जिन्हें AI actually execute कर सके।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ BREAK ═══ -->
  <section id="break" class="py-16 px-6" style="background: linear-gradient(180deg, var(--color-cream) 0%, rgba(123,97,255,0.06) 15%, rgba(123,97,255,0.06) 85%, var(--color-cream) 100%);">
    <div class="max-w-[900px] mx-auto">
      <BreakReveal accentColor="#7B61FF" toolName="Ship It" client:visible>
        <ShipIt client:visible />
      </BreakReveal>
    </div>
  </section>

</ChapterLayout>
