---
export const prerender = true;
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { chapters } from '../../data/chapters';
import FadeInBlock from '../../components/scroll/FadeInBlock';
import AccentBar from '../../components/ui/AccentBar';
import Divider from '../../components/ui/Divider';
import ProjectInstructionsBuilder from '../../components/widgets/ch11/ProjectInstructionsBuilder';

const chapter = chapters[10];
---

<ChapterLayout chapter={chapter} locale="hi">

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[80vh] flex flex-col items-center justify-end px-6 pb-20 relative overflow-hidden">
    <div class="chapter-number" style={`color: ${chapter.accent};`}>11</div>

    <div class="max-w-[680px] mx-auto text-center relative z-10">
      <FadeInBlock client:visible>
        <p class="text-[13px] italic text-subtle/60 mb-5" style="font-family: var(--font-body);">
          अध्याय ग्यारह
        </p>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.15}>
        <h1
          class="mb-8 leading-[1.08]"
          style={`font-family: var(--font-heading); color: ${chapter.accent}; font-size: clamp(2.8rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em;`}
        >
          कुछ Real<br />बनाओ
        </h1>
      </FadeInBlock>

      <FadeInBlock client:visible delay={0.3}>
        <p class="text-lg md:text-xl italic text-deep/40 leading-relaxed max-w-sm mx-auto" style="font-family: var(--font-body);">
          Creation के बिना knowledge सिर्फ trivia है।<br />Ship करने का time है।
        </p>
      </FadeInBlock>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-20 animate-pulse">
      <div class="w-px h-10 bg-deep/40"></div>
    </div>
  </section>

  <!-- ═══ OPENING HOOK ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-24 pb-16">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] drop-cap" style="margin: 0;">
        तुम यहाँ तक पहुँच गए। दस chapters में तुम "मेरे essay में help करो" से context engineering, agents बनाना, और hallucinations debug करना तक पहुँचे। तुमने AI के बारे में ज़्यादातर adults से ज़्यादा सीखा है। लेकिन uncomfortable truth यह है: <strong>जब तक तुम कुछ नहीं बनाते, इसमें से कुछ भी matter नहीं करता।</strong> AI के बारे में पढ़ना swimming के बारे में पढ़ने जैसा है — तुम हर stroke technique study कर सकते हो, लेकिन जब तक पानी में नहीं जाते, तुम इसे <em>जानते</em> नहीं। तुम सिर्फ इसके <em>बारे में</em> जानते हो।
      </p>
    </FadeInBlock>
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ SET UP YOUR AI ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-16">
    <FadeInBlock client:visible>
      <AccentBar color={chapter.accent} className="w-16 mb-10" client:visible />
      <h2 class="mb-8" style="font-family: var(--font-heading);">
        अपना AI Set Up करो
      </h2>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] mb-14" style="margin-top: 0;">
        पहला prompt लिखने से पहले एक power move है जो most beginners skip कर देते हैं: <strong>अपने AI tool को permanent instruction file दो।</strong> हर session में project re-explain करने के बजाय, एक बार लिखो और AI automatically पढ़ लेता है। Claude Code <code>CLAUDE.md</code> पढ़ता है। Cursor <code>.cursorrules</code> पढ़ता है। GitHub Copilot <code>.github/copilot-instructions.md</code> पढ़ता है। Same concept, different filenames। यह Chapter 3 की context engineering है — project level पर applied।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-lg leading-[1.85] mb-14">
        एक अच्छी instruction file तीन questions answer करती है: तुम क्या बना रहे हो, rules क्या हैं, और "good" कैसा दिखता है? ये सही रखो और AI के साथ हर conversation दस steps आगे से शुरू होगी। Project को इतना small scope करो कि finish कर सको — एक completed weekend hack abandoned masterpiece को हर बार beat करता है।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.3}>
      <div class="insight-box">
        <p style="font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: var(--color-amber); margin: 0 0 0.5rem;">Key insight</p>
        <p style="font-size: 1rem; line-height: 1.75; margin: 0;">
          अच्छी project instruction file ऐसे AI में फर्क है जो तुम्हारी help करता है और ऐसे AI में जो तुम्हें <em>समझता</em> है। एक बार लिखो, हर session में benefit।
        </p>
      </div>
    </FadeInBlock>
  </section>

  <!-- ═══ WIDGET BRIDGE ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 pt-4 pb-8">
    <FadeInBlock client:visible>
      <p class="text-lg leading-[1.85] text-center mx-auto italic text-deep/50" style="max-width: 45ch; font-family: var(--font-body);">
        अपनी project instruction file यहीं build करो। Sections fill करो और अपनी पसंद के AI tool के लिए export करो।
      </p>
    </FadeInBlock>
  </section>

  <!-- ═══ THE WIDGET ═══ -->
  <section id="project-instructions-builder" class="max-w-[900px] mx-auto px-6 md:px-10 py-8">
    <ProjectInstructionsBuilder client:visible />
  </section>

  <Divider accent={chapter.accent} client:load />

  <!-- ═══ SEND-OFF ═══ -->
  <section class="max-w-[680px] mx-auto px-6 md:px-10 py-24">
    <FadeInBlock client:visible>
      <div class="pull-quote" style={`border-color: ${chapter.accent}; max-width: 50ch; margin: 0 auto 2rem;`}>
        Tools चीज़ें नहीं बनाते। Tools के साथ लोग चीज़ें बनाते हैं। और तुम्हारे पास तुम्हारी generation का सबसे अच्छा toolkit है।
      </div>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.1}>
      <p class="text-lg leading-[1.85] text-center mx-auto mb-8" style="max-width: 55ch;">
        ग्यारह chapters पहले तुमने "मेरे essay में help करो" type किया था और best की hope की थी। अब तुम context engineer करते हो, agents design करते हो, outputs verify करते हो, और हर step में judgment लाते हो। Course खत्म हुआ। असली learning अब शुरू होती है — जाओ और कुछ ऐसा बनाओ जो सिर्फ तुम बनाने के बारे में सोचोगे।
      </p>
    </FadeInBlock>

    <FadeInBlock client:visible delay={0.2}>
      <p class="text-center mt-4" style={`font-family: var(--font-heading); font-size: 1.8rem; font-weight: 800; color: ${chapter.accent}; letter-spacing: -0.02em;`}>
        Ship करो।
      </p>
    </FadeInBlock>
  </section>

</ChapterLayout>
